@* Views/AdminUrunGaleri/Index.cshtml *@
@using WebApp.Models
@using WepApp.Models
@{
    ViewData["Title"] = "Ürün Galeri Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Seçim satırı için cursor pointer */
    tr[data-galeri-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* Buton grupları için */
    .btn-group .btn {
        margin: 0 2px;
    }

        .btn-group .btn:first-child {
            margin-left: 0;
        }

        .btn-group .btn:last-child {
            margin-right: 0;
        }
</style>

<div class="row">
    <div class="col-md-12">
        <!-- Başarı/Hata Mesajları -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card" style="margin-top:70px;">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Ürün Galerisi Resimleri</h5>
                <div class="d-flex align-items-center gap-3">
                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları -->
                    <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                        <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                            <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-danger btn-sm" id="seciliSilBtn" data-button-permission="sil" title="Seçili Resmi Sil" disabled>
                                <i class="fas fa-trash"></i> 
                            </button>
                        </div>
                    </div>

                    <!-- Yeni Ekle Butonu -->
                    <button type="button" class="btn btn-success" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                        <i class="fas fa-plus"></i> Yeni Resim Ekle
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-head-bg-primary">
                            <tr>
                                <th width="40">Seç</th>
                                <th scope="col">#</th>
                                <th scope="col">Resim</th>
                                <th scope="col">Ürün</th>
                                <th scope="col">Kategori</th>
                                <th scope="col">Eklenme Tarihi</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="galeriTablosu">
                            @if (ViewBag.GaleriList != null && ((List<UrunGaleri>)ViewBag.GaleriList).Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in ViewBag.GaleriList)
                                {
                                    <tr data-galeri-id="@item.Id" data-galeri-urun="@(item.Urun != null ? item.Urun.Adi : "Bilinmeyen Ürün")" class="galeri-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input galeri-sec-radio" type="radio" name="seciliGaleriRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td>
                                            <img src="@item.FotografKucuk" alt="" style="width: 80px; height: 80px; object-fit: cover;" class="img-thumbnail">
                                        </td>
                                        <td>@(item.Urun != null ? item.Urun.Adi : "Bilinmeyen Ürün")</td>
                                        <td>@(item.Urun != null && item.Urun.Kategori != null ? item.Urun.Kategori.Adi : "Bilinmeyen Kategori")</td>
                                        <td>@item.EklenmeTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                                        <!-- İşlemler sütunundaki butonlar KALDIRILDI -->
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">Henüz resim eklenmemiş. <a href="#" data-bs-toggle="modal" data-button-permission="ekle" data-bs-target="#ekleModal" class="btn btn-success btn-sm">Yeni Resim Ekle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminUrunGaleri", FormMethod.Post, new { enctype = "multipart/form-data", id = "ekleForm" }))
            {
                <input type="hidden" id="selectedUrunId" name="UrunId" />
                <div class="modal-header">
                    <h5 class="modal-title" id="ekleModalLabel">Yeni Ürün Galeri Resmi Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kategori Seçin</label>
                            <select class="form-select" id="ekleKategoriSelect" onchange="loadEkleUrunler();">
                                <option value="">Kategori Seçin</option>
                                @foreach (var kategori in ViewBag.Kategoriler)
                                {
                                    <option value="@kategori.Id">@kategori.Adi</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ürün Seçin</label>
                            <select class="form-select" id="ekleUrunSelect" disabled>
                                <option value="">Önce Kategori Seçin</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label for="imagefile" class="form-label">Resim Seçin (Birden Fazla)</label>
                            <input type="file" class="form-control" id="imagefile" name="imagefile" accept="image/*" multiple required>
                            <div class="form-text">Birden fazla resim seçebilirsiniz. Büyük boyutlu resimler otomatik olarak küçültülecektir.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary" id="ekleSubmit" disabled>Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminUrunGaleri")" method="post" id="silForm">
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="silModalLabel">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Bu galeri resmini silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz. Resim hem veritabanından hem de sunucudan silinecektir.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            // Toastr ayarları
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "5000"
            };

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============
            let suAnSeciliGaleriId = null;
            let suAnSeciliGaleriUrun = null;
            let suAnSeciliSatir = null;

            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#galeriTablosu tr[data-galeri-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button') && !$(e.target).is('a') && !$(e.target).is('img')) {
                    const $radio = $(this).find('.galeri-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.galeri-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliGaleriId = $(this).val();
                    suAnSeciliSatir = $(this).closest('tr');
                    suAnSeciliGaleriUrun = suAnSeciliSatir.data('galeri-urun');

                    // Tüm satırlardan active class'ı kaldır
                    $('#galeriTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    suAnSeciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${suAnSeciliGaleriUrun.substring(0, 30)}${suAnSeciliGaleriUrun.length > 30 ? '...' : ''}`);

                    // Butonları aktif et
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliGaleriId) {
                    $('#silId').val(suAnSeciliGaleriId);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir resim seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliGaleriId) {
                    const $satir = $(`tr[data-galeri-id="${suAnSeciliGaleriId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        clearSelection();
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.galeri-sec-radio[value="${suAnSeciliGaleriId}"]`).prop('checked', false);
                        clearSelection();
                    }
                }
            });

            // Seçimi temizleme yardımcı fonksiyonu
            function clearSelection() {
                $('#galeriTablosu tr').removeClass('table-active');
                suAnSeciliGaleriId = null;
                suAnSeciliGaleriUrun = null;
                suAnSeciliSatir = null;
                $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                // Tüm butonları devre dışı bırak
                $seciliSilBtn.prop('disabled', true);
            }

            // Ekle Modal için
            window.loadEkleUrunler = function() {
                const kategoriId = document.getElementById('ekleKategoriSelect').value;
                const urunSelect = document.getElementById('ekleUrunSelect');
                const submitBtn = document.getElementById('ekleSubmit');
                urunSelect.innerHTML = '<option value="">Yükleniyor...</option>';
                urunSelect.disabled = true;
                submitBtn.disabled = true;

                if (kategoriId) {
                    fetch('@Url.Action("UrunlerByKategori", "AdminUrunGaleri")' + '?kategoriId=' + kategoriId)
                        .then(response => response.json())
                        .then(data => {
                            urunSelect.innerHTML = '<option value="">Ürün Seçin</option>';
                            data.forEach(urun => {
                                const option = document.createElement('option');
                                option.value = urun.id;
                                option.textContent = urun.adi;
                                urunSelect.appendChild(option);
                            });
                            urunSelect.disabled = false;
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            urunSelect.innerHTML = '<option value="">Hata Oluştu</option>';
                        });
                } else {
                    urunSelect.innerHTML = '<option value="">Önce Kategori Seçin</option>';
                    urunSelect.disabled = true;
                }
            }

            document.getElementById('ekleUrunSelect').addEventListener('change', function() {
                const urunId = this.value;
                document.getElementById('selectedUrunId').value = urunId;
                document.getElementById('ekleSubmit').disabled = !urunId || !document.getElementById('imagefile').files.length;
            });

            document.getElementById('imagefile').addEventListener('change', function() {
                const urunId = document.getElementById('ekleUrunSelect').value;
                document.getElementById('ekleSubmit').disabled = !urunId || this.files.length === 0;
            });

            // Modal kapandığında formları temizle
            document.getElementById('ekleModal').addEventListener('hidden.bs.modal', function () {
                this.querySelector('form').reset();
                loadEkleUrunler(); // Sıfırla
                document.getElementById('ekleSubmit').disabled = true;
            });

            // Başarı mesajlarını 5 saniye sonra otomatik kapat
            setTimeout(function() {
                var alerts = document.querySelectorAll('.alert');
                alerts.forEach(function(alert) {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        });

        function silOnay(id) {
            document.getElementById('silId').value = id;
            var silModal = new bootstrap.Modal(document.getElementById('silModal'));
            silModal.show();
        }
    </script>
}