@{
    ViewData["Title"] = "Hakkımızda Fotoğraf Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Seçim satırı için cursor pointer */
    tr[data-fotograf-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* Buton grupları için */
    .btn-group .btn {
        margin: 0 2px;
    }

        .btn-group .btn:first-child {
            margin-left: 0;
        }

        .btn-group .btn:last-child {
            margin-right: 0;
        }
</style>

<div class="row">
    <div class="col-md-12">
        <!-- Başarı/Hata Mesajları -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Hakkımızda Fotoğrafları</h5>
                <div class="d-flex align-items-center gap-3">
                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları -->
                    <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                        <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                            <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-danger btn-sm" id="seciliSilBtn" data-button-permission="sil" title="Seçili Resmi Sil" disabled style="margin-right:5px;">
                                <i class="fas fa-trash"></i> 
                            </button>
                        </div>
                    </div>

                    <!-- Yeni Ekle Butonu -->
                    <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                        <i class="fas fa-plus"></i> Yeni Resim Ekle
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-head-bg-primary">
                            <tr>
                                <th width="40">Seç</th>
                                <th scope="col">#</th>
                                <th scope="col">Resim</th>
                                <th scope="col">Eklenme Tarihi</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="fotografTablosu">
                            @if (ViewBag.FotografList != null && ViewBag.FotografList.Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in ViewBag.FotografList)
                                {
                                    <tr data-fotograf-id="@item.Id" data-fotograf-adi="Resim @counter" class="fotograf-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input fotograf-sec-radio" type="radio" name="seciliFotografRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td>
                                            <img src="@item.FotografKucuk" alt="Resim" style="width: 80px; height: 80px; object-fit: cover;" class="img-thumbnail">
                                        </td>
                                        <td>@item.EklenmeTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                                        <!-- İşlemler sütunundaki buton KALDIRILDI -->
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center">Henüz resim eklenmemiş. <a href="#" data-bs-toggle="modal" data-bs-target="#ekleModal" class="btn btn-primary btn-sm">Yeni Resim Ekle</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminHakkimizdaFotograf", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <div class="modal-header">
                    <h5 class="modal-title" id="ekleModalLabel">Yeni Hakkımızda Resim Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label for="imagefile" class="form-label">Resim Seçin (Birden fazla seçebilirsiniz)</label>
                            <input type="file" class="form-control" id="imagefile" name="imagefile" accept="image/*" multiple>
                            <div class="form-text">Lütfen hakkımızda resimlerini seçin. Büyük boyutlu resimler otomatik olarak küçültülecektir.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminHakkimizdaFotograf")" method="post">
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="silModalLabel">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Seçili resmi silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz. Resim hem veritabanından hem de sunucudan silinecektir.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            // Toastr ayarları
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "5000"
            };

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============
            let suAnSeciliFotografId = null;
            let suAnSeciliFotografAdi = null;
            let suAnSeciliSatir = null;

            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#fotografTablosu tr[data-fotograf-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button') && !$(e.target).is('a')) {
                    const $radio = $(this).find('.fotograf-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.fotograf-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliFotografId = $(this).val();
                    suAnSeciliSatir = $(this).closest('tr');
                    suAnSeciliFotografAdi = suAnSeciliSatir.data('fotograf-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#fotografTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    suAnSeciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${suAnSeciliFotografAdi}`);

                    // Butonları aktif et
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliFotografId) {
                    $('#silId').val(suAnSeciliFotografId);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir resim seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliFotografId) {
                    const $satir = $(`tr[data-fotograf-id="${suAnSeciliFotografId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        clearSelection();
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.fotograf-sec-radio[value="${suAnSeciliFotografId}"]`).prop('checked', false);
                        clearSelection();
                    }
                }
            });

            // Seçimi temizleme yardımcı fonksiyonu
            function clearSelection() {
                $('#fotografTablosu tr').removeClass('table-active');
                suAnSeciliFotografId = null;
                suAnSeciliFotografAdi = null;
                suAnSeciliSatir = null;
                $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                // Tüm butonları devre dışı bırak
                $seciliSilBtn.prop('disabled', true);
            }

            // Modal kapandığında formları temizle
            document.getElementById('ekleModal').addEventListener('hidden.bs.modal', function () {
                this.querySelector('form').reset();
            });

            // Başarı mesajlarını 5 saniye sonra otomatik kapat
            setTimeout(function() {
                var alerts = document.querySelectorAll('.alert');
                alerts.forEach(function(alert) {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        });

        // Silme onay fonksiyonu (sayfadaki mevcut butonlar için)
        function silOnay(id) {
            document.getElementById('silId').value = id;

            var silModal = new bootstrap.Modal(document.getElementById('silModal'));
            silModal.show();
        }
    </script>
}