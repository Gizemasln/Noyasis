@using WepApp.Models
@model List<KDV>

@{
    ViewData["Title"] = "KDV Oranları Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    .table-actions {
        white-space: nowrap;
        width: 120px;
    }

    .card {
        margin-top: 70px;
    }

    .table th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .badge-kdv {
        background-color: #20c997;
        color: white;
        padding: 5px 10px;
        border-radius: 20px;
        font-weight: 600;
    }

    /* Seçim satırı için cursor pointer */
    tr[data-kdv-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">KDV Oranları Yönetimi</h5>
                    <div class="d-flex align-items-center gap-3">
                        <!-- Seçili Kayıt Bilgisi ve İşlem Butonları -->
                        <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                            <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                                <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                            </div>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-warning aksiyon-btn" id="seciliDuzenleBtn" data-button-permission="duzenle" title="Seçili KDV Oranını Düzenle" disabled>
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="btn btn-danger aksiyon-btn" data-button-permission="sil" id="seciliSilBtn" title="Seçili KDV Oranını Sil" disabled>
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Yeni Ekle Butonu -->
                        <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni KDV Oranı Ekle
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th width="50">#</th>
                                <th>KDV Oranı</th>
                                <th>Eklenme Tarihi</th>
                                <th>Son Güncelleme</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="kdvTablosu">
                            @if (ViewBag.KDVListesi != null && ((List<KDV>)ViewBag.KDVListesi).Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in (List<KDV>)ViewBag.KDVListesi)
                                {
                                    <tr data-kdv-id="@item.Id" data-kdv-oran="@item.Oran" class="kdv-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input kdv-sec-radio" type="radio" name="seciliKDVRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td>
                                            <span class="badge-kdv">%@item.Oran</span>
                                        </td>
                                        <td>@item.EklenmeTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@item.GuncellenmeTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center">
                                        <div class="py-4">
                                            <i class="fas fa-percentage fa-3x text-muted mb-3"></i>
                                            <p class="text-muted">Henüz KDV oranı eklenmemiş.</p>
                                            <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                                                İlk KDV Oranını Ekle
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminKDV", FormMethod.Post, new { id = "ekleForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="ekleModalLabel">Yeni KDV Oranı Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="Oran" class="form-label">KDV Oranı (%) *</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="Oran" name="Oran"
                                   placeholder="KDV oranını giriniz"
                                   required
                                   min="0"
                                   max="100">
                            <span class="input-group-text">%</span>
                        </div>
                        <div class="form-text">KDV oranı 0 ile 100 arasında olmalıdır. Örneğin: 18, 20, 1.08</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1" aria-labelledby="duzenleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Guncelle", "AdminKDV")" method="post" id="duzenleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="duzenleModalLabel">KDV Oranı Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editOran" class="form-label">KDV Oranı (%) *</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="editOran" name="Oran"
                                   placeholder="KDV oranını giriniz"
                                   required
                                   min="0"
                                   max="100">
                            <span class="input-group-text">%</span>
                        </div>
                        <div class="form-text">KDV oranı 0 ile 100 arasında olmalıdır.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminKDV")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="silModalLabel">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"%<span id="silOran"></span>"</strong> KDV oranını silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger">
                        <small>
                            Bu işlem geri alınamaz. Bu KDV oranını kullanan ürünler varsa sorun yaşayabilirsiniz.
                        </small>
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function() {
            let suAnSeciliKDVId = null;
            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#kdvTablosu tr[data-kdv-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button')) {
                    const $radio = $(this).find('.kdv-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.kdv-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliKDVId = $(this).val();
                    const $seciliSatir = $(this).closest('tr');
                    const kdvOran = $seciliSatir.data('kdv-oran');

                    // Tüm satırlardan active class'ı kaldır
                    $('#kdvTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    $seciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: %${kdvOran}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliKDVId) {
                    const $seciliSatir = $(`tr[data-kdv-id="${suAnSeciliKDVId}"]`);
                    const oran = $seciliSatir.data('kdv-oran');

                    duzenleGetir(suAnSeciliKDVId, oran);
                } else {
                    toastr.warning('Lütfen önce bir KDV oranı seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliKDVId) {
                    const $seciliSatir = $(`tr[data-kdv-id="${suAnSeciliKDVId}"]`);
                    const kdvOran = $seciliSatir.data('kdv-oran');

                    $('#silId').val(suAnSeciliKDVId);
                    $('#silOran').text(kdvOran);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir KDV oranı seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliKDVId) {
                    const $satir = $(`tr[data-kdv-id="${suAnSeciliKDVId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        suAnSeciliKDVId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.kdv-sec-radio[value="${suAnSeciliKDVId}"]`).prop('checked', false);
                        $('#kdvTablosu tr').removeClass('table-active');
                        suAnSeciliKDVId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    }
                }
            });

            // ============= MEVCUT FONKSİYONLAR (AYNEN KORUNDU) =============

            // Düzenle modalını aç
            window.duzenleGetir = function(id, oran) {
                $('#editId').val(id);
                $('#editOran').val(oran);
                new bootstrap.Modal(document.getElementById('duzenleModal')).show();
            };

            // Silme onayı modalı
            window.silOnay = function(id, oran) {
                $('#silId').val(id);
                $('#silOran').text(oran);
                new bootstrap.Modal(document.getElementById('silModal')).show();
            };

            // Form validasyonları
            document.addEventListener('DOMContentLoaded', function() {
                // Oran validasyonu
                function validateOran(input) {
                    const oran = parseFloat(input.value);
                    if (isNaN(oran) || oran < 0 || oran > 100) {
                        input.setCustomValidity('KDV oranı 0 ile 100 arasında olmalıdır.');
                        return false;
                    } else {
                        input.setCustomValidity('');
                        return true;
                    }
                }

                // Oran inputlarına validation ekle
                const oranInputs = document.querySelectorAll('input[name="Oran"]');
                oranInputs.forEach(input => {
                    input.addEventListener('input', function() {
                        validateOran(this);
                    });

                    input.addEventListener('change', function() {
                        validateOran(this);
                    });
                });

                // Form submit kontrolleri
                const forms = document.querySelectorAll('form');
                forms.forEach(form => {
                    form.addEventListener('submit', function(e) {
                        const oranInput = this.querySelector('input[name="Oran"]');
                        if (oranInput && !validateOran(oranInput)) {
                            e.preventDefault();
                            toastr.error('Geçerli bir KDV oranı giriniz (0-100 arası).');
                            oranInput.focus();
                            return false;
                        }

                        // Boş kontrolü
                        if (oranInput && oranInput.value.trim().length === 0) {
                            e.preventDefault();
                            toastr.error('KDV oranı gereklidir.');
                            oranInput.focus();
                            return false;
                        }
                    });
                });

                // Modal kapandığında formları sıfırla
                ['ekleModal', 'duzenleModal'].forEach(modalId => {
                    const modal = document.getElementById(modalId);
                    if (modal) {
                        modal.addEventListener('hidden.bs.modal', function() {
                            const form = this.querySelector('form');
                            if (form) {
                                form.reset();
                                const inputs = form.querySelectorAll('input');
                                inputs.forEach(input => input.setCustomValidity(''));
                            }
                        });
                    }
                });

                // Alert mesajlarını 5 saniye sonra otomatik kapat
                setTimeout(() => {
                    document.querySelectorAll('.alert').forEach(alert => {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    });
                }, 5000);
            });

            // Enter tuşu ile form submit
            document.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    const activeModal = document.querySelector('.modal.show');
                    if (activeModal) {
                        const form = activeModal.querySelector('form');
                        if (form) {
                            const submitButton = form.querySelector('button[type="submit"]');
                            if (submitButton) {
                                submitButton.click();
                            }
                        }
                    }
                }
            });
        });
    </script>
}