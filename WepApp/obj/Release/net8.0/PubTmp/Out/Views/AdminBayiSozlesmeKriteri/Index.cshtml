@using WepApp.Models
@{
    ViewData["Title"] = "Bayi Sözleşme Kriterleri Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Filtreleme stilleri - Diğer sayfalarla uyumlu */
    .card-header .flex-wrap {
        gap: 15px;
    }

    .card-header .gap-2 {
        gap: 0.5rem !important;
    }

    .search-box {
        position: relative;
    }

        .search-box .input-group {
            transition: all 0.3s ease;
            width: 200px;
        }

            .search-box .input-group:focus-within {
                width: 250px;
            }

        .search-box .form-control:focus {
            background-color: #fff !important;
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
        }

    #kriterAramaTemizle {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        z-index: 5;
        color: #6c757d;
        padding: 0.25rem 0.5rem;
    }

        #kriterAramaTemizle:hover {
            color: #dc3545;
        }

    .dropdown-menu {
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        border: none;
    }

        .dropdown-menu .form-control-sm,
        .dropdown-menu .form-select-sm {
            border: 1px solid #dee2e6;
        }

            .dropdown-menu .form-control-sm:focus,
            .dropdown-menu .form-select-sm:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
            }

    #kriterFiltreTemizleBtn {
        transition: all 0.3s ease;
    }

        #kriterFiltreTemizleBtn:hover {
            transform: scale(1.1);
        }

    /* Aktif filtre butonu stilleri */
    .btn-primary .fas {
        color: white;
    }

    /* Filtre etiketleri */
    #aktifFiltreler {
        background-color: #f8f9fa;
        border-radius: 0.35rem;
        padding: 10px;
        border: 1px solid #e3e6f0;
        margin-top: 15px !important;
    }

        #aktifFiltreler .badge {
            font-size: 0.85rem;
            padding: 0.5rem 0.75rem;
        }

    /* Tablo satırları için geçiş efekti */
    #kriterTablosu tr {
        transition: all 0.3s ease;
    }

        #kriterTablosu tr[style*="display: none"] {
            opacity: 0;
            transform: scale(0.95);
        }

    /* Responsive düzenlemeler */
    media (max-width: 768px) {
        .card-header .d-flex

    {
        flex-direction: column;
        align-items: stretch !important;
    }

    .card-header .gap-2 {
        flex-wrap: wrap;
        justify-content: space-between;
    }

    .search-box {
        width: 100% !important;
        margin-bottom: 5px;
    }

        .search-box .input-group {
            width: 100% !important;
        }

            .search-box .input-group:focus-within {
                width: 100% !important;
            }

    .card-header .dropdown {
        flex: 1;
    }

    .islem-butonlari-alani {
        width: 100%;
        justify-content: space-between;
    }

    #aktifFiltreler .d-flex {
        flex-direction: column;
        align-items: flex-start !important;
        gap: 10px;
    }

    #filtreEtiketleri {
        flex-wrap: wrap;
    }

    }
    .table-actions {
        white-space: nowrap;
        width: 120px;
    }

    .card {
        margin-top: 70px;
    }

    .table th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    /* Seçim satırı için cursor pointer */
    tr[data-kriter-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-0">Bayi Sözleşme Kriterleri</h5>

                    <!-- FİLTRELEME ALANI - Diğer sayfalarla uyumlu -->
                    <div class="d-flex align-items-center gap-2">
                        <!-- Arama Kutusu -->
                        <div class="search-box">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light border-0">
                                    <i class="fas fa-search text-muted"></i>
                                </span>
                                <input type="text" id="kriterArama" class="form-control form-control-sm border-0 bg-light"
                                       placeholder="Kriter ara..." style="box-shadow: none;">
                                <button class="btn btn-outline-secondary btn-sm" type="button" id="kriterAramaTemizle" style="display:none;">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Tarih Filtreleri -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="tarihFiltreBtn">
                                <i class="fas fa-calendar-alt me-1"></i> Tarih
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 300px;">
                                <div class="mb-2">
                                    <label class="form-label small">Eklenme Tarihi Aralığı</label>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Başlangıç</label>
                                    <input type="date" id="filtreBaslangicTarih" class="form-control form-control-sm">
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Bitiş</label>
                                    <input type="date" id="filtreBitisTarih" class="form-control form-control-sm">
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="kriterTarihFiltreTemizle()">Temizle</button>
                                    <button class="btn btn-sm btn-primary" onclick="kriterTarihFiltreUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Oran Filtresi -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="oranFiltreBtn">
                                <i class="fas fa-percent me-1"></i> Oran
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 250px;">
                                <div class="mb-2">
                                    <label class="form-label small">Min Oran (%)</label>
                                    <input type="number" id="filtreMinOran" class="form-control form-control-sm" min="0" max="100" step="0.01">
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Max Oran (%)</label>
                                    <input type="number" id="filtreMaxOran" class="form-control form-control-sm" min="0" max="100" step="0.01">
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="kriterOranFiltreTemizle()">Temizle</button>
                                    <button class="btn btn-sm btn-primary" onclick="kriterOranFiltreUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Sıralama -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="siralamaFiltreBtn">
                                <i class="fas fa-sort-amount-down me-1"></i> Sıralama
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 200px;">
                                <div class="mb-2">
                                    <select class="form-select form-select-sm" id="siralamaFiltre">
                                        <option value="yeni">En Yeni → En Eski</option>
                                        <option value="eski">En Eski → En Yeni</option>
                                        <option value="adi_az">İsim (A-Z)</option>
                                        <option value="adi_za">İsim (Z-A)</option>
                                        <option value="oran_azalan">Oran (Azalan)</option>
                                        <option value="oran_artan">Oran (Artan)</option>
                                    </select>
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-primary" onclick="kriterSiralamaUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Filtre Temizleme Butonu -->
                        <button class="btn btn-sm btn-outline-danger" onclick="kriterTumFiltreleriTemizle()"
                                title="Tüm filtreleri temizle" id="kriterFiltreTemizleBtn" style="display: none;">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları (mevcut kod) -->
                    <div class="d-flex align-items-center gap-3">
                        <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                            <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                                <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                            </div>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-warning aksiyon-btn" id="seciliDuzenleBtn" title="Seçili Kriteri Düzenle" disabled data-button-permission="duzenle">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="btn btn-danger aksiyon-btn" id="seciliSilBtn" title="Seçili Kriteri Sil" disabled data-button-permission="sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Yeni Ekle Butonu -->
                        <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Kriter Ekle
                        </button>
                    </div>
                </div>

                <!-- Aktif Filtreler -->
                <div class="row mt-3" id="aktifFiltreler" style="display: none;">
                    <div class="col-12">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-light text-dark me-2 p-2">
                                <i class="fas fa-filter me-1"></i>Aktif Filtreler:
                            </span>
                            <div id="filtreEtiketleri" class="d-flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th width="50">#</th>
                                <th>Kriter Adı</th>
                                <th>Açıklama</th>
                                <th>Oran (%)</th>
                                <th>Eklenme Tarihi</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="kriterTablosu">
                            @if (ViewBag.Kriterler != null && ((List<BayiSozlesmeKriteri>)ViewBag.Kriterler).Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in (List<BayiSozlesmeKriteri>)ViewBag.Kriterler)
                                {
                                    <tr data-kriter-id="@item.Id" data-kriter-adi="@item.Adi" data-kriter-aciklama="@(item.Aciklama ?? "")" data-kriter-uzunaciklama="@(item.UzunAciklama ?? "")" data-kriter-konu="@(item.Konu ?? "")" data-kriter-oran="@item.Oran" class="kriter-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input kriter-sec-radio" type="radio" name="seciliKriterRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td><strong>@item.Adi</strong></td>
                                        <td>@(string.IsNullOrEmpty(item.Aciklama) ? "-" : item.Aciklama)</td>
                                        <td>%@item.Oran.ToString("N2")</td>
                                        <td>@item.EklenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                        <p class="text-muted">Henüz kriter eklenmemiş.</p>
                                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ekleModal">
                                            İlk Kriteri Ekle
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminBayiSozlesmeKriteri", FormMethod.Post, new { id = "ekleForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Bayi Sözleşme Kriteri Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kriter Adı *</label>
                            <input type="text" class="form-control" name="Adi" required maxlength="200" placeholder="Örn: Ciro Hedefi" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Oran (%)</label>
                            <input class="form-control" name="Oran" value="0" min="0" max="100" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kısa Açıklama</label>
                        <input type="text" class="form-control" name="Aciklama" maxlength="500" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Konu / Madde</label>
                        <input type="text" class="form-control" name="Konu" maxlength="300" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Uzun Açıklama (Opsiyonel)</label>
                        <textarea class="form-control" name="UzunAciklama" rows="4"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form action="@Url.Action("Guncelle", "AdminBayiSozlesmeKriteri")" method="post" id="duzenleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Kriter Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kriter Adı *</label>
                            <input type="text" class="form-control" id="editAdi" name="Adi" required maxlength="200" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Oran (%)</label>
                            <input  class="form-control" id="editOran" name="Oran" min="0" max="10000" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kısa Açıklama</label>
                        <input type="text" class="form-control" id="editAciklama" name="Aciklama" maxlength="500" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Konu / Madde</label>
                        <input type="text" class="form-control" id="editKonu" name="Konu" maxlength="300" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Uzun Açıklama</label>
                        <textarea class="form-control" id="editUzunAciklama" name="UzunAciklama" rows="4"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Modal -->
<div class="modal fade" id="silModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminBayiSozlesmeKriteri")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="silId" name="Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silAdi"></span>"</strong> kriterini silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function() {
                    // ============= KRİTER FİLTRELEME SİSTEMİ =============
        let kriterAktifFiltreler = {
            arama: '',
            baslangicTarih: null,
            bitisTarih: null,
            minOran: null,
            maxOran: null,
            siralama: 'yeni'
        };

        // Arama fonksiyonu
        function kriterAramaFiltrele() {
            const aramaInput = document.getElementById('kriterArama');
            const temizleBtn = document.getElementById('kriterAramaTemizle');

            if (aramaInput && temizleBtn) {
                const kelime = aramaInput.value.trim().toLowerCase();

                // Temizle butonunu göster/gizle
                temizleBtn.style.display = kelime ? 'block' : 'none';

                kriterAktifFiltreler.arama = kelime;
                kriterFiltreEtiketleriniGoster();
                kriterFiltreleVeSirala();
            }
        }

        // Arama inputuna event listener ekle
        const aramaInput = document.getElementById('kriterArama');
        const temizleBtn = document.getElementById('kriterAramaTemizle');

        if (aramaInput) {
            aramaInput.addEventListener('input', kriterAramaFiltrele);
            aramaInput.addEventListener('keyup', kriterAramaFiltrele);
        }

        if (temizleBtn) {
            temizleBtn.addEventListener('click', function () {
                aramaInput.value = '';
                kriterAramaFiltrele();
                aramaInput.focus();
            });
        }

        // Tarih Filtresi Uygula
        window.kriterTarihFiltreUygula = function() {
            const baslangicInput = document.getElementById('filtreBaslangicTarih');
            const bitisInput = document.getElementById('filtreBitisTarih');

            kriterAktifFiltreler.baslangicTarih = baslangicInput.value || null;
            kriterAktifFiltreler.bitisTarih = bitisInput.value || null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('tarihFiltreBtn'));
            if (dropdown) dropdown.hide();

            kriterFiltreEtiketleriniGoster();
            kriterFiltreleVeSirala();
        };

        // Tarih Filtresi Temizle
        window.kriterTarihFiltreTemizle = function() {
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';
            kriterAktifFiltreler.baslangicTarih = null;
            kriterAktifFiltreler.bitisTarih = null;
            kriterFiltreEtiketleriniGoster();
            kriterFiltreleVeSirala();
        };

        // Oran Filtresi Uygula
        window.kriterOranFiltreUygula = function() {
            const minInput = document.getElementById('filtreMinOran');
            const maxInput = document.getElementById('filtreMaxOran');

            kriterAktifFiltreler.minOran = minInput.value ? parseFloat(minInput.value) : null;
            kriterAktifFiltreler.maxOran = maxInput.value ? parseFloat(maxInput.value) : null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('oranFiltreBtn'));
            if (dropdown) dropdown.hide();

            kriterFiltreEtiketleriniGoster();
            kriterFiltreleVeSirala();
        };

        // Oran Filtresi Temizle
        window.kriterOranFiltreTemizle = function() {
            document.getElementById('filtreMinOran').value = '';
            document.getElementById('filtreMaxOran').value = '';
            kriterAktifFiltreler.minOran = null;
            kriterAktifFiltreler.maxOran = null;
            kriterFiltreEtiketleriniGoster();
            kriterFiltreleVeSirala();
        };

        // Sıralama Uygula
        window.kriterSiralamaUygula = function() {
            const siralama = document.getElementById('siralamaFiltre').value;
            kriterAktifFiltreler.siralama = siralama;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('siralamaFiltreBtn'));
            if (dropdown) dropdown.hide();

            kriterFiltreEtiketleriniGoster();
            kriterFiltreleVeSirala();
        };

        // Tüm Filtreleri Temizle
        window.kriterTumFiltreleriTemizle = function() {
            // Arama kutusunu temizle
            document.getElementById('kriterArama').value = '';
            document.getElementById('kriterAramaTemizle').style.display = 'none';

            // Tarih filtrelerini temizle
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';

            // Oran filtrelerini temizle
            document.getElementById('filtreMinOran').value = '';
            document.getElementById('filtreMaxOran').value = '';

            // Sıralamayı varsayılana getir
            document.getElementById('siralamaFiltre').value = 'yeni';

            // Buton stillerini sıfırla
            document.getElementById('tarihFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('oranFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('siralamaFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';

            // Filtre değişkenlerini sıfırla
            kriterAktifFiltreler = {
                arama: '',
                baslangicTarih: null,
                bitisTarih: null,
                minOran: null,
                maxOran: null,
                siralama: 'yeni'
            };

            // Filtre etiketlerini gizle
            document.getElementById('aktifFiltreler').style.display = 'none';
            document.getElementById('kriterFiltreTemizleBtn').style.display = 'none';

            // Filtrelemeyi yeniden uygula
            kriterFiltreleVeSirala();
        };

        // Filtre etiketlerini göster
        function kriterFiltreEtiketleriniGoster() {
            const etiketler = [];
            const filtreTemizleBtn = document.getElementById('kriterFiltreTemizleBtn');

            if (kriterAktifFiltreler.arama) {
                etiketler.push(`<span class="badge bg-primary">Arama: ${kriterAktifFiltreler.arama}</span>`);
            }

            if (kriterAktifFiltreler.baslangicTarih) {
                etiketler.push(`<span class="badge bg-primary">Başlangıç: ${formatKriterDate(kriterAktifFiltreler.baslangicTarih)}</span>`);
            }
            if (kriterAktifFiltreler.bitisTarih) {
                etiketler.push(`<span class="badge bg-primary">Bitiş: ${formatKriterDate(kriterAktifFiltreler.bitisTarih)}</span>`);
            }

            if (kriterAktifFiltreler.minOran !== null && kriterAktifFiltreler.maxOran !== null) {
                etiketler.push(`<span class="badge bg-success">Oran: %${kriterAktifFiltreler.minOran} - %${kriterAktifFiltreler.maxOran}</span>`);
            } else if (kriterAktifFiltreler.minOran !== null) {
                etiketler.push(`<span class="badge bg-success">Min Oran: %${kriterAktifFiltreler.minOran}</span>`);
            } else if (kriterAktifFiltreler.maxOran !== null) {
                etiketler.push(`<span class="badge bg-success">Max Oran: %${kriterAktifFiltreler.maxOran}</span>`);
            }

            if (kriterAktifFiltreler.siralama !== 'yeni') {
                const siralamaMetin = {
                    'eski': 'En Eski',
                    'adi_az': 'İsim (A-Z)',
                    'adi_za': 'İsim (Z-A)',
                    'oran_azalan': 'Oran (Azalan)',
                    'oran_artan': 'Oran (Artan)'
                };
                etiketler.push(`<span class="badge bg-info">Sıralama: ${siralamaMetin[kriterAktifFiltreler.siralama]}</span>`);
            }

            if (etiketler.length > 0) {
                document.getElementById('filtreEtiketleri').innerHTML = etiketler.join(' ');
                document.getElementById('aktifFiltreler').style.display = 'block';
                filtreTemizleBtn.style.display = 'inline-block';

                // Buton stillerini güncelle
                document.getElementById('tarihFiltreBtn').className = kriterAktifFiltreler.baslangicTarih || kriterAktifFiltreler.bitisTarih
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('oranFiltreBtn').className = kriterAktifFiltreler.minOran !== null || kriterAktifFiltreler.maxOran !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';
            } else {
                document.getElementById('aktifFiltreler').style.display = 'none';
                filtreTemizleBtn.style.display = 'none';
            }
        }

        // Tarih formatlama
        function formatKriterDate(dateStr) {
            if (!dateStr) return '';
            const [yil, ay, gun] = dateStr.split('-');
            return `${gun}.${ay}.${yil}`;
        }

        // Tarih parse (dd.MM.yyyy HH:mm formatı)
        function kriterParseDate(dateStr) {
            if (!dateStr) return null;
            const [gun, ay, yilSaat] = dateStr.split('.');
            const [yil, saat] = yilSaat.split(' ');
            return new Date(`${yil}-${ay}-${gun}T${saat}`);
        }

        // Ana filtreleme ve sıralama fonksiyonu
        function kriterFiltreleVeSirala() {
            const tbody = document.getElementById('kriterTablosu');
            if (!tbody) return;

            const satirlar = Array.from(tbody.querySelectorAll('tr.kriter-satiri'));

            if (satirlar.length === 0) return;

            // Filtreleme
            let filtrelenmisSatirlar = satirlar.filter(satir => {
                let goster = true;

                // Arama filtresi (Kriter Adı - 3. sütun)
                if (kriterAktifFiltreler.arama) {
                    const adi = satir.querySelector('td:nth-child(3)')?.textContent.toLowerCase() || '';
                    if (!adi.includes(kriterAktifFiltreler.arama.toLowerCase())) {
                        goster = false;
                    }
                }

                // Tarih filtresi (6. sütun - Eklenme Tarihi)
                if (goster && (kriterAktifFiltreler.baslangicTarih || kriterAktifFiltreler.bitisTarih)) {
                    const tarihTd = satir.querySelector('td:nth-child(6)')?.textContent.trim();
                    if (tarihTd) {
                        const tarih = kriterParseDate(tarihTd);

                        if (kriterAktifFiltreler.baslangicTarih) {
                            const filtreBaslangic = new Date(kriterAktifFiltreler.baslangicTarih + 'T00:00:00');
                            if (tarih < filtreBaslangic) {
                                goster = false;
                            }
                        }

                        if (goster && kriterAktifFiltreler.bitisTarih) {
                            const filtreBitis = new Date(kriterAktifFiltreler.bitisTarih + 'T23:59:59');
                            if (tarih > filtreBitis) {
                                goster = false;
                            }
                        }
                    }
                }

                // Oran filtresi (5. sütun - % işaretini kaldır)
                if (goster && (kriterAktifFiltreler.minOran !== null || kriterAktifFiltreler.maxOran !== null)) {
                    const oranTd = satir.querySelector('td:nth-child(5)')?.textContent.trim();
                    if (oranTd) {
                        const oran = parseFloat(oranTd.replace('%', ''));

                        if (kriterAktifFiltreler.minOran !== null && oran < kriterAktifFiltreler.minOran) {
                            goster = false;
                        }

                        if (goster && kriterAktifFiltreler.maxOran !== null && oran > kriterAktifFiltreler.maxOran) {
                            goster = false;
                        }
                    }
                }

                return goster;
            });

            // Sıralama
            switch(kriterAktifFiltreler.siralama) {
                case 'yeni':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = kriterParseDate(a.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        const tarihB = kriterParseDate(b.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        return (tarihB || 0) - (tarihA || 0);
                    });
                    break;

                case 'eski':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = kriterParseDate(a.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        const tarihB = kriterParseDate(b.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        return (tarihA || 0) - (tarihB || 0);
                    });
                    break;

                case 'adi_az':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiA.localeCompare(adiB, 'tr');
                    });
                    break;

                case 'adi_za':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiB.localeCompare(adiA, 'tr');
                    });
                    break;

                case 'oran_azalan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const oranA = parseFloat(a.querySelector('td:nth-child(5)')?.textContent.replace('%', '') || '0');
                        const oranB = parseFloat(b.querySelector('td:nth-child(5)')?.textContent.replace('%', '') || '0');
                        return oranB - oranA;
                    });
                    break;

                case 'oran_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const oranA = parseFloat(a.querySelector('td:nth-child(5)')?.textContent.replace('%', '') || '0');
                        const oranB = parseFloat(b.querySelector('td:nth-child(5)')?.textContent.replace('%', '') || '0');
                        return oranA - oranB;
                    });
                    break;
            }

            // Tüm satırları gizle
            satirlar.forEach(satir => {
                satir.style.display = 'none';
            });

            // Filtrelenmiş satırları göster ve tbody'ye yeniden ekle (sıralama için)
            filtrelenmisSatirlar.forEach((satir, index) => {
                satir.style.display = '';
                // Sıra numarasını güncelle (2. sütun)
                const siraHucresi = satir.querySelector('td:nth-child(2)');
                if (siraHucresi) {
                    siraHucresi.textContent = index + 1;
                }
                tbody.appendChild(satir);
            });

            // "Gösterilecek kayıt yok" mesajı
            let bosSatir = tbody.querySelector('.filtre-bos-satir');

            if (filtrelenmisSatirlar.length === 0) {
                if (!bosSatir) {
                    bosSatir = document.createElement('tr');
                    bosSatir.className = 'filtre-bos-satir';
                    bosSatir.innerHTML = '<td colspan="7" class="text-center py-5"><i class="fas fa-filter fa-3x text-muted mb-3"></i><p class="text-muted">Filtreleme kriterlerine uygun kriter bulunamadı.</p><button class="btn btn-sm btn-outline-secondary" onclick="kriterTumFiltreleriTemizle()">Filtreleri Temizle</button></td>';
                    tbody.appendChild(bosSatir);
                }
            } else if (bosSatir) {
                bosSatir.remove();
            }
        }

        // Enter tuşu ile filtreleme
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const aktifElement = document.activeElement;
                if (aktifElement.id === 'kriterArama' ||
                    aktifElement.id === 'filtreBaslangicTarih' ||
                    aktifElement.id === 'filtreBitisTarih' ||
                    aktifElement.id === 'filtreMinOran' ||
                    aktifElement.id === 'filtreMaxOran') {
                    e.preventDefault();
                    kriterFiltreleVeSirala();
                }
            }
        });
            let suAnSeciliKriterId = null;
            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#kriterTablosu tr[data-kriter-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button')) {
                    const $radio = $(this).find('.kriter-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.kriter-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliKriterId = $(this).val();
                    const $seciliSatir = $(this).closest('tr');
                    const kriterAdi = $seciliSatir.data('kriter-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#kriterTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    $seciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${kriterAdi}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliKriterId) {
                    const $seciliSatir = $(`tr[data-kriter-id="${suAnSeciliKriterId}"]`);
                    const adi = $seciliSatir.data('kriter-adi');
                    const aciklama = $seciliSatir.data('kriter-aciklama') || '';
                    const uzunAciklama = $seciliSatir.data('kriter-uzunaciklama') || '';
                    const konu = $seciliSatir.data('kriter-konu') || '';
                    const oran = $seciliSatir.data('kriter-oran') || 0;

                    duzenleGetir(suAnSeciliKriterId, adi, aciklama, uzunAciklama, konu, oran);
                } else {
                    toastr.warning('Lütfen önce bir kriter seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliKriterId) {
                    const $seciliSatir = $(`tr[data-kriter-id="${suAnSeciliKriterId}"]`);
                    const kriterAdi = $seciliSatir.data('kriter-adi');

                    $('#silId').val(suAnSeciliKriterId);
                    $('#silAdi').text(kriterAdi);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir kriter seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliKriterId) {
                    const $satir = $(`tr[data-kriter-id="${suAnSeciliKriterId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        suAnSeciliKriterId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.kriter-sec-radio[value="${suAnSeciliKriterId}"]`).prop('checked', false);
                        $('#kriterTablosu tr').removeClass('table-active');
                        suAnSeciliKriterId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    }
                }
            });

            // ============= MEVCUT FONKSİYONLAR (AYNEN KORUNDU) =============

            window.duzenleGetir = function(id, adi, aciklama, uzunAciklama, konu, oran) {
                $('#editId').val(id);
                $('#editAdi').val(adi);
                $('#editAciklama').val(aciklama);
                $('#editUzunAciklama').val(uzunAciklama);
                $('#editKonu').val(konu);
                $('#editOran').val(oran);
                new bootstrap.Modal(document.getElementById('duzenleModal')).show();
            };

            window.silOnay = function(id, adi) {
                $('#silId').val(id);
                $('#silAdi').text(adi);
                new bootstrap.Modal(document.getElementById('silModal')).show();
            };

            // Form validasyon + modal temizleme + alert kapatma
            document.querySelectorAll('form').forEach(f => {
                f.addEventListener('submit', e => {
                    const adi = f.querySelector('[name="Adi"]');
                    if (adi && !adi.value.trim()) {
                        e.preventDefault();
                        toastr.error('Kriter adı zorunludur.');
                        adi.focus();
                    }
                });
            });

            ['ekleModal', 'duzenleModal'].forEach(id => {
                const modal = document.getElementById(id);
                if (modal) modal.addEventListener('hidden.bs.modal', () => modal.querySelector('form')?.reset());
            });

            setTimeout(() => document.querySelectorAll('.alert').forEach(a => bootstrap.Alert.getOrCreateInstance(a).close()), 5000);
        });
    </script>
}