@{
    ViewData["Title"] = "Hakkımızda Bilgileri Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <!-- Başarı/Hata Mesajları -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span>Hakkımızda Bilgileri Yönetimi</span>
                </div>
            </div>
            <div class="card-body">
                @if (ViewBag.Hakkimizda != null)
                {
                    <!-- Mevcut Hakkımızda Bilgisi Kartı -->
                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">Aktif Hakkımızda Bilgisi</h5>
                                </div>
                                <div class="card-body">
                                    <h3 class="text-primary">@ViewBag.Hakkimizda.Baslik</h3>
                                    @if (!string.IsNullOrEmpty(ViewBag.Hakkimizda.AltBaslik))
                                    {
                                        <h5 class="text-muted">@ViewBag.Hakkimizda.AltBaslik</h5>
                                    }
                                    <hr>
                                    <p class="lead">@ViewBag.Hakkimizda.Metin</p>
                                    <hr>
                                    <div class="row">
                                        <div class="col-md-6">
                                            <small class="text-muted">
                                                <i class="fas fa-calendar"></i> Eklenme: @ViewBag.Hakkimizda.EklenmeTarihi?.ToString("dd.MM.yyyy HH:mm")
                                            </small>
                                        </div>
                                        <div class="col-md-6 text-end">
                                            <button type="button" class="btn btn-warning" data-button-permission="duzenle" onclick="duzenleGetir(@ViewBag.Hakkimizda.Id)" title="Düzenle">
                                                <i class="fas fa-edit"></i> 
                                            </button>
                                            <button type="button" class="btn btn-danger" data-button-permission="sil" onclick="silOnay(@ViewBag.Hakkimizda.Id, '@ViewBag.Hakkimizda.Baslik')" title="Sil">
                                                <i class="fas fa-trash"></i> 
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Yeni Bilgi Ekle Uyarısı -->
                    <div class="alert alert-warning">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-info-circle"></i>
                                Zaten bir aktif hakkımızda bilgisi bulunmaktadır. Yeni bir bilgi eklemek isterseniz, mevcut bilgi otomatik olarak pasif edilecektir.
                            </div>
                            <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                                <i class="fas fa-plus"></i> Yeni Bilgi Ekle
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Hiç kayıt yoksa -->
                    <div class="alert alert-info text-center">
                        <i class="fas fa-info-circle fa-2x mb-3"></i>
                        <h5>Henüz bir hakkımızda bilgisi eklenmemiş.</h5>
                        <p>Hemen yeni bir hakkımızda bilgisi ekleyin.</p>
                        <button type="button" class="btn btn-primary btn-lg" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Hakkımızda Bilgisi Ekle
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Ekle", "AdminHakkimizdaBilgileri")" id="ekleForm">
                <div class="modal-header">
                    <h5 class="modal-title" id="ekleModalLabel">Yeni Hakkımızda Bilgisi Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (ViewBag.Hakkimizda != null)
                    {
                        <div class="alert alert-warning mb-3">
                            <i class="fas fa-exclamation-triangle"></i>
                            Yeni bilgi eklendiğinde mevcut aktif bilgi otomatik olarak pasif edilecektir.
                        </div>
                    }
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="Baslik" name="Baslik" placeholder="Başlık" required>
                                <label for="Baslik">Başlık</label>
                            </div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="AltBaslik" name="AltBaslik" placeholder="Alt Başlık">
                                <label for="AltBaslik">Alt Başlık</label>
                            </div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <textarea class="form-control" id="Metin" name="Metin" placeholder="Metin" style="height: 200px" required></textarea>
                                <label for="Metin">Metin</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1" aria-labelledby="duzenleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Guncelle", "AdminHakkimizdaBilgileri")" id="duzenleForm">
                <input type="hidden" id="editId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="duzenleModalLabel">Hakkımızda Bilgisi Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="editBaslik" name="Baslik" placeholder="Başlık" required>
                                <label for="editBaslik">Başlık</label>
                            </div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="editAltBaslik" name="AltBaslik" placeholder="Alt Başlık">
                                <label for="editAltBaslik">Alt Başlık</label>
                            </div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <textarea class="form-control" id="editMetin" name="Metin" placeholder="Metin" style="height: 200px" required></textarea>
                                <label for="editMetin">Metin</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Sil", "AdminHakkimizdaBilgileri")">
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="silModalLabel">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silBaslik"></span>"</strong> başlıklı hakkımızda bilgisini silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz. Bilgi pasif hale getirilecektir.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <script>
        function duzenleGetir(id) {
            fetch('@Url.Action("Getir", "AdminHakkimizdaBilgileri")' + '?id=' + id)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    document.getElementById('editId').value = data.id;
                    document.getElementById('editBaslik').value = data.baslik || '';
                    document.getElementById('editAltBaslik').value = data.altBaslik || '';
                    document.getElementById('editMetin').value = data.metin || '';

                    var duzenleModal = new bootstrap.Modal(document.getElementById('duzenleModal'));
                    duzenleModal.show();
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Kayıt getirilirken bir hata oluştu.');
                });
        }

        function silOnay(id, baslik) {
            document.getElementById('silId').value = id;
            document.getElementById('silBaslik').textContent = baslik;

            var silModal = new bootstrap.Modal(document.getElementById('silModal'));
            silModal.show();
        }

        // Modal kapandığında formları temizle
        document.addEventListener('DOMContentLoaded', function() {
            var ekleModal = document.getElementById('ekleModal');
            if (ekleModal) {
                ekleModal.addEventListener('hidden.bs.modal', function () {
                    var form = this.querySelector('form');
                    if (form) form.reset();
                });
            }

            var duzenleModal = document.getElementById('duzenleModal');
            if (duzenleModal) {
                duzenleModal.addEventListener('hidden.bs.modal', function () {
                    var form = this.querySelector('form');
                    if (form) form.reset();
                });
            }
        });

        // Başarı mesajlarını 5 saniye sonra otomatik kapat
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}