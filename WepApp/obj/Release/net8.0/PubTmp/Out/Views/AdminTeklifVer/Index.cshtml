        async function kontrolKullaniciAdiYeniMusteri(kullaniciAdi) {
            try {
                let url = `/AdminMusteri/KullaniciAdiKontrol?kullaniciAdi=${encodeURIComponent(kullaniciAdi)}`;
                const res = await fetch(url);
                const json = await res.json();
                const el = $('#yeniKullaniciAdiKontrol');
                el.text(json.message);
                el.removeClass('text-success text-danger');
                el.addClass(json.success ? 'text-success' : 'text-danger');
            } catch (err) {
                console.error('Kullanıcı adı kontrolü hatası:', err);
            }
        }
            function kaydetGeciciMusteri() {
            const form = $('#yeniMusteriForm')[0];
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const musteriDurumuId = parseInt($('#yeniMusteriDurumuId').val()) || 1;
            const musteriTipiId = parseInt($('#yeniMusteriTipiId').val()) || null;
            const diger = $('#yeniDiger').val() ? $('#yeniDiger').val().trim() : '';
            const adayMi = musteriDurumuId == 2;

            // Aday müşteri için özel kontroller
            if (adayMi) {
                const ticariUnvan = $('#yeniTicariUnvan').val() ? $('#yeniTicariUnvan').val().trim() : '';
                const adSoyad = $('#yeniAdSoyad').val() ? $('#yeniAdSoyad').val().trim() : '';

                if (!ticariUnvan || !adSoyad) {
                    showToast('Hata', 'Aday müşteri için Ticari Unvan, Ad ve Soyad alanları zorunludur!', false);
                    return;
                }
            } else {
                if (musteriTipiId === digerTipId && !diger) {
                    showToast('Hata', 'Müşteri tipi "Diğer" seçildiyse, lütfen diğer tipi belirtin.', false);
                    return;
                }

                const ilId = $('#yeniIl').val();
                const ilceId = $('#yeniIlce').val();
                if (!ilId || !ilceId) {
                    showToast('Hata', 'İl ve ilçe seçimi zorunludur!', false);
                    return;
                }

                const kullaniciAdi = $('#yeniKullaniciAdi').val() ? $('#yeniKullaniciAdi').val().trim() : '';
                if (!kullaniciAdi) {
                    showToast('Hata', 'Kullanıcı adı zorunludur!', false);
                    return;
                }

                const sifre = $('#yeniSifre').val() ? $('#yeniSifre').val().trim() : '';
                if (!sifre) {
                    showToast('Hata', 'Şifre zorunludur!', false);
                    return;
                }
            }

            const spinner = $('#yeniMusteriSpinner');
            const btn = $('#geciciMusteriKaydetBtn');
            spinner.removeClass('d-none');
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Kaydediliyor...');

            // Form verilerini topla
            const formData = {
                TicariUnvan: $('#yeniTicariUnvan').val() ? $('#yeniTicariUnvan').val().trim() : '',
                AdSoyad: $('#yeniAdSoyad').val() ? $('#yeniAdSoyad').val().trim() : '',
                KullaniciAdi: adayMi ? '' : ($('#yeniKullaniciAdi').val() ? $('#yeniKullaniciAdi').val().trim() : ''),
                Sifre: adayMi ? '' : ($('#yeniSifre').val() ? $('#yeniSifre').val().trim() : ''),
                Email: $('#yeniEmail').length ? ($('#yeniEmail').val() ? $('#yeniEmail').val().trim() : '') : '',
                Telefon: $('#yeniTelefon').length ? ($('#yeniTelefon').val() ? $('#yeniTelefon').val().trim() : '') : '',
