            // İlçeleri getir (yeni müşteri modalı için)
    function ilceleriGetirYeni(ilId, hedefSelectId) {
        return new Promise((resolve, reject) => {
            const ilceSelect = document.getElementById(hedefSelectId);
            if (!ilceSelect) {
                reject('Hedef select bulunamadı');
                return;
            }

                ilceSelect.innerHTML = '<option value="">Yükleniyor...</option>';
                ilceSelect.disabled = true;

                if (!ilId) {
                    ilceSelect.innerHTML = '<option value="">Önce il seçiniz</option>';
                    ilceSelect.disabled = false;
                    resolve();
                    return;
                }

                fetch(`/AdminTeklifVer/GetIlcelerByIlId?ilId=${ilId}`)
                    .then(response => response.json())
                    .then(res => {
                        ilceSelect.innerHTML = '<option value="">Seçiniz</option>';
                        if (res.success && res.data && res.data.length > 0) {
                            res.data.forEach(ilce => {
                                ilceSelect.innerHTML += `<option value="${ilce.id}">${escapeHtml(ilce.ilceadi)}</option>`;
                            });

                            // Seçim yapıldıktan sonra change event'ini ekle
                            $(ilceSelect).off('change').on('change', function() {
                                yeniIlceSecildi();
                            });
                        } else {
                            ilceSelect.innerHTML = '<option value="">İlçe bulunamadı</option>';
                        }
                        ilceSelect.disabled = false;
                        resolve();
                    })
                    .catch(err => {
                        console.error('İlçeler yüklenirken hata:', err);
                        ilceSelect.innerHTML = '<option value="">Hata oluştu</option>';
                        ilceSelect.disabled = false;
                        reject(err);
                    });
            });
        }
        function showToast(title, message, success = true) {
            const toastHtml = `
                <div class="toast align-items-center text-bg-${success ? 'success' : 'danger'} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <strong>${title}:</strong> ${message}
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>`;
            const toastEl = $(toastHtml).appendTo('#toastContainer')[0];
            const bsToast = new bootstrap.Toast(toastEl, { delay: success ? 3000 : 5000 });
            bsToast.show();
            toastEl.addEventListener('hidden.bs.toast', () => toastEl.remove());
        }
