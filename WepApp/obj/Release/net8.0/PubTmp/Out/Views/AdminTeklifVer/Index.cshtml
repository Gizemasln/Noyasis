                document.getElementById('yeniMusteriForm').reset();
                $('#yeniDigerContainer').hide();
            }
        });

        $(document).on('click', '#geciciMusteriKaydetBtn', function(e) {
            e.preventDefault();
            e.stopPropagation();
            kaydetGeciciMusteri();
        });

        $(document).on('click', '#yeniMusteriVazgecBtn', function() {
            $('#yeniMusteriModal').modal('hide');
        });
    </script>
}