                eklenecekler.push(paket.adi);
                eklenecekListe += `<li style="margin-left: 20px; font-size: 12px;">${paket.adi} <span style="color: #6c757d; font-size: 11px;">(${paket.anaModul} modülüne bağlı)</span></li>`;
            });

            Swal.fire({
                title: 'Bağlı Modüller Otomatik Eklendi',
                html: `
                    <div style="text-align: left;">
                        <p style="margin-bottom: 10px;">
                            <strong>"${paketAdi}" paketi için ${eklenecekler.length} bağlı modül otomatik eklendi:</strong>
                        </p>
                        <ul style="list-style-type: disc; padding-left: 20px; max-height: 200px; overflow-y: auto;">
                            ${eklenecekListe}
                        </ul>
                        <p style="margin-top: 15px; color: #28a745; font-size: 13px;">
                            <i class="fas fa-info-circle"></i> Bu modüller bağımlı modül olduğu için otomatik eklendi.
                        </p>
                    </div>
                `,
                icon: 'success',
                confirmButtonText: 'Tamam',
                customClass: {
                    confirmButton: 'btn btn-success'
                },
                buttonsStyling: false,
                width: '550px'
            });

            setTimeout(() => hesaplaToplam(), 800);
        }
        function yukleMevcutTeklifDetaylari(teklifId) {
