        // Kaldırılan modüle bağımlı olan diğer modülleri kontrol et
        function bagliPaketleriKontrolEt(kaldirilanModulId, kaldirilanModulAdi) {
            console.log(`Kaldırılan modül: ${kaldirilanModulAdi} (ID: ${kaldirilanModulId}) - Bağımlı modüller kontrol ediliyor...`);

            if (!bagimlilikMap || Object.keys(bagimlilikMap).length === 0) {
                console.log('Bağımlılık haritası henüz yüklenmemiş veya boş');
                return;
            }

            // Bu modüle bağımlı olan modülleri bul (BagliPaketId = kaldirilanModulId olan kayıtlar)
            const bagimliAnaModuller = bagimlilikMap[kaldirilanModulId] || [];

            console.log(`BagimlilikMap[${kaldirilanModulId}] =`, bagimliAnaModuller);

            if (bagimliAnaModuller.length === 0) {
                console.log('Bu modüle bağımlı başka modül yok.');
                return;
            }

            console.log(`${bagimliAnaModuller.length} modül bu modüle bağımlı:`, bagimliAnaModuller);

            let kaldirilanSayisi = 0;
            let kaldirilanListe = [];
            let silinecekKeyler = [];

            bagimliAnaModuller.forEach(anaModulId => {
                console.log(`Bağımlı modül aranıyor: ID=${anaModulId}`);

                // Önce direkt ID'ye bak (bağımsız modül)
                for (const [key, val] of seciliItemler.entries()) {
                    if (val.id === anaModulId && val.tip === 'modul' && !val.paketMi) {
                        console.log(`"${val.adi}" bağımsız modülü (ID: ${anaModulId}) bulundu, kaldırılıyor...`);
                        silinecekKeyler.push(key);
                        kaldirilanSayisi++;
                        kaldirilanListe.push(val.adi);
                        break;
                    }
                }

                // Eğer bağımsız modül olarak bulunamadıysa, paket içinde modül olarak ara
                for (const [key, val] of seciliItemler.entries()) {
                    if (val.id === anaModulId && val.paketMi) {
                        console.log(`"${val.adi}" paket içi modülü (ID: ${anaModulId}) bulundu, kaldırılıyor...`);

                        // Bu modülün ait olduğu paketi bul
                        const paketId = val.parentId;
                        const paket = seciliItemler.get(paketId);

                        if (paket && paket.tip === 'grup') {
                            console.log(`"${paket.adi}" paketi içindeki modül kaldırılıyor...`);

                            // Paket içindeki diğer modülleri kontrol et
                            const paketModulleri = Array.from(seciliItemler.values())
                                .filter(i => i.paketMi && i.parentId === paketId);

                            // Eğer pakette sadece bu modül varsa, paketi de kaldır
                            if (paketModulleri.length === 1) {
                                silinecekKeyler.push(paketId);
                                console.log(`Pakette başka modül kalmadı, "${paket.adi}" paketi de kaldırılıyor...`);
                            }

                            silinecekKeyler.push(key);
                            kaldirilanSayisi++;
                            kaldirilanListe.push(`${paket.adi} > ${val.adi}`);
                        } else {
                            silinecekKeyler.push(key);
                            kaldirilanSayisi++;
                            kaldirilanListe.push(val.adi);
                        }
                        break;
                    }
                }
            });

            // Tek seferde sil
            if (silinecekKeyler.length > 0) {
                // Aynı key'leri tekrar silmemek için unique yap
                const uniqueKeys = [...new Set(silinecekKeyler)];
                console.log('Silinecek keyler:', uniqueKeys);

                uniqueKeys.forEach(key => seciliItemler.delete(key));

                showToast('Bağımlı Modüller Kaldırıldı',
                    `"${kaldirilanModulAdi}" modülü kaldırıldığı için bağımlı olduğu ${kaldirilanSayisi} modül de otomatik kaldırıldı: ${kaldirilanListe.join(', ')}`,
                    true);

                renderPaketListesi();
                renderSecilenItemler();
                hesaplaToplam();
            }
        }

        // Paket eklendiğinde, bu paketin bağımlı olduğu diğer paketleri kontrol et
        function otomatikBagliPaketleriKontrolEt(eklenenPaketId, eklenenPaketAdi) {
            console.log(`Eklenen paket: ${eklenenPaketAdi} (ID: ${eklenenPaketId}) - Bağımlı olduğu paketler kontrol ediliyor...`);

            if (!paketBagimliliklari || paketBagimliliklari.length === 0) {
                console.log('Paket bağımlılıkları henüz yüklenmemiş');
                return;
            }

            // Bu paketin bağımlı olduğu paketleri bul (AnaPaketId = eklenenPaketId olan kayıtlar)
            const bagliOlduguPaketler = paketBagimliliklari
                .filter(b => b.AnaPaketId === eklenenPaketId)
                .map(b => b.BagliPaketId);

            if (bagliOlduguPaketler.length === 0) {
                console.log('Bu paketin bağımlı olduğu başka paket yok.');
                return;
            }

            console.log(`${bagliOlduguPaketler.length} pakete bağımlı:`, bagliOlduguPaketler);

            let eksikPaketler = [];

            bagliOlduguPaketler.forEach(bagliPaketId => {
                // Bağımlı olunan paket (B) seçili mi kontrol et
                let bagliPaketSecili = false;

                for (const [key, val] of seciliItemler.entries()) {
                    if (val.id === bagliPaketId && val.tip === 'grup') {
                        bagliPaketSecili = true;
                        break;
                    }
                }

                if (!bagliPaketSecili) {
                    const paketVerisi = tumVeriler.find(v => v.id === bagliPaketId);
                    if (paketVerisi) {
                        eksikPaketler.push({
                            id: bagliPaketId,
                            adi: paketVerisi.adi
                        });
                    }
                }
            });

            if (eksikPaketler.length > 0) {
                let mesaj = `<strong>"${eklenenPaketAdi}" paketi aşağıdaki paketlere bağımlıdır:</strong><br><br>`;
                eksikPaketler.forEach((p, i) => {
                    mesaj += `${i+1}. ${p.adi}<br>`;
                });
                mesaj += `<br><strong>Bu paketleri de eklemek ister misiniz?</strong>`;

                Swal.fire({
                    title: 'Bağımlı Paketler Bulundu',
                    html: mesaj,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Evet, Tümünü Ekle',
                    cancelButtonText: 'Hayır, Sadece Bu Paketi Ekle',
                    customClass: {
                        confirmButton: 'btn btn-success',
                        cancelButton: 'btn btn-secondary'
                    },
                    buttonsStyling: false
                }).then((result) => {
                    if (result.isConfirmed) {
                        eksikPaketler.forEach(p => {
                            itemEkle(p.id, 'grup');
                        });

                        showToast('Bağımlı Paketler Eklendi',
                            `${eksikPaketler.length} bağımlı paket otomatik eklendi.`,
                            true);
                    }
                });
            }
        }

