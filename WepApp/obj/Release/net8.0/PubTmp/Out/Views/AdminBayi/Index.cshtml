        // Ana filtreleme ve sıralama fonksiyonu
        function bayiFiltreleVeSirala() {
            const tbody = document.querySelector('#bayiTablosu tbody');
            if (!tbody) return;

            const satirlar = Array.from(tbody.querySelectorAll('tr'));
            const baslikSatiri = satirlar[0]?.querySelector('th') ? satirlar.shift() : null;

            if (satirlar.length === 0) return;

            // Filtreleme
            let filtrelenmisSatirlar = satirlar.filter(satir => {
                let goster = true;

                // Arama filtresi (tüm sütunlarda)
                if (bayiAktifFiltreler.arama) {
                    const rowText = satir.textContent.toLowerCase();
                    if (!rowText.includes(bayiAktifFiltreler.arama.toLowerCase())) {
                        goster = false;
                    }
                }

                // Seviye filtresi (2. sütun)
                if (goster && bayiAktifFiltreler.seviye) {
                    const seviyeSpan = satir.querySelector('td:nth-child(2) .table-seviye-badge');
                    if (seviyeSpan) {
                        const seviyeText = seviyeSpan.textContent.trim();
                        const seviye = parseInt(seviyeText.replace('Seviye ', ''));

                        if (seviye !== bayiAktifFiltreler.seviye) {
                            goster = false;
                        }
                    }
                }

                // Distribütör filtresi (6. sütun)
                if (goster && bayiAktifFiltreler.distributor !== null) {
                    const distributorTd = satir.querySelector('td:nth-child(6)');
                    if (distributorTd) {
                        const distributorIcon = distributorTd.querySelector('.fa-check-circle');
                        const distributorVar = distributorIcon !== null;

                        if (distributorVar !== bayiAktifFiltreler.distributor) {
                            goster = false;
                        }
                    }
                }

                // Alt bayi sayısı filtresi (8. sütun)
                if (goster && (bayiAktifFiltreler.minAltBayi !== null || bayiAktifFiltreler.maxAltBayi !== null)) {
                    const altBayiTd = satir.querySelector('td:nth-child(8)');
                    if (altBayiTd) {
                        const altBayiText = altBayiTd.textContent.trim();
                        let altBayiSayisi = 0;

                        const match = altBayiText.match(/(\d+)/);
                        if (match) {
                            altBayiSayisi = parseInt(match[1]);
                        }

                        if (bayiAktifFiltreler.minAltBayi !== null && altBayiSayisi < bayiAktifFiltreler.minAltBayi) {
                            goster = false;
                        }

                        if (goster && bayiAktifFiltreler.maxAltBayi !== null && altBayiSayisi > bayiAktifFiltreler.maxAltBayi) {
                            goster = false;
                        }
                    }
                }

                // Müşteri sayısı filtresi (9. sütun)
                if (goster && (bayiAktifFiltreler.minMusteri !== null || bayiAktifFiltreler.maxMusteri !== null)) {
                    const musteriTd = satir.querySelector('td:nth-child(9)');
                    if (musteriTd) {
                        const musteriText = musteriTd.textContent.trim();
                        let musteriSayisi = 0;

                        const match = musteriText.match(/(\d+)/);
                        if (match) {
                            musteriSayisi = parseInt(match[1]);
                        }

                        if (bayiAktifFiltreler.minMusteri !== null && musteriSayisi < bayiAktifFiltreler.minMusteri) {
                            goster = false;
                        }

                        if (goster && bayiAktifFiltreler.maxMusteri !== null && musteriSayisi > bayiAktifFiltreler.maxMusteri) {
                            goster = false;
                        }
                    }
                }

                return goster;
            });

            // Sıralama
            switch(bayiAktifFiltreler.siralama) {
                case 'unvan_az':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const unvanA = a.querySelector('td:nth-child(3) .bayi-unvani')?.getAttribute('data-orjinal') ||
                                       a.querySelector('td:nth-child(3)')?.textContent.replace(/[└─\s]+/g, ' ').trim() || '';
                        const unvanB = b.querySelector('td:nth-child(3) .bayi-unvani')?.getAttribute('data-orjinal') ||
                                       b.querySelector('td:nth-child(3)')?.textContent.replace(/[└─\s]+/g, ' ').trim() || '';
                        return unvanA.localeCompare(unvanB, 'tr');
                    });
                    break;

                case 'unvan_za':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const unvanA = a.querySelector('td:nth-child(3) .bayi-unvani')?.getAttribute('data-orjinal') ||
                                       a.querySelector('td:nth-child(3)')?.textContent.replace(/[└─\s]+/g, ' ').trim() || '';
                        const unvanB = b.querySelector('td:nth-child(3) .bayi-unvani')?.getAttribute('data-orjinal') ||
                                       b.querySelector('td:nth-child(3)')?.textContent.replace(/[└─\s]+/g, ' ').trim() || '';
                        return unvanB.localeCompare(unvanA, 'tr');
                    });
                    break;

                case 'seviye_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const getSeviye = (satir) => {
                            const seviyeSpan = satir.querySelector('td:nth-child(2) .table-seviye-badge');
                            if (seviyeSpan) {
                                const seviyeText = seviyeSpan.textContent.trim();
                                return parseInt(seviyeText.replace('Seviye ', ''));
                            }
                            return 0;
                        };

                        const seviyeA = getSeviye(a);
                        const seviyeB = getSeviye(b);
                        return seviyeA - seviyeB;
                    });
                    break;

                case 'seviye_azalan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const getSeviye = (satir) => {
                            const seviyeSpan = satir.querySelector('td:nth-child(2) .table-seviye-badge');
                            if (seviyeSpan) {
                                const seviyeText = seviyeSpan.textContent.trim();
                                return parseInt(seviyeText.replace('Seviye ', ''));
                            }
                            return 0;
                        };

                        const seviyeA = getSeviye(a);
                        const seviyeB = getSeviye(b);
                        return seviyeB - seviyeA;
                    });
                    break;

                case 'altBayi_azalan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const getAltBayiSayisi = (satir) => {
                            const altBayiTd = satir.querySelector('td:nth-child(8)');
                            if (altBayiTd) {
                                const match = altBayiTd.textContent.match(/(\d+)/);
                                return match ? parseInt(match[1]) : 0;
                            }
                            return 0;
                        };

                        const sayiA = getAltBayiSayisi(a);
                        const sayiB = getAltBayiSayisi(b);
                        return sayiB - sayiA;
                    });
                    break;

                case 'altBayi_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const getAltBayiSayisi = (satir) => {
                            const altBayiTd = satir.querySelector('td:nth-child(8)');
                            if (altBayiTd) {
                                const match = altBayiTd.textContent.match(/(\d+)/);
                                return match ? parseInt(match[1]) : 0;
                            }
                            return 0;
                        };

                        const sayiA = getAltBayiSayisi(a);
                        const sayiB = getAltBayiSayisi(b);
                        return sayiA - sayiB;
                    });
                    break;

                case 'musteri_azalan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const getMusteriSayisi = (satir) => {
                            const musteriTd = satir.querySelector('td:nth-child(9)');
                            if (musteriTd) {
                                const match = musteriTd.textContent.match(/(\d+)/);
                                return match ? parseInt(match[1]) : 0;
                            }
                            return 0;
                        };

                        const sayiA = getMusteriSayisi(a);
                        const sayiB = getMusteriSayisi(b);
                        return sayiB - sayiA;
                    });
                    break;

                case 'musteri_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const getMusteriSayisi = (satir) => {
                            const musteriTd = satir.querySelector('td:nth-child(9)');
                            if (musteriTd) {
                                const match = musteriTd.textContent.match(/(\d+)/);
                                return match ? parseInt(match[1]) : 0;
                            }
                            return 0;
                        };

                        const sayiA = getMusteriSayisi(a);
                        const sayiB = getMusteriSayisi(b);
                        return sayiA - sayiB;
                    });
                    break;
            }

            // Tüm satırları gizle
            satirlar.forEach(satir => {
                satir.style.display = 'none';
            });

            // Filtrelenmiş satırları göster
            filtrelenmisSatirlar.forEach((satir, index) => {
                satir.style.display = '';
            });

            // "Gösterilecek kayıt yok" mesajı
