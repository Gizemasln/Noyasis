            }

            const bayiId = secili.value;

            // Silme işlemi için bayi adını da al
            if (tip === 'sil') {
                const seciliTr = secili.closest('tr');
                const unvanTd = seciliTr.querySelector('td:nth-child(3)');
                let bayiAd = unvanTd ? unvanTd.textContent.trim() : '';
                bayiAd = bayiAd.replace(/[└─\s]+/g, ' ').trim();
                silOnay(bayiId, bayiAd);
            } else {
                switch(tip) {
                    case 'detay':    detayGetir(bayiId); break;
                    case 'duzenle':  duzenleGetir(bayiId); break;
                    case 'teklif':   bayiTeklifleriGetir(bayiId); break;
                    case 'sozlesme': bayiSozlesmeleriGetir(bayiId); break;
                }
            }
        }
        // Email format kontrolü
function emailKontrol(email) {
    if (!email) return true; // Boş email geçerli sayılır (zorunlu değilse)
    
    // Email regex: genel email formatı kontrolü
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

    return emailRegex.test(email);
}

