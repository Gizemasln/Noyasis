        // ============= FORM DOĞRULAMA =============
        function setupFormValidations() {
            const emailInput = document.getElementById('Email');
            if (emailInput) {
                emailInput.addEventListener('blur', function() {
                    emailUyariGoster(this, 'emailUyari');
                });
            }

            const editEmailInput = document.getElementById('editEmail');
            if (editEmailInput) {
                editEmailInput.addEventListener('blur', function() {
                    emailUyariGoster(this, 'editEmailUyari');
                });
            }

            const tcvNoInput = document.getElementById('TCVNo');
            if (tcvNoInput) {
                tcvNoInput.addEventListener('input', function() {
                    vknKontrol(this, 'tcvNoUyari');
                });
            }

            const editTcvNoInput = document.getElementById('editTCVNo');
            if (editTcvNoInput) {
                editTcvNoInput.addEventListener('input', function() {
                    vknKontrol(this, 'editTcvNoUyari');
                });
            }
        }

        function emailKontrol(email) {
            if (!email) return true;
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            return emailRegex.test(email);
        }

        function emailUyariGoster(input, uyariId) {
            const email = input.value.trim();
            let uyariDiv = document.getElementById(uyariId);

            if (!uyariDiv) {
                uyariDiv = document.createElement('div');
                uyariDiv.id = uyariId;
                uyariDiv.className = 'invalid-feedback';
                input.parentNode.appendChild(uyariDiv);
            }

            if (email && !emailKontrol(email)) {
                input.classList.add('is-invalid');
                uyariDiv.textContent = 'Geçerli bir email adresi giriniz (örn: mail@domain.com)';
                uyariDiv.style.display = 'block';
                return false;
            } else {
                input.classList.remove('is-invalid');
                uyariDiv.style.display = 'none';
                return true;
            }
        }

        function vknKontrol(input, uyariId) {
            let deger = input.value.trim();
            let uyariDiv = document.getElementById(uyariId);

            if (!uyariDiv) {
                uyariDiv = document.createElement('div');
                uyariDiv.id = uyariId;
                uyariDiv.className = 'invalid-feedback';
                input.parentNode.appendChild(uyariDiv);
            }

            deger = deger.replace(/[^0-9]/g, '');

            if (deger.length > 11) {
                deger = deger.substring(0, 11);
            }

            input.value = deger;

            if (deger && deger.length !== 10 && deger.length !== 11) {
                input.classList.add('is-invalid');
                uyariDiv.textContent = 'Vergi No 10, TC Kimlik No 11 karakter olmalıdır. Girilen: ' + deger.length + ' karakter';
                uyariDiv.style.display = 'block';
                return false;
            } else {
                input.classList.remove('is-invalid');
                uyariDiv.style.display = 'none';
                return true;
            }
        }

        // ============= YARDIMCI FONKSİYONLAR =============
        function escapeHtml(text) {
            if (text === null || text === undefined) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function showToast(type, title, message) {
            Swal.fire({
                icon: type,
                title: title,
                text: message,
                timer: 3000,
                showConfirmButton: false,
                toast: true,
                position: 'top-end'
            });
        }

        function guncelleDuzenleYetkiliListesi() {
            const container = document.getElementById('duzenleYetkiliListesiContainer');
            if (!container) return;

            if (!duzenleYetkiliListesi || duzenleYetkiliListesi.length === 0) {
                container.innerHTML = '<div class="alert alert-info text-center">Yeni eklenecek yetkili yok.</div>';
                return;
            }

            let html = '<div class="card mb-3"><div class="card-header bg-primary text-white"><strong>Yeni Eklenecek Yetkililer</strong></div><div class="card-body p-3">';

            duzenleYetkiliListesi.forEach((y, i) => {
                html += `
                    <div class="yetkili-item p-3 mb-2 border rounded position-relative bg-light">
                        <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2" onclick="duzenleYetkiliListedenSil(${i})">
                            <i class="fas fa-times"></i>
                        </button>
                        <div class="row">
                            <div class="col-md-4"><strong>${escapeHtml(y.adi)} ${escapeHtml(y.soyadi)}</strong></div>
                            <div class="col-md-4"><small>Görevi: ${escapeHtml(y.gorevi || '-')}</small></div>
                            <div class="col-md-4"><small>Email: ${escapeHtml(y.email || '-')}</small></div>
                        </div>
                        <input type="hidden" name="YeniYetkililer[${i}].Adi" value="${escapeHtml(y.adi)}">
                        <input type="hidden" name="YeniYetkililer[${i}].Soyadi" value="${escapeHtml(y.soyadi)}">
                        <input type="hidden" name="YeniYetkililer[${i}].Gorevi" value="${escapeHtml(y.gorevi)}">
                        <input type="hidden" name="YeniYetkililer[${i}].Email" value="${escapeHtml(y.email)}">
                        <input type="hidden" name="YeniYetkililer[${i}].Cep" value="${escapeHtml(y.cep)}">
                        <input type="hidden" name="YeniYetkililer[${i}].DahiliNo" value="${escapeHtml(y.dahiliNo)}">
                        <input type="hidden" name="YeniYetkililer[${i}].Cinsiyet" value="${escapeHtml(y.cinsiyet)}">
                        <input type="hidden" name="YeniYetkililer[${i}].Kodu" value="${escapeHtml(y.kodu)}">
                        <input type="hidden" name="YeniYetkililer[${i}].DepartmanId" value="${y.departmanId || ''}">
                    </div>`;
            });

            html += `</div></div>`;
            container.innerHTML = html;
        }

        function duzenleYetkiliListedenSil(i) {
            if (confirm('Kaldırmak istediğinizden emin misiniz?')) {
                duzenleYetkiliListesi.splice(i, 1);
                guncelleDuzenleYetkiliListesi();
            }
        }

        function tumFiltreleriTemizle() {
            $('#akilliArama').val('');
            aramaMetni = '';
            sutunFiltresiniKaldir();

            if (typeof flatpickr !== 'undefined') {
                const fp = $("#tarihAraligi").flatpickr();
                if (fp) {
                    fp.clear();
                }
            }
            $('#tarihAraligi').val('');
            tarihFiltre.baslangic = null;
            tarihFiltre.bitis = null;
            tarihFiltre.aktif = false;

            $('#siralamaSecenek').val('unvan_az');
            mevcutSiralama = 'unvan_az';

            $('#aktifFiltreler').hide();
            $('#filtreTemizleBtn').hide();

            filtreleVeSirala();
        }
    </script>
}