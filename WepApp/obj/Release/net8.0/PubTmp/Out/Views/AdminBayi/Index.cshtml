                   function seciliBayiSayisiniGuncelle() {
            const tumCheckboxlar = document.querySelectorAll('.bayi-sec-checkbox');
            const seciliCheckboxlar = document.querySelectorAll('.bayi-sec-checkbox:checked');
            const sayi = seciliCheckboxlar.length;
            const gosterge = document.getElementById('seciliBayiGosterge');
            const metinSpan = document.getElementById('seciliBayiMetin');

            // Eğer birden fazla seçiliyse → sadece son seçileni bırak (tek seçim zorla)
            if (sayi > 1) {
                const sonSecili = seciliCheckboxlar[seciliCheckboxlar.length - 1];
                tumCheckboxlar.forEach(cb => {
                    if (cb !== sonSecili) cb.checked = false;
                });
                return seciliBayiSayisiniGuncelle(); // recursive çağrı
            }

            if (sayi === 0) {
                gosterge.classList.add('d-none');
                metinSpan.textContent = '';

                // Butonları devre dışı bırak
                document.getElementById('topluDetayBtn').disabled = true;
                document.getElementById('topluDuzenleBtn').disabled = true;
                document.getElementById('topluSilBtn').disabled = true;
                document.getElementById('topluTeklifBtn').disabled = true;
                document.getElementById('topluSozlesmeBtn').disabled = true;
            }
            else if (sayi === 1) {
                // Tek bayi seçili → Ünvanını göster
                const seciliTr = seciliCheckboxlar[0].closest('tr');
                const unvanTd = seciliTr.querySelector('td:nth-child(3)'); // Bayi Adı sütunu (3. td)

                // Bayi adını al (└─ karakterlerini temizle)
                let unvan = '';
                if (unvanTd) {
                    // Direkt textContent al, sonra temizle
                    unvan = unvanTd.textContent.trim();
                    // └─ ve benzeri karakterleri temizle
                    unvan = unvan.replace(/[└─\s]+/g, ' ').trim();
                }

                // Hala boşsa alternatif olarak data attribute'dan al
                if (!unvan) {
                    const unvanSpan = seciliTr.querySelector('.bayi-unvani');
                    unvan = unvanSpan ? unvanSpan.getAttribute('data-orjinal') || unvanSpan.textContent : 'Bayi';
                }

                // Çok uzunsa kısalt
                if (unvan.length > 30) {
                    unvan = unvan.substring(0, 27) + '...';
                }

                metinSpan.textContent = `"${unvan}" seçili`;
                gosterge.classList.remove('d-none');

                // Butonları aktif et
                document.getElementById('topluDetayBtn').disabled = false;
                document.getElementById('topluDuzenleBtn').disabled = false;
                document.getElementById('topluSilBtn').disabled = false;
                document.getElementById('topluTeklifBtn').disabled = false;
                document.getElementById('topluSozlesmeBtn').disabled = false;
            }
        }

        // Tümünü seç checkbox
        function tumunuSecFonksiyonu(checkbox) {
            document.querySelectorAll('.bayi-sec-checkbox').forEach(cb => {
                cb.checked = checkbox.checked;
            });
            seciliBayiSayisiniGuncelle();
        }

        // Her checkbox değiştiğinde
        document.addEventListener('change', function(e) {
            if (e.target.classList.contains('bayi-sec-checkbox')) {
                seciliBayiSayisiniGuncelle();
            }
        });
            // Tek seçim kısıtlaması
        document.querySelectorAll('.bayi-sec-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                if (this.checked) {
                    // Diğerlerini temizle
                    document.querySelectorAll('.bayi-sec-checkbox').forEach(cb => {
                        if (cb !== this) cb.checked = false;
                    });
                }
                seciliBayiSayisiniGuncelle();
            });
        });
         // Tablonun tamamına tıklayınca da checkbox seçilsin
        document.querySelector('#bayiTablosu tbody').addEventListener('click', function(e) {
            const tr = e.target.closest('tr');
            if (!tr) return;

            // Eğer zaten checkbox'a, link'e veya butona tıklanmışsa işlem yapma
            if (e.target.type === 'checkbox' || e.target.tagName === 'A' || e.target.closest('a') || e.target.tagName === 'BUTTON' || e.target.closest('button')) {
                return;
            }

            const checkbox = tr.querySelector('.bayi-sec-checkbox');
            if (checkbox) {
                // Diğer tüm checkbox'ları temizle
                document.querySelectorAll('.bayi-sec-checkbox').forEach(cb => {
                    cb.checked = false;
                });
                // Sadece bu satırın checkbox'ını seç
                checkbox.checked = true;
                seciliBayiSayisiniGuncelle();
            }
        });
            // Tümünü seç checkbox'ını kaldır veya devre dışı bırak (tek seçim istediğin için)
        const tumunuSec = document.getElementById('tumunuSec');
        if (tumunuSec) {
            tumunuSec.disabled = true;
            tumunuSec.title = 'Çoklu seçim desteklenmiyor';
        }
          // Seçili bayi için işlem yap
        function seciliBayiIslem(tip) {
            const secili = document.querySelector('.bayi-sec-checkbox:checked');
            if (!secili) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Uyarı',
                    text: 'Lütfen önce bir bayi seçin!'
