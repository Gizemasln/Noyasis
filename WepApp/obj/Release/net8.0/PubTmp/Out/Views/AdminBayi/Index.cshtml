        // Kullanıcı adı benzersizlik kontrolü
        function kullaniciAdiKontrolEt(kullaniciAdi, modal = 'ekle') {
            if (!kullaniciAdi) return;

            const durumDiv = document.getElementById(modal === 'ekle' ? 'kullaniciAdiDurumEkle' : 'kullaniciAdiDurumDuzenle');
            const submitBtn = document.getElementById(modal === 'ekle' ? 'ekleBtn' : 'duzenleSubmitBtn');

            fetch(`/AdminBayi/KullaniciAdiKontrol?kullaniciAdi=${encodeURIComponent(kullaniciAdi)}`)
                .then(response => response.json())
                .then(res => {
                    durumDiv.style.display = 'block';

                    if (res.success) {
                        if (res.kullaniliyor) {
                            durumDiv.className = 'mt-2 alert alert-danger py-2';
                            durumDiv.innerHTML = `<i class="fas fa-times-circle me-1"></i> ${res.mesaj}`;
                            if (submitBtn) submitBtn.disabled = true;

                            // 2 saniye sonra otomatik yeni kullanıcı adı oluştur
                            setTimeout(() => {
                                if (modal === 'ekle') {
                                    kullaniciAdiOluştur('ekle');
                                } else {
                                    kullaniciAdiYenileDuzenle();
                                }
                            }, 2000);
                        } else {
                            durumDiv.className = 'mt-2 alert alert-success py-2';
                            durumDiv.innerHTML = `<i class="fas fa-check-circle me-1"></i> ${res.mesaj}`;
                            if (submitBtn) submitBtn.disabled = false;
                        }
                    } else {
                        durumDiv.className = 'mt-2 alert alert-danger py-2';
                        durumDiv.innerHTML = `<i class="fas fa-exclamation-triangle me-1"></i> Kontrol sırasında hata: ${res.message}`;
                    }
                })
                .catch(err => {
                    durumDiv.style.display = 'block';
                    durumDiv.className = 'mt-2 alert alert-danger py-2';
                    durumDiv.innerHTML = `<i class="fas fa-exclamation-triangle me-1"></i> Bağlantı hatası: ${err}`;
                });
        }

        // Türkçe karakterleri İngilizce'ye çevir
        function turkceKarakterDonustur(text) {
            if (!text) return '';

            const turkce = {
                'ı': 'i', 'ğ': 'g', 'ü': 'u', 'ş': 's', 'ö': 'o', 'ç': 'c',
                'İ': 'I', 'Ğ': 'G', 'Ü': 'U', 'Ş': 'S', 'Ö': 'O', 'Ç': 'C'
            };

            return text.replace(/[ığüşöçİĞÜŞÖÇ]/g, function(matched) {
                return turkce[matched] || matched;
            });
        }

        // İl seçildiğinde otomatik kullanıcı adı oluşturma (opsiyonel)
        function ilSecildi(ilId, hedefSelectId, modalTipi) {
            ilceleriGetir(ilId, hedefSelectId).then(() => {
                // İlçeler yüklendikten sonra eğer ilçe de seçiliyse kullanıcı adı oluştur
                const ilceSelect = document.getElementById(hedefSelectId);
                if (ilceSelect.value && modalTipi === 'ekle') {
                    kullaniciAdiOluştur('ekle');
                }
            });
        }

        // İlçe seçildiğinde otomatik kullanıcı adı oluştur
        function ilceSecildi(modalTipi) {
            if (modalTipi === 'ekle') {
                const ilSelect = document.getElementById('Il');
                const ilceSelect = document.getElementById('Ilce');

                if (ilSelect.value && ilceSelect.value) {
                    kullaniciAdiOluştur('ekle');
                }
            } else {
                const ilSelect = document.getElementById('editIl');
                const ilceSelect = document.getElementById('editIlce');

                if (ilSelect.value && ilceSelect.value) {
                    kullaniciAdiYenileDuzenle();
                }
            }
        }
        // Şifre göster/gizle fonksiyonu
        function toggleSifreGoster() {
            const sifreInput = document.getElementById('editSifre');
            const icon = document.getElementById('gosterSifreIcon');
            const gizliSifre = document.getElementById('sifreSakla').value;

            if (!gizliSifre) {
                // Eğer gizli şifre yoksa (yeni şifre oluşturulmamışsa) işlem yapma
                Swal.fire({
                    icon: 'info',
                    title: 'Bilgi',
                    text: 'Önce şifre yenile butonuna tıklayarak bir şifre oluşturun.',
                    timer: 2000,
                    showConfirmButton: false
                });
                return;
            }

            if (sifreInput.type === 'password') {
                // Şifreyi göster
                sifreInput.type = 'text';
                sifreInput.value = gizliSifre; // Gizli şifreyi göster
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');

                // 3 saniye sonra tekrar gizle
                setTimeout(() => {
                    sifreInput.type = 'password';
                    sifreInput.value = '********'; // Yer tutucu göster
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                }, 3000);
            } else {
                // Şifreyi gizle
                sifreInput.type = 'password';
                sifreInput.value = '********';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        // Şifre alanını temizle ve düzenlenebilir yap (şifre yenileme sonrası)
        function sifreDüzenlenebilirYap(yeniSifre) {
            const sifreInput = document.getElementById('editSifre');
            sifreInput.value = yeniSifre;
            sifreInput.readOnly = false;
            sifreInput.type = 'text';

            // 5 saniye sonra tekrar read-only yap ve gizle
            setTimeout(() => {
                sifreInput.readOnly = true;
                sifreInput.type = 'password';
                sifreInput.value = '********'; // Placeholder göster
