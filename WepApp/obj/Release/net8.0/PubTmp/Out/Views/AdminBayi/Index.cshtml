// Email uyarı göster
function emailUyariGoster(input, uyariId) {
    const email = input.value.trim();
    let uyariDiv = document.getElementById(uyariId);
    
    // Uyarı div'i yoksa oluştur
    if (!uyariDiv) {
        uyariDiv = document.createElement('div');
        uyariDiv.id = uyariId;
        uyariDiv.className = 'invalid-feedback';
        input.parentNode.appendChild(uyariDiv);
    }
    
    if (email && !emailKontrol(email)) {
        input.classList.add('is-invalid');
        uyariDiv.textContent = 'Geçerli bir email adresi giriniz (örn: mail@domain.com)';
        uyariDiv.style.display = 'block';
        return false;
    } else {
        input.classList.remove('is-invalid');
        uyariDiv.style.display = 'none';
        return true;
    }
}

        // VKN/TCKN kontrol (10 veya 11 karakter)
        function vknKontrol(input, uyariId) {
            let deger = input.value.trim();
            let uyariDiv = document.getElementById(uyariId);

            // Uyarı div'i yoksa oluştur
            if (!uyariDiv) {
                uyariDiv = document.createElement('div');
                uyariDiv.id = uyariId;
                uyariDiv.className = 'invalid-feedback';
                input.parentNode.appendChild(uyariDiv);
            }

            // Sadece rakam girişine izin ver
            deger = deger.replace(/[^0-9]/g, '');

            // Maksimum 11 karakter sınırı (fazlasını kes)
            if (deger.length > 11) {
                deger = deger.substring(0, 11);
            }

            input.value = deger;

            // Eğer değer varsa uzunluk kontrolü yap
            if (deger && deger.length !== 10 && deger.length !== 11) {
                input.classList.add('is-invalid');
                uyariDiv.textContent = 'Vergi No 10, TC Kimlik No 11 karakter olmalıdır. Girilen: ' + deger.length + ' karakter';
                uyariDiv.style.display = 'block';
                return false;
            } else {
                input.classList.remove('is-invalid');
                uyariDiv.style.display = 'none';
                return true;
            }
        }
        // Toast mesajı göster (gelişmiş versiyon)
        function showToast(type, title, message) {
            // SweetAlert2 kullan
            Swal.fire({
                icon: type,
                title: title,
                text: message,
                timer: 3000,
                showConfirmButton: false,
                toast: true,
                position: 'top-end'
            });
        }
        function buildTreeHtml(node) {
            if (!node) return '';

            const seviyeClass = `seviye-${Math.min(node.seviye || 0, 4)}`;
            const seviyeBadge = node.seviye > 0 ? `<span class="seviye-badge">${node.seviye}</span>` : '';

            let html = `
                <div class="tree-item">
                    <div class="tree-node ${seviyeClass}" onclick="detayGetir(${node.id})">
                        ${seviyeBadge}
                        <div class="fw-bold">${escapeHtml(node.unvan)}</div>
                        <div class="small mt-1">${escapeHtml(node.kodu || '')}</div>
                        <div class="small text-muted">${escapeHtml(node.telefon || '')}</div>
                        ${node.altBayiSayisi > 0 ?
                            `<div class="small mt-1">
                                <span class="badge bg-info">${node.altBayiSayisi} Alt Bayi</span>
                            </div>` : ''}
                    </div>`;

            if (node.children && node.children.length > 0) {
                html += `<div class="tree-children">`;
                node.children.forEach(child => {
                    html += buildTreeHtml(child);
                });
                html += `</div>`;
            }

            html += `</div>`;
            return html;
        }
    </script>
