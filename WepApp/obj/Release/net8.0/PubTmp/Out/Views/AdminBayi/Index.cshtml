@section Script {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <script type="text/javascript">
        // ============= GLOBAL DEĞİŞKENLER =============
        let aktifAramaSutunu = null;
        let aramaMetni = '';
        let aramaZamanlayici = null;
        let mevcutSiralama = 'unvan_az';
        let currentBayiId = 0;
        let suAnSeciliBayiId = null;
        let suAnSeciliBayiUnvan = null;
        let suAnSeciliSatir = null;

        let ekleYetkiliListesi = [];
        let duzenleYetkiliListesi = [];
        let secilenYetkiliId = 0;
        let mevcutLogoAdi = '';
        let mevcutImzaAdi = '';
        let currentDosyaTipi = '';

        let tarihFiltre = {
            baslangic: null,
            bitis: null,
            aktif: false
        };

        // Sütun tanımları
        const sutunlar = [
            { index: 1, ad: 'Seviye', alan: 'seviye' },
            { index: 2, ad: 'Bayi Adı', alan: 'unvan' },
            { index: 3, ad: 'Kullanıcı Adı', alan: 'kullaniciAdi' },
            { index: 4, ad: 'Kodu', alan: 'kodu' },
            { index: 5, ad: 'Distribütör', alan: 'distributor' },
            { index: 6, ad: 'Üst Bayi', alan: 'ustBayi' },
            { index: 7, ad: 'Alt Bayi', alan: 'altBayi' },
            { index: 8, ad: 'Müşteri', alan: 'musteri' }
        ];

        // ============= SAYFA YÜKLENDİĞİNDE =============
        $(document).ready(function() {
            initTarihFiltresi();

            // Sütun başlıklarına tıklama olayı
            $('thead th[data-sutun-index]').each(function() {
                const index = $(this).data('sutun-index');
                const ad = $(this).data('sutun-ad');
                const alan = $(this).data('sutun-alan');

                $(this).css('cursor', 'pointer').attr('title', 'Bu sütunda ara');

                $(this).on('click', function(e) {
                    if (!$(e.target).is('button') && !$(e.target).is('a')) {
                        e.stopPropagation();

                        if (aktifAramaSutunu === alan) {
                            sutunFiltresiniKaldir();
                        } else {
                            sutunFiltresiAktifEt(index, ad, alan);
                        }
                        $('#akilliArama').focus();
                    }
                });
            });

            // Çift tıklama ile sütun filtresini kaldır
            $('thead th[data-sutun-index]').on('dblclick', function(e) {
                e.stopPropagation();
                sutunFiltresiniKaldir();
            });

            // Arama inputu olayları
            $('#akilliArama').on('input', function() {
                aramaMetni = $(this).val().toLowerCase().trim();
                if (aramaZamanlayici) {
                    clearTimeout(aramaZamanlayici);
                }
                aramaZamanlayici = setTimeout(function() {
                    filtreleVeSirala();
                }, 300);
            });

            // Enter tuşu ile anında arama
            $('#akilliArama').on('keypress', function(e) {
                if (e.which === 13) {
                    e.preventDefault();
                    if (aramaZamanlayici) {
                        clearTimeout(aramaZamanlayici);
                    }
                    filtreleVeSirala();
                }
            });

            // Temizle butonu
            $('#akilliAramaTemizle').on('click', function() {
                $('#akilliArama').val('');
                aramaMetni = '';
                sutunFiltresiniKaldir();
                filtreleVeSirala();
            });

            // Tarih filtre temizle butonu
            $('#tarihFiltreTemizle').on('click', function() {
                if (typeof flatpickr !== 'undefined') {
                    const fp = $("#tarihAraligi").flatpickr();
                    if (fp) {
                        fp.clear();
                    }
                }
                $('#tarihAraligi').val('');
                tarihFiltre.baslangic = null;
                tarihFiltre.bitis = null;
                tarihFiltre.aktif = false;
                filtreleVeSirala();
            });

            // Sıralama değişikliği
            $('#siralamaSecenek').on('change', function() {
                mevcutSiralama = $(this).val();
                filtreleVeSirala();
            });

            // Başlangıçta aktif sütun göstergesini gizle
            $('#aktifSutunGosterge').hide();

            // Klavye kısayolu: ESC tuşu ile temizle
            $(document).on('keydown', function(e) {
                if (e.key === 'Escape' && $('#akilliArama').is(':focus')) {
                    $('#akilliAramaTemizle').click();
                }
            });

            // Tablo satırına tıklandığında seç
            $(document).on('click', '#bayiTablosu tbody tr[data-bayi-id]', function(e) {
                if (!$(e.target).is('button') && !$(e.target).is('a') && !$(e.target).closest('.btn').length) {
                    satirSec($(this));
                }
            });

            // Üstteki butonlar için event listener
            $('#seciliDetayGoster').click(function() {
                if (suAnSeciliBayiId) {
                    detayGetir(suAnSeciliBayiId);
                } else {
                    toastr.warning('Lütfen önce bir bayi seçin.');
                }
            });

            $('#seciliDuzenleBtn').click(function() {
                if (suAnSeciliBayiId) {
                    duzenleGetir(suAnSeciliBayiId);
                } else {
                    toastr.warning('Lütfen önce bir bayi seçin.');
                }
            });

            $('#seciliTekliflerBtn').click(function() {
                if (suAnSeciliBayiId) {
                    bayiTeklifleriGetir(suAnSeciliBayiId);
                } else {
                    toastr.warning('Lütfen önce bir bayi seçin.');
                }
            });

            $('#seciliSozlesmelerBtn').click(function() {
                if (suAnSeciliBayiId) {
                    bayiSozlesmeleriGetir(suAnSeciliBayiId);
                } else {
                    toastr.warning('Lütfen önce bir bayi seçin.');
                }
            });

            $('#seciliSilBtn').click(function() {
                if (suAnSeciliBayiId) {
                    $('#silId').val(suAnSeciliBayiId);
                    $('#silAdi').text(suAnSeciliBayiUnvan || 'Bayi');
                    new bootstrap.Modal('#silModal').show();
                } else {
                    toastr.warning('Lütfen önce bir bayi seçin.');
                }
            });

            // Modal kapandığında seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliBayiId) {
                    const $satir = $(`tr[data-bayi-id="${suAnSeciliBayiId}"]`);
                    if ($satir.length === 0) {
                        clearSelection();
                    } else {
                        clearSelection();
                    }
                }
            });

            // Tab butonlarının type'ını button yap
            $('button[data-bs-toggle="tab"]').each(function() {
                $(this).attr('type', 'button');
            });

            // Modal kapandığında temizlik
            $('#duzenleModal').on('hidden.bs.modal', function() {
                const sifreInput = document.getElementById('editSifre');
                if (sifreInput) {
                    sifreInput.value = '';
                    sifreInput.type = 'password';
                }

                const btn = document.getElementById('sifreYenileBtn');
                if (btn) {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-key"></i> Şifre Yenile';
                }

                duzenleYetkiliListesi = [];
                guncelleDuzenleYetkiliListesi();
            });

            $('#ekleModal').on('show.bs.modal', function() {
                ekleYetkiliListesi = [];
                guncelleEkleYetkiliListesi();
            });

            $('#ekleModal').on('hidden.bs.modal', function() {
                document.getElementById('ekleForm').reset();
                $('#logoPreviewEkle, #imzaPreviewEkle').empty();
            });

            // Email ve VKN kontrolleri
            setupFormValidations();
        });

        // ============= SEÇİM TEMİZLEME =============
        function clearSelection() {
            $('#bayiTablosu tbody tr').removeClass('table-active');
            suAnSeciliBayiId = null;
            suAnSeciliBayiUnvan = null;
            suAnSeciliSatir = null;
            $('#seciliKayitBilgi').html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

            $('#seciliDetayGoster, #seciliDuzenleBtn, #seciliTekliflerBtn, #seciliSozlesmelerBtn, #seciliSilBtn')
                .prop('disabled', true);
        }

        // ============= TARİH FİLTRESİ =============
        function initTarihFiltresi() {
            if (typeof flatpickr !== 'undefined') {
                flatpickr("#tarihAraligi", {
                    mode: "range",
                    dateFormat: "d.m.Y",
                    locale: {
                        rangeSeparator: " - ",
                        firstDayOfWeek: 1,
                        weekdays: {
                            shorthand: ['Paz', 'Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt'],
                            longhand: ['Pazar', 'Pazartesi', 'Salı', 'Çarşamba', 'Perşembe', 'Cuma', 'Cumartesi']
                        },
                        months: {
                            shorthand: ['Oca', 'Şub', 'Mar', 'Nis', 'May', 'Haz', 'Tem', 'Ağu', 'Eyl', 'Eki', 'Kas', 'Ara'],
                            longhand: ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran', 'Temmuz', 'Ağustos', 'Eylül', 'Ekim', 'Kasım', 'Aralık']
                        }
                    },
                    onChange: function(selectedDates, dateStr, instance) {
                        if (selectedDates.length === 2) {
                            tarihFiltre.baslangic = selectedDates[0];
                            tarihFiltre.bitis = selectedDates[1];
                            tarihFiltre.bitis.setHours(23, 59, 59, 999);
                            tarihFiltre.aktif = true;
                            gosterAktifFiltreler();
                            filtreleVeSirala();
                        } else if (selectedDates.length === 0) {
                            tarihFiltre.baslangic = null;
                            tarihFiltre.bitis = null;
                            tarihFiltre.aktif = false;
                            gosterAktifFiltreler();
                            filtreleVeSirala();
                        }
                    }
                });
            } else {
                setTimeout(initTarihFiltresi, 100);
            }
        }

        // ============= SÜTUN FİLTRESİ =============
        function sutunFiltresiAktifEt(index, ad, alan) {
            $('thead th[data-sutun-index]').removeClass('sutun-aktif');
            $(`thead th[data-sutun-index="${index}"]`).addClass('sutun-aktif');
            aktifAramaSutunu = alan;
            $('#aktifSutunAdi').text(ad);
            $('#aktifSutunGosterge').fadeIn(200);
            if (aramaMetni) {
                filtreleVeSirala();
            }
        }

        function sutunFiltresiniKaldir() {
            $('thead th[data-sutun-index]').removeClass('sutun-aktif');
            aktifAramaSutunu = null;
            $('#aktifSutunGosterge').fadeOut(200);
            if (aramaMetni) {
                filtreleVeSirala();
            } else {
                tumSatirlariGoster();
            }
        }

        function tumSatirlariGoster() {
            $('#bayiTablosu tbody tr:not(.empty-state)').each(function() {
                $(this).show();
                $(this).find('td').removeClass('arama-vurgula');
            });
            $('#bayiTablosu .arama-bos-mesaj').remove();
        }

        function hucreMetniniAl($hucre, sutunAlani) {
            if (sutunAlani === 'seviye') {
                const badge = $hucre.find('.table-seviye-badge');
                return badge.length ? badge.text().toLowerCase().trim() : $hucre.text().toLowerCase().trim();
            } else if (sutunAlani === 'distributor') {
                return $hucre.text().toLowerCase().trim();
            } else if (sutunAlani === 'altBayi' || sutunAlani === 'musteri') {
                return $hucre.text().toLowerCase().trim();
            } else {
                return $hucre.text().toLowerCase().trim();
            }
        }

        function getSutunIndex(sutunAlani) {
            const bulunan = sutunlar.find(s => s.alan === sutunAlani);
            return bulunan ? bulunan.index : -1;
        }

        function getSutunAlani(index) {
            const bulunan = sutunlar.find(s => s.index === index);
            return bulunan ? bulunan.alan : null;
        }

        function parseTableDate(dateStr) {
            if (!dateStr || dateStr === '-' || dateStr.trim() === '') return null;
            const parts = dateStr.split('.');
            if (parts.length === 3) {
                const day = parseInt(parts[0]);
                const month = parseInt(parts[1]) - 1;
                const year = parseInt(parts[2]);
                return new Date(year, month, day);
            }
            return null;
        }

        function formatDateForDisplay(date) {
            if (!date) return '';
            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();
            return `${day}.${month}.${year}`;
        }

        function gosterAktifFiltreler() {
            const $aktifFiltreler = $('#aktifFiltreler');
            $aktifFiltreler.empty();

            if (tarihFiltre.aktif && tarihFiltre.baslangic && tarihFiltre.bitis) {
                const baslangicStr = formatDateForDisplay(tarihFiltre.baslangic);
                const bitisStr = formatDateForDisplay(tarihFiltre.bitis);
                $aktifFiltreler.append(`
                    <div class="filtre-badge">
                        <i class="fas fa-calendar-alt"></i>
                        Oluşturma Tarihi: ${baslangicStr} - ${bitisStr}
                        <span class="filtre-temizle" onclick="$('#tarihFiltreTemizle').click()">
                            <i class="fas fa-times"></i>
                        </span>
                    </div>
                `);
            }
        }

        // ============= FİLTRELEME VE SIRALAMA =============
        function filtreleVeSirala() {
            const $satirlar = $('#bayiTablosu tbody tr:not(.empty-state, .filtre-bos-satir)');
            if ($satirlar.length === 0) return;

            let gosterilecekSatirlar = [];

            $satirlar.each(function() {
                const $satir = $(this);
                let goster = true;

                // Arama filtresi
                if (aramaMetni) {
                    let eslesmeVar = false;

                    if (aktifAramaSutunu) {
                        const sutunIndex = getSutunIndex(aktifAramaSutunu);
                        if (sutunIndex !== -1) {
                            const $hucre = $satir.find(`td:eq(${sutunIndex})`);
                            const hucreMetni = hucreMetniniAl($hucre, aktifAramaSutunu);
                            if (hucreMetni.includes(aramaMetni)) {
                                eslesmeVar = true;
                                $hucre.addClass('arama-vurgula');
                            }
                        }
                    } else {
                        $satir.find('td').each(function(index) {
                            if (index > 0) {
                                const $hucre = $(this);
                                const sutunAlani = getSutunAlani(index);
                                if (sutunAlani) {
                                    const hucreMetni = hucreMetniniAl($hucre, sutunAlani);
                                    if (hucreMetni.includes(aramaMetni)) {
                                        eslesmeVar = true;
                                        $hucre.addClass('arama-vurgula');
                                    }
                                }
                            }
                        });
                    }

                    if (!eslesmeVar) {
                        goster = false;
                    }
                }

                // Tarih filtresi
                if (goster && tarihFiltre.aktif && tarihFiltre.baslangic && tarihFiltre.bitis) {
                    const tarihStr = $satir.data('olusma-tarihi');
                    if (tarihStr) {
                        const tarih = parseTableDate(tarihStr);
                        if (tarih) {
                            if (tarih < tarihFiltre.baslangic || tarih > tarihFiltre.bitis) {
                                goster = false;
                            }
                        } else {
                            goster = false;
                        }
                    } else {
                        goster = false;
                    }
                }

                if (goster) {
                    const unvan = $satir.find('td:nth-child(3)').text().trim().replace(/[└─\s]+/g, ' ').trim();
                    const kodu = $satir.find('td:nth-child(5)').text().trim();
                    const kullaniciAdi = $satir.find('td:nth-child(4)').text().trim();
                    const seviyeText = $satir.find('td:nth-child(2) .table-seviye-badge').text().trim();
                    const seviye = parseInt(seviyeText.replace('Seviye ', '')) || 0;

                    gosterilecekSatirlar.push({
                        element: $satir,
                        unvan: unvan,
                        kodu: kodu,
                        kullaniciAdi: kullaniciAdi,
                        seviye: seviye
                    });
                }
            });

            // Sıralama
            gosterilecekSatirlar.sort((a, b) => {
                switch (mevcutSiralama) {
                    case 'unvan_az':
                        return (a.unvan || '').localeCompare(b.unvan || '', 'tr');
                    case 'unvan_za':
                        return (b.unvan || '').localeCompare(a.unvan || '', 'tr');
                    case 'kodu_az':
                        return (a.kodu || '').localeCompare(b.kodu || '', 'tr');
                    case 'kodu_za':
                        return (b.kodu || '').localeCompare(a.kodu || '', 'tr');
                    case 'kullanici_az':
                        return (a.kullaniciAdi || '').localeCompare(b.kullaniciAdi || '', 'tr');
                    case 'kullanici_za':
                        return (b.kullaniciAdi || '').localeCompare(a.kullaniciAdi || '', 'tr');
                    case 'seviye_artan':
                        return a.seviye - b.seviye;
                    case 'seviye_azalan':
                        return b.seviye - a.seviye;
                    case 'tarih_azalan':
                    case 'tarih_artan':
                    default:
                        return 0;
                }
            });

            $satirlar.hide();

            gosterilecekSatirlar.forEach((item, index) => {
                const $tbody = $('#bayiTablosu tbody');
                $tbody.append(item.element);
                item.element.show();

                const siraHucresi = item.element.find('td:nth-child(1)');
                if (siraHucresi) {
                    siraHucresi.text(index + 1);
                }
            });

            if (gosterilecekSatirlar.length === 0) {
                let bosMesaj = $('#bayiTablosu tbody .arama-bos-mesaj');
                if (bosMesaj.length === 0) {
                    let mesaj = 'Filtreleme kriterlerine uygun bayi bulunamadı.';
                    if (tarihFiltre.aktif) {
                        mesaj = `Seçilen tarih aralığında bayi bulunamadı.`;
                    } else if (aramaMetni) {
                        mesaj = `"${aramaMetni}" için sonuç bulunamadı.`;
                    }

                    $('#bayiTablosu tbody').append(`
                        <tr class="arama-bos-mesaj">
                            <td colspan="10" class="text-center text-muted py-5">
                                <i class="fas fa-search fa-3x mb-3 opacity-50"></i><br>
                                <strong>${mesaj}</strong>
                                ${aktifAramaSutunu ? `<br><small class="text-muted">Aranan sütun: ${$('thead th.sutun-aktif').data('sutun-ad')}</small>` : ''}
                            </td>
                        </tr>
                    `);
                }
            } else {
                $('#bayiTablosu tbody .arama-bos-mesaj').remove();
            }
        }

        // ============= SATIR SEÇME =============
        function satirSec($satir) {
            const bayiId = $satir.data('bayi-id');

            if (suAnSeciliBayiId === bayiId) {
                clearSelection();
            } else {
                suAnSeciliBayiId = bayiId;
                suAnSeciliSatir = $satir;
                suAnSeciliBayiUnvan = $satir.data('bayi-unvan') || $satir.find('td:nth-child(3)').text().replace(/[└─\s]+/g, ' ').trim();

                $('#bayiTablosu tbody tr').removeClass('table-active');
                $satir.addClass('table-active');

                const displayInfo = suAnSeciliBayiUnvan || 'Bayi';
                $('#seciliKayitBilgi').html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${displayInfo.substring(0, 30)}${displayInfo.length > 30 ? '...' : ''}`);

                $('#seciliDetayGoster, #seciliDuzenleBtn, #seciliTekliflerBtn, #seciliSozlesmelerBtn, #seciliSilBtn')
                    .prop('disabled', false);
            }
        }

        // ============= İL/İLÇE İŞLEMLERİ =============
        function ilSecildi(ilId, hedefSelectId, modalTipi) {
            ilceleriGetir(ilId, hedefSelectId).then(() => {
                const ilceSelect = document.getElementById(hedefSelectId);
                if (ilceSelect.value && modalTipi === 'ekle') {
                    kullaniciAdiOluştur('ekle');
                } else if (ilceSelect.value && modalTipi === 'duzenle') {
                    kullaniciAdiYenileDuzenle();
                }
            });
        }

        function ilceSecildi(modalTipi) {
            if (modalTipi === 'ekle') {
                const ilSelect = document.getElementById('Il');
                const ilceSelect = document.getElementById('Ilce');
                if (ilSelect.value && ilceSelect.value) {
                    kullaniciAdiOluştur('ekle');
                }
            } else {
                const ilSelect = document.getElementById('editIl');
                const ilceSelect = document.getElementById('editIlce');
                if (ilSelect.value && ilceSelect.value) {
                    kullaniciAdiYenileDuzenle();
                }
            }
        }

        function ilceleriGetir(ilId, hedefSelectId) {
            return new Promise((resolve, reject) => {
                const ilceSelect = document.getElementById(hedefSelectId);
                if (!ilceSelect) {
                    reject('Hedef select bulunamadı');
                    return;
                }

                ilceSelect.innerHTML = '<option value="">Yükleniyor...</option>';
                ilceSelect.disabled = true;

                if (!ilId) {
                    ilceSelect.innerHTML = '<option value="">Önce il seçiniz</option>';
                    ilceSelect.disabled = false;
                    resolve();
                    return;
                }

                fetch(`/AdminBayi/GetIlcelerByIlId?ilId=${ilId}`)
                    .then(response => response.json())
                    .then(res => {
                        ilceSelect.innerHTML = '<option value="">Seçiniz</option>';
                        if (res.success && res.data && res.data.length > 0) {
                            res.data.forEach(ilce => {
                                ilceSelect.innerHTML += `<option value="${ilce.id}">${escapeHtml(ilce.ilceadi)}</option>`;
                            });
                        } else {
                            ilceSelect.innerHTML = '<option value="">İlçe bulunamadı</option>';
                        }
                        ilceSelect.disabled = false;
                        resolve();
                    })
                    .catch(err => {
                        console.error('İlçeler yüklenirken hata:', err);
                        ilceSelect.innerHTML = '<option value="">Hata oluştu</option>';
                        ilceSelect.disabled = false;
                        reject(err);
                    });
            });
        }

        // ============= KULLANICI ADI İŞLEMLERİ =============
        function kullaniciAdiOluştur(mod = 'ekle') {
            const ilSelect = document.getElementById('Il');
            const ilceSelect = document.getElementById('Ilce');
            const kullaniciAdiInput = document.getElementById('KullaniciAdi');
            const durumDiv = document.getElementById('kullaniciAdiDurumEkle');
            const btn = document.getElementById('kullaniciAdiOluşturBtn');

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Oluşturuluyor...';

            if (!ilSelect.value) {
                durumDiv.style.display = 'block';
                durumDiv.className = 'mt-2 alert alert-warning py-2';
                durumDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Lütfen önce il seçiniz.';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Kullanıcı Adı Oluştur';
                return;
            }

            if (!ilceSelect.value) {
                durumDiv.style.display = 'block';
                durumDiv.className = 'mt-2 alert alert-warning py-2';
                durumDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Lütfen önce ilçe seçiniz.';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Kullanıcı Adı Oluştur';
                return;
            }

            const ilId = ilSelect.value;
            const ilceId = ilceSelect.value;
            const rastgeleSayi = Math.floor(1000 + Math.random() * 9000);
            let olusanKullaniciAdi = `${ilId}${ilceId}${rastgeleSayi}`;

            kullaniciAdiInput.value = olusanKullaniciAdi;
            kullaniciAdiKontrolEt(olusanKullaniciAdi, 'ekle');

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Kullanıcı Adı Oluştur';
        }

        function kullaniciAdiYenileDuzenle() {
            const ilSelect = document.getElementById('editIl');
            const ilceSelect = document.getElementById('editIlce');
            const kullaniciAdiInput = document.getElementById('editKullaniciAdi');
            const durumDiv = document.getElementById('kullaniciAdiDurumDuzenle');
            const btn = document.getElementById('editKullaniciAdiOluşturBtn');

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Yenileniyor...';

            if (!ilSelect.value) {
                durumDiv.style.display = 'block';
                durumDiv.className = 'mt-2 alert alert-warning py-2';
                durumDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Lütfen önce il seçiniz.';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Yenile';
                return;
            }

            if (!ilceSelect.value) {
                durumDiv.style.display = 'block';
                durumDiv.className = 'mt-2 alert alert-warning py-2';
                durumDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Lütfen önce ilçe seçiniz.';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Yenile';
                return;
            }

            const ilId = ilSelect.value;
            const ilceId = ilceSelect.value;
            const rastgeleSayi = Math.floor(1000 + Math.random() * 9000);
            let olusanKullaniciAdi = `${ilId}${ilceId}${rastgeleSayi}`;

            kullaniciAdiInput.value = olusanKullaniciAdi;
            kullaniciAdiKontrolEt(olusanKullaniciAdi, 'duzenle');

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Yenile';
        }

        function kullaniciAdiKontrolEt(kullaniciAdi, modal = 'ekle') {
            if (!kullaniciAdi) return;

            const durumDiv = document.getElementById(modal === 'ekle' ? 'kullaniciAdiDurumEkle' : 'kullaniciAdiDurumDuzenle');
            const submitBtn = document.getElementById(modal === 'ekle' ? 'ekleBtn' : 'duzenleSubmitBtn');

            fetch(`/AdminBayi/KullaniciAdiKontrol?kullaniciAdi=${encodeURIComponent(kullaniciAdi)}`)
                .then(response => response.json())
                .then(res => {
                    durumDiv.style.display = 'block';

                    if (res.success) {
                        if (res.kullaniliyor) {
                            durumDiv.className = 'mt-2 alert alert-danger py-2';
                            durumDiv.innerHTML = `<i class="fas fa-times-circle me-1"></i> ${res.mesaj}`;
                            if (submitBtn) submitBtn.disabled = true;

                            setTimeout(() => {
                                if (modal === 'ekle') {
                                    kullaniciAdiOluştur('ekle');
                                } else {
                                    kullaniciAdiYenileDuzenle();
                                }
                            }, 2000);
                        } else {
                            durumDiv.className = 'mt-2 alert alert-success py-2';
                            durumDiv.innerHTML = `<i class="fas fa-check-circle me-1"></i> ${res.mesaj}`;
                            if (submitBtn) submitBtn.disabled = false;
                        }
                    } else {
                        durumDiv.className = 'mt-2 alert alert-danger py-2';
                        durumDiv.innerHTML = `<i class="fas fa-exclamation-triangle me-1"></i> Kontrol sırasında hata: ${res.message}`;
                    }
                })
                .catch(err => {
                    durumDiv.style.display = 'block';
                    durumDiv.className = 'mt-2 alert alert-danger py-2';
                    durumDiv.innerHTML = `<i class="fas fa-exclamation-triangle me-1"></i> Bağlantı hatası: ${err}`;
                });
        }

        // ============= ŞİFRE İŞLEMLERİ =============
        function sifreYenilePencere() {
            if (!currentBayiId) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Uyarı',
                    text: 'Önce bir bayi seçin!'
                });
                return;
            }

            Swal.fire({
                title: 'Şifre Yenile',
                html: `
                    <div class="text-center mb-4">
                        <i class="fas fa-key fa-3x text-warning mb-3"></i>
                        <p class="mb-3">Bayi için yeni bir şifre oluşturulacak.</p>
                        <div class="alert alert-info p-2 small">
                            <i class="fas fa-info-circle me-1"></i>
                            Oluşturulacak şifre 8 karakterli ve rastgele olacaktır.
                        </div>
                    </div>
                `,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Evet, Şifre Oluştur',
                cancelButtonText: 'İptal',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    sifreYenile();
                }
            });
        }

        function sifreYenile() {
            const btn = document.getElementById('sifreYenileBtn');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Oluşturuluyor...';
            }

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch('/AdminBayi/SifreSifirla', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: 'id=' + currentBayiId
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const sifreInput = document.getElementById('editSifre');
                    sifreInput.value = data.yeniSifre;

                    Swal.fire({
                        title: 'Şifre Oluşturuldu!',
                        html: `
                            <div class="text-center">
                                <i class="fas fa-check-circle text-success fa-4x mb-3"></i>
                                <p class="mb-2">Yeni şifre oluşturuldu:</p>
                                <div class="input-group mb-3 mx-auto" style="max-width: 300px;">
                                    <input type="text" class="form-control text-center fw-bold form-control-lg"
                                           id="yeniSifreInput" value="${data.yeniSifre}" readonly
                                           style="font-size: 1.5rem; letter-spacing: 2px; background-color: #f8f9fa;">
                                    <button class="btn btn-outline-primary" type="button"
                                            onclick="kopyalaSifre('${data.yeniSifre}')">
                                        <i class="fas fa-copy"></i>
                                    </button>
                                </div>
                            </div>
                        `,
                        icon: 'success',
                        confirmButtonText: 'Tamam',
                        width: 500
                    });
                } else {
                    Swal.fire('Hata!', data.message || 'Şifre oluşturulurken bir hata oluştu.', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                Swal.fire('Hata!', 'Sunucuyla iletişim kurulamadı.', 'error');
            })
            .finally(() => {
                if (btn) {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-key"></i> Şifre Yenile';
                }
            });
        }

        function kopyalaSifre(sifre) {
            navigator.clipboard.writeText(sifre).then(() => {
                Swal.fire({
                    title: 'Kopyalandı!',
                    text: 'Şifre panoya kopyalandı.',
                    icon: 'success',
                    timer: 1500,
                    showConfirmButton: false
                });
            }).catch(err => {
                console.error('Kopyalama hatası:', err);
                const input = document.getElementById('yeniSifreInput');
                if (input) {
                    input.select();
                    document.execCommand('copy');
                    Swal.fire('Kopyalandı!', 'Şifre panoya kopyalandı.', 'success');
                }
            });
        }

        // ============= DOSYA YÖNETİMİ =============
        function yukleDosyaBilgileri(bayiId) {
            if (!bayiId) return;

            fetch(`/AdminBayi/GetDosyaBilgisi?id=${bayiId}`)
                .then(r => r.json())
                .then(res => {
                    if (res.success) {
                        if (res.logoVar && res.logoUzanti) {
                            mevcutLogoAdi = res.logoUzanti;
                            document.getElementById('mevcutLogoContainer').style.display = 'block';
                            document.getElementById('mevcutLogoImg').src = `/AdminBayi/LogoGoster/${bayiId}?t=${Date.now()}`;
                            document.getElementById('logoDurumBadge').className = 'badge bg-success';
                            document.getElementById('logoDurumBadge').textContent = 'Var';
                            document.getElementById('logoStat').className = 'badge bg-success';
                            document.getElementById('logoStat').textContent = 'Mevcut';
                        } else {
                            document.getElementById('mevcutLogoContainer').style.display = 'none';
                            document.getElementById('logoDurumBadge').className = 'badge bg-secondary';
                            document.getElementById('logoDurumBadge').textContent = 'Yok';
                            document.getElementById('logoStat').className = 'badge bg-secondary';
                            document.getElementById('logoStat').textContent = 'Yok';
                        }

                        if (res.imzaVar && res.imzaUzanti) {
                            mevcutImzaAdi = res.imzaUzanti;
                            document.getElementById('mevcutImzaContainer').style.display = 'block';
                            document.getElementById('mevcutImzaImg').src = `/AdminBayi/ImzaGoster/${bayiId}?t=${Date.now()}`;
                            document.getElementById('imzaDurumBadge').className = 'badge bg-success';
                            document.getElementById('imzaDurumBadge').textContent = 'Var';
                            document.getElementById('imzaStat').className = 'badge bg-success';
                            document.getElementById('imzaStat').textContent = 'Mevcut';
                        } else {
                            document.getElementById('mevcutImzaContainer').style.display = 'none';
                            document.getElementById('imzaDurumBadge').className = 'badge bg-secondary';
                            document.getElementById('imzaDurumBadge').textContent = 'Yok';
                            document.getElementById('imzaStat').className = 'badge bg-secondary';
                            document.getElementById('imzaStat').textContent = 'Yok';
                        }

                        guncelleDosyaIstatistikleri(res);
                    }
                })
                .catch(err => {
                    console.error('Dosya bilgileri yüklenemedi:', err);
                });
        }

        function guncelleDosyaIstatistikleri(data) {
            const toplamBoyut = (data.toplamBoyut || 0);

            function formatBoyut(bytes) {
                if (bytes === 0) return '0 B';
                const k = 1024;
                const sizes = ['B', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
            }

            document.getElementById('toplamBoyut').textContent = formatBoyut(toplamBoyut);
            document.getElementById('sonGuncelleme').textContent = new Date().toLocaleDateString('tr-TR');
        }

        function handleLogoSelect(event) {
            handleFileSelect(event, 'logo');
        }

        function handleImzaSelect(event) {
            handleFileSelect(event, 'imza');
        }

        function handleFileSelectEkle(event, tip) {
            const file = event.target.files[0];
            if (!file) return;

            if (!validateFile(file, tip)) {
                return;
            }

            createPreviewEkle(file, tip);
        }

        function handleFileSelect(event, tip) {
            const file = event.target.files[0];
            if (!file) return;

            if (!validateFile(file, tip)) {
                return;
            }

            createPreview(file, tip);
            showFileInfo(file, tip);
            showProgressBar(tip);
            simulateUpload(tip);
        }

        function validateFile(file, tip) {
            const maxSize = 5 * 1024 * 1024;
            const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/bmp', 'image/webp'];

            if (file.size > maxSize) {
                alert(`${tip === 'logo' ? 'Logo' : 'İmza'} boyutu 5MB'tan büyük olamaz. Seçilen dosya: ${(file.size / 1024 / 1024).toFixed(2)}MB`);
                return false;
            }

            if (!allowedTypes.includes(file.type)) {
                alert(`${tip === 'logo' ? 'Logo' : 'İmza'} için sadece JPG, PNG, GIF, BMP ve WEBP dosyaları yüklenebilir.`);
                return false;
            }

            return true;
        }

        function createPreviewEkle(file, tip) {
            const reader = new FileReader();
            const previewDiv = document.getElementById(`${tip}PreviewEkle`);

            reader.onload = function(e) {
                previewDiv.innerHTML = `
                    <div class="position-relative">
                        <button type="button" class="remove-file-btn" onclick="removePreviewEkle('${tip}')">
                            <i class="fas fa-times"></i>
                        </button>
                        <img src="${e.target.result}" class="img-fluid rounded" alt="${file.name}">
                        <div class="file-info">
                            <div><strong>${escapeHtml(file.name)}</strong></div>
                            <div>${(file.size / 1024).toFixed(2)} KB</div>
                        </div>
                    </div>
                `;
            };

            reader.readAsDataURL(file);
        }

        function createPreview(file, tip) {
            const reader = new FileReader();
            const previewDiv = document.getElementById(`${tip}Preview`);

            reader.onload = function(e) {
                previewDiv.innerHTML = `
                    <div class="position-relative">
                        <button type="button" class="remove-file-btn" onclick="removePreview('${tip}')">
                            <i class="fas fa-times"></i>
                        </button>
                        <img src="${e.target.result}" class="img-fluid rounded" alt="${file.name}">
                        <div class="file-info">
                            <div><strong>${escapeHtml(file.name)}</strong></div>
                            <div>${(file.size / 1024).toFixed(2)} KB</div>
                        </div>
                    </div>
                `;
            };

            reader.readAsDataURL(file);
        }

        function showFileInfo(file, tip) {
            const infoDiv = document.getElementById(`${tip}BilgiAlert`);
            const infoText = document.getElementById(`${tip}BilgiText`);

            const fileInfo = `
                Yeni ${tip === 'logo' ? 'logo' : 'imza'} seçildi:<br>
                <strong>${escapeHtml(file.name)}</strong> (${(file.size / 1024).toFixed(2)} KB)<br>
                ${file.type} - ${new Date(file.lastModified).toLocaleDateString('tr-TR')}
            `;

            infoText.innerHTML = fileInfo;
            infoDiv.style.display = 'block';
        }

        function showProgressBar(tip) {
            const progress = document.getElementById(`${tip}Progress`);
            const progressBar = document.getElementById(`${tip}ProgressBar`);

            progress.style.display = 'block';
            progressBar.style.width = '0%';
        }

        function simulateUpload(tip) {
            const progressBar = document.getElementById(`${tip}ProgressBar`);
            let width = 0;

            const interval = setInterval(() => {
                if (width >= 100) {
                    clearInterval(interval);
                    setTimeout(() => {
                        document.getElementById(`${tip}Progress`).style.display = 'none';
                        showSuccessMessage(tip);
                    }, 300);
                } else {
                    width += 10;
                    progressBar.style.width = width + '%';
                }
            }, 50);
        }

        function showSuccessMessage(tip) {
            const infoDiv = document.getElementById(`${tip}BilgiAlert`);
            const oldHtml = infoDiv.innerHTML;

            infoDiv.className = 'alert alert-success mt-3';
            infoDiv.innerHTML = `
                <i class="fas fa-check-circle"></i>
                <strong>Başarılı!</strong> ${tip === 'logo' ? 'Logo' : 'İmza'} yüklendi.
                Formu göndererek kaydedebilirsiniz.
            `;

            setTimeout(() => {
                infoDiv.className = 'alert alert-info mt-3';
                infoDiv.innerHTML = oldHtml;
            }, 3000);
        }

        function removePreviewEkle(tip) {
            const previewDiv = document.getElementById(`${tip}PreviewEkle`);
            const fileInput = document.getElementById(tip.charAt(0).toUpperCase() + tip.slice(1));

            previewDiv.innerHTML = '';
            fileInput.value = '';
        }

        function removePreview(tip) {
            const previewDiv = document.getElementById(`${tip}Preview`);
            const fileInput = document.getElementById(`edit${tip.charAt(0).toUpperCase() + tip.slice(1)}`);
            const infoDiv = document.getElementById(`${tip}BilgiAlert`);

            previewDiv.innerHTML = '';
            fileInput.value = '';
            infoDiv.style.display = 'none';
            document.getElementById(`${tip}Progress`).style.display = 'none';
        }

        function handleDragOver(e) {
            e.preventDefault();
            e.stopPropagation();
            e.currentTarget.classList.add('dragover');
        }

        function handleDragLeave(e) {
            e.preventDefault();
            e.stopPropagation();
            e.currentTarget.classList.remove('dragover');
        }

        function handleDrop(e, tip) {
            e.preventDefault();
            e.stopPropagation();
            e.currentTarget.classList.remove('dragover');

            const files = e.dataTransfer.files;
            if (files.length > 0) {
                const fileInput = document.getElementById(`edit${tip.charAt(0).toUpperCase() + tip.slice(1)}`);
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(files[0]);
                fileInput.files = dataTransfer.files;

                const event = new Event('change', { bubbles: true });
                fileInput.dispatchEvent(event);
            }
        }

        function buyukGoster(tip) {
            const modal = new bootstrap.Modal(document.getElementById('buyukGosterModal'));
            const modalTitle = document.getElementById('buyukGosterModalLabel');
            const modalImg = document.getElementById('buyukGosterImg');

            if (tip === 'logo') {
                modalTitle.textContent = 'Logo Görüntüle';
                modalImg.src = document.getElementById('mevcutLogoImg').src;
                currentDosyaTipi = 'logo';
            } else {
                modalTitle.textContent = 'İmza Görüntüle';
                modalImg.src = document.getElementById('mevcutImzaImg').src;
                currentDosyaTipi = 'imza';
            }

            modal.show();
        }

        function indirBuyukResim() {
            if (currentDosyaTipi === 'logo') {
                indirLogo();
            } else {
                indirImza();
            }
            bootstrap.Modal.getInstance(document.getElementById('buyukGosterModal')).hide();
        }

        function indirLogo() {
            if (currentBayiId) {
                window.open(`/AdminBayi/LogoIndir/${currentBayiId}`, '_blank');
            }
        }

        function indirImza() {
            if (currentBayiId) {
                window.open(`/AdminBayi/ImzaIndir/${currentBayiId}`, '_blank');
            }
        }

        function silLogoOnay() {
            document.getElementById('silinecekDosyaAdi').textContent = 'Logo';
            currentDosyaTipi = 'logo';

            const modal = new bootstrap.Modal(document.getElementById('dosyaSilModal'));
            modal.show();

            const silBtn = document.getElementById('dosyaSilOnayBtn');
            silBtn.onclick = function() {
                silLogo();
                modal.hide();
            };
        }

        function silImzaOnay() {
            document.getElementById('silinecekDosyaAdi').textContent = 'İmza';
            currentDosyaTipi = 'imza';

            const modal = new bootstrap.Modal(document.getElementById('dosyaSilModal'));
            modal.show();

            const silBtn = document.getElementById('dosyaSilOnayBtn');
            silBtn.onclick = function() {
                silImza();
                modal.hide();
            };
        }

        function silLogo() {
            if (!currentBayiId) return;

            const formData = new FormData();
            formData.append('Id', currentBayiId);

            fetch('@Url.Action("SilLogo", "AdminBayi")', {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Logo silinirken bir hata oluştu.');
            });
        }

        function silImza() {
            if (!currentBayiId) return;

            const formData = new FormData();
            formData.append('Id', currentBayiId);

            fetch('@Url.Action("SilImza", "AdminBayi")', {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('İmza silinirken bir hata oluştu.');
            });
        }

