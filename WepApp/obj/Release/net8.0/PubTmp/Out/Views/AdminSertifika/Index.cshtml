@{
    ViewData["Title"] = "Sertifika Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Seçim satırı için cursor pointer */
    tr[data-sertifika-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* Buton grupları için */
    .btn-group .btn {
        margin: 0 2px;
    }

        .btn-group .btn:first-child {
            margin-left: 0;
        }

        .btn-group .btn:last-child {
            margin-right: 0;
        }
</style>

<div class="row">
    <div class="col-md-12">
        <!-- Mesajlar -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <!-- Kullanıcı Bilgisi -->
        @if (ViewBag.CurrentUserType == "Musteri")
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                Müşteri olarak giriş yaptınız. Tüm bayilerinizin sertifikalarını görüntülüyorsunuz.
            </div>
        }
        else if (ViewBag.CurrentUserType == "Bayi")
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                Bayi olarak giriş yaptınız. Sadece kendi sertifikalarınızı görüntülüyorsunuz.
            </div>
        }

        <div class="card" style="margin-top: 70px;">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Sertifikalar</h5>
                @if (ViewBag.Kullanici != null)
                {
                    <div class="d-flex align-items-center gap-3">
                        <!-- Seçili Kayıt Bilgisi ve İşlem Butonları -->
                        <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                            <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                                <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                            </div>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-warning btn-sm" id="seciliDuzenleBtn" data-button-permission="duzenle" title="Seçili Sertifikayı Düzenle" disabled style="margin-right:5px;">
                                    <i class="fas fa-edit"></i> 
                                </button>
                                <button type="button" class="btn btn-danger btn-sm" id="seciliSilBtn" data-button-permission="sil" title="Seçili Sertifikayı Sil" disabled>
                                    <i class="fas fa-trash"></i> 
                                </button>
                            </div>
                        </div>

                        <!-- Yeni Ekle Butonu -->
                        <button class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Sertifika Ekle
                        </button>
                    </div>
                }
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-head-bg-primary">
                            <tr>
                                <th width="40">Seç</th>
                                <th>#</th>
                                @if (ViewBag.CurrentUserType != "Bayi")
                                {
                                    <th>Bayi</th>
                                }
                                <th>Sertifika Adı</th>
                                <th>Açıklama</th>
                                <th>Veriliş Tarihi</th>
                                <th>Geçerlilik Tarihi</th>
                                <th>Dosya</th>
                                @if (ViewBag.Kullanici != null)
                                {
                                    <!-- İşlemler sütunu kaldırıldı -->
                                }
                            </tr>
                        </thead>
                        <tbody id="sertifikaTablosu">
                            @if (ViewBag.Sertifikalar != null && ViewBag.Sertifikalar.Count > 0)
                            {
                                var counter = 1;
                                foreach (var s in ViewBag.Sertifikalar)
                                {
                                    <tr data-sertifika-id="@s.Id" data-sertifika-adi="@s.SertifikaAdi" class="sertifika-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input sertifika-sec-radio" type="radio" name="seciliSertifikaRadio" value="@s.Id" id="secim_@s.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        @if (ViewBag.CurrentUserType != "Bayi")
                                        {
                                            <td>@(s.Bayi?.Unvan ?? "Silinmiş Bayi")</td>
                                        }
                                        <td><strong>@s.SertifikaAdi</strong></td>
                                        <td>@s.Aciklama</td>
                                        <td>@s.VerilisTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@(s.GecerlilikTarihi?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                        <td>
                                            <a href="@Url.Action("ViewSertifika", new { path = s.DosyaYolu })" target="_blank" class="btn btn-info btn-sm" data-button-permission="goruntule" title="Sertifikayı Görüntüle">
                                                <i class="fas fa-file-pdf"></i>
                                            </a>
                                        </td>
                                        <!-- İşlemler sütunundaki butonlar KALDIRILDI -->
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan='@(ViewBag.CurrentUserType != "Bayi" ? "9" : "8")' class="text-center">
                                        Henüz sertifika eklenmemiş.
                                        @if (ViewBag.CurrentUserType != "Bayi")
                                        {
                                            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#ekleModal" data-button-permission="ekle">
                                                Yeni Sertifika Ekle
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.CurrentUserType != "Bayi")
{
    <!-- Ekle Modal -->
    <div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form method="post" action="@Url.Action("Ekle")" id="ekleForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title" id="ekleModalLabel">Yeni Sertifika Ekle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            @if (ViewBag.CurrentUserType != "Musteri")
                            {
                                <div class="col-md-12 mb-3">
                                    <label class="form-label">Müşteri</label>
                                    <select name="MusteriId" id="musteriSelect" class="form-select" required onchange="loadBayiler()">
                                        <option value="">Müşteri Seçiniz</option>
                                        @foreach (var m in ViewBag.Musteriler)
                                        {
                                            <option value="@m.Id">@m.Ad @m.Soyad (@m.KullaniciAdi)</option>
                                        }
                                    </select>
                                </div>
                            }
                            else
                            {
                                <input type="hidden" name="MusteriId" id="musteriSelect" value="@ViewBag.CurrentUserId" />
                            }
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Bayi</label>
                                <select name="BayiId" id="bayiSelect" class="form-select" required>
                                    <option value="">Bayi Seçiniz</option>
                                </select>
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Sertifika Adı</label>
                                <input type="text" name="SertifikaAdi" class="form-control" required />
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Açıklama (isteğe bağlı)</label>
                                <input type="text" name="Aciklama" class="form-control" placeholder="Örn: Teknik Eğitim Sertifikası" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Veriliş Tarihi</label>
                                <input type="datetime-local" name="VerilisTarihi" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Geçerlilik Tarihi (isteğe bağlı)</label>
                                <input type="datetime-local" name="GecerlilikTarihi" class="form-control" />
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Sertifika Dosyası (PDF)</label>
                                <input type="file" name="Dosya" class="form-control" accept=".pdf" required />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1" aria-labelledby="duzenleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Guncelle")" id="duzenleForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title" id="duzenleModalLabel">Sertifika Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Sertifika Adı</label>
                            <input type="text" name="SertifikaAdi" id="editSertifikaAdi" class="form-control" required />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Açıklama</label>
                            <input type="text" name="Aciklama" id="editAciklama" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Veriliş Tarihi</label>
                            <input type="datetime-local" name="VerilisTarihi" id="editVerilisTarihi" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Geçerlilik Tarihi</label>
                            <input type="datetime-local" name="GecerlilikTarihi" id="editGecerlilikTarihi" class="form-control" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Sertifika Dosyası (Mevcut dosya değiştirilmek istenirse)</label>
                            <input type="file" name="Dosya" class="form-control" accept=".pdf" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Sil")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="silId" />
                <div class="modal-header">
                    <h5 class="modal-title" id="silModalLabel">Sertifika Sil</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silSertifikaAdi"></span>"</strong> sertifikasını pasif yapmak istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz. Sertifika pasif hale getirilecek.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Pasif Yap</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            // Toastr ayarları
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "5000"
            };

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============
            let suAnSeciliSertifikaId = null;
            let suAnSeciliSertifikaAdi = null;
            let suAnSeciliSatir = null;

            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#sertifikaTablosu tr[data-sertifika-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button') && !$(e.target).is('a') && !$(e.target).is('span')) {
                    const $radio = $(this).find('.sertifika-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.sertifika-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliSertifikaId = $(this).val();
                    suAnSeciliSatir = $(this).closest('tr');
                    suAnSeciliSertifikaAdi = suAnSeciliSatir.data('sertifika-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#sertifikaTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    suAnSeciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${suAnSeciliSertifikaAdi}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliSertifikaId) {
                    duzenleGetir(suAnSeciliSertifikaId);
                } else {
                    toastr.warning('Lütfen önce bir sertifika seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliSertifikaId) {
                    $('#silId').val(suAnSeciliSertifikaId);
                    $('#silSertifikaAdi').text(suAnSeciliSertifikaAdi);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir sertifika seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliSertifikaId) {
                    const $satir = $(`tr[data-sertifika-id="${suAnSeciliSertifikaId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        clearSelection();
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.sertifika-sec-radio[value="${suAnSeciliSertifikaId}"]`).prop('checked', false);
                        clearSelection();
                    }
                }
            });

            // Seçimi temizleme yardımcı fonksiyonu
            function clearSelection() {
                $('#sertifikaTablosu tr').removeClass('table-active');
                suAnSeciliSertifikaId = null;
                suAnSeciliSertifikaAdi = null;
                suAnSeciliSatir = null;
                $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                // Tüm butonları devre dışı bırak
                $seciliDuzenleBtn.prop('disabled', true);
                $seciliSilBtn.prop('disabled', true);
            }

            // Sayfa yüklendiğinde müşteri ise bayileri yükle
        @if (ViewBag.CurrentUserType == "Musteri")
        {
                @:loadBayiler();
        }

            // Mesajları 5 saniye sonra kapat
            setTimeout(() => {
                document.querySelectorAll('.alert').forEach(a => {
                    new bootstrap.Alert(a).close();
                });
            }, 5000);
        });

        function loadBayiler() {
            const musteriSelect = document.getElementById('musteriSelect');
            const bayiSelect = document.getElementById('bayiSelect');
            const musteriId = musteriSelect ? musteriSelect.value : '@ViewBag.CurrentUserId';

            // Reset bayi select
            bayiSelect.innerHTML = '<option value="">Bayi Seçiniz</option>';

            if (musteriId) {
                fetch('@Url.Action("GetBayilerByMusteri")' + '?musteriId=' + encodeURIComponent(musteriId))
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok: ' + response.statusText);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data && Array.isArray(data)) {
                            data.forEach(bayi => {
                                const option = document.createElement('option');
                                option.value = bayi.id;
                                option.textContent = bayi.ad;
                                bayiSelect.appendChild(option);
                            });
                        } else {
                            console.warn('No bayiler returned or invalid data format');
                            toastr.error('Bayiler yüklenemedi: Veri formatı hatalı.');
                        }
                    })
                    .catch(error => {
                        console.error('Error fetching bayiler:', error);
                        toastr.error('Bayiler yüklenemedi: ' + error.message);
                    });
            } else {
                console.warn('No musteriId selected');
                toastr.error('Lütfen bir müşteri seçiniz.');
            }
        }

        function duzenleGetir(id) {
            fetch('@Url.Action("Getir")' + '?id=' + id)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    document.getElementById('editId').value = data.id;
                    document.getElementById('editSertifikaAdi').value = data.sertifikaAdi || '';
                    document.getElementById('editAciklama').value = data.aciklama || '';
                    document.getElementById('editVerilisTarihi').value = data.verilisTarihi || '';
                    document.getElementById('editGecerlilikTarihi').value = data.gecerlilikTarihi || '';
                    new bootstrap.Modal(document.getElementById('duzenleModal')).show();
                })
                .catch(error => {
                    console.error('Error fetching sertifika:', error);
                    toastr.error('Sertifika bilgileri alınamadı: ' + error.message);
                });
        }

        function silOnay(id, sertifikaAdi) {
            document.getElementById('silId').value = id;
            document.getElementById('silSertifikaAdi').textContent = sertifikaAdi;
            new bootstrap.Modal(document.getElementById('silModal')).show();
        }
    </script>
}