@{
    ViewData["Title"] = "Makale Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Seçim satırı için cursor pointer */
    tr[data-makale-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* Buton grupları için */
    .btn-group .btn {
        margin: 0 2px;
    }

        .btn-group .btn:first-child {
            margin-left: 0;
        }

        .btn-group .btn:last-child {
            margin-right: 0;
        }
</style>

<div class="row">
    <div class="col-md-12">
        <!-- Başarı/Hata Mesajları -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card" style="margin-top:70px;">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Makale Bilgileri</h5>
                <div class="d-flex align-items-center gap-3">
                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları -->
                    <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                        <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                            <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-warning btn-sm" id="seciliDuzenleBtn" data-button-permission="duzenle" title="Seçili Makaleyi Düzenle" disabled style="margin-right:5px;">
                                <i class="fas fa-edit"></i> 
                            </button>
                            <button type="button" class="btn btn-danger btn-sm" id="seciliSilBtn" data-button-permission="sil" title="Seçili Makaleyi Sil" disabled>
                                <i class="fas fa-trash"></i> 
                            </button>
                        </div>
                    </div>

                    <!-- Yeni Ekle Butonu -->
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-button-permission="ekle" data-bs-target="#ekleModal">
                        <i class="fas fa-plus"></i> Yeni Makale Ekle
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-head-bg-primary">
                            <tr>
                                <th width="40">Seç</th>
                                <th scope="col">#</th>
                                <th scope="col">Başlık</th>
                                <th scope="col">Metin</th>
                                <th scope="col">Fotoğraf</th>
                                <th scope="col">Eklenme Tarihi</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="makaleTablosu">
                            @if (ViewBag.MakaleList != null && ViewBag.MakaleList.Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in ViewBag.MakaleList)
                                {
                                    <tr data-makale-id="@item.Id" data-makale-baslik="@item.Baslik" class="makale-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input makale-sec-radio" type="radio" name="seciliMakaleRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td><strong>@item.Baslik</strong></td>
                                        <td>
                                            @{
                                                string metin = item.Metin?.ToString() ?? "";
                                                if (metin.Length > 50)
                                                {
                                                    @Html.Raw(metin.Substring(0, 50) + "...")
                                                }
                                                else
                                                {
                                                    @Html.Raw(metin)
                                                }
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Fotograf))
                                            {
                                                <div class="d-flex align-items-center">
                                                    <img src="@item.Fotograf" alt="Fotoğraf" style="width: 50px; height: 50px; object-fit: cover; border-radius:4px;" class="me-2">
                                                    <a href="@item.Fotograf" target="_blank" class="btn btn-info btn-sm" data-button-permission="detay" title="Fotoğrafı Görüntüle">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Fotoğraf yok</span>
                                            }
                                        </td>
                                        <td>
                                            @{
                                                var tarih = item.EklenmeTarihi as DateTime?;
                                                @(tarih?.ToString("dd.MM.yyyy HH:mm") ?? "")
                                            }
                                        </td>
                                        <!-- İşlemler sütunundaki butonlar KALDIRILDI -->
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">
                                        Henüz makale eklenmemiş.
                                        <a href="#" data-bs-toggle="modal" data-bs-target="#ekleModal" class="btn btn-primary btn-sm">
                                            Yeni Makale Ekle
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Ekle", "AdminMakale")" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Makale Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="Baslik" class="form-label">Başlık</label>
                        <input type="text" class="form-control" id="Baslik" name="Baslik" required>
                    </div>
                    <div class="mb-3">
                        <label for="Metin" class="form-label">Metin</label>
                        <textarea class="form-control" id="Metin" name="Metin" rows="10"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="Dosya" class="form-label">Fotoğraf</label>
                        <input type="file" class="form-control" id="Dosya" name="Dosya" accept="image/*">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Guncelle", "AdminMakale")" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title">Makale Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editBaslik" class="form-label">Başlık</label>
                        <input type="text" class="form-control" id="editBaslik" name="Baslik" required>
                    </div>
                    <div class="mb-3">
                        <label for="editMetin" class="form-label">Metin</label>
                        <textarea class="form-control" id="editMetin" name="Metin" rows="10"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="editDosya" class="form-label">Fotoğraf (Değiştirmek isterseniz seçin)</label>
                        <input type="file" class="form-control" id="editDosya" name="Dosya" accept="image/*">
                        <div id="mevcutFotograf" class="mt-2"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Sil", "AdminMakale")">
                @Html.AntiForgeryToken()
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silBaslik"></span>"</strong> başlıklı makaleyi silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        var ekleEditor, duzenleEditor;

        // CKEditor başlat
        function initEditors() {
            if (document.getElementById('Metin') && !ekleEditor) {
                ekleEditor = CKEDITOR.replace('Metin', {
                    height: 300,
                    language: 'tr'
                });
            }
            if (document.getElementById('editMetin') && !duzenleEditor) {
                duzenleEditor = CKEDITOR.replace('editMetin', {
                    height: 300,
                    language: 'tr'
                });
            }
        }

        $(document).ready(function () {
            // Toastr ayarları
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "5000"
            };

            initEditors();

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============
            let suAnSeciliMakaleId = null;
            let suAnSeciliMakaleBaslik = null;
            let suAnSeciliSatir = null;

            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#makaleTablosu tr[data-makale-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button') && !$(e.target).is('a')) {
                    const $radio = $(this).find('.makale-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.makale-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliMakaleId = $(this).val();
                    suAnSeciliSatir = $(this).closest('tr');
                    suAnSeciliMakaleBaslik = suAnSeciliSatir.data('makale-baslik');

                    // Tüm satırlardan active class'ı kaldır
                    $('#makaleTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    suAnSeciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${suAnSeciliMakaleBaslik.substring(0, 30)}${suAnSeciliMakaleBaslik.length > 30 ? '...' : ''}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliMakaleId) {
                    duzenleGetir(suAnSeciliMakaleId);
                } else {
                    toastr.warning('Lütfen önce bir makale seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliMakaleId) {
                    $('#silId').val(suAnSeciliMakaleId);
                    $('#silBaslik').text(suAnSeciliMakaleBaslik);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir makale seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliMakaleId) {
                    const $satir = $(`tr[data-makale-id="${suAnSeciliMakaleId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        clearSelection();
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.makale-sec-radio[value="${suAnSeciliMakaleId}"]`).prop('checked', false);
                        clearSelection();
                    }
                }
            });

            // Seçimi temizleme yardımcı fonksiyonu
            function clearSelection() {
                $('#makaleTablosu tr').removeClass('table-active');
                suAnSeciliMakaleId = null;
                suAnSeciliMakaleBaslik = null;
                suAnSeciliSatir = null;
                $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                // Tüm butonları devre dışı bırak
                $seciliDuzenleBtn.prop('disabled', true);
                $seciliSilBtn.prop('disabled', true);
            }

            // Düzenleme modalı gösterildiğinde
            $('#duzenleModal').on('shown.bs.modal', function() {
                if (duzenleEditor) {
                    setTimeout(function() {
                        duzenleEditor.focus();
                    }, 200);
                }
            });

            // Modal kapandığında
            $('#ekleModal').on('hidden.bs.modal', function() {
                if (ekleEditor) {
                    ekleEditor.setData('');
                }
                this.querySelector('form').reset();
            });

            $('#duzenleModal').on('hidden.bs.modal', function() {
                if (duzenleEditor) {
                    duzenleEditor.setData('');
                }
                document.getElementById('mevcutFotograf').innerHTML = '';
            });

            // Alertleri otomatik kapat
            setTimeout(function() {
                document.querySelectorAll('.alert').forEach(function(alert) {
                    var bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        });

        // Düzenleme için veri getir
        function duzenleGetir(id) {
            fetch('@Url.Action("Getir", "AdminMakale")?id=' + id)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('editId').value = data.id;
                    document.getElementById('editBaslik').value = data.baslik || '';

                    if (duzenleEditor) {
                        duzenleEditor.setData(data.metin || '');
                    } else {
                        document.getElementById('editMetin').value = data.metin || '';
                    }

                    if (data.fotograf) {
                        document.getElementById('mevcutFotograf').innerHTML =
                            '<img src="' + data.fotograf + '" style="max-width: 200px; max-height: 100px; border-radius:4px;" class="mt-2 border p-1"/>' +
                            '<div><small class="text-muted">Mevcut fotoğraf</small></div>';
                    } else {
                        document.getElementById('mevcutFotograf').innerHTML = '';
                    }

                    var modal = new bootstrap.Modal(document.getElementById('duzenleModal'));
                    modal.show();
                })
                .catch(error => {
                    toastr.error('Kayıt getirilirken hata oluştu.');
                });
        }

        // Silme onay
        function silOnay(id, baslik) {
            document.getElementById('silId').value = id;
            document.getElementById('silBaslik').textContent = baslik;
            var modal = new bootstrap.Modal(document.getElementById('silModal'));
            modal.show();
        }
    </script>
}