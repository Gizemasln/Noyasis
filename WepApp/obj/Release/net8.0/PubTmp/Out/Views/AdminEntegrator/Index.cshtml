@using WepApp.Models
@model List<Entegrator>

@{
    ViewData["Title"] = "Entegratör Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Filtreleme stilleri - Diğer sayfalarla uyumlu */
    .card-header .flex-wrap {
        gap: 15px;
    }

    .card-header .gap-2 {
        gap: 0.5rem !important;
    }

    .search-box {
        position: relative;
    }

        .search-box .input-group {
            transition: all 0.3s ease;
            width: 200px;
        }

            .search-box .input-group:focus-within {
                width: 250px;
            }

        .search-box .form-control:focus {
            background-color: #fff !important;
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
        }

    #entegratorAramaTemizle {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        z-index: 5;
        color: #6c757d;
        padding: 0.25rem 0.5rem;
    }

        #entegratorAramaTemizle:hover {
            color: #dc3545;
        }

    .dropdown-menu {
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        border: none;
    }

        .dropdown-menu .form-control-sm,
        .dropdown-menu .form-select-sm {
            border: 1px solid #dee2e6;
        }

            .dropdown-menu .form-control-sm:focus,
            .dropdown-menu .form-select-sm:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
            }

    #entegratorFiltreTemizleBtn {
        transition: all 0.3s ease;
    }

        #entegratorFiltreTemizleBtn:hover {
            transform: scale(1.1);
        }

    /* Aktif filtre butonu stilleri */
    .btn-primary .fas {
        color: white;
    }

    /* Filtre etiketleri */
    #aktifFiltreler {
        background-color: #f8f9fa;
        border-radius: 0.35rem;
        padding: 10px;
        border: 1px solid #e3e6f0;
        margin-top: 15px !important;
    }

        #aktifFiltreler .badge {
            font-size: 0.85rem;
            padding: 0.5rem 0.75rem;
        }

    /* Tablo satırları için geçiş efekti */
    #entegratorTablosu tr {
        transition: all 0.3s ease;
    }

        #entegratorTablosu tr[style*="display: none"] {
            opacity: 0;
            transform: scale(0.95);
        }

    /* Responsive düzenlemeler */
    media (max-width: 768px) {
        .card-header .d-flex

    {
        flex-direction: column;
        align-items: stretch !important;
    }

    .card-header .gap-2 {
        flex-wrap: wrap;
        justify-content: space-between;
    }

    .search-box {
        width: 100% !important;
        margin-bottom: 5px;
    }

        .search-box .input-group {
            width: 100% !important;
        }

            .search-box .input-group:focus-within {
                width: 100% !important;
            }

    .card-header .dropdown {
        flex: 1;
    }

    .islem-butonlari-alani {
        width: 100%;
        justify-content: space-between;
    }

    #aktifFiltreler .d-flex {
        flex-direction: column;
        align-items: flex-start !important;
        gap: 10px;
    }

    #filtreEtiketleri {
        flex-wrap: wrap;
    }

    }
    .table-actions {
        white-space: nowrap;
        width: 150px;
    }

    .card {
        margin-top: 70px;
    }

    .table th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .badge-entegrator {
        background-color: #6f42c1;
        color: white;
        padding: 3px 8px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 500;
    }

    .description-cell {
        max-width: 300px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Seçim satırı için cursor pointer */
    tr[data-entegrator-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-0">Entegratör Yönetimi</h5>

                    <!-- FİLTRELEME ALANI - Diğer sayfalarla uyumlu -->
                    <div class="d-flex align-items-center gap-2">
                        <!-- Arama Kutusu -->
                        <div class="search-box">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light border-0">
                                    <i class="fas fa-search text-muted"></i>
                                </span>
                                <input type="text" id="entegratorArama" class="form-control form-control-sm border-0 bg-light"
                                       placeholder="Entegratör ara..." style="box-shadow: none;">
                                <button class="btn btn-outline-secondary btn-sm" type="button" id="entegratorAramaTemizle" style="display:none;">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Kod Filtresi -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="kodFiltreBtn">
                                <i class="fas fa-code me-1"></i> Kod
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 250px;">
                                <div class="mb-2">
                                    <label class="form-label small">Kod Ara</label>
                                    <input type="text" id="filtreKod" class="form-control form-control-sm" placeholder="Kod girin...">
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="entegratorKodFiltreTemizle()">Temizle</button>
                                    <button class="btn btn-sm btn-primary" onclick="entegratorKodFiltreUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Tarih Filtreleri -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="tarihFiltreBtn">
                                <i class="fas fa-calendar-alt me-1"></i> Tarih
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 300px;">
                                <div class="mb-2">
                                    <label class="form-label small">Eklenme Tarihi Aralığı</label>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Başlangıç</label>
                                    <input type="date" id="filtreBaslangicTarih" class="form-control form-control-sm">
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Bitiş</label>
                                    <input type="date" id="filtreBitisTarih" class="form-control form-control-sm">
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="entegratorTarihFiltreTemizle()">Temizle</button>
                                    <button class="btn btn-sm btn-primary" onclick="entegratorTarihFiltreUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Sıralama -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="siralamaFiltreBtn">
                                <i class="fas fa-sort-amount-down me-1"></i> Sıralama
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 200px;">
                                <div class="mb-2">
                                    <select class="form-select form-select-sm" id="siralamaFiltre">
                                        <option value="yeni">En Yeni → En Eski</option>
                                        <option value="eski">En Eski → En Yeni</option>
                                        <option value="adi_az">İsim (A-Z)</option>
                                        <option value="adi_za">İsim (Z-A)</option>
                                        <option value="kod_az">Kod (A-Z)</option>
                                        <option value="kod_za">Kod (Z-A)</option>
                                    </select>
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-primary" onclick="entegratorSiralamaUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Filtre Temizleme Butonu -->
                        <button class="btn btn-sm btn-outline-danger" onclick="entegratorTumFiltreleriTemizle()"
                                title="Tüm filtreleri temizle" id="entegratorFiltreTemizleBtn" style="display: none;">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları (mevcut kod) -->
                    <div class="d-flex align-items-center gap-3">
                        <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                            <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                                <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                            </div>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-warning aksiyon-btn" id="seciliDuzenleBtn" data-button-permission="duzenle" title="Seçili Entegratörü Düzenle" disabled>
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="btn btn-danger aksiyon-btn" id="seciliSilBtn" data-button-permission="sil" title="Seçili Entegratörü Sil" disabled>
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Yeni Ekle Butonu -->
                        <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Entegratör Ekle
                        </button>
                    </div>
                </div>

                <!-- Aktif Filtreler -->
                <div class="row mt-3" id="aktifFiltreler" style="display: none;">
                    <div class="col-12">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-light text-dark me-2 p-2">
                                <i class="fas fa-filter me-1"></i>Aktif Filtreler:
                            </span>
                            <div id="filtreEtiketleri" class="d-flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th width="50">#</th>
                                <th>Entegratör Adı</th>
                                <th>Kodu</th>
                                <th>Açıklama</th>
                                <th>Eklenme Tarihi</th>
                                <th>Son Güncelleme</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="entegratorTablosu">
                            @if (ViewBag.Entegratorler != null && ((List<Entegrator>)ViewBag.Entegratorler).Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in (List<Entegrator>)ViewBag.Entegratorler)
                                {
                                    <tr data-entegrator-id="@item.Id"
                                        data-entegrator-adi="@item.Adi"
                                        data-entegrator-kodu="@item.Kodu"
                                        data-entegrator-aciklama="@(item.Aciklama ?? "")"
                                        class="entegrator-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input entegrator-sec-radio" type="radio" name="seciliEntegratorRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td><strong>@item.Adi</strong></td>
                                        <td><span class="badge-entegrator">@item.Kodu</span></td>
                                        <td class="description-cell" title="@item.Aciklama">
                                            @if (!string.IsNullOrEmpty(item.Aciklama))
                                            {
                                                @item.Aciklama
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>@item.EklenmeTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@item.GuncellenmeTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center">
                                        <div class="py-4">
                                            <i class="fas fa-plug fa-3x text-muted mb-3"></i>
                                            <p class="text-muted">Henüz entegratör eklenmemiş.</p>
                                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ekleModal">
                                                İlk Entegratörü Ekle
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminEntegrator", FormMethod.Post, new { id = "ekleForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="ekleModalLabel">Yeni Entegratör Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="Adi" class="form-label">Entegratör Adı *</label>
                        <input type="text" class="form-control" id="Adi" name="Adi"
                               placeholder="Entegratör adını giriniz" required maxlength="100">
                        <div class="form-text">Entegratör adı benzersiz olmalıdır.</div>
                    </div>
                    <div class="mb-3">
                        <label for="Kodu" class="form-label">Entegratör Kodu *</label>
                        <input type="text" class="form-control" id="Kodu" name="Kodu"
                               placeholder="Entegratör kodunu giriniz" required maxlength="50">
                        <div class="form-text">Entegratör kodu benzersiz olmalıdır.</div>
                    </div>
                    <div class="mb-3">
                        <label for="Aciklama" class="form-label">Açıklama</label>
                        <textarea class="form-control" id="Aciklama" name="Aciklama"
                              rows="3" placeholder="Entegratör açıklamasını giriniz"
                              maxlength="500"></textarea>
                        <div class="form-text">Opsiyonel açıklama alanı.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1" aria-labelledby="duzenleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Guncelle", "AdminEntegrator")" method="post" id="duzenleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="duzenleModalLabel">Entegratör Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editAdi" class="form-label">Entegratör Adı *</label>
                        <input type="text" class="form-control" id="editAdi" name="Adi"
                               placeholder="Entegratör adını giriniz" required maxlength="100">
                        <div class="form-text">Entegratör adı benzersiz olmalıdır.</div>
                    </div>
                    <div class="mb-3">
                        <label for="editKodu" class="form-label">Entegratör Kodu *</label>
                        <input type="text" class="form-control" id="editKodu" name="Kodu"
                               placeholder="Entegratör kodunu giriniz" required maxlength="50">
                        <div class="form-text">Entegratör kodu benzersiz olmalıdır.</div>
                    </div>
                    <div class="mb-3">
                        <label for="editAciklama" class="form-label">Açıklama</label>
                        <textarea class="form-control" id="editAciklama" name="Aciklama"
                                  rows="3" placeholder="Entegratör açıklamasını giriniz"
                                  maxlength="500"></textarea>
                        <div class="form-text">Opsiyonel açıklama alanı.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminEntegrator")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="silModalLabel">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silAdi"></span>"</strong> adlı entegratörü silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger">
                        <small>
                            Bu işlem geri alınamaz. Bu entegratörü kullanan kayıtlar varsa sorun yaşayabilirsiniz.
                        </small>
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function() {
                    // ============= ENTEGRATÖR FİLTRELEME SİSTEMİ =============
        let entegratorAktifFiltreler = {
            arama: '',
            kod: '',
            baslangicTarih: null,
            bitisTarih: null,
            siralama: 'yeni'
        };

        // Arama fonksiyonu
        function entegratorAramaFiltrele() {
            const aramaInput = document.getElementById('entegratorArama');
            const temizleBtn = document.getElementById('entegratorAramaTemizle');

            if (aramaInput && temizleBtn) {
                const kelime = aramaInput.value.trim().toLowerCase();

                // Temizle butonunu göster/gizle
                temizleBtn.style.display = kelime ? 'block' : 'none';

                entegratorAktifFiltreler.arama = kelime;
                entegratorFiltreEtiketleriniGoster();
                entegratorFiltreleVeSirala();
            }
        }

        // Arama inputuna event listener ekle
        const aramaInput = document.getElementById('entegratorArama');
        const temizleBtn = document.getElementById('entegratorAramaTemizle');

        if (aramaInput) {
            aramaInput.addEventListener('input', entegratorAramaFiltrele);
            aramaInput.addEventListener('keyup', entegratorAramaFiltrele);
        }

        if (temizleBtn) {
            temizleBtn.addEventListener('click', function () {
                aramaInput.value = '';
                entegratorAramaFiltrele();
                aramaInput.focus();
            });
        }

        // Kod Filtresi Uygula
        window.entegratorKodFiltreUygula = function() {
            const kodInput = document.getElementById('filtreKod');
            entegratorAktifFiltreler.kod = kodInput.value.trim().toLowerCase() || '';

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('kodFiltreBtn'));
            if (dropdown) dropdown.hide();

            entegratorFiltreEtiketleriniGoster();
            entegratorFiltreleVeSirala();
        };

        // Kod Filtresi Temizle
        window.entegratorKodFiltreTemizle = function() {
            document.getElementById('filtreKod').value = '';
            entegratorAktifFiltreler.kod = '';
            entegratorFiltreEtiketleriniGoster();
            entegratorFiltreleVeSirala();
        };

        // Tarih Filtresi Uygula
        window.entegratorTarihFiltreUygula = function() {
            const baslangicInput = document.getElementById('filtreBaslangicTarih');
            const bitisInput = document.getElementById('filtreBitisTarih');

            entegratorAktifFiltreler.baslangicTarih = baslangicInput.value || null;
            entegratorAktifFiltreler.bitisTarih = bitisInput.value || null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('tarihFiltreBtn'));
            if (dropdown) dropdown.hide();

            entegratorFiltreEtiketleriniGoster();
            entegratorFiltreleVeSirala();
        };

        // Tarih Filtresi Temizle
        window.entegratorTarihFiltreTemizle = function() {
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';
            entegratorAktifFiltreler.baslangicTarih = null;
            entegratorAktifFiltreler.bitisTarih = null;
            entegratorFiltreEtiketleriniGoster();
            entegratorFiltreleVeSirala();
        };

        // Sıralama Uygula
        window.entegratorSiralamaUygula = function() {
            const siralama = document.getElementById('siralamaFiltre').value;
            entegratorAktifFiltreler.siralama = siralama;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('siralamaFiltreBtn'));
            if (dropdown) dropdown.hide();

            entegratorFiltreEtiketleriniGoster();
            entegratorFiltreleVeSirala();
        };

        // Tüm Filtreleri Temizle
        window.entegratorTumFiltreleriTemizle = function() {
            // Arama kutusunu temizle
            document.getElementById('entegratorArama').value = '';
            document.getElementById('entegratorAramaTemizle').style.display = 'none';

            // Kod filtresini temizle
            document.getElementById('filtreKod').value = '';

            // Tarih filtrelerini temizle
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';

            // Sıralamayı varsayılana getir
            document.getElementById('siralamaFiltre').value = 'yeni';

            // Buton stillerini sıfırla
            document.getElementById('kodFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('tarihFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('siralamaFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';

            // Filtre değişkenlerini sıfırla
            entegratorAktifFiltreler = {
                arama: '',
                kod: '',
                baslangicTarih: null,
                bitisTarih: null,
                siralama: 'yeni'
            };

            // Filtre etiketlerini gizle
            document.getElementById('aktifFiltreler').style.display = 'none';
            document.getElementById('entegratorFiltreTemizleBtn').style.display = 'none';

            // Filtrelemeyi yeniden uygula
            entegratorFiltreleVeSirala();
        };

        // Filtre etiketlerini göster
        function entegratorFiltreEtiketleriniGoster() {
            const etiketler = [];
            const filtreTemizleBtn = document.getElementById('entegratorFiltreTemizleBtn');

            if (entegratorAktifFiltreler.arama) {
                etiketler.push(`<span class="badge bg-primary">Arama: ${entegratorAktifFiltreler.arama}</span>`);
            }

            if (entegratorAktifFiltreler.kod) {
                etiketler.push(`<span class="badge bg-primary">Kod: ${entegratorAktifFiltreler.kod}</span>`);
            }

            if (entegratorAktifFiltreler.baslangicTarih) {
                etiketler.push(`<span class="badge bg-primary">Başlangıç: ${formatEntegratorDate(entegratorAktifFiltreler.baslangicTarih)}</span>`);
            }
            if (entegratorAktifFiltreler.bitisTarih) {
                etiketler.push(`<span class="badge bg-primary">Bitiş: ${formatEntegratorDate(entegratorAktifFiltreler.bitisTarih)}</span>`);
            }

            if (entegratorAktifFiltreler.siralama !== 'yeni') {
                const siralamaMetin = {
                    'eski': 'En Eski',
                    'adi_az': 'İsim (A-Z)',
                    'adi_za': 'İsim (Z-A)',
                    'kod_az': 'Kod (A-Z)',
                    'kod_za': 'Kod (Z-A)'
                };
                etiketler.push(`<span class="badge bg-info">Sıralama: ${siralamaMetin[entegratorAktifFiltreler.siralama]}</span>`);
            }

            if (etiketler.length > 0) {
                document.getElementById('filtreEtiketleri').innerHTML = etiketler.join(' ');
                document.getElementById('aktifFiltreler').style.display = 'block';
                filtreTemizleBtn.style.display = 'inline-block';

                // Buton stillerini güncelle
                document.getElementById('kodFiltreBtn').className = entegratorAktifFiltreler.kod
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('tarihFiltreBtn').className = entegratorAktifFiltreler.baslangicTarih || entegratorAktifFiltreler.bitisTarih
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';
            } else {
                document.getElementById('aktifFiltreler').style.display = 'none';
                filtreTemizleBtn.style.display = 'none';
            }
        }

        // Tarih formatlama
        function formatEntegratorDate(dateStr) {
            if (!dateStr) return '';
            const [yil, ay, gun] = dateStr.split('-');
            return `${gun}.${ay}.${yil}`;
        }

        // Tarih parse (dd.MM.yyyy HH:mm formatı)
        function entegratorParseDate(dateStr) {
            if (!dateStr) return null;
            const [gun, ay, yilSaat] = dateStr.split('.');
            const [yil, saat] = yilSaat.split(' ');
            return new Date(`${yil}-${ay}-${gun}T${saat}`);
        }

        // Ana filtreleme ve sıralama fonksiyonu
        function entegratorFiltreleVeSirala() {
            const tbody = document.getElementById('entegratorTablosu');
            if (!tbody) return;

            const satirlar = Array.from(tbody.querySelectorAll('tr.entegrator-satiri'));

            if (satirlar.length === 0) return;

            // Filtreleme
            let filtrelenmisSatirlar = satirlar.filter(satir => {
                let goster = true;

                // Arama filtresi (Entegratör Adı - 3. sütun)
                if (entegratorAktifFiltreler.arama) {
                    const adi = satir.querySelector('td:nth-child(3)')?.textContent.toLowerCase() || '';
                    if (!adi.includes(entegratorAktifFiltreler.arama.toLowerCase())) {
                        goster = false;
                    }
                }

                // Kod filtresi (4. sütun)
                if (goster && entegratorAktifFiltreler.kod) {
                    const kod = satir.querySelector('td:nth-child(4)')?.textContent.toLowerCase() || '';
                    if (!kod.includes(entegratorAktifFiltreler.kod)) {
                        goster = false;
                    }
                }

                // Tarih filtresi (6. sütun - Eklenme Tarihi)
                if (goster && (entegratorAktifFiltreler.baslangicTarih || entegratorAktifFiltreler.bitisTarih)) {
                    const tarihTd = satir.querySelector('td:nth-child(6)')?.textContent.trim();
                    if (tarihTd) {
                        const tarih = entegratorParseDate(tarihTd);

                        if (entegratorAktifFiltreler.baslangicTarih) {
                            const filtreBaslangic = new Date(entegratorAktifFiltreler.baslangicTarih + 'T00:00:00');
                            if (tarih < filtreBaslangic) {
                                goster = false;
                            }
                        }

                        if (goster && entegratorAktifFiltreler.bitisTarih) {
                            const filtreBitis = new Date(entegratorAktifFiltreler.bitisTarih + 'T23:59:59');
                            if (tarih > filtreBitis) {
                                goster = false;
                            }
                        }
                    }
                }

                return goster;
            });

            // Sıralama
            switch(entegratorAktifFiltreler.siralama) {
                case 'yeni':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = entegratorParseDate(a.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        const tarihB = entegratorParseDate(b.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        return (tarihB || 0) - (tarihA || 0);
                    });
                    break;

                case 'eski':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = entegratorParseDate(a.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        const tarihB = entegratorParseDate(b.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        return (tarihA || 0) - (tarihB || 0);
                    });
                    break;

                case 'adi_az':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiA.localeCompare(adiB, 'tr');
                    });
                    break;

                case 'adi_za':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiB.localeCompare(adiA, 'tr');
                    });
                    break;

                case 'kod_az':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const kodA = a.querySelector('td:nth-child(4)')?.textContent.trim() || '';
                        const kodB = b.querySelector('td:nth-child(4)')?.textContent.trim() || '';
                        return kodA.localeCompare(kodB, 'tr');
                    });
                    break;

                case 'kod_za':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const kodA = a.querySelector('td:nth-child(4)')?.textContent.trim() || '';
                        const kodB = b.querySelector('td:nth-child(4)')?.textContent.trim() || '';
                        return kodB.localeCompare(kodA, 'tr');
                    });
                    break;
            }

            // Tüm satırları gizle
            satirlar.forEach(satir => {
                satir.style.display = 'none';
            });

            // Filtrelenmiş satırları göster ve tbody'ye yeniden ekle (sıralama için)
            filtrelenmisSatirlar.forEach((satir, index) => {
                satir.style.display = '';
                // Sıra numarasını güncelle (2. sütun)
                const siraHucresi = satir.querySelector('td:nth-child(2)');
                if (siraHucresi) {
                    siraHucresi.textContent = index + 1;
                }
                tbody.appendChild(satir);
            });

            // "Gösterilecek kayıt yok" mesajı
            let bosSatir = tbody.querySelector('.filtre-bos-satir');

            if (filtrelenmisSatirlar.length === 0) {
                if (!bosSatir) {
                    bosSatir = document.createElement('tr');
                    bosSatir.className = 'filtre-bos-satir';
                    bosSatir.innerHTML = '<td colspan="8" class="text-center py-5"><i class="fas fa-filter fa-3x text-muted mb-3"></i><p class="text-muted">Filtreleme kriterlerine uygun entegratör bulunamadı.</p><button class="btn btn-sm btn-outline-secondary" onclick="entegratorTumFiltreleriTemizle()">Filtreleri Temizle</button></td>';
                    tbody.appendChild(bosSatir);
                }
            } else if (bosSatir) {
                bosSatir.remove();
            }
        }

        // Enter tuşu ile filtreleme
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const aktifElement = document.activeElement;
                if (aktifElement.id === 'entegratorArama' ||
                    aktifElement.id === 'filtreKod' ||
                    aktifElement.id === 'filtreBaslangicTarih' ||
                    aktifElement.id === 'filtreBitisTarih') {
                    e.preventDefault();
                    entegratorFiltreleVeSirala();
                }
            }
        });
            let suAnSeciliEntegratorId = null;
            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#entegratorTablosu tr[data-entegrator-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button')) {
                    const $radio = $(this).find('.entegrator-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.entegrator-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliEntegratorId = $(this).val();
                    const $seciliSatir = $(this).closest('tr');
                    const entegratorAdi = $seciliSatir.data('entegrator-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#entegratorTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    $seciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${entegratorAdi}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliEntegratorId) {
                    const $seciliSatir = $(`tr[data-entegrator-id="${suAnSeciliEntegratorId}"]`);
                    const adi = $seciliSatir.data('entegrator-adi');
                    const kodu = $seciliSatir.data('entegrator-kodu');
                    const aciklama = $seciliSatir.data('entegrator-aciklama') || '';

                    duzenleGetir(suAnSeciliEntegratorId, adi, kodu, aciklama);
                } else {
                    toastr.warning('Lütfen önce bir entegratör seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliEntegratorId) {
                    const $seciliSatir = $(`tr[data-entegrator-id="${suAnSeciliEntegratorId}"]`);
                    const entegratorAdi = $seciliSatir.data('entegrator-adi');

                    $('#silId').val(suAnSeciliEntegratorId);
                    $('#silAdi').text(entegratorAdi);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir entegratör seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliEntegratorId) {
                    const $satir = $(`tr[data-entegrator-id="${suAnSeciliEntegratorId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        suAnSeciliEntegratorId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.entegrator-sec-radio[value="${suAnSeciliEntegratorId}"]`).prop('checked', false);
                        $('#entegratorTablosu tr').removeClass('table-active');
                        suAnSeciliEntegratorId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    }
                }
            });

            // ============= MEVCUT FONKSİYONLAR (AYNEN KORUNDU) =============

            // Düzenle modalını aç
            window.duzenleGetir = function(id, adi, kodu, aciklama) {
                $('#editId').val(id);
                $('#editAdi').val(adi);
                $('#editKodu').val(kodu);
                $('#editAciklama').val(aciklama);
                new bootstrap.Modal(document.getElementById('duzenleModal')).show();
            };

            // Silme onayı modalı
            window.silOnay = function(id, adi) {
                $('#silId').val(id);
                $('#silAdi').text(adi);
                new bootstrap.Modal(document.getElementById('silModal')).show();
            };

            // Form validasyonları
            document.addEventListener('DOMContentLoaded', function() {
                // Form submit kontrolleri
                const forms = document.querySelectorAll('form');
                forms.forEach(form => {
                    form.addEventListener('submit', function(e) {
                        const adiInput = this.querySelector('input[name="Adi"]');
                        const koduInput = this.querySelector('input[name="Kodu"]');

                        let isValid = true;

                        if (adiInput && adiInput.value.trim().length === 0) {
                            toastr.error('Entegratör adı gereklidir.');
                            adiInput.focus();
                            isValid = false;
                        }

                        if (koduInput && koduInput.value.trim().length === 0) {
                            toastr.error('Entegratör kodu gereklidir.');
                            koduInput.focus();
                            isValid = false;
                        }

                        if (!isValid) {
                            e.preventDefault();
                        }
                    });
                });

                // Modal kapandığında formları sıfırla
                ['ekleModal', 'duzenleModal'].forEach(modalId => {
                    const modal = document.getElementById(modalId);
                    if (modal) {
                        modal.addEventListener('hidden.bs.modal', function() {
                            const form = this.querySelector('form');
                            if (form) {
                                form.reset();
                            }
                        });
                    }
                });

                // Alert mesajlarını 5 saniye sonra otomatik kapat
                setTimeout(() => {
                    document.querySelectorAll('.alert').forEach(alert => {
                        const bsAlert = new bootstrap.Alert(alert);
                        bsAlert.close();
                    });
                }, 5000);
            });

            // Enter tuşu ile form submit
            document.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    const activeModal = document.querySelector('.modal.show');
                    if (activeModal) {
                        const form = activeModal.querySelector('form');
                        if (form) {
                            const submitButton = form.querySelector('button[type="submit"]');
                            if (submitButton) {
                            if (submitButton) {
                                submitButton.click();
                            }
                        }
                    }
                }
            });
        });
    </script>
}