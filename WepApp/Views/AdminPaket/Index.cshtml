@section Script {
    <script>
        // ============= GLOBAL DEĞİŞKENLER =============
        let suAnSeciliModulId = null;
        let suAnSeciliModulAdi = null;
        let suAnSeciliSabitCarpimVar = false;
        let suAnSeciliSabitCarpimId = 0;
        let suAnSeciliSatir = null;

        // ============= FİLTRELEME DEĞİŞKENLERİ =============
        let modulAktifFiltreler = {
            arama: '',
            lisansTipId: null,
            birimId: null,
            minFiyat: null,
            maxFiyat: null,
            minIndirim: null,
            maxIndirim: null,
            durum: null,
            dahilmi: null,
            minSure: null,
            maxSure: null,
            siralama: 'adi_az'
        };

        // ============= ÜST BUTONLAR =============
        const $seciliOranEkleBtn = $('#oranEkleBtn');
        const $seciliDuzenleBtn = $('#duzenleBtn');
        const $seciliSilBtn = $('#silBtn');
        const $seciliTemizleBtn = $('#secimiTemizleBtn');
        const $seciliBilgiDiv = $('#seciliKayitBilgi');

        // Tablo satırına tıklandığında radio'yu seç
        $(document).on('click', '#paketTable tbody tr[data-id]', function(e) {
            // Eğer tıklanan element radio butonunun kendisi değilse ve buton/badge değilse
            if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button') && !$(e.target).is('span.badge') && !$(e.target).hasClass('status-toggle')) {
                const $radio = $(this).find('.modul-sec-radio');
                $radio.prop('checked', true).trigger('change');
            }
        });

        // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
        $(document).on('change', '.modul-sec-radio', function() {
            if ($(this).is(':checked')) {
                suAnSeciliModulId = $(this).val();
                suAnSeciliSatir = $(this).closest('tr');
                suAnSeciliModulAdi = suAnSeciliSatir.data('adi');
                suAnSeciliSabitCarpimVar = suAnSeciliSatir.data('sabitcarpimvar') === 'true';
                suAnSeciliSabitCarpimId = suAnSeciliSatir.data('sabitcarpimid');

                // Tüm satırlardan active class'ı kaldır
                $('#paketTable tbody tr').removeClass('table-active selected-row');
                // Seçili satıra active class ekle
                suAnSeciliSatir.addClass('table-active selected-row');

                // Bilgiyi güncelle
                $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${suAnSeciliModulAdi}`);

                // Seçimi temizle butonunu göster
                $seciliTemizleBtn.show();

                // Duruma göre butonları güncelle
                updateSeciliButtonStates();
            }
        });

        // Seçili modülün durumuna göre butonları güncelle
        function updateSeciliButtonStates() {
            // Tüm butonları varsayılan olarak aktif et
            $seciliOranEkleBtn.prop('disabled', false);
            $seciliDuzenleBtn.prop('disabled', false);
            $seciliSilBtn.prop('disabled', false);

            // Sabit çarpım varsa oran ekle butonunu devre dışı bırak
            if (suAnSeciliSabitCarpimVar) {
                $seciliOranEkleBtn.prop('disabled', true);
            }
        }

        // Seçimi temizle
        function secimiTemizle() {
            if (suAnSeciliModulId) {
                $(`.modul-sec-radio[value="${suAnSeciliModulId}"]`).prop('checked', false);
                $('#paketTable tbody tr').removeClass('table-active selected-row');
            }

            suAnSeciliModulId = null;
            suAnSeciliModulAdi = null;
            suAnSeciliSabitCarpimVar = false;
            suAnSeciliSabitCarpimId = 0;
            suAnSeciliSatir = null;

            $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
            $seciliTemizleBtn.hide();

            // Tüm butonları devre dışı bırak
            $seciliOranEkleBtn.prop('disabled', true);
            $seciliDuzenleBtn.prop('disabled', true);
            $seciliSilBtn.prop('disabled', true);
        }

        // Seçimi temizle butonuna tıkla
        $seciliTemizleBtn.click(function() {
            secimiTemizle();
        });

        // Üstteki "Oran Ekle" butonu
        $seciliOranEkleBtn.click(function() {
            if (suAnSeciliModulId) {
                if (suAnSeciliSabitCarpimVar) {
                    sabitCarpimUyariGoster(suAnSeciliModulAdi);
                    return;
                }
                fiyatOraniEkle(suAnSeciliModulId);
            } else {
                uyariGoster('Lütfen önce bir modül seçin.');
            }
        });

        // Üstteki "Düzenle" butonu
        $seciliDuzenleBtn.click(function() {
            if (suAnSeciliModulId) {
                duzenleGetir(suAnSeciliModulId);
            } else {
                uyariGoster('Lütfen önce bir modül seçin.');
            }
        });

        // Üstteki "Sil" butonu
        $seciliSilBtn.click(function() {
            if (suAnSeciliModulId) {
                if (suAnSeciliSabitCarpimVar) {
                    sabitCarpimUyariGoster(suAnSeciliModulAdi);
                    return;
                }
                $('#silId').val(suAnSeciliModulId);
                $('#silAdi').text(suAnSeciliModulAdi);
                new bootstrap.Modal('#silModal').show();
            } else {
                uyariGoster('Lütfen önce bir modül seçin.');
            }
        });

        // Silme modalı kapandıktan sonra seçimi temizleme
        $('#silModal').on('hidden.bs.modal', function() {
            if (suAnSeciliModulId) {
                const $satir = $(`tr[data-id="${suAnSeciliModulId}"]`);
                if ($satir.length === 0) {
                    // Satır silinmiş, seçimi temizle
                    secimiTemizle();
                }
            }
        });

        // Sabit çarpım uyarısı göster
        function sabitCarpimUyariGoster(modulAdi) {
            $('#sabitCarpimAdi').text(modulAdi);
            new bootstrap.Modal('#sabitCarpimUyariModal').show();
        }

        // ============= ARAMA VE FİLTRELEME SİSTEMİ =============

        // Arama fonksiyonu
        function modulAramaFiltrele() {
            const aramaInput = document.getElementById('modulArama');
            const temizleBtn = document.getElementById('modulAramaTemizle');

            if (aramaInput && temizleBtn) {
                const kelime = aramaInput.value.trim().toLowerCase();

                // Temizle butonunu göster/gizle
                temizleBtn.style.display = kelime ? 'block' : 'none';

                modulAktifFiltreler.arama = kelime;
                modulFiltreEtiketleriniGoster();
                modulFiltreleVeSirala();
            }
        }

        // Arama inputuna event listener ekle
        const modulAramaInput = document.getElementById('modulArama');
        const modulTemizleBtn = document.getElementById('modulAramaTemizle');

        if (modulAramaInput) {
            modulAramaInput.addEventListener('input', modulAramaFiltrele);
            modulAramaInput.addEventListener('keyup', modulAramaFiltrele);
        }

        if (modulTemizleBtn) {
            modulTemizleBtn.addEventListener('click', function () {
                modulAramaInput.value = '';
