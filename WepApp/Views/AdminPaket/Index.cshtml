        // Filtre etiketlerini göster
        function modulFiltreEtiketleriniGoster() {
            const etiketler = [];
            const filtreTemizleBtn = document.getElementById('modulFiltreTemizleBtn');

            if (modulAktifFiltreler.arama) {
                etiketler.push(`<span class="badge bg-primary">Arama: ${modulAktifFiltreler.arama}</span>`);
            }

            if (modulAktifFiltreler.lisansTipId) {
                const lisansTipAdi = document.getElementById('lisansTipFiltre').options[document.getElementById('lisansTipFiltre').selectedIndex]?.text || 'Seçili';
                etiketler.push(`<span class="badge bg-primary">Lisans: ${lisansTipAdi}</span>`);
            }

            if (modulAktifFiltreler.birimId) {
                const birimAdi = document.getElementById('birimFiltre').options[document.getElementById('birimFiltre').selectedIndex]?.text || 'Seçili';
                etiketler.push(`<span class="badge bg-primary">Birim: ${birimAdi}</span>`);
            }

            if (modulAktifFiltreler.minFiyat !== null && modulAktifFiltreler.maxFiyat !== null) {
                etiketler.push(`<span class="badge bg-success">Fiyat: ${modulAktifFiltreler.minFiyat} ₺ - ${modulAktifFiltreler.maxFiyat} ₺</span>`);
            } else if (modulAktifFiltreler.minFiyat !== null) {
                etiketler.push(`<span class="badge bg-success">Min Fiyat: ${modulAktifFiltreler.minFiyat} ₺</span>`);
            } else if (modulAktifFiltreler.maxFiyat !== null) {
                etiketler.push(`<span class="badge bg-success">Max Fiyat: ${modulAktifFiltreler.maxFiyat} ₺</span>`);
            }

            if (modulAktifFiltreler.minIndirim !== null && modulAktifFiltreler.maxIndirim !== null) {
                etiketler.push(`<span class="badge bg-warning text-dark">İndirim: %${modulAktifFiltreler.minIndirim} - %${modulAktifFiltreler.maxIndirim}</span>`);
            } else if (modulAktifFiltreler.minIndirim !== null) {
                etiketler.push(`<span class="badge bg-warning text-dark">Min İndirim: %${modulAktifFiltreler.minIndirim}</span>`);
            } else if (modulAktifFiltreler.maxIndirim !== null) {
                etiketler.push(`<span class="badge bg-warning text-dark">Max İndirim: %${modulAktifFiltreler.maxIndirim}</span>`);
            }

            if (modulAktifFiltreler.durum !== null) {
                const durumMetin = modulAktifFiltreler.durum === 1 ? 'Aktif' : 'Pasif';
                etiketler.push(`<span class="badge bg-info">Durum: ${durumMetin}</span>`);
            }

            if (modulAktifFiltreler.dahilmi !== null) {
                const dahilMetin = modulAktifFiltreler.dahilmi === true ? 'Evet' : 'Hayır';
                etiketler.push(`<span class="badge bg-secondary">Dahil: ${dahilMetin}</span>`);
            }

            if (modulAktifFiltreler.minSure !== null && modulAktifFiltreler.maxSure !== null) {
                etiketler.push(`<span class="badge bg-info">Süre: ${modulAktifFiltreler.minSure} - ${modulAktifFiltreler.maxSure} gün</span>`);
            } else if (modulAktifFiltreler.minSure !== null) {
                etiketler.push(`<span class="badge bg-info">Min Süre: ${modulAktifFiltreler.minSure} gün</span>`);
            } else if (modulAktifFiltreler.maxSure !== null) {
                etiketler.push(`<span class="badge bg-info">Max Süre: ${modulAktifFiltreler.maxSure} gün</span>`);
            }

            if (modulAktifFiltreler.siralama !== 'adi_az') {
                const siralamaMetin = {
                    'adi_za': 'İsim (Z-A)',
                    'fiyat_azalan': 'Fiyat (Azalan)',
                    'fiyat_artan': 'Fiyat (Artan)',
                    'indirim_azalan': 'İndirim (Azalan)',
                    'indirim_artan': 'İndirim (Artan)',
                    'sure_azalan': 'Süre (Azalan)',
                    'sure_artan': 'Süre (Artan)'
                };
                etiketler.push(`<span class="badge bg-secondary">Sıralama: ${siralamaMetin[modulAktifFiltreler.siralama]}</span>`);
            }

            if (etiketler.length > 0) {
                document.getElementById('filtreEtiketleri').innerHTML = etiketler.join(' ');
                document.getElementById('aktifFiltreler').style.display = 'block';
                filtreTemizleBtn.style.display = 'inline-block';

                // Buton stillerini güncelle
                document.getElementById('lisansTipFiltreBtn').className = modulAktifFiltreler.lisansTipId
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('birimFiltreBtn').className = modulAktifFiltreler.birimId
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('fiyatFiltreBtn').className = modulAktifFiltreler.minFiyat !== null || modulAktifFiltreler.maxFiyat !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('indirimFiltreBtn').className = modulAktifFiltreler.minIndirim !== null || modulAktifFiltreler.maxIndirim !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('durumFiltreBtn').className = modulAktifFiltreler.durum !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('dahilFiltreBtn').className = modulAktifFiltreler.dahilmi !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('sureFiltreBtn').className = modulAktifFiltreler.minSure !== null || modulAktifFiltreler.maxSure !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';
            } else {
                document.getElementById('aktifFiltreler').style.display = 'none';
                filtreTemizleBtn.style.display = 'none';
            }
        }

        // Tarih formatlama (filtreler için gerekli değil ama uyumluluk için)
        function formatModulDate(dateStr) {
            if (!dateStr) return '';
            const [yil, ay, gun] = dateStr.split('-');
            return `${gun}.${ay}.${yil}`;
        }

        // Ana filtreleme ve sıralama fonksiyonu
        function modulFiltreleVeSirala() {
            const tbody = document.getElementById('tableBody');
            if (!tbody) return;

            const satirlar = Array.from(tbody.querySelectorAll('tr[data-id]'));
            const noDataRow = document.getElementById('noDataRow');

            if (satirlar.length === 0) return;

            // Filtreleme
            let filtrelenmisSatirlar = satirlar.filter(satir => {
                let goster = true;
                const $satir = $(satir);

                // Arama filtresi
                if (modulAktifFiltreler.arama) {
                    const searchData = $satir.data('search') || '';
                    const rowText = satir.textContent.toLowerCase();
                    const aramaKelime = modulAktifFiltreler.arama.toLowerCase();

                    if (!searchData.includes(aramaKelime) && !rowText.includes(aramaKelime)) {
                        goster = false;
                    }
                }

                // Lisans Tipi filtresi (5. sütun)
                if (goster && modulAktifFiltreler.lisansTipId) {
                    const lisansTip = satir.querySelector('td:nth-child(5)')?.textContent.trim() || '';
                    const seciliLisansTipAdi = document.getElementById('lisansTipFiltre').options[document.getElementById('lisansTipFiltre').selectedIndex]?.text;

                    if (lisansTip !== seciliLisansTipAdi) {
                        goster = false;
                    }
                }

                // Birim filtresi (6. sütun)
                if (goster && modulAktifFiltreler.birimId) {
                    const birim = satir.querySelector('td:nth-child(6)')?.textContent.trim() || '';
                    const seciliBirimAdi = document.getElementById('birimFiltre').options[document.getElementById('birimFiltre').selectedIndex]?.text;

                    if (birim !== seciliBirimAdi) {
                        goster = false;
                    }
                }

                // Fiyat filtresi (7. sütun)
                if (goster && (modulAktifFiltreler.minFiyat !== null || modulAktifFiltreler.maxFiyat !== null)) {
                    const fiyatTd = satir.querySelector('td:nth-child(7)')?.textContent.trim();
                    if (fiyatTd) {
                        const fiyat = parseFloat(fiyatTd.replace(' ₺', '').replace(',', '.'));

                        if (modulAktifFiltreler.minFiyat !== null && fiyat < modulAktifFiltreler.minFiyat) {
                            goster = false;
                        }

                        if (goster && modulAktifFiltreler.maxFiyat !== null && fiyat > modulAktifFiltreler.maxFiyat) {
                            goster = false;
                        }
                    }
                }

                // İndirim filtresi (8. sütun)
                if (goster && (modulAktifFiltreler.minIndirim !== null || modulAktifFiltreler.maxIndirim !== null)) {
                    const indirimTd = satir.querySelector('td:nth-child(8)')?.textContent.trim();
                    if (indirimTd) {
                        const indirim = parseFloat(indirimTd.replace('%', ''));

                        if (modulAktifFiltreler.minIndirim !== null && indirim < modulAktifFiltreler.minIndirim) {
                            goster = false;
                        }

                        if (goster && modulAktifFiltreler.maxIndirim !== null && indirim > modulAktifFiltreler.maxIndirim) {
                            goster = false;
                        }
                    }
                }

                // Durum filtresi (son sütun - 13. sütun)
                if (goster && modulAktifFiltreler.durum !== null) {
                    const durumSpan = satir.querySelector('td:last-child .badge');
                    if (durumSpan) {
                        const durumText = durumSpan.textContent.trim();
                        const aktif = durumText === 'Aktif' ? 1 : 0;

                        if (aktif !== modulAktifFiltreler.durum) {
                            goster = false;
                        }
                    }
                }

                // Dahil mi filtresi (10. sütun)
                if (goster && modulAktifFiltreler.dahilmi !== null) {
                    const dahilSpan = satir.querySelector('td:nth-child(10) .badge');
                    if (dahilSpan) {
                        const dahilText = dahilSpan.textContent.trim();
                        let dahilmi;

                        if (dahilText.includes('Evet')) dahilmi = true;
                        else if (dahilText.includes('Hayır')) dahilmi = false;
                        else dahilmi = null;

                        if (dahilmi !== modulAktifFiltreler.dahilmi) {
                            goster = false;
                        }
                    }
                }

                // Süre filtresi (11. sütun)
                if (goster && (modulAktifFiltreler.minSure !== null || modulAktifFiltreler.maxSure !== null)) {
                    const sureTd = satir.querySelector('td:nth-child(11)')?.textContent.trim();
                    if (sureTd) {
                        const sure = parseFloat(sureTd.replace(' gün', ''));

                        if (modulAktifFiltreler.minSure !== null && sure < modulAktifFiltreler.minSure) {
                            goster = false;
                        }

                        if (goster && modulAktifFiltreler.maxSure !== null && sure > modulAktifFiltreler.maxSure) {
                            goster = false;
                        }
                    }
                }

                return goster;
            });

            // Sıralama
            switch(modulAktifFiltreler.siralama) {
                case 'adi_az':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiA.localeCompare(adiB, 'tr');
                    });
                    break;

                case 'adi_za':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiB.localeCompare(adiA, 'tr');
                    });
                    break;

                case 'fiyat_azalan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const fiyatA = parseFloat(a.querySelector('td:nth-child(7)')?.textContent.replace(' ₺', '').replace(',', '.')) || 0;
                        const fiyatB = parseFloat(b.querySelector('td:nth-child(7)')?.textContent.replace(' ₺', '').replace(',', '.')) || 0;
                        return fiyatB - fiyatA;
                    });
                    break;

                case 'fiyat_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const fiyatA = parseFloat(a.querySelector('td:nth-child(7)')?.textContent.replace(' ₺', '').replace(',', '.')) || 0;
                        const fiyatB = parseFloat(b.querySelector('td:nth-child(7)')?.textContent.replace(' ₺', '').replace(',', '.')) || 0;
                        return fiyatA - fiyatB;
                    });
                    break;

                case 'indirim_azalan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const indirimA = parseFloat(a.querySelector('td:nth-child(8)')?.textContent.replace('%', '')) || 0;
                        const indirimB = parseFloat(b.querySelector('td:nth-child(8)')?.textContent.replace('%', '')) || 0;
                        return indirimB - indirimA;
                    });
                    break;

                case 'indirim_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const indirimA = parseFloat(a.querySelector('td:nth-child(8)')?.textContent.replace('%', '')) || 0;
                        const indirimB = parseFloat(b.querySelector('td:nth-child(8)')?.textContent.replace('%', '')) || 0;
                        return indirimA - indirimB;
                    });
                    break;

                case 'sure_azalan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const sureA = parseFloat(a.querySelector('td:nth-child(11)')?.textContent.replace(' gün', '')) || 0;
                        const sureB = parseFloat(b.querySelector('td:nth-child(11)')?.textContent.replace(' gün', '')) || 0;
                        return sureB - sureA;
                    });
                    break;

                case 'sure_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const sureA = parseFloat(a.querySelector('td:nth-child(11)')?.textContent.replace(' gün', '')) || 0;
                        const sureB = parseFloat(b.querySelector('td:nth-child(11)')?.textContent.replace(' gün', '')) || 0;
                        return sureA - sureB;
                    });
                    break;
            }

            // Tüm satırları gizle
            satirlar.forEach(satir => {
                satir.style.display = 'none';
            });

            // Filtrelenmiş satırları göster
            filtrelenmisSatirlar.forEach((satir, index) => {
                satir.style.display = '';
                // Sıra numarasını güncelle (2. sütun)
                const siraHucresi = satir.querySelector('td:nth-child(2)');
                if (siraHucresi) {
                    siraHucresi.textContent = index + 1;
                }
            });

            // "Gösterilecek kayıt yok" mesajı
            let bosSatir = tbody.querySelector('.filtre-bos-satir');

            if (filtrelenmisSatirlar.length === 0) {
                if (!bosSatir) {
                    bosSatir = document.createElement('tr');
                    bosSatir.className = 'filtre-bos-satir';
                    bosSatir.innerHTML = '<td colspan="13" class="text-center py-5"><i class="fas fa-filter fa-3x text-muted mb-3"></i><p class="text-muted">Filtreleme kriterlerine uygun modül bulunamadı.</p><button class="btn btn-sm btn-outline-secondary" onclick="modulTumFiltreleriTemizle()">Filtreleri Temizle</button></td>';
                    tbody.appendChild(bosSatir);
                }

                // noDataRow varsa gizle
                if (noDataRow) noDataRow.style.display = 'none';
            } else {
                if (bosSatir) bosSatir.remove();
                if (noDataRow) noDataRow.style.display = 'none';
            }

            // Arama sonuç sayısını güncelle
            const searchResultCount = document.getElementById('searchResultCount');
            if (searchResultCount) {
                if (modulAktifFiltreler.arama) {
                    searchResultCount.textContent = `${filtrelenmisSatirlar.length} sonuç bulundu`;
                } else {
                    searchResultCount.textContent = '';
                }
            }
        }

        // Enter tuşu ile filtreleme
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const aktifElement = document.activeElement;
                if (aktifElement.id === 'modulArama' ||
                    aktifElement.id === 'filtreMinFiyat' ||
                    aktifElement.id === 'filtreMaxFiyat' ||
                    aktifElement.id === 'filtreMinIndirim' ||
                    aktifElement.id === 'filtreMaxIndirim' ||
                    aktifElement.id === 'filtreMinSure' ||
                    aktifElement.id === 'filtreMaxSure') {
                    e.preventDefault();
                    modulFiltreleVeSirala();
                }
            }
        });

        // ============= MODAL İŞLEMLERİ =============

        // Paket düzenle modalını doldur
        function duzenleGetir(id) {
            $.get('/AdminPaket/Getir/' + id, function (data) {
                $('#editId').val(data.id);
                $('#editAdi').val(data.adi);
                $('#editModulKodu').val(data.modulKodu);
                $('#editLisansTipiId').val(data.lisansTipiId);
                $('#editBirimId').val(data.birimId);
                $('#editFiyat').val(data.fiyat);
                $('#editIndOran').val(data.indOran);
                $('#editKDVId').val(data.kdvId);
                $('#editDahilmi').prop('checked', data.dahilmi === true);
                $('#editEgitimSuresi').val(data.egitimSuresi);
                $('#editSira').val(data.sira);
                $('#editAktif').val(data.aktif);
                new bootstrap.Modal('#duzenleModal').show();
            }).fail(function () {
                uyariGoster("Modül bilgileri yüklenirken hata oluştu.");
            });
        }

        // Durum değiştir (Aktif/Pasif)
        function durumGuncelle(id, mevcutDurum, modulAdi) {
            const yeniDurum = mevcutDurum === 1 ? 0 : 1;
            if (confirm(`"${modulAdi}" modülünün durumunu değiştirmek istediğinizden emin misiniz?`)) {
                $.post('/AdminPaket/DurumGuncelle', { Id: id, aktif: yeniDurum }, function (response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        uyariGoster(response.message);
                    }
                }).fail(function () {
                    uyariGoster('İşlem sırasında hata oluştu.');
                });
            }
        }

        // Fiyat Oranı Ekle modalını aç
        function fiyatOraniEkle(paketId) {
            $('#fiyatOraniPaketId').val(paketId);
            $('#hataMesaji').hide().empty();

            // Mevcut oranları kontrol et
            $.get('/AdminPaket/FiyatOranlariGetir?paketId=' + paketId, function (response) {
                let sabitCarpimVar = false;
                let miktarBazliVar = false;

                if (response.success && response.data.length > 0) {
                    sabitCarpimVar = response.data.some(x => x.min == 0 && x.max == 0);
                    miktarBazliVar = response.data.some(x => x.min > 0 && x.max > 0);
                }

                // Temizlik
                $('#oranTipi').prop('disabled', false);
                $('#minMaxGroup').hide();
                $('#fiyatOraniBilgi').hide();
                $('#minDeger').prop('readonly', false).val('');
                $('#maxDeger').val('');
                $('#oranYuzde').val('');

                if (sabitCarpimVar && miktarBazliVar) {
                    $('#hataMesaji').html("Bu modülde hem Sabit Çarpım hem Miktar Bazlı oran bulunamaz. Önce mevcut oranları silin.").show();
                    return;
                }

                if (sabitCarpimVar) {
                    $('#oranTipi').val('false').prop('disabled', true);
                    $('#hataMesaji').html("Bu modülde zaten Sabit Çarpım oranı var. Sadece Sabit Çarpım ekleyebilirsiniz.").show();
                } else if (miktarBazliVar) {
                    $('#oranTipi').val('true').prop('disabled', true);
                    $('#minMaxGroup').show();
                    $('#hataMesaji').html("Bu modülde zaten Miktar Bazlı oranlar tanımlı. Sadece bu şekilde devam edebilirsiniz.").show();

                    // Tüm miktar bazlı oranları al ve boşlukları kontrol et
                    const miktarOranlari = response.data.filter(x => x.min > 0).sort((a, b) => a.min - b.min);
                    if (miktarOranlari.length > 0) {
                        // Boşlukları bul
                        let bosluklar = [];
                        let oncekiMax = 0;

                        for (let i = 0; i < miktarOranlari.length; i++) {
                            const oran = miktarOranlari[i];
                            if (oran.min > oncekiMax + 1) {
                                bosluklar.push({
                                    baslangic: oncekiMax + 1,
                                    bitis: oran.min - 1
                                });
                            }
                            oncekiMax = oran.max;
                        }

                        // Bilgi mesajını güncelle
                        if (bosluklar.length > 0) {
                            const ilkBosluk = bosluklar[0];
                            $('#bilgiIcerik').html(`Mevcut aralıklar arasında boşluklar var. İlk boşluk: <strong>${ilkBosluk.baslangic}-${ilkBosluk.bitis}</strong>`);
                        } else {
                            // Boşluk yoksa, son aralıktan sonra başla
                            const sonOran = miktarOranlari[miktarOranlari.length - 1];
                            $('#bilgiIcerik').html(`Son aralık: <strong>${sonOran.min}-${sonOran.max}</strong> → Yeni aralık <strong>${sonOran.max + 1}</strong>'dan başlamalı.`);
                        }
                        $('#fiyatOraniBilgi').show();
                    }
                } else {
                    $('#oranTipi').prop('disabled', false);
                }

                new bootstrap.Modal('#fiyatOraniModal').show();
            });
        }

        // Oran tipi değiştiğinde min-max göster/gizle
        $('#oranTipi').off('change').on('change', function () {
            const miktarBazli = $(this).val() === 'true';
            if (miktarBazli) {
                $('#minMaxGroup').show();
                $('#hataMesaji').hide().empty();

                const paketId = $('#fiyatOraniPaketId').val();
                $.get('/AdminPaket/FiyatOranlariGetir?paketId=' + paketId, function (response) {
                    if (response.success && response.data.length > 0) {
                        const miktarOranlari = response.data.filter(x => x.min > 0).sort((a, b) => a.min - b.min);

                        if (miktarOranlari.length > 0) {
                            // Boşlukları kontrol et
                            let bosluklar = [];
                            let oncekiMax = 0;

                            for (let i = 0; i < miktarOranlari.length; i++) {
                                const oran = miktarOranlari[i];
                                if (oran.min > oncekiMax + 1) {
                                    bosluklar.push({
                                        baslangic: oncekiMax + 1,
                                        bitis: oran.min - 1
                                    });
                                }
                                oncekiMax = oran.max;
                            }

                            if (bosluklar.length > 0) {
                                const ilkBosluk = bosluklar[0];
                                $('#bilgiIcerik').html(`Mevcut aralıklar arasında boşluklar var. İlk boşluk: <strong>${ilkBosluk.baslangic}-${ilkBosluk.bitis}</strong>`);
                                $('#minDeger').val(ilkBosluk.baslangic).prop('readonly', true);
                                $('#maxDeger').val(ilkBosluk.bitis);
                            } else {
                                const sonOran = miktarOranlari[miktarOranlari.length - 1];
                                $('#bilgiIcerik').html(`Son aralık: <strong>${sonOran.min}-${sonOran.max}</strong> → Yeni aralık <strong>${sonOran.max + 1}</strong>'dan başlamalı.`);
                                $('#minDeger').val(sonOran.max + 1).prop('readonly', true);
                                $('#maxDeger').val('');
                            }
                            $('#fiyatOraniBilgi').show();
                        } else {
                            $('#minDeger').val(1).prop('readonly', false);
                            $('#bilgiIcerik').html('İlk aralığı ekliyorsunuz. Minimum değer 1 olmalıdır.');
                            $('#fiyatOraniBilgi').show();
                        }
                    } else {
                        $('#minDeger').val(1).prop('readonly', false);
                        $('#bilgiIcerik').html('İlk aralığı ekliyorsunuz. Minimum değer 1 olmalıdır.');
                        $('#fiyatOraniBilgi').show();
                    }
                });
            } else {
                $('#minMaxGroup').hide();
                $('#fiyatOraniBilgi').hide();
            }
        });

        // Fiyat oranı ekle formu gönder
        $('#fiyatOraniForm').submit(function (e) {
            e.preventDefault();
            $('#hataMesaji').hide().empty();

            const paketId = $('#fiyatOraniPaketId').val();
            const oranUygula = $('#oranTipi').val() === 'true';
            const oranYuzde = $('#oranYuzde').val();

            if (!oranYuzde || oranYuzde === '') {
                $('#hataMesaji').html('Oran yüzdesi gereklidir.').show();
                return;
            }

            let min = 0, max = 0;
            if (oranUygula) {
                min = $('#minDeger').val();
                max = $('#maxDeger').val();
                if (!min || !max) {
                    $('#hataMesaji').html('Min ve Max değerleri gereklidir.').show();
                    return;
                }
                if (parseInt(min) >= parseInt(max)) {
                    $('#hataMesaji').html('Max değeri Min değerinden büyük olmalıdır.').show();
                    return;
                }
            }

            $.post('/AdminPaket/FiyatOraniEkle', {
                paketId: paketId,
                min: min,
                max: max,
                oranYuzde: oranYuzde,
                oranUygula: oranUygula
            }, function (response) {
                if (response.success) {
                    $('#fiyatOraniModal').modal('hide');
                    uyariGoster(response.message);
                    setTimeout(() => location.reload(), 1500);
                } else {
                    $('#hataMesaji').html(response.message).show();
                }
            }).fail(function () {
                $('#hataMesaji').html('İşlem sırasında hata oluştu.').show();
            });
        });

        // Fiyat oranlarını göster
        function fiyatOranlariGoster(paketId, paketAdi) {
            $('#fiyatOranlariModalTitle').text(paketAdi + ' - Fiyat Oranları');
            $('#fiyatOranlariListesi').html('<div class="text-center py-4"><div class="spinner-border text-primary"></div><p>Yükleniyor...</p></div>');
            new bootstrap.Modal('#fiyatOranlariModal').show();

            $.get('/AdminPaket/FiyatOranlariGetir?paketId=' + paketId, function (response) {
                let html = '';
                if (response.success && response.data.length > 0) {
                    html = `<div class="table-responsive">
                        <table class="table table-bordered table-hover fiyat-oranlari-table">
                            <thead>
                                <tr>
                                    <th>Aralık</th>
                                    <th>Oran</th>
                                    <th>İşlem</th>
                                </tr>
                            </thead>
                            <tbody>`;
                    response.data.forEach(oran => {
                        const aralik = oran.min == 0 && oran.max == 0 ? "Tüm Miktarlar" : `${oran.min} - ${oran.max}`;
                        const tip = oran.min == 0 && oran.max == 0 ? "Sabit Çarpım" : "Miktar Bazlı";
                        html += `<tr>
                            <td>${aralik}</td>
                            <td>%${oran.oranYuzde} (${tip})</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-danger btn-sm" onclick="fiyatOraniSil(${oran.id})">
                                    <i class="fas fa-trash"></i> Sil
                                </button>
                            </td>
                        </tr>`;
                    });
                    html += `</tbody></table></div>`;
                } else {
                    html = `<div class="text-center py-4">
                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Henüz fiyat oranı eklenmemiş.</p>
                    </div>`;
                }
                $('#fiyatOranlariListesi').html(html);
            }).fail(function() {
                $('#fiyatOranlariListesi').html('<div class="alert alert-danger">Fiyat oranları yüklenirken hata oluştu.</div>');
            });
        }

        // Fiyat oranı sil
        function fiyatOraniSil(oranId) {
            if (confirm('Bu fiyat oranını silmek istediğinizden emin misiniz?')) {
                $.post('/AdminPaket/FiyatOraniSil', { id: oranId }, function (response) {
                    if (response.success) {
                        uyariGoster(response.message);
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        uyariGoster(response.message);
                    }
                }).fail(function() {
                    uyariGoster('Silme işlemi sırasında hata oluştu.');
                });
            }
        }

        // Paket sil onayı (eski fonksiyon - butonlardan çağrılıyor)
        function silOnay(id, adi) {
            $('#silId').val(id);
            $('#silAdi').text(adi);
            new bootstrap.Modal('#silModal').show();
        }

        // Uyarı gösterme fonksiyonu
        function uyariGoster(mesaj) {
            $('#uyariMesaji').text(mesaj);
            new bootstrap.Modal('#uyariModal').show();
        }

        // Modal kapandığında temizlik
        $('#fiyatOraniModal').on('hidden.bs.modal', function () {
            $('#oranTipi').prop('disabled', false);
            $('#minMaxGroup').hide();
            $('#fiyatOraniBilgi').hide();
            $('#hataMesaji').hide().empty();
            $('#minDeger').prop('readonly', false).val('');
            $('#maxDeger').val('');
            $('#oranYuzde').val('');
        });

        // ============= SAYFA YÜKLENDİĞİNDE =============
        $(function () {
            // Filtreleme sistemini başlat
            modulFiltreleVeSirala();

            // Alert 5 saniye sonra kapansın
            setTimeout(() => {
                $('.alert').fadeOut();
            }, 5000);

            // Seçimi temizle (başlangıçta)
            secimiTemizle();
        });

        // Enter tuşu ile submit
        $(document).on('keypress', function (e) {
            if (e.which == 13 && $('.modal.show').length) {
                e.preventDefault();
                $('.modal.show button[type="submit"]').click();
            }
        });
    </script>
}