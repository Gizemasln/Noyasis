@functions {
    int FiyatOranAdedi(int paketId)
    {
        var dict = ViewBag.FiyatOranSayilari as System.Collections.Generic.Dictionary<int, int>;
        return dict != null && dict.ContainsKey(paketId) ? dict[paketId] : 0;
    }
}
@using WepApp.Models
@{
    ViewData["Title"] = "Modül Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}
<style>
    /* Filtreleme stilleri - Diğer sayfalarla uyumlu */
    .card-header .flex-wrap {
        gap: 15px;
    }

    .card-header .gap-2 {
        gap: 0.5rem !important;
    }

    .search-box {
        position: relative;
    }

        .search-box .input-group {
            transition: all 0.3s ease;
            width: 200px;
        }

            .search-box .input-group:focus-within {
                width: 250px;
            }

        .search-box .form-control:focus {
            background-color: #fff !important;
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
        }

    #modulAramaTemizle {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        z-index: 5;
        color: #6c757d;
        padding: 0.25rem 0.5rem;
    }

        #modulAramaTemizle:hover {
            color: #dc3545;
        }

    .dropdown-menu {
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        border: none;
    }

        .dropdown-menu .form-control-sm,
        .dropdown-menu .form-select-sm {
            border: 1px solid #dee2e6;
        }

            .dropdown-menu .form-control-sm:focus,
            .dropdown-menu .form-select-sm:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
            }

    #modulFiltreTemizleBtn {
        transition: all 0.3s ease;
    }

        #modulFiltreTemizleBtn:hover {
            transform: scale(1.1);
        }

    /* Aktif filtre butonu stilleri */
    .btn-primary .fas {
        color: white;
    }

    /* Filtre etiketleri */
    #aktifFiltreler {
        background-color: #f8f9fa;
        border-radius: 0.35rem;
        padding: 10px;
        border: 1px solid #e3e6f0;
        margin-top: 15px !important;
    }

        #aktifFiltreler .badge {
            font-size: 0.85rem;
            padding: 0.5rem 0.75rem;
        }

    /* Tablo satırları için geçiş efekti */
    #paketTable tbody tr {
        transition: all 0.3s ease;
    }

        #paketTable tbody tr[style*="display: none"] {
            opacity: 0;
            transform: scale(0.95);
        }

    /* Responsive düzenlemeler */
    media (max-width: 768px) {
        .card-header .d-flex

    {
        flex-direction: column;
        align-items: stretch !important;
    }

    .card-header .gap-2 {
        flex-wrap: wrap;
        justify-content: space-between;
    }

    .search-box {
        width: 100% !important;
        margin-bottom: 5px;
    }

        .search-box .input-group {
            width: 100% !important;
        }

            .search-box .input-group:focus-within {
                width: 100% !important;
            }

    .card-header .dropdown {
        flex: 1;
    }

    .islem-butonlari-alani {
        width: 100%;
        justify-content: space-between;
    }

    #aktifFiltreler .d-flex {
        flex-direction: column;
        align-items: flex-start !important;
        gap: 10px;
    }

    #filtreEtiketleri {
        flex-wrap: wrap;
    }

    }
    .table-actions {
        white-space: nowrap;
        width: 180px;
    }

    .card {
        margin-top: 70px;
    }

    .table th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    .status-toggle {
        cursor: pointer;
    }

    .badge-active {
        background-color: #28a745;
    }

    .badge-inactive {
        background-color: #6c757d;
    }

    .fiyat-oranlari-table {
        font-size: 0.9rem;
    }

        .fiyat-oranlari-table th {
            background-color: #e9ecef;
        }

    /* Arama Stilleri */
    .table-search-container {
        margin-bottom: 20px;
    }

    .search-input-group {
        max-width: 400px;
    }

    .search-info {
        font-size: 0.875rem;
        color: #6c757d;
        margin-top: 5px;
    }

    .no-results {
        text-align: center;
        padding: 40px 20px;
        background-color: #f8f9fa;
        border-radius: 5px;
    }

    .highlight {
        background-color: #fff3cd;
        font-weight: bold;
    }

    /* Seçim ve buton stilleri - Teklif listesiyle aynı */
    .selected-row {
        background-color: #cfe2ff !important;
        border-left: 4px solid #0d6efd !important;
    }

    .table-active {
        background-color: #e7f1ff !important;
    }

    .action-buttons-container {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .action-button {
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .action-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .selection-info {
        font-size: 0.875rem;
        color: #0d6efd;
        background-color: #e7f1ff;
        padding: 5px 10px;
        border-radius: 4px;
        margin-left: 10px;
    }

    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap">
                <h5 class="mb-0">Modül Yönetimi</h5>

                <!-- FİLTRELEME ALANI - Diğer sayfalarla uyumlu -->
                <div class="d-flex align-items-center gap-2">
                    <!-- Arama Kutusu (Mevcut arama kutusu burada kalacak) -->
                    <div class="search-box">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-0">
                                <i class="fas fa-search text-muted"></i>
                            </span>
                            <input type="text" id="modulArama" class="form-control form-control-sm border-0 bg-light"
                                   placeholder="Modül ara..." style="box-shadow: none;">
                            <button class="btn btn-outline-secondary btn-sm" type="button" id="modulAramaTemizle" style="display:none;">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Lisans Tipi Filtresi -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" id="lisansTipFiltreBtn">
                            <i class="fas fa-tag me-1"></i> Lisans Tipi
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 250px;">
                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="lisansTipFiltre">
                                    <option value="">Tüm Lisans Tipleri</option>
                                    @foreach (var tip in ViewBag.LisansTipleri as List<LisansTip>)
                                    {
                                        <option value="@tip.Id">@tip.Adi</option>
                                    }
                                </select>
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-primary" onclick="modulLisansTipFiltreUygula()">Uygula</button>
                            </div>
                        </div>
                    </div>

                    <!-- Birim Filtresi -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" id="birimFiltreBtn">
                            <i class="fas fa-scale-balanced me-1"></i> Birim
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 250px;">
                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="birimFiltre">
                                    <option value="">Tüm Birimler</option>
                                    @foreach (var birim in ViewBag.Birimler as List<Birim>)
                                    {
                                        <option value="@birim.Id">@birim.Adi</option>
                                    }
                                </select>
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-primary" onclick="modulBirimFiltreUygula()">Uygula</button>
                            </div>
                        </div>
                    </div>

                    <!-- Fiyat Filtresi -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" id="fiyatFiltreBtn">
                            <i class="fas fa-lira-sign me-1"></i> Fiyat
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 250px;">
                            <div class="mb-2">
                                <label class="form-label small">Min Fiyat (₺)</label>
                                <input type="number" id="filtreMinFiyat" class="form-control form-control-sm" min="0" step="0.01">
                            </div>
                            <div class="mb-2">
                                <label class="form-label small">Max Fiyat (₺)</label>
                                <input type="number" id="filtreMaxFiyat" class="form-control form-control-sm" min="0" step="0.01">
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-outline-secondary" onclick="modulFiyatFiltreTemizle()">Temizle</button>
                                <button class="btn btn-sm btn-primary" onclick="modulFiyatFiltreUygula()">Uygula</button>
                            </div>
                        </div>
                    </div>

                    <!-- İndirim Filtresi -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" id="indirimFiltreBtn">
                            <i class="fas fa-percent me-1"></i> İndirim
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 250px;">
                            <div class="mb-2">
                                <label class="form-label small">Min İndirim (%)</label>
                                <input type="number" id="filtreMinIndirim" class="form-control form-control-sm" min="0" max="100">
                            </div>
                            <div class="mb-2">
                                <label class="form-label small">Max İndirim (%)</label>
                                <input type="number" id="filtreMaxIndirim" class="form-control form-control-sm" min="0" max="100">
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-outline-secondary" onclick="modulIndirimFiltreTemizle()">Temizle</button>
                                <button class="btn btn-sm btn-primary" onclick="modulIndirimFiltreUygula()">Uygula</button>
                            </div>
                        </div>
                    </div>

                    <!-- Durum Filtresi -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" id="durumFiltreBtn">
                            <i class="fas fa-toggle-on me-1"></i> Durum
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 200px;">
                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="durumFiltre">
                                    <option value="">Tümü</option>
                                    <option value="1">Aktif</option>
                                    <option value="0">Pasif</option>
                                </select>
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-primary" onclick="modulDurumFiltreUygula()">Uygula</button>
                            </div>
                        </div>
                    </div>

                    <!-- Dahil mi Filtresi -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" id="dahilFiltreBtn">
                            <i class="fas fa-check-circle me-1"></i> Dahil mi?
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 200px;">
                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="dahilFiltre">
                                    <option value="">Tümü</option>
                                    <option value="true">Evet</option>
                                    <option value="false">Hayır</option>
                                    <option value="null">Belirtilmemiş</option>
                                </select>
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-primary" onclick="modulDahilFiltreUygula()">Uygula</button>
                            </div>
                        </div>
                    </div>

                    <!-- Süre Filtresi -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" id="sureFiltreBtn">
                            <i class="fas fa-clock me-1"></i> Süre
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 250px;">
                            <div class="mb-2">
                                <label class="form-label small">Min Süre (gün)</label>
                                <input type="number" id="filtreMinSure" class="form-control form-control-sm" min="0" step="0.1">
                            </div>
                            <div class="mb-2">
                                <label class="form-label small">Max Süre (gün)</label>
                                <input type="number" id="filtreMaxSure" class="form-control form-control-sm" min="0" step="0.1">
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-outline-secondary" onclick="modulSureFiltreTemizle()">Temizle</button>
                                <button class="btn btn-sm btn-primary" onclick="modulSureFiltreUygula()">Uygula</button>
                            </div>
                        </div>
                    </div>

                    <!-- Sıralama -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false" id="siralamaFiltreBtn">
                            <i class="fas fa-sort-amount-down me-1"></i> Sıralama
                        </button>
                        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 200px;">
                            <div class="mb-2">
                                <select class="form-select form-select-sm" id="siralamaFiltre">
                                    <option value="adi_az">İsim (A-Z)</option>
                                    <option value="adi_za">İsim (Z-A)</option>
                                    <option value="fiyat_azalan">Fiyat (Azalan)</option>
                                    <option value="fiyat_artan">Fiyat (Artan)</option>
                                    <option value="indirim_azalan">İndirim (Azalan)</option>
                                    <option value="indirim_artan">İndirim (Artan)</option>
                                    <option value="sure_azalan">Süre (Azalan)</option>
                                    <option value="sure_artan">Süre (Artan)</option>
                                </select>
                            </div>
                            <div class="d-flex gap-2 justify-content-end">
                                <button class="btn btn-sm btn-primary" onclick="modulSiralamaUygula()">Uygula</button>
                            </div>
                        </div>
                    </div>

                    <!-- Filtre Temizleme Butonu -->
                    <button class="btn btn-sm btn-outline-danger" onclick="modulTumFiltreleriTemizle()"
                            title="Tüm filtreleri temizle" id="modulFiltreTemizleBtn" style="display: none;">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <!-- Seçili Kayıt Bilgisi ve İşlem Butonları (mevcut kod) -->
                <div class="d-flex align-items-center gap-3">
                    <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                        <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                            <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <!-- Oran Ekle (Açık Mavi - teklifteki PDF gibi) -->
                            <button type="button" class="btn btn-secondary aksiyon-btn btn-icon" id="oranEkleBtn" disabled title="Oran Ekle" data-button-permission="oranekle">
                                <i class="fas fa-percentage"></i>
                            </button>
                            <!-- Düzenle (Sarı - teklifteki Revize gibi) -->
                            <button type="button" class="btn btn-warning btn-sm" id="duzenleBtn" disabled title="Düzenle" data-button-permission="duzenle">
                                <i class="fas fa-edit"></i>
                            </button>
                            <!-- Sil (Kırmızı - teklifteki Sil gibi) -->
                            <button type="button" class="btn btn-danger btn-sm" id="silBtn" disabled title=" Sil" data-button-permission="sil">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                    <!-- Yeni Ekle (Yeşil - tıpkı teklifteki Yeni Teklif Oluştur gibi) -->
                    <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal" title="Yeni Modül Ekle">
                        <i class="fas fa-plus"></i> Yeni Modül Ekle
                    </button>
                </div>
            </div>

            <!-- Aktif Filtreler -->
            <div class="row mt-3" id="aktifFiltreler" style="display: none;">
                <div class="col-12">
                    <div class="d-flex align-items-center">
                        <span class="badge bg-light text-dark me-2 p-2">
                            <i class="fas fa-filter me-1"></i>Aktif Filtreler:
                        </span>
                        <div id="filtreEtiketleri" class="d-flex flex-wrap gap-2"></div>
                    </div>
                </div>
            </div>            <div class="card-body">
                <!-- Arama Bilgisi -->
                <div class="search-info mb-3">
                    <span id="searchResultCount"></span>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="paketTable">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th width="50">#</th>
                                <th>Adı</th>
                                <th>Kodu</th>
                                <th>L. Tipi</th>
                                <th>Birim</th>
                                <th>List.F.</th>
                                <th>İnd. Oranı</th>
                                <th>KDV</th>
                                <th>Dahil mi?</th>  <!-- Yeni sütun -->

                                <th>E. Süresi</th>
                                <th>F. Oran.</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody id="tableBody">
                            @if (ViewBag.Paketler != null && ((List<Paket>)ViewBag.Paketler).Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in (List<Paket>)ViewBag.Paketler)
                                {
                                    <tr data-id="@item.Id"
                                        data-adi="@item.Adi"
                                        data-search="@(item.Adi?.ToLower()) @(item.ModulKodu?.ToLower()) @(item.LisansTip?.Adi?.ToLower()) @(item.Birim?.Adi?.ToLower()) @item.Fiyat @item.IndOran @(item.KDV?.Oran) @item.EgitimSuresi @(item.Aktif == 1 ? "aktif" : "pasif")"
                                        data-sabitcarpimvar="@(ViewBag.SabitCarpimVarMi != null && ((Dictionary<int, bool>)ViewBag.SabitCarpimVarMi).ContainsKey(item.Id) ? ((Dictionary<int, bool>)ViewBag.SabitCarpimVarMi)[item.Id].ToString().ToLower() : "false")"
                                        data-sabitcarpimid="@(ViewBag.SabitCarpimIdleri != null && ((Dictionary<int, int>)ViewBag.SabitCarpimIdleri).ContainsKey(item.Id) ? ((Dictionary<int, int>)ViewBag.SabitCarpimIdleri)[item.Id] : 0)">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input modul-sec-radio" type="radio" name="seciliModulRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td><strong>@item.Adi</strong></td>
                                        <td>@(item.ModulKodu ?? "-")</td>
                                        <td>@(item.LisansTip?.Adi ?? "-")</td>
                                        <td>@(item.Birim?.Adi ?? "-")</td>
                                        <td>@item.Fiyat.ToString() ₺</td>
                                        <td>%@item.IndOran</td>
                                        <td>
                                            @if (item.KDV != null)
                                            {
                                                @:%@item.KDV.Oran
                                            }
                                            else
                                            {
                                                @:-
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (item.Dahilmi == true)
                                            {
                                                <span class="badge bg-success"><i class="fas fa-check"></i> Evet</span>
                                            }
                                            else if (item.Dahilmi == false)
                                            {
                                                <span class="badge bg-secondary"><i class="fas fa-times"></i> Hayır</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Belirtilmemiş</span>
                                            }
                                        </td>
                                        <td>@item.EgitimSuresi gün</td>
                                        <td class="text-center">
                                            @{
                                                var dict = ViewBag.FiyatOranSayilari as System.Collections.Generic.Dictionary<int, int>;
                                                var adet = dict != null && dict.TryGetValue(item.Id, out int count) ? count : 0;
                                                var sabitCarpimVarMi = ViewBag.SabitCarpimVarMi as Dictionary<int, bool>;
                                                var sabitCarpimVar = sabitCarpimVarMi != null && sabitCarpimVarMi.ContainsKey(item.Id) ? sabitCarpimVarMi[item.Id] : false;
                                            }

                                            @if (adet > 0)
                                            {
                                                <button type="button" class="btn btn-outline-info btn-sm" data-button-permission="oranlarigor"
                                                        onclick="fiyatOranlariGoster(@item.Id, '@item.Adi')">
                                                    <i class="fas fa-list"></i> Oranları Gör
                                                    @if (sabitCarpimVar)
                                                    {
                                                        <span class="badge bg-warning ms-1" title="Sabit Çarpım Oranı Var">
                                                            <i class="fas fa-exclamation-circle"></i> Sabit
                                                        </span>
                                                    }
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-danger fw-bold">
                                                    <i class="fas fa-times-circle"></i> Oran Yok
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @(item.Aktif == 1 ? "bg-success" : "bg-secondary") status-toggle"
                                                  onclick="durumGuncelle(@item.Id, @item.Aktif, '@item.Adi')">
                                                @(item.Aktif == 1 ? "Aktif" : "Pasif")
                                            </span>
                                        </td>
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr id="noDataRow">
                                    <td colspan="12" class="text-center">
                                        <div class="py-4">
                                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                            <p class="text-muted">Henüz modül eklenmemiş.</p>
                                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-button-permission="ekle"
                                                    data-bs-target="#ekleModal">
                                                İlk Modülü Ekle
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

