                        <div class="col-md-6 mb-3">
                            <div class="form-check" style="margin-top: 2rem;">
                                <input class="form-check-input" type="checkbox" id="editYayindaMi" name="YayindaMi" value="true">
                                <label class="form-check-label" for="editYayindaMi">
                                    Duyuru Yayında Olsun
                                </label>
