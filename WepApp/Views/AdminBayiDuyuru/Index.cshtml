</div>

@section Script {
    <script>
        let silinecekGorselId = null;
        let seciliDuyuruId = 0;
        let seciliDuyuruBaslik = '';

        // Görsel önizleme fonksiyonu
        function previewImage(input, previewId) {
            const preview = document.getElementById(previewId);
            preview.innerHTML = '';

            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'modal-gorsel-preview';
                    img.alt = 'Görsel önizleme';
                    preview.appendChild(img);
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        // Görsel büyütme fonksiyonu
        function gorselGoster(gorselYolu) {
            document.getElementById('modalGorsel').src = gorselYolu;
            var gorselModal = new bootstrap.Modal(document.getElementById('gorselModal'));
            gorselModal.show();
        }

        // Seçili duyuru sayısını güncelle
        function seciliDuyuruSayisiniGuncelle() {
            const tumCheckboxlar = document.querySelectorAll('.duyuru-sec-checkbox');
            const seciliCheckboxlar = document.querySelectorAll('.duyuru-sec-checkbox:checked');
            const sayi = seciliCheckboxlar.length;
            const gosterge = document.getElementById('seciliDuyuruGosterge');
            const metinSpan = document.getElementById('seciliDuyuruMetin');

            // Eğer birden fazla seçiliyse → sadece son seçileni bırak (tek seçim zorla)
            if (sayi > 1) {
                const sonSecili = seciliCheckboxlar[seciliCheckboxlar.length - 1];
                tumCheckboxlar.forEach(cb => {
                    if (cb !== sonSecili) cb.checked = false;
                });
                return seciliDuyuruSayisiniGuncelle();
            }

            if (sayi === 0) {
                gosterge.classList.add('d-none');
                metinSpan.textContent = '';

                // Butonları devre dışı bırak
                document.getElementById('topluDuyuruDuzenleBtn').disabled = true;
                document.getElementById('topluDuyuruSilBtn').disabled = true;

                seciliDuyuruId = 0;
                seciliDuyuruBaslik = '';
            }
            else if (sayi === 1) {
                // Tek duyuru seçili
                const seciliTr = seciliCheckboxlar[0].closest('tr');
                const baslikTd = seciliTr.querySelector('td:nth-child(4)'); // Başlık sütunu (4. td)
                let baslik = baslikTd ? baslikTd.textContent.trim() : 'Duyuru';

                // Çok uzunsa kısalt
                if (baslik.length > 30) {
                    baslik = baslik.substring(0, 27) + '...';
                }

                seciliDuyuruId = seciliCheckboxlar[0].value;
                seciliDuyuruBaslik = baslik;

                metinSpan.textContent = `"${baslik}" seçili`;
                gosterge.classList.remove('d-none');

                // Butonları aktif et
                document.getElementById('topluDuyuruDuzenleBtn').disabled = false;
                document.getElementById('topluDuyuruSilBtn').disabled = false;
            }
        }
                // ============= DUYURU FİLTRELEME SİSTEMİ (Sözleşmeler/Kampanya sayfalarından uyarlandı) =============
        let duyuruAktifFiltreler = {
            arama: '',
            baslangicTarih: null,
            bitisTarih: null,
            oncelik: null,
            yayinDurum: null,
            siralama: 'yeni'
        };

        // Duyuru arama fonksiyonu
        document.addEventListener('DOMContentLoaded', function () {
            const aramaInput = document.getElementById('duyuruArama');
            const temizleBtn = document.getElementById('duyuruAramaTemizle');

            if (aramaInput && temizleBtn) {
                function duyuruAramaFiltrele() {
                    const kelime = aramaInput.value.trim().toLowerCase();

                    // Temizle butonunu göster/gizle
                    temizleBtn.style.display = kelime ? 'block' : 'none';

                    duyuruAktifFiltreler.arama = kelime;
                    duyuruFiltreEtiketleriniGoster();
                    duyuruFiltreleVeSirala();
                }

                aramaInput.addEventListener('input', duyuruAramaFiltrele);
                aramaInput.addEventListener('keyup', duyuruAramaFiltrele);

                temizleBtn.addEventListener('click', function () {
                    aramaInput.value = '';
                    duyuruAramaFiltrele();
                    aramaInput.focus();
                });
            }
        });

        // Tarih Filtresi Uygula
        function duyuruTarihFiltreUygula() {
            const baslangicInput = document.getElementById('filtreBaslangicTarih');
            const bitisInput = document.getElementById('filtreBitisTarih');

            duyuruAktifFiltreler.baslangicTarih = baslangicInput.value || null;
            duyuruAktifFiltreler.bitisTarih = bitisInput.value || null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('tarihFiltreBtn'));
            if (dropdown) dropdown.hide();

            duyuruFiltreEtiketleriniGoster();
            duyuruFiltreleVeSirala();
        }

        // Tarih Filtresi Temizle
        function duyuruTarihFiltreTemizle() {
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';
            duyuruAktifFiltreler.baslangicTarih = null;
            duyuruAktifFiltreler.bitisTarih = null;
            duyuruFiltreEtiketleriniGoster();
            duyuruFiltreleVeSirala();
        }

        // Öncelik Filtresi Uygula
        function duyuruOncelikFiltreUygula() {
            const oncelik = document.getElementById('oncelikFiltre').value;
            duyuruAktifFiltreler.oncelik = oncelik !== '' ? parseInt(oncelik) : null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('oncelikFiltreBtn'));
            if (dropdown) dropdown.hide();

            duyuruFiltreEtiketleriniGoster();
            duyuruFiltreleVeSirala();
        }

        // Yayın Durumu Filtresi Uygula
        function duyuruYayinDurumFiltreUygula() {
            const yayinDurum = document.getElementById('yayinDurumFiltre').value;
            duyuruAktifFiltreler.yayinDurum = yayinDurum !== '' ? parseInt(yayinDurum) : null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('yayinDurumFiltreBtn'));
            if (dropdown) dropdown.hide();

            duyuruFiltreEtiketleriniGoster();
            duyuruFiltreleVeSirala();
        }

        // Sıralama Uygula
        function duyuruSiralamaUygula() {
            const siralama = document.getElementById('siralamaFiltre').value;
            duyuruAktifFiltreler.siralama = siralama;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('siralamaFiltreBtn'));
            if (dropdown) dropdown.hide();

            duyuruFiltreEtiketleriniGoster();
            duyuruFiltreleVeSirala();
        }

        // Tüm Filtreleri Temizle
        function duyuruTumFiltreleriTemizle() {
            // Arama kutusunu temizle
            document.getElementById('duyuruArama').value = '';
            document.getElementById('duyuruAramaTemizle').style.display = 'none';

            // Tarih filtrelerini temizle
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';

            // Öncelik filtresini temizle
            document.getElementById('oncelikFiltre').value = '';

            // Yayın durumu filtresini temizle
            document.getElementById('yayinDurumFiltre').value = '';

            // Sıralamayı varsayılana getir
            document.getElementById('siralamaFiltre').value = 'yeni';

            // Buton stillerini sıfırla
            document.getElementById('tarihFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('oncelikFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('yayinDurumFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('siralamaFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';

            // Filtre değişkenlerini sıfırla
            duyuruAktifFiltreler = {
                arama: '',
                baslangicTarih: null,
                bitisTarih: null,
                oncelik: null,
                yayinDurum: null,
                siralama: 'yeni'
            };

            // Filtre etiketlerini gizle
            document.getElementById('aktifFiltreler').style.display = 'none';
            document.getElementById('duyuruFiltreTemizleBtn').style.display = 'none';

            // Filtrelemeyi yeniden uygula
            duyuruFiltreleVeSirala();
        }

        // Filtre etiketlerini göster
        function duyuruFiltreEtiketleriniGoster() {
            const etiketler = [];
            const filtreTemizleBtn = document.getElementById('duyuruFiltreTemizleBtn');

            if (duyuruAktifFiltreler.arama) {
                etiketler.push(`<span class="badge bg-primary">Arama: ${duyuruAktifFiltreler.arama}</span>`);
            }

            if (duyuruAktifFiltreler.baslangicTarih) {
                etiketler.push(`<span class="badge bg-primary">Başlangıç: ${formatDuyuruDate(duyuruAktifFiltreler.baslangicTarih)}</span>`);
            }
            if (duyuruAktifFiltreler.bitisTarih) {
                etiketler.push(`<span class="badge bg-primary">Bitiş: ${formatDuyuruDate(duyuruAktifFiltreler.bitisTarih)}</span>`);
            }

            if (duyuruAktifFiltreler.oncelik !== null) {
                const oncelikMetin = duyuruAktifFiltreler.oncelik === 1 ? 'Yüksek' : 'Normal';
                etiketler.push(`<span class="badge bg-warning text-dark">Öncelik: ${oncelikMetin}</span>`);
            }

            if (duyuruAktifFiltreler.yayinDurum !== null) {
                const yayinMetin = duyuruAktifFiltreler.yayinDurum === 1 ? 'Yayında' : 'Yayında Değil';
                etiketler.push(`<span class="badge bg-success">Yayın: ${yayinMetin}</span>`);
            }

            if (duyuruAktifFiltreler.siralama !== 'yeni') {
                const siralamaMetin = {
                    'eski': 'En Eski',
                    'baslik': 'Başlık (A-Z)',
                    'oncelik_yuksek': 'Öncelik (Yüksek → Normal)',
                    'oncelik_dusuk': 'Öncelik (Normal → Yüksek)',
                    'yayin_durum': 'Yayın Durumu'
                };
                etiketler.push(`<span class="badge bg-info">Sıralama: ${siralamaMetin[duyuruAktifFiltreler.siralama]}</span>`);
            }

            if (etiketler.length > 0) {
                document.getElementById('filtreEtiketleri').innerHTML = etiketler.join(' ');
                document.getElementById('aktifFiltreler').style.display = 'block';
                filtreTemizleBtn.style.display = 'inline-block';

                // Buton stillerini güncelle
                document.getElementById('tarihFiltreBtn').className = duyuruAktifFiltreler.baslangicTarih || duyuruAktifFiltreler.bitisTarih
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('oncelikFiltreBtn').className = duyuruAktifFiltreler.oncelik !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('yayinDurumFiltreBtn').className = duyuruAktifFiltreler.yayinDurum !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';
            } else {
                document.getElementById('aktifFiltreler').style.display = 'none';
                filtreTemizleBtn.style.display = 'none';
            }
        }

        // Tarih formatlama
        function formatDuyuruDate(dateStr) {
            if (!dateStr) return '';
            const [yil, ay, gun] = dateStr.split('-');
            return `${gun}.${ay}.${yil}`;
        }

        // Duyuru tarih parse (dd.MM.yyyy HH:mm formatı)
        function duyuruParseDate(dateStr) {
            if (!dateStr) return null;
            const [gun, ay, yilSaat] = dateStr.split('.');
            const [yil, saat] = yilSaat.split(' ');
            return new Date(`${yil}-${ay}-${gun}T${saat}`);
        }

        // Ana filtreleme ve sıralama fonksiyonu
        function duyuruFiltreleVeSirala() {
            const tablo = document.getElementById('duyuruTablosu');
            if (!tablo) return;

            const tbody = tablo.querySelector('tbody');
            if (!tbody) return;

            const satirlar = Array.from(tbody.querySelectorAll('tr.duyuru-satiri'));

            if (satirlar.length === 0) return;

            // Filtreleme
            let filtrelenmisSatirlar = satirlar.filter(satir => {
                let goster = true;

                // Arama filtresi (Başlık - 4. sütun)
                if (duyuruAktifFiltreler.arama) {
                    const baslik = satir.querySelector('td:nth-child(4)')?.textContent.toLowerCase() || '';
                    if (!baslik.includes(duyuruAktifFiltreler.arama.toLowerCase())) {
                        goster = false;
                    }
                }

                // Tarih filtresi (6. sütun - Eklenme Tarihi)
                if (goster && (duyuruAktifFiltreler.baslangicTarih || duyuruAktifFiltreler.bitisTarih)) {
                    const tarihTd = satir.querySelector('td:nth-child(6)')?.textContent.trim();
                    if (tarihTd) {
                        const tarih = duyuruParseDate(tarihTd);

                        if (duyuruAktifFiltreler.baslangicTarih) {
                            const filtreBaslangic = new Date(duyuruAktifFiltreler.baslangicTarih + 'T00:00:00');
                            if (tarih < filtreBaslangic) {
                                goster = false;
                            }
                        }

                        if (goster && duyuruAktifFiltreler.bitisTarih) {
                            const filtreBitis = new Date(duyuruAktifFiltreler.bitisTarih + 'T23:59:59');
                            if (tarih > filtreBitis) {
                                goster = false;
                            }
                        }
                    }
                }

                // Öncelik filtresi (7. sütun)
                if (goster && duyuruAktifFiltreler.oncelik !== null) {
                    const oncelikSpan = satir.querySelector('td:nth-child(7) .badge.bg-warning');
                    const yuksekOncelik = oncelikSpan !== null;

                    if (duyuruAktifFiltreler.oncelik === 1 && !yuksekOncelik) {
                        goster = false;
                    } else if (duyuruAktifFiltreler.oncelik === 0 && yuksekOncelik) {
                        goster = false;
                    }
                }

                // Yayın durumu filtresi (8. sütun)
                if (goster && duyuruAktifFiltreler.yayinDurum !== null) {
                    const yayinSpan = satir.querySelector('td:nth-child(8) .badge');
                    const yayinda = yayinSpan?.classList.contains('bg-success') || false;

                    if (duyuruAktifFiltreler.yayinDurum === 1 && !yayinda) {
                        goster = false;
                    } else if (duyuruAktifFiltreler.yayinDurum === 0 && yayinda) {
                        goster = false;
                    }
                }

                return goster;
            });

            // Sıralama
            switch(duyuruAktifFiltreler.siralama) {
                case 'yeni':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = duyuruParseDate(a.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        const tarihB = duyuruParseDate(b.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        return (tarihB || 0) - (tarihA || 0);
                    });
                    break;

                case 'eski':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = duyuruParseDate(a.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        const tarihB = duyuruParseDate(b.querySelector('td:nth-child(6)')?.textContent.trim() || '');
                        return (tarihA || 0) - (tarihB || 0);
                    });
                    break;

                case 'baslik':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const baslikA = a.querySelector('td:nth-child(4)')?.textContent.trim() || '';
                        const baslikB = b.querySelector('td:nth-child(4)')?.textContent.trim() || '';
                        return baslikA.localeCompare(baslikB, 'tr');
                    });
                    break;

                case 'oncelik_yuksek':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const oncelikA = a.querySelector('td:nth-child(7) .badge.bg-warning') ? 1 : 0;
                        const oncelikB = b.querySelector('td:nth-child(7) .badge.bg-warning') ? 1 : 0;
                        return oncelikB - oncelikA;
                    });
                    break;

                case 'oncelik_dusuk':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const oncelikA = a.querySelector('td:nth-child(7) .badge.bg-warning') ? 1 : 0;
                        const oncelikB = b.querySelector('td:nth-child(7) .badge.bg-warning') ? 1 : 0;
                        return oncelikA - oncelikB;
                    });
                    break;

                case 'yayin_durum':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const yayinA = a.querySelector('td:nth-child(8) .badge.bg-success') ? 1 : 0;
                        const yayinB = b.querySelector('td:nth-child(8) .badge.bg-success') ? 1 : 0;
                        return yayinB - yayinA;
                    });
                    break;
            }

            // Tüm satırları gizle
            satirlar.forEach(satir => {
                satir.style.display = 'none';
            });

            // Filtrelenmiş satırları göster ve tbody'ye yeniden ekle (sıralama için)
            filtrelenmisSatirlar.forEach((satir, index) => {
                satir.style.display = '';
                // Sıra numarasını güncelle
                const siraHucresi = satir.querySelector('td:first-child');
                if (siraHucresi) {
                    siraHucresi.textContent = index + 1;
                }
                tbody.appendChild(satir);
            });

            // "Gösterilecek kayıt yok" mesajı
            let bosSatir = tbody.querySelector('.filtre-bos-satir');

            if (filtrelenmisSatirlar.length === 0) {
                if (!bosSatir) {
                    bosSatir = document.createElement('tr');
                    bosSatir.className = 'filtre-bos-satir';
                    bosSatir.innerHTML = '<td colspan="9" class="text-center py-5"><i class="fas fa-filter fa-3x text-muted mb-3"></i><p class="text-muted">Filtreleme kriterlerine uygun duyuru bulunamadı.</p><button class="btn btn-sm btn-outline-secondary" onclick="duyuruTumFiltreleriTemizle()">Filtreleri Temizle</button></td>';
                    tbody.appendChild(bosSatir);
                }
            } else if (bosSatir) {
                bosSatir.remove();
            }
        }

        // Enter tuşu ile filtreleme
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const aktifElement = document.activeElement;
                if (aktifElement.id === 'duyuruArama' ||
                    aktifElement.id === 'filtreBaslangicTarih' ||
                    aktifElement.id === 'filtreBitisTarih') {
                    e.preventDefault();
                    duyuruFiltreleVeSirala();
                }
            }
        });

        // Dropdown'lar dışında bir yere tıklandığında kapanma sorununu çöz
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.dropdown')) {
                // Dropdown dışı tıklamalarda bir şey yapma
            }
        });
        // Seçili duyuru için işlem yap
        function seciliDuyuruIslem(tip) {
            const secili = document.querySelector('.duyuru-sec-checkbox:checked');
            if (!secili) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Uyarı',
                    text: 'Lütfen önce bir duyuru seçin!'
                });
                return;
            }

            const duyuruId = secili.value;

            switch(tip) {
                case 'duzenle':
                    duzenleGetir(duyuruId);
                    break;
                case 'sil':
                    silOnay(duyuruId, seciliDuyuruBaslik);
                    break;
            }
        }

        function duzenleGetir(id) {
            fetch('@Url.Action("Getir", "AdminBayiDuyuru")' + '?id=' + id)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    document.getElementById('editId').value = data.id;
                    document.getElementById('editBaslik').value = data.baslik || '';
                    document.getElementById('editIcerik').value = data.icerik || '';
                    document.getElementById('editOncelik').value = data.oncelik || 0;
                    document.getElementById('editYayinBaslangicTarihi').value = data.yayinbaslangictarihi || '';
                    document.getElementById('editYayinBitisTarihi').value = data.yayinbitistarihi || '';
                    document.getElementById('editYayindaMi').checked = data.yayindami == 1;

                    // Mevcut görsel varsa göster
                    const mevcutGorselAlani = document.getElementById('mevcutGorselAlani');
                    const mevcutGorselImg = document.getElementById('mevcutGorselImg');
                    const editMevcutGorsel = document.getElementById('editMevcutGorsel');

                    if (data.gorselyolu) {
                        mevcutGorselImg.src = data.gorselyolu;
                        mevcutGorselAlani.style.display = 'block';
                        editMevcutGorsel.value = data.gorselyolu;
                        silinecekGorselId = data.id;
                    } else {
                        mevcutGorselAlani.style.display = 'none';
                        editMevcutGorsel.value = '';
                        silinecekGorselId = null;
                    }

                    // Önizleme alanını temizle
                    document.getElementById('editPreview').innerHTML = '';
                    document.getElementById('editGorsel').value = '';

                    var duzenleModal = new bootstrap.Modal(document.getElementById('duzenleModal'));
                    duzenleModal.show();
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Kayıt getirilirken bir hata oluştu.');
                });
        }

        function mevcutGorselSil() {
            if (silinecekGorselId) {
                if (confirm('Görseli silmek istediğinizden emin misiniz?')) {
                    fetch('@Url.Action("GorselSilAjax", "AdminBayiDuyuru")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: 'id=' + silinecekGorselId
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById('mevcutGorselAlani').style.display = 'none';
                            document.getElementById('editMevcutGorsel').value = '';
                            silinecekGorselId = null;

                            // Başarı mesajı göster
                            var alertHtml = '<div class="alert alert-success alert-dismissible fade show" role="alert">' +
                                data.message +
                                '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                                '</div>';
                            document.querySelector('.modal-body').insertAdjacentHTML('afterbegin', alertHtml);

                            // 3 saniye sonra mesajı kaldır
                            setTimeout(function() {
                                var alerts = document.querySelectorAll('.alert');
                                alerts.forEach(function(alert) {
                                    alert.remove();
                                });
                            }, 3000);
                        } else {
                            alert('Hata: ' + data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Görsel silinirken bir hata oluştu.');
                    });
                }
            }
        }

        function silOnay(id, baslik) {
            document.getElementById('silId').value = id;
            document.getElementById('silBaslik').textContent = baslik;

            var silModal = new bootstrap.Modal(document.getElementById('silModal'));
            silModal.show();
        }

        // Modal kapandığında formları temizle
        document.getElementById('ekleModal').addEventListener('hidden.bs.modal', function () {
            this.querySelector('form').reset();
            document.getElementById('eklePreview').innerHTML = '';
        });

        document.getElementById('duzenleModal').addEventListener('hidden.bs.modal', function () {
            this.querySelector('form').reset();
            document.getElementById('mevcutGorselAlani').style.display = 'none';
            document.getElementById('editPreview').innerHTML = '';
            silinecekGorselId = null;
        });

        // Başarı mesajlarını 5 saniye sonra otomatik kapat
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);

        // Sürükle-bırak desteği
        document.querySelectorAll('.gorsel-upload-area').forEach(area => {
            area.addEventListener('dragover', (e) => {
                e.preventDefault();
                area.style.borderColor = '#0d6efd';
                area.style.backgroundColor = '#e7f1ff';
            });

            area.addEventListener('dragleave', (e) => {
                e.preventDefault();
                area.style.borderColor = '#dee2e6';
                area.style.backgroundColor = '#f8f9fa';
            });

            area.addEventListener('drop', (e) => {
                e.preventDefault();
                area.style.borderColor = '#dee2e6';
                area.style.backgroundColor = '#f8f9fa';

                const files = e.dataTransfer.files;
                const input = area.nextElementSibling;
                if (files.length > 0 && input) {
                    input.files = files;
                    const previewId = input.id === 'Gorsel' ? 'eklePreview' : 'editPreview';
                    previewImage(input, previewId);
                }
            });
        });

        // Sayfa yüklendiğinde event listener'ları ekle
        document.addEventListener('DOMContentLoaded', function() {
            // Satır tıklama ile seçim
            const duyuruTbody = document.querySelector('#duyuruTablosu tbody');
            if (duyuruTbody) {
                duyuruTbody.addEventListener('click', function(e) {
                    const tr = e.target.closest('tr');
                    if (!tr) return;

                    // Eğer checkbox'a, butona veya link'e tıklanmışsa işlem yapma
                    if (e.target.type === 'checkbox' ||
                        e.target.tagName === 'BUTTON' ||
                        e.target.closest('button') ||
                        e.target.tagName === 'A' ||
                        e.target.closest('a') ||
                        e.target.classList.contains('duyuru-gorsel-preview')) {
                        return;
                    }

                    const checkbox = tr.querySelector('.duyuru-sec-checkbox');
                    if (checkbox) {
                        // Diğer tüm checkbox'ları temizle
                        document.querySelectorAll('.duyuru-sec-checkbox').forEach(cb => {
                            cb.checked = false;
                        });
                        // Sadece bu satırın checkbox'ını seç
                        checkbox.checked = true;
                        seciliDuyuruSayisiniGuncelle();
                    }
                });
            }

            // Checkbox değişim olayı
            document.addEventListener('change', function(e) {
                if (e.target.classList.contains('duyuru-sec-checkbox')) {
                    seciliDuyuruSayisiniGuncelle();
                }
            });

            // Modal kapandığında seçimi temizle
            const modals = ['duzenleModal', 'silModal'];
            modals.forEach(modalId => {
                const modal = document.getElementById(modalId);
                if (modal) {
                    modal.addEventListener('hidden.bs.modal', function() {
                        // Seçimi temizle
                        document.querySelectorAll('.duyuru-sec-checkbox').forEach(cb => {
                            cb.checked = false;
                        });
                        seciliDuyuruSayisiniGuncelle();
                    });
                }
            });
        });
    </script>
}