@{
    ViewData["Title"] = "Ana Sayfa Banner Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <!-- Başarı/Hata Mesajları -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="card-title">
                    <span>Ana Sayfa Banner Yönetimi</span>
                </div>
            </div>
            <div class="card-body">
                @if (ViewBag.Banner != null)
                {
                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <div class="card">
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <img src="@ViewBag.Banner.FotografBuyuk" alt="@ViewBag.Banner.Baslik" class="img-fluid img-thumbnail">
                                        </div>
                                        <div class="col-md-8">
                                            <h4>@ViewBag.Banner.Baslik</h4>
                                            <p>@ViewBag.Banner.Metin</p>
                                            <hr>
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <small class="text-muted">Eklenme Tarihi: @ViewBag.Banner.EklenmeTarihi?.ToString("dd.MM.yyyy HH:mm")</small>
                                                </div>
                                                <div class="col-md-6 text-end">
                                                    <button type="button" class="btn btn-warning" data-button-permission="duzenle" onclick="duzenleGetir(@ViewBag.Banner.Id)">
                                                        <i class="fas fa-edit"></i> Düzenle
                                                    </button>
                                                    <button type="button" class="btn btn-danger" data-button-permission="sil" onclick="silOnay(@ViewBag.Banner.Id, '@ViewBag.Banner.Baslik')">
                                                        <i class="fas fa-trash"></i> Sil
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Yeni Banner Ekle butonu (mevcut banner varsa uyarı ile) -->
                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle"></i>
                        Zaten bir aktif banner bulunmaktadır. Yeni bir banner eklemek isterseniz, mevcut banner otomatik olarak pasif edilecektir.
                        <button type="button" class="btn btn-primary float-end" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Banner Ekle
                        </button>
                        <div class="clearfix"></div>
                    </div>
                }
                else
                {
                    <!-- Hiç banner yoksa -->
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i> Henüz bir banner eklenmemiş. Hemen yeni bir banner ekleyin.
                    </div>

                    <div class="text-center">
                        <button type="button" class="btn btn-primary btn-lg" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Banner Ekle
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Ekle", "AdminAnaSayfaBannerResim")" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title" id="ekleModalLabel">Yeni Banner Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label for="imagefile" class="form-label">Banner Resmi</label>
                            <input type="file" class="form-control" id="imagefile" name="imagefile" accept="image/*" required>
                            <div class="form-text">Önerilen boyut: 1920x1080 piksel</div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="Baslik" name="Baslik" placeholder="Başlık" required>
                                <label for="Baslik">Başlık</label>
                            </div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <textarea class="form-control" id="Metin" name="Metin" placeholder="Metin" style="height: 100px" required></textarea>
                                <label for="Metin">Metin</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1" aria-labelledby="duzenleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Guncelle", "AdminAnaSayfaBannerResim")">
                <input type="hidden" id="editId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="duzenleModalLabel">Banner Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i>
                                Resim değiştirmek için mevcut banner'ı silip yeni banner ekleyebilirsiniz.
                            </div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" id="editBaslik" name="Baslik" placeholder="Başlık" required>
                                <label for="editBaslik">Başlık</label>
                            </div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-floating">
                                <textarea class="form-control" id="editMetin" name="Metin" placeholder="Metin" style="height: 100px" required></textarea>
                                <label for="editMetin">Metin</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="@Url.Action("Sil", "AdminAnaSayfaBannerResim")">
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="silModalLabel">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silBaslik"></span>"</strong> başlıklı banner'ı silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz. Banner hem veritabanından hem de sunucudan silinecektir.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <script>
        function duzenleGetir(id) {
            fetch('@Url.Action("Getir", "AdminAnaSayfaBannerResim")' + '?id=' + id)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Network response was not ok');
                    }
                    return response.json();
                })
                .then(data => {
                    document.getElementById('editId').value = data.id;
                    document.getElementById('editBaslik').value = data.baslik || '';
                    document.getElementById('editMetin').value = data.metin || '';

                    var duzenleModal = new bootstrap.Modal(document.getElementById('duzenleModal'));
                    duzenleModal.show();
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Kayıt getirilirken bir hata oluştu.');
                });
        }

        function silOnay(id, baslik) {
            document.getElementById('silId').value = id;
            document.getElementById('silBaslik').textContent = baslik;

            var silModal = new bootstrap.Modal(document.getElementById('silModal'));
            silModal.show();
        }

        // Modal kapandığında formları temizle
        document.addEventListener('DOMContentLoaded', function() {
            var ekleModal = document.getElementById('ekleModal');
            if (ekleModal) {
                ekleModal.addEventListener('hidden.bs.modal', function () {
                    this.querySelector('form').reset();
                });
            }

            var duzenleModal = document.getElementById('duzenleModal');
            if (duzenleModal) {
                duzenleModal.addEventListener('hidden.bs.modal', function () {
                    this.querySelector('form').reset();
                });
            }
        });

        // Başarı mesajlarını 5 saniye sonra otomatik kapat
        setTimeout(function() {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                var bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>
}