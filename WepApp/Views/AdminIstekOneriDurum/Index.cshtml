@using WepApp.Models
@{
    ViewData["Title"] = "İstek/Öneri Durum Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    .table-actions {
        white-space: nowrap;
        width: 120px;
    }

    .card {
        margin-top: 70px;
    }

    .table th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    /* Seçim satırı için cursor pointer */
    tr[data-durum-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <div class="card" style="margin-top: 70px;">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">İstek/Öneri Durumları</h5>
                <div class="d-flex align-items-center gap-3">
                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları -->
                    <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                        <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                            <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-warning aksiyon-btn" id="seciliDuzenleBtn" data-button-permission="duzenle" title="Seçili Durumu Düzenle" disabled>
                                <i class="fas fa-edit"></i>
                            </button>
                            <button type="button" class="btn btn-danger aksiyon-btn" id="seciliSilBtn" data-button-permission="sil" title="Seçili Durumu Sil" disabled>
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Yeni Ekle Butonu -->
                    <button class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                        <i class="fas fa-plus"></i> Yeni Durum Ekle
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="durumTablosu">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th style="width: 60px;">Sıra</th>
                                <th>Durum Adı</th>
                                <th>Eklenme Tarihi</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="istekOneriDurumTablosu">
                            @if (ViewBag.IstekOneriDurumlar != null && ViewBag.IstekOneriDurumlar.Count > 0)
                            {
                                foreach (var item in ViewBag.IstekOneriDurumlar)
                                {
                                    <tr data-durum-id="@item.Id" data-durum-adi="@item.Adi" data-durum-sira="@item.Sira" class="durum-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input durum-sec-radio" type="radio" name="seciliDurumRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@item.Sira</span>
                                        </td>
                                        <td><strong>@item.Adi</strong></td>
                                        <td>@item.EklenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4">
                                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                        <p>Henüz istek/öneri durumu eklenmemiş.</p>
                                        <button class="btn btn-primary" data-bs-toggle="modal" data-button-permission="ekle" data-bs-target="#ekleModal">
                                            İlk Durumu Ekle
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Sıralamayı Kaydet butonu ve sürükle-bırak özelliği tamamen kaldırıldı -->
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Ekle", "AdminIstekOneriDurum")" method="post" id="ekleForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Yeni İstek/Öneri Durumu Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Durum Adı *</label>
                        <input type="text" class="form-control" name="Adi" id="Adi"
                               placeholder="Ör: Beklemede, İnceleniyor, Çözüldü, Reddedildi"
                               required oninput="kontrolEtAdi()">
                        <div id="adiMesaj" class="form-text"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Sıra Numarası</label>
                        <input  class="form-control" name="Sira" id="Sira"
                               min="1" value="" oninput="kontrolEtSira()">
                        <div id="siraMesaj" class="form-text">
                            <small class="text-muted">Boş bırakırsanız otomatik sıralanacaktır.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary" disabled>Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Guncelle", "AdminIstekOneriDurum")" method="post" id="duzenleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId">
                <div class="modal-header">
                    <h5 class="modal-title">İstek/Öneri Durumu Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Durum Adı *</label>
                        <input type="text" class="form-control" name="Adi" id="editAdi" required oninput="kontrolEtAdi(true)">
                        <div id="editAdiMesaj" class="form-text"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Sıra Numarası *</label>
                        <input  class="form-control" name="Sira" id="editSira" min="1" required oninput="kontrolEtSira(true)">
                        <div id="editSiraMesaj" class="form-text"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary" disabled>Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Modal -->
<div class="modal fade" id="silModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminIstekOneriDurum")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="silId">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p><strong id="silAdiGoster"></strong> durumunu pasif yapmak istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <!-- jQuery UI sortable tamamen kaldırıldı -->
    <script>
        $(document).ready(function() {
            // Toastr ayarları
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "5000"
            };

            let suAnSeciliDurumId = null;
            let adiGecerli = false;
            let siraGecerli = true;
            let duzenleme = false;

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#istekOneriDurumTablosu tr[data-durum-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button')) {
                    const $radio = $(this).find('.durum-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.durum-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliDurumId = $(this).val();
                    const $seciliSatir = $(this).closest('tr');
                    const durumAdi = $seciliSatir.data('durum-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#istekOneriDurumTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    $seciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $('#seciliKayitBilgi').html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${durumAdi}`);

                    // Butonları aktif et
                    $('#seciliDuzenleBtn').prop('disabled', false);
                    $('#seciliSilBtn').prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $('#seciliDuzenleBtn').click(function() {
                if (suAnSeciliDurumId) {
                    const $seciliSatir = $(`tr[data-durum-id="${suAnSeciliDurumId}"]`);
                    const adi = $seciliSatir.data('durum-adi');
                    const sira = $seciliSatir.data('durum-sira');

                    duzenleGetir(suAnSeciliDurumId, adi, sira);
                } else {
                    toastr.warning('Lütfen önce bir durum seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $('#seciliSilBtn').click(function() {
                if (suAnSeciliDurumId) {
                    const $seciliSatir = $(`tr[data-durum-id="${suAnSeciliDurumId}"]`);
                    const durumAdi = $seciliSatir.data('durum-adi');

                    $('#silId').val(suAnSeciliDurumId);
                    $('#silAdiGoster').text(durumAdi);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir durum seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliDurumId) {
                    const $satir = $(`tr[data-durum-id="${suAnSeciliDurumId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        suAnSeciliDurumId = null;
                        $('#seciliKayitBilgi').html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $('#seciliDuzenleBtn').prop('disabled', true);
                        $('#seciliSilBtn').prop('disabled', true);
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.durum-sec-radio[value="${suAnSeciliDurumId}"]`).prop('checked', false);
                        $('#istekOneriDurumTablosu tr').removeClass('table-active');
                        suAnSeciliDurumId = null;
                        $('#seciliKayitBilgi').html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $('#seciliDuzenleBtn').prop('disabled', true);
                        $('#seciliSilBtn').prop('disabled', true);
                    }
                }
            });

            // ============= MEVCUT FONKSİYONLAR (AYNEN KORUNDU) =============

            window.kontrolEtAdi = function (duzenle = false) {
                const input = duzenle ? $('#editAdi') : $('#Adi');
                const mesaj = duzenle ? $('#editAdiMesaj') : $('#adiMesaj');
                const val = input.val().trim();
                const istekOneriDurumId = duzenle ? $('#editId').val() : null;

                if (val === '') {
                    mesaj.html('<small class="text-muted">Durum adı giriniz.</small>');
                    adiGecerli = false;
                } else if (val.length < 2) {
                    mesaj.html('<small class="text-warning">En az 2 karakter.</small>');
                    adiGecerli = false;
                } else {
                    fetch(`@Url.Action("AdiKontrol", "AdminIstekOneriDurum")?adi=${encodeURIComponent(val)}&istekOneriDurumId=${istekOneriDurumId || ''}`)
                        .then(r => r.json())
                        .then(d => {
                            if (d.success) {
                                mesaj.html(`<small class="text-success">${d.message}</small>`);
                                adiGecerli = true;
                            } else {
                                mesaj.html(`<small class="text-danger">${d.message}</small>`);
                                adiGecerli = false;
                            }
                            guncelleButon();
                        })
                        .catch(() => {
                            mesaj.html('<small class="text-danger">Kontrol hatası.</small>');
                            adiGecerli = false;
                            guncelleButon();
                        });
                    return;
                }
                guncelleButon();
            };

            window.kontrolEtSira = function (duzenle = false) {
                const input = duzenle ? $('#editSira') : $('#Sira');
                const mesaj = duzenle ? $('#editSiraMesaj') : $('#siraMesaj');
                const val = parseInt(input.val());
                const istekOneriDurumId = duzenle ? $('#editId').val() : null;

                if (duzenle) {
                    if (isNaN(val) || val < 1) {
                        mesaj.html('<small class="text-danger">Geçerli bir sıra numarası giriniz.</small>');
                        siraGecerli = false;
                    } else {
                        fetch(`@Url.Action("SiraKontrol", "AdminIstekOneriDurum")?sira=${val}&istekOneriDurumId=${istekOneriDurumId || ''}`)
                            .then(r => r.json())
                            .then(d => {
                                if (d.success) {
                                    mesaj.html(`<small class="text-success">${d.message}</small>`);
                                    siraGecerli = true;
                                } else {
                                    mesaj.html(`<small class="text-danger">${d.message}</small>`);
                                    siraGecerli = false;
                                }
                                guncelleButon();
                            });
                        return;
                    }
                } else {
                    if (val && val < 1) {
                        mesaj.html('<small class="text-danger">Sıra numarası 1 veya daha büyük olmalıdır.</small>');
                        siraGecerli = false;
                    } else {
                        siraGecerli = true;
                    }
                }
                guncelleButon();
            };

            function guncelleButon() {
                const modal = duzenleme ? '#duzenleModal' : '#ekleModal';
                if (duzenleme) {
                    $(modal).find('button[type="submit"]').prop('disabled', !(adiGecerli && siraGecerli));
                } else {
                    $(modal).find('button[type="submit"]').prop('disabled', !adiGecerli);
                }
            }

            window.duzenleGetir = function (id, adi, sira) {
                $('#editId').val(id);
                $('#editAdi').val(adi);
                $('#editSira').val(sira);
                duzenleme = true;
                adiGecerli = true;
                siraGecerli = true;
                guncelleButon();
                kontrolEtAdi(true);
                kontrolEtSira(true);
                const modal = new bootstrap.Modal(document.getElementById('duzenleModal'));
                modal.show();
            };

            window.silOnay = function (id, adi) {
                $('#silId').val(id);
                $('#silAdiGoster').text(adi);
                const modal = new bootstrap.Modal(document.getElementById('silModal'));
                modal.show();
            };

            // Modal sıfırlama
            $('#ekleModal').on('show.bs.modal', function () {
                duzenleme = false;
                adiGecerli = false;
                siraGecerli = true;
                $('#Adi').val('');
                $('#Sira').val('');
                $('#adiMesaj').empty();
                $('#siraMesaj').html('<small class="text-muted">Boş bırakırsanız otomatik sıralanacaktır.</small>');
                guncelleButon();
            });

            $('#duzenleModal').on('show.bs.modal', function () {
                duzenleme = true;
            });

            // Mevcut alert'leri otomatik kapat
            setTimeout(() => {
                $('.alert').each(function () {
                    bootstrap.Alert.getOrCreateInstance(this).close();
                });
            }, 5000);
        });
    </script>
}