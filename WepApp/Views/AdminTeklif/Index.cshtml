                                <div class="card border-0 shadow-sm mb-3">
                                    <div class="card-header bg-light"><h6 class="mb-0">Teklif Bilgileri</h6></div>
                                    <div class="card-body">
                                        <table class="table table-sm table-borderless mb-0">
