        async function teklifSil(id) {
            try {
                $('#silBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Siliniyor...');

                const response = await $.ajax({
                    url: '/AdminTeklif/SilTeklif',
                    type: 'POST',
                    data: { id: id },
                    dataType: 'json'
                });

                if (response.success) {
                    toastr.success(response.message);

                    if (suAnSeciliTeklifId == id) {
                        suAnSeciliTeklifId = null;
                        suAnSeciliTeklifNo = null;
                        suAnSeciliDurumId = null;
                        suAnSeciliSatir = null;
                        $('#seciliKayitBilgi').html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $('#seciliDetayGoster, #seciliPdfGoster, #seciliRevizeGoster, #seciliSozlesmeGoster, #seciliSil').prop('disabled', true);
                    }

                    const modal = bootstrap.Modal.getInstance(document.getElementById('silModal'));
                    if (modal) {
                        modal.hide();
                    }

                    setTimeout(() => {
                        location.reload();
                    }, 1500);
                } else {
                    toastr.error(response.message);
                    $('#silBtn').prop('disabled', false).html('<i class="fas fa-trash me-2"></i>Sil');
                }
            } catch (error) {
                console.error('Silme hatası:', error);
                if (error.status === 401) {
                    toastr.error('Oturum süresi doldu. Lütfen tekrar giriş yapın.');
                } else if (error.status === 404) {
                    toastr.error('Teklif bulunamadı.');
                } else {
                    toastr.error('Sunucu ile bağlantı kurulamadı.');
                }
                $('#silBtn').prop('disabled', false).html('<i class="fas fa-trash me-2"></i>Sil');
            }
        }

        function formatTutar(val, decimals = 2) {
            if (val === null || val === undefined || val === '') return '0,00';

            let num;
            if (typeof val === 'string') {
                const cleaned = val
                    .replace(/\./g, '')
                    .replace(',', '.')
                    .trim();
                num = parseFloat(cleaned);
            } else {
                num = val;
            }

            if (isNaN(num)) return '0,00';

            return new Intl.NumberFormat('tr-TR', {
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals
            }).format(num);
        }

        function getDurumBadgeCss(id) {
            const map = {
                1: 'bg-warning text-dark',
                2: 'bg-success',
                3: 'bg-success',
                4: 'bg-danger',
                5: 'bg-secondary',
                6: 'bg-success',
                7: 'bg-warning text-dark',
                8: 'bg-info',
                9: 'bg-purple text-white',
                10: 'bg-warning text-dark',
                12: 'bg-secondary'
            };
            return map[id] || 'bg-light text-dark';
        }

        function musteriDuzenleAc(musteriId) {
            const url = `/AdminMusteri/Index?musteriId=${musteriId}`;
            window.open(url, '_blank');
        }

        // ============= SATIR SEÇME VE ÜST BUTONLAR =============
        let suAnSeciliTeklifId = null;
        let suAnSeciliTeklifNo = null;
        let suAnSeciliDurumId = null;
        let suAnSeciliSatir = null;

        const $seciliDetayBtn = $('#seciliDetayGoster');
        const $seciliPdfBtn = $('#seciliPdfGoster');
        const $seciliRevizeBtn = $('#seciliRevizeGoster');
        const $seciliSozlesmeBtn = $('#seciliSozlesmeGoster');
        const $seciliSilBtn = $('#seciliSil');
        const $seciliBilgiDiv = $('#seciliKayitBilgi');

        const kilitliDurumlar = [5, 8, 9, 10, 12];
        const sozlesmeAktifDurumlar = [6];
        const revizeAktifDurumlar = [1];

        // Tablo satırına tıklandığında seçimi yap
        $(document).on('click', '#teklifTablosu tr[data-teklif-id]', function(e) {
            if (!$(e.target).is('button') && !$(e.target).is('select') && !$(e.target).is('a')) {
                satirSec($(this));
            }
        });

        // Satır seçme fonksiyonu
        function satirSec($satir) {
            const teklifId = $satir.data('teklif-id');

            if (suAnSeciliTeklifId === teklifId) {
                suAnSeciliTeklifId = null;
                suAnSeciliTeklifNo = null;
                suAnSeciliDurumId = null;
                suAnSeciliSatir = null;

                $('#teklifTablosu tr').removeClass('table-active');
                $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                $seciliDetayBtn.prop('disabled', true);
                $seciliPdfBtn.prop('disabled', true);
                $seciliRevizeBtn.prop('disabled', true);
                $seciliSozlesmeBtn.prop('disabled', true);
                $seciliSilBtn.prop('disabled', true);
            } else {
                suAnSeciliTeklifId = teklifId;
                suAnSeciliSatir = $satir;
                suAnSeciliTeklifNo = $satir.find('.teklif-no').text().trim();
                suAnSeciliDurumId = parseInt($satir.data('durum-id'));

                $('#teklifTablosu tr').removeClass('table-active');
                $satir.addClass('table-active');

                $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${suAnSeciliTeklifNo}`);

                updateSeciliButtonStates();
            }
        }

        function updateSeciliButtonStates() {
            $seciliDetayBtn.prop('disabled', false);
            $seciliPdfBtn.prop('disabled', false);
            $seciliRevizeBtn.prop('disabled', false);
            $seciliSozlesmeBtn.prop('disabled', false);
            $seciliSilBtn.prop('disabled', false);

            if (kilitliDurumlar.includes(suAnSeciliDurumId)) {
                $seciliRevizeBtn.prop('disabled', true);

                if (suAnSeciliDurumId !== 5) {
                    $seciliSilBtn.prop('disabled', true);
                }
            }

            if (!sozlesmeAktifDurumlar.includes(suAnSeciliDurumId)) {
                $seciliSozlesmeBtn.prop('disabled', true);
            }

            if (!revizeAktifDurumlar.includes(suAnSeciliDurumId)) {
                $seciliRevizeBtn.prop('disabled', true);
            }
        }

        $seciliDetayBtn.click(function() {
            if (suAnSeciliTeklifId) {
                detaylariGetir(suAnSeciliTeklifId);
            } else {
                toastr.warning('Lütfen önce bir teklif seçin.');
            }
        });

        $seciliPdfBtn.click(function() {
            if (suAnSeciliTeklifId) {
                window.open(`/AdminTeklifVer/TeklifPdf?teklifId=${suAnSeciliTeklifId}`, '_blank');
            } else {
                toastr.warning('Lütfen önce bir teklif seçin.');
            }
        });

        $seciliRevizeBtn.click(function() {
            if (suAnSeciliTeklifId && !kilitliDurumlar.includes(suAnSeciliDurumId)) {
                window.open(`/AdminTeklifVer?teklifId=${suAnSeciliTeklifId}`, '_blank');
            } else {
                toastr.warning('Bu teklif revize edilemez.');
            }
        });

        $seciliSozlesmeBtn.click(function() {
            if (suAnSeciliTeklifId && sozlesmeAktifDurumlar.includes(suAnSeciliDurumId)) {
                sozlesmeModalAc(suAnSeciliTeklifId);
            } else {
                toastr.warning('Bu teklif için sözleşme oluşturulamaz.');
            }
        });

        $seciliSilBtn.click(function() {
            if (suAnSeciliTeklifId) {
                $('#silinecekTeklifNo').text(suAnSeciliTeklifNo);
                window.seciliTeklifId = suAnSeciliTeklifId;
                new bootstrap.Modal('#silModal').show();
            } else {
                toastr.warning('Lütfen önce bir teklif seçin.');
            }
        });

        $('#silModal').on('hidden.bs.modal', function() {
            if (suAnSeciliTeklifId) {
                const $satir = $(`tr[data-teklif-id="${suAnSeciliTeklifId}"]`);
                if ($satir.length === 0) {
                    suAnSeciliTeklifId = null;
                    suAnSeciliTeklifNo = null;
                    suAnSeciliDurumId = null;
                    suAnSeciliSatir = null;
                    $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                    $seciliDetayBtn.prop('disabled', true);
                    $seciliPdfBtn.prop('disabled', true);
                    $seciliRevizeBtn.prop('disabled', true);
                    $seciliSozlesmeBtn.prop('disabled', true);
                    $seciliSilBtn.prop('disabled', true);
                } else {
                    $('#teklifTablosu tr').removeClass('table-active');
                    suAnSeciliTeklifId = null;
                    suAnSeciliTeklifNo = null;
                    suAnSeciliDurumId = null;
                    suAnSeciliSatir = null;
                    $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                    $seciliDetayBtn.prop('disabled', true);
                    $seciliPdfBtn.prop('disabled', true);
                    $seciliRevizeBtn.prop('disabled', true);
                    $seciliSozlesmeBtn.prop('disabled', true);
                    $seciliSilBtn.prop('disabled', true);
                }
            }
        });

        function scheduleArchiveAfterOneMonth(teklifId) {
            console.log(`Teklif ${teklifId} için 1 ay sonra Arşiv kontrolü yapılacak`);
        }
    </script>
}