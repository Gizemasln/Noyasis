@using WepApp.Models
@{
    ViewData["Title"] = "Departman Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Filtreleme stilleri - Diğer sayfalarla uyumlu */
    .card-header .flex-wrap {
        gap: 15px;
    }

    .card-header .gap-2 {
        gap: 0.5rem !important;
    }

    .search-box {
        position: relative;
    }

        .search-box .input-group {
            transition: all 0.3s ease;
            width: 200px;
        }

            .search-box .input-group:focus-within {
                width: 250px;
            }

        .search-box .form-control:focus {
            background-color: #fff !important;
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
        }

    #departmanAramaTemizle {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        z-index: 5;
        color: #6c757d;
        padding: 0.25rem 0.5rem;
    }

        #departmanAramaTemizle:hover {
            color: #dc3545;
        }

    .dropdown-menu {
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        border: none;
    }

        .dropdown-menu .form-control-sm,
        .dropdown-menu .form-select-sm {
            border: 1px solid #dee2e6;
        }

            .dropdown-menu .form-control-sm:focus,
            .dropdown-menu .form-select-sm:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
            }

    #departmanFiltreTemizleBtn {
        transition: all 0.3s ease;
    }

        #departmanFiltreTemizleBtn:hover {
            transform: scale(1.1);
        }

    /* Aktif filtre butonu stilleri */
    .btn-primary .fas {
        color: white;
    }

    /* Filtre etiketleri */
    #aktifFiltreler {
        background-color: #f8f9fa;
        border-radius: 0.35rem;
        padding: 10px;
        border: 1px solid #e3e6f0;
        margin-top: 15px !important;
    }

        #aktifFiltreler .badge {
            font-size: 0.85rem;
            padding: 0.5rem 0.75rem;
        }

    /* Tablo satırları için geçiş efekti */
    #departmanTablosu tr {
        transition: all 0.3s ease;
    }

        #departmanTablosu tr[style*="display: none"] {
            opacity: 0;
            transform: scale(0.95);
        }

    /* Responsive düzenlemeler */
    media (max-width: 768px) {
        .card-header .d-flex

    {
        flex-direction: column;
        align-items: stretch !important;
    }

    .card-header .gap-2 {
        flex-wrap: wrap;
        justify-content: space-between;
    }

    .search-box {
        width: 100% !important;
        margin-bottom: 5px;
    }

        .search-box .input-group {
            width: 100% !important;
        }

            .search-box .input-group:focus-within {
                width: 100% !important;
            }

    .card-header .dropdown {
        flex: 1;
    }

    .islem-butonlari-alani {
        width: 100%;
        justify-content: space-between;
    }

    #aktifFiltreler .d-flex {
        flex-direction: column;
        align-items: flex-start !important;
        gap: 10px;
    }

    #filtreEtiketleri {
        flex-wrap: wrap;
    }

    }
    .table-actions {
        white-space: nowrap;
        width: 120px;
    }

    .card {
        margin-top: 70px;
    }

    .table th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    /* Seçim satırı için cursor pointer */
    tr[data-departman-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-0">Departmanlar</h5>

                    <!-- FİLTRELEME ALANI - Diğer sayfalarla uyumlu -->
                    <div class="d-flex align-items-center gap-2">
                        <!-- Arama Kutusu -->
                        <div class="search-box">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light border-0">
                                    <i class="fas fa-search text-muted"></i>
                                </span>
                                <input type="text" id="departmanArama" class="form-control form-control-sm border-0 bg-light"
                                       placeholder="Departman ara..." style="box-shadow: none;">
                                <button class="btn btn-outline-secondary btn-sm" type="button" id="departmanAramaTemizle" style="display:none;">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Tarih Filtreleri -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="tarihFiltreBtn">
                                <i class="fas fa-calendar-alt me-1"></i> Tarih
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 300px;">
                                <div class="mb-2">
                                    <label class="form-label small">Eklenme Tarihi Aralığı</label>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Başlangıç</label>
                                    <input type="date" id="filtreBaslangicTarih" class="form-control form-control-sm">
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Bitiş</label>
                                    <input type="date" id="filtreBitisTarih" class="form-control form-control-sm">
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="departmanTarihFiltreTemizle()">Temizle</button>
                                    <button class="btn btn-sm btn-primary" onclick="departmanTarihFiltreUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Sıralama -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="siralamaFiltreBtn">
                                <i class="fas fa-sort-amount-down me-1"></i> Sıralama
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 200px;">
                                <div class="mb-2">
                                    <select class="form-select form-select-sm" id="siralamaFiltre">
                                        <option value="yeni">En Yeni → En Eski</option>
                                        <option value="eski">En Eski → En Yeni</option>
                                        <option value="adi_az">İsim (A-Z)</option>
                                        <option value="adi_za">İsim (Z-A)</option>
                                    </select>
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-primary" onclick="departmanSiralamaUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Filtre Temizleme Butonu -->
                        <button class="btn btn-sm btn-outline-danger" onclick="departmanTumFiltreleriTemizle()"
                                title="Tüm filtreleri temizle" id="departmanFiltreTemizleBtn" style="display: none;">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları (mevcut kod) -->
                    <div class="d-flex align-items-center gap-3">
                        <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                            <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                                <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                            </div>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-warning aksiyon-btn" id="seciliDuzenleBtn" title="Seçili Departmanı Düzenle" data-button-permission="duzenle" disabled>
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="btn btn-danger aksiyon-btn" id="seciliSilBtn" title="Seçili Departmanı Sil" data-button-permission="sil" disabled>
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Yeni Ekle Butonu -->
                        <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Departman Ekle
                        </button>
                    </div>
                </div>

                <!-- Aktif Filtreler -->
                <div class="row mt-3" id="aktifFiltreler" style="display: none;">
                    <div class="col-12">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-light text-dark me-2 p-2">
                                <i class="fas fa-filter me-1"></i>Aktif Filtreler:
                            </span>
                            <div id="filtreEtiketleri" class="d-flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th width="50">#</th>
                                <th>Departman Adı</th>
                                <th>Eklenme Tarihi</th>
                                <th>Son Güncelleme</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="departmanTablosu">
                            @if (ViewBag.Departmanlar != null && ((List<Departman>)ViewBag.Departmanlar).Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in (List<Departman>)ViewBag.Departmanlar)
                                {
                                    <tr data-departman-id="@item.Id" data-departman-adi="@item.Adi" class="departman-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input departman-sec-radio" type="radio" name="seciliDepartmanRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td><strong>@item.Adi</strong></td>
                                        <td>@item.EklenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@item.GuncellenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center">
                                        <div class="py-4">
                                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                            <p class="text-muted">Henüz departman eklenmemiş.</p>
                                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ekleModal">
                                                İlk Departmanı Ekle
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminDepartman", FormMethod.Post, new { id = "ekleForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Departman Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Departman Adı *</label>
                        <input type="text" class="form-control" name="Adi" placeholder="Departman adını giriniz" required maxlength="100">
                        <div class="form-text">Departman adı benzersiz olmalıdır.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1" aria-labelledby="duzenleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Guncelle", "AdminDepartman")" method="post" id="duzenleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title">Departman Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Departman Adı *</label>
                        <input type="text" class="form-control" id="editAdi" name="Adi" required maxlength="100">
                        <div class="form-text">Departman adı benzersiz olmalıdır.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminDepartman")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silAdi"></span>"</strong> adlı departmanı silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function() {
                    // ============= DEPARTMAN FİLTRELEME SİSTEMİ =============
        let departmanAktifFiltreler = {
            arama: '',
            baslangicTarih: null,
            bitisTarih: null,
            siralama: 'yeni'
        };

        // Arama fonksiyonu
        function departmanAramaFiltrele() {
            const aramaInput = document.getElementById('departmanArama');
            const temizleBtn = document.getElementById('departmanAramaTemizle');

            if (aramaInput && temizleBtn) {
                const kelime = aramaInput.value.trim().toLowerCase();

                // Temizle butonunu göster/gizle
                temizleBtn.style.display = kelime ? 'block' : 'none';

                departmanAktifFiltreler.arama = kelime;
                departmanFiltreEtiketleriniGoster();
                departmanFiltreleVeSirala();
            }
        }

        // Arama inputuna event listener ekle
        const aramaInput = document.getElementById('departmanArama');
        const temizleBtn = document.getElementById('departmanAramaTemizle');

        if (aramaInput) {
            aramaInput.addEventListener('input', departmanAramaFiltrele);
            aramaInput.addEventListener('keyup', departmanAramaFiltrele);
        }

        if (temizleBtn) {
            temizleBtn.addEventListener('click', function () {
                aramaInput.value = '';
                departmanAramaFiltrele();
                aramaInput.focus();
            });
        }

        // Tarih Filtresi Uygula
        window.departmanTarihFiltreUygula = function() {
            const baslangicInput = document.getElementById('filtreBaslangicTarih');
            const bitisInput = document.getElementById('filtreBitisTarih');

            departmanAktifFiltreler.baslangicTarih = baslangicInput.value || null;
            departmanAktifFiltreler.bitisTarih = bitisInput.value || null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('tarihFiltreBtn'));
            if (dropdown) dropdown.hide();

            departmanFiltreEtiketleriniGoster();
            departmanFiltreleVeSirala();
        };

        // Tarih Filtresi Temizle
        window.departmanTarihFiltreTemizle = function() {
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';
            departmanAktifFiltreler.baslangicTarih = null;
            departmanAktifFiltreler.bitisTarih = null;
            departmanFiltreEtiketleriniGoster();
            departmanFiltreleVeSirala();
        };

        // Sıralama Uygula
        window.departmanSiralamaUygula = function() {
            const siralama = document.getElementById('siralamaFiltre').value;
            departmanAktifFiltreler.siralama = siralama;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('siralamaFiltreBtn'));
            if (dropdown) dropdown.hide();

            departmanFiltreEtiketleriniGoster();
            departmanFiltreleVeSirala();
        };

        // Tüm Filtreleri Temizle
        window.departmanTumFiltreleriTemizle = function() {
            // Arama kutusunu temizle
            document.getElementById('departmanArama').value = '';
            document.getElementById('departmanAramaTemizle').style.display = 'none';

            // Tarih filtrelerini temizle
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';

            // Sıralamayı varsayılana getir
            document.getElementById('siralamaFiltre').value = 'yeni';

            // Buton stillerini sıfırla
            document.getElementById('tarihFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('siralamaFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';

            // Filtre değişkenlerini sıfırla
            departmanAktifFiltreler = {
                arama: '',
                baslangicTarih: null,
                bitisTarih: null,
                siralama: 'yeni'
            };

            // Filtre etiketlerini gizle
            document.getElementById('aktifFiltreler').style.display = 'none';
            document.getElementById('departmanFiltreTemizleBtn').style.display = 'none';

            // Filtrelemeyi yeniden uygula
            departmanFiltreleVeSirala();
        };

        // Filtre etiketlerini göster
        function departmanFiltreEtiketleriniGoster() {
            const etiketler = [];
            const filtreTemizleBtn = document.getElementById('departmanFiltreTemizleBtn');

            if (departmanAktifFiltreler.arama) {
                etiketler.push(`<span class="badge bg-primary">Arama: ${departmanAktifFiltreler.arama}</span>`);
            }

            if (departmanAktifFiltreler.baslangicTarih) {
                etiketler.push(`<span class="badge bg-primary">Başlangıç: ${formatDepartmanDate(departmanAktifFiltreler.baslangicTarih)}</span>`);
            }
            if (departmanAktifFiltreler.bitisTarih) {
                etiketler.push(`<span class="badge bg-primary">Bitiş: ${formatDepartmanDate(departmanAktifFiltreler.bitisTarih)}</span>`);
            }

            if (departmanAktifFiltreler.siralama !== 'yeni') {
                const siralamaMetin = {
                    'eski': 'En Eski',
                    'adi_az': 'İsim (A-Z)',
                    'adi_za': 'İsim (Z-A)'
                };
                etiketler.push(`<span class="badge bg-info">Sıralama: ${siralamaMetin[departmanAktifFiltreler.siralama]}</span>`);
            }

            if (etiketler.length > 0) {
                document.getElementById('filtreEtiketleri').innerHTML = etiketler.join(' ');
                document.getElementById('aktifFiltreler').style.display = 'block';
                filtreTemizleBtn.style.display = 'inline-block';

                // Buton stillerini güncelle
                document.getElementById('tarihFiltreBtn').className = departmanAktifFiltreler.baslangicTarih || departmanAktifFiltreler.bitisTarih
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';
            } else {
                document.getElementById('aktifFiltreler').style.display = 'none';
                filtreTemizleBtn.style.display = 'none';
            }
        }

        // Tarih formatlama
        function formatDepartmanDate(dateStr) {
            if (!dateStr) return '';
            const [yil, ay, gun] = dateStr.split('-');
            return `${gun}.${ay}.${yil}`;
        }

        // Tarih parse (dd.MM.yyyy HH:mm formatı)
        function departmanParseDate(dateStr) {
            if (!dateStr) return null;
            const [gun, ay, yilSaat] = dateStr.split('.');
            const [yil, saat] = yilSaat.split(' ');
            return new Date(`${yil}-${ay}-${gun}T${saat}`);
        }

        // Ana filtreleme ve sıralama fonksiyonu
        function departmanFiltreleVeSirala() {
            const tbody = document.getElementById('departmanTablosu');
            if (!tbody) return;

            const satirlar = Array.from(tbody.querySelectorAll('tr.departman-satiri'));

            if (satirlar.length === 0) return;

            // Filtreleme
            let filtrelenmisSatirlar = satirlar.filter(satir => {
                let goster = true;

                // Arama filtresi (Departman Adı - 3. sütun)
                if (departmanAktifFiltreler.arama) {
                    const adi = satir.querySelector('td:nth-child(3)')?.textContent.toLowerCase() || '';
                    if (!adi.includes(departmanAktifFiltreler.arama.toLowerCase())) {
                        goster = false;
                    }
                }

                // Tarih filtresi (4. sütun - Eklenme Tarihi)
                if (goster && (departmanAktifFiltreler.baslangicTarih || departmanAktifFiltreler.bitisTarih)) {
                    const tarihTd = satir.querySelector('td:nth-child(4)')?.textContent.trim();
                    if (tarihTd) {
                        const tarih = departmanParseDate(tarihTd);

                        if (departmanAktifFiltreler.baslangicTarih) {
                            const filtreBaslangic = new Date(departmanAktifFiltreler.baslangicTarih + 'T00:00:00');
                            if (tarih < filtreBaslangic) {
                                goster = false;
                            }
                        }

                        if (goster && departmanAktifFiltreler.bitisTarih) {
                            const filtreBitis = new Date(departmanAktifFiltreler.bitisTarih + 'T23:59:59');
                            if (tarih > filtreBitis) {
                                goster = false;
                            }
                        }
                    }
                }

                return goster;
            });

            // Sıralama
            switch(departmanAktifFiltreler.siralama) {
                case 'yeni':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = departmanParseDate(a.querySelector('td:nth-child(4)')?.textContent.trim() || '');
                        const tarihB = departmanParseDate(b.querySelector('td:nth-child(4)')?.textContent.trim() || '');
                        return (tarihB || 0) - (tarihA || 0);
                    });
                    break;

                case 'eski':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = departmanParseDate(a.querySelector('td:nth-child(4)')?.textContent.trim() || '');
                        const tarihB = departmanParseDate(b.querySelector('td:nth-child(4)')?.textContent.trim() || '');
                        return (tarihA || 0) - (tarihB || 0);
                    });
                    break;

                case 'adi_az':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiA.localeCompare(adiB, 'tr');
                    });
                    break;

                case 'adi_za':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiB.localeCompare(adiA, 'tr');
                    });
                    break;
            }

            // Tüm satırları gizle
            satirlar.forEach(satir => {
                satir.style.display = 'none';
            });

            // Filtrelenmiş satırları göster ve tbody'ye yeniden ekle (sıralama için)
            filtrelenmisSatirlar.forEach((satir, index) => {
                satir.style.display = '';
                // Sıra numarasını güncelle (2. sütun)
                const siraHucresi = satir.querySelector('td:nth-child(2)');
                if (siraHucresi) {
                    siraHucresi.textContent = index + 1;
                }
                tbody.appendChild(satir);
            });

            // "Gösterilecek kayıt yok" mesajı
            let bosSatir = tbody.querySelector('.filtre-bos-satir');

            if (filtrelenmisSatirlar.length === 0) {
                if (!bosSatir) {
                    bosSatir = document.createElement('tr');
                    bosSatir.className = 'filtre-bos-satir';
                    bosSatir.innerHTML = '<td colspan="6" class="text-center py-5"><i class="fas fa-filter fa-3x text-muted mb-3"></i><p class="text-muted">Filtreleme kriterlerine uygun departman bulunamadı.</p><button class="btn btn-sm btn-outline-secondary" onclick="departmanTumFiltreleriTemizle()">Filtreleri Temizle</button></td>';
                    tbody.appendChild(bosSatir);
                }
            } else if (bosSatir) {
                bosSatir.remove();
            }
        }

        // Enter tuşu ile filtreleme
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const aktifElement = document.activeElement;
                if (aktifElement.id === 'departmanArama' ||
                    aktifElement.id === 'filtreBaslangicTarih' ||
                    aktifElement.id === 'filtreBitisTarih') {
                    e.preventDefault();
                    departmanFiltreleVeSirala();
                }
            }
        });
            let suAnSeciliDepartmanId = null;
            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#departmanTablosu tr[data-departman-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button')) {
                    const $radio = $(this).find('.departman-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.departman-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliDepartmanId = $(this).val();
                    const $seciliSatir = $(this).closest('tr');
                    const departmanAdi = $seciliSatir.data('departman-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#departmanTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    $seciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${departmanAdi}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliDepartmanId) {
                    const $seciliSatir = $(`tr[data-departman-id="${suAnSeciliDepartmanId}"]`);
                    const adi = $seciliSatir.data('departman-adi');

                    duzenleGetir(suAnSeciliDepartmanId, adi);
                } else {
                    toastr.warning('Lütfen önce bir departman seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliDepartmanId) {
                    const $seciliSatir = $(`tr[data-departman-id="${suAnSeciliDepartmanId}"]`);
                    const departmanAdi = $seciliSatir.data('departman-adi');

                    $('#silId').val(suAnSeciliDepartmanId);
                    $('#silAdi').text(departmanAdi);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir departman seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliDepartmanId) {
                    const $satir = $(`tr[data-departman-id="${suAnSeciliDepartmanId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        suAnSeciliDepartmanId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.departman-sec-radio[value="${suAnSeciliDepartmanId}"]`).prop('checked', false);
                        $('#departmanTablosu tr').removeClass('table-active');
                        suAnSeciliDepartmanId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    }
                }
            });

            // ============= MEVCUT FONKSİYONLAR (AYNEN KORUNDU) =============

            window.duzenleGetir = function(id, adi) {
                $('#editId').val(id);
                $('#editAdi').val(adi);
                new bootstrap.Modal(document.getElementById('duzenleModal')).show();
            };

            window.silOnay = function(id, adi) {
                $('#silId').val(id);
                $('#silAdi').text(adi);
                new bootstrap.Modal(document.getElementById('silModal')).show();
            };

            document.addEventListener('DOMContentLoaded', function () {
                // Boş alan kontrolü
                document.querySelectorAll('form').forEach(form => {
                    form.addEventListener('submit', function (e) {
                        const adi = this.querySelector('input[name="Adi"]');
                        if (adi && adi.value.trim() === '') {
                            e.preventDefault();
                            toastr.error('Departman adı gereklidir.');
                            adi.focus();
                        }
                    });
                });

                // Modal kapandığında form sıfırlama
                ['ekleModal', 'duzenleModal'].forEach(id => {
                    const modal = document.getElementById(id);
                    if (modal) {
                        modal.addEventListener('hidden.bs.modal', () => modal.querySelector('form')?.reset());
                    }
                });

                // Alert otomatik kapanma
                setTimeout(() => {
                    document.querySelectorAll('.alert').forEach(a => bootstrap.Alert.getOrCreateInstance(a).close());
                }, 5000);
            });
        });
    </script>
}