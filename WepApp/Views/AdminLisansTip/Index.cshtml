@using WepApp.Models
@model List<LisansTip>
@{
    ViewData["Title"] = "Lisans Tipi Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Filtreleme stilleri - Diğer sayfalarla uyumlu */
    .card-header .flex-wrap {
        gap: 15px;
    }

    .card-header .gap-2 {
        gap: 0.5rem !important;
    }

    .search-box {
        position: relative;
    }

        .search-box .input-group {
            transition: all 0.3s ease;
            width: 200px;
        }

            .search-box .input-group:focus-within {
                width: 250px;
            }

        .search-box .form-control:focus {
            background-color: #fff !important;
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
        }

    #lisansAramaTemizle {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        z-index: 5;
        color: #6c757d;
        padding: 0.25rem 0.5rem;
    }

        #lisansAramaTemizle:hover {
            color: #dc3545;
        }

    .dropdown-menu {
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15);
        border: none;
    }

        .dropdown-menu .form-control-sm,
        .dropdown-menu .form-select-sm {
            border: 1px solid #dee2e6;
        }

            .dropdown-menu .form-control-sm:focus,
            .dropdown-menu .form-select-sm:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.2rem rgba(13,110,253,0.25);
            }

    #lisansFiltreTemizleBtn {
        transition: all 0.3s ease;
    }

        #lisansFiltreTemizleBtn:hover {
            transform: scale(1.1);
        }

    /* Aktif filtre butonu stilleri */
    .btn-primary .fas {
        color: white;
    }

    /* Filtre etiketleri */
    #aktifFiltreler {
        background-color: #f8f9fa;
        border-radius: 0.35rem;
        padding: 10px;
        border: 1px solid #e3e6f0;
        margin-top: 15px !important;
    }

        #aktifFiltreler .badge {
            font-size: 0.85rem;
            padding: 0.5rem 0.75rem;
        }

    /* Tablo satırları için geçiş efekti */
    #lisansTablosu tr {
        transition: all 0.3s ease;
    }

        #lisansTablosu tr[style*="display: none"] {
            opacity: 0;
            transform: scale(0.95);
        }

    /* Responsive düzenlemeler */
    media (max-width: 768px) {
        .card-header .d-flex

    {
        flex-direction: column;
        align-items: stretch !important;
    }

    .card-header .gap-2 {
        flex-wrap: wrap;
        justify-content: space-between;
    }

    .search-box {
        width: 100% !important;
        margin-bottom: 5px;
    }

        .search-box .input-group {
            width: 100% !important;
        }

            .search-box .input-group:focus-within {
                width: 100% !important;
            }

    .card-header .dropdown {
        flex: 1;
    }

    .islem-butonlari-alani {
        width: 100%;
        justify-content: space-between;
    }

    #aktifFiltreler .d-flex {
        flex-direction: column;
        align-items: flex-start !important;
        gap: 10px;
    }

    #filtreEtiketleri {
        flex-wrap: wrap;
    }

    }
    .table-actions {
        white-space: nowrap;
        width: 120px;
    }

    .card {
        margin-top: 70px;
    }

    .table th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    /* Seçim satırı için cursor pointer */
    tr[data-lisans-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <h5 class="mb-0">Lisans Tipleri</h5>

                    <!-- FİLTRELEME ALANI - Diğer sayfalarla uyumlu -->
                    <div class="d-flex align-items-center gap-2">
                        <!-- Arama Kutusu -->
                        <div class="search-box">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light border-0">
                                    <i class="fas fa-search text-muted"></i>
                                </span>
                                <input type="text" id="lisansArama" class="form-control form-control-sm border-0 bg-light"
                                       placeholder="Lisans tipi ara..." style="box-shadow: none;">
                                <button class="btn btn-outline-secondary btn-sm" type="button" id="lisansAramaTemizle" style="display:none;">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Tarih Filtreleri -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="tarihFiltreBtn">
                                <i class="fas fa-calendar-alt me-1"></i> Tarih
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 300px;">
                                <div class="mb-2">
                                    <label class="form-label small">Eklenme Tarihi Aralığı</label>
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Başlangıç</label>
                                    <input type="date" id="filtreBaslangicTarih" class="form-control form-control-sm">
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Bitiş</label>
                                    <input type="date" id="filtreBitisTarih" class="form-control form-control-sm">
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="lisansTarihFiltreTemizle()">Temizle</button>
                                    <button class="btn btn-sm btn-primary" onclick="lisansTarihFiltreUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Sayı Filtresi -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="sayiFiltreBtn">
                                <i class="fas fa-sort-numeric-down me-1"></i> Sayı
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 250px;">
                                <div class="mb-2">
                                    <label class="form-label small">Minimum Sayı</label>
                                    <input type="number" id="filtreMinSayi" class="form-control form-control-sm" min="0">
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Maksimum Sayı</label>
                                    <input type="number" id="filtreMaxSayi" class="form-control form-control-sm" min="0">
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-outline-secondary" onclick="lisansSayiFiltreTemizle()">Temizle</button>
                                    <button class="btn btn-sm btn-primary" onclick="lisansSayiFiltreUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Sıralama -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false" id="siralamaFiltreBtn">
                                <i class="fas fa-sort-amount-down me-1"></i> Sıralama
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-3" style="min-width: 200px;">
                                <div class="mb-2">
                                    <select class="form-select form-select-sm" id="siralamaFiltre">
                                        <option value="yeni">En Yeni → En Eski</option>
                                        <option value="eski">En Eski → En Yeni</option>
                                        <option value="adi_az">İsim (A-Z)</option>
                                        <option value="adi_za">İsim (Z-A)</option>
                                        <option value="sayi_azalan">Sayı (Azalan)</option>
                                        <option value="sayi_artan">Sayı (Artan)</option>
                                    </select>
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-sm btn-primary" onclick="lisansSiralamaUygula()">Uygula</button>
                                </div>
                            </div>
                        </div>

                        <!-- Filtre Temizleme Butonu -->
                        <button class="btn btn-sm btn-outline-danger" onclick="lisansTumFiltreleriTemizle()"
                                title="Tüm filtreleri temizle" id="lisansFiltreTemizleBtn" style="display: none;">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>

                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları (mevcut kod) -->
                    <div class="d-flex align-items-center gap-3">
                        <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                            <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                                <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                            </div>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-warning aksiyon-btn" id="seciliDuzenleBtn" data-button-permission="duzenle" title="Seçili Lisans Tipini Düzenle" disabled>
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="btn btn-danger aksiyon-btn" data-button-permission="sil" id="seciliSilBtn" title="Seçili Lisans Tipini Sil" disabled>
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Yeni Ekle Butonu -->
                        <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Lisans Tipi Ekle
                        </button>
                    </div>
                </div>

                <!-- Aktif Filtreler -->
                <div class="row mt-3" id="aktifFiltreler" style="display: none;">
                    <div class="col-12">
                        <div class="d-flex align-items-center">
                            <span class="badge bg-light text-dark me-2 p-2">
                                <i class="fas fa-filter me-1"></i>Aktif Filtreler:
                            </span>
                            <div id="filtreEtiketleri" class="d-flex flex-wrap gap-2"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th width="50">#</th>
                                <th>Lisans Tipi Adı</th>
                                <th>Sayı</th>
                                <th>Eklenme Tarihi</th>
                                <th>Son Güncelleme</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="lisansTablosu">
                            @if (ViewBag.LisansTipleri != null && ((List<LisansTip>)ViewBag.LisansTipleri).Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in (List<LisansTip>)ViewBag.LisansTipleri)
                                {
                                    <tr data-lisans-id="@item.Id" data-lisans-adi="@item.Adi" class="lisans-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input lisans-sec-radio" type="radio" name="seciliLisansRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td><strong>@item.Adi</strong></td>
                                        <td>@(item.Sayi?.ToString() ?? "-")</td>
                                        <td>@item.EklenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@item.GuncellenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">
                                        <div class="py-4">
                                            <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                            <p class="text-muted">Henüz lisans tipi eklenmemiş.</p>
                                            <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                                                İlk Lisans Tipini Ekle
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1" aria-labelledby="ekleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminLisansTip", FormMethod.Post, new { id = "ekleForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="ekleModalLabel">Yeni Lisans Tipi Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="Adi" class="form-label">Lisans Tipi Adı *</label>
                        <input type="text" class="form-control" id="Adi" name="Adi" placeholder="Lisans tipi adını giriniz" required maxlength="100">
                        <div class="form-text">Lisans tipi adı benzersiz olmalıdır.</div>
                    </div>
                    <div class="mb-3">
                        <label for="Sayi" class="form-label">Sayı</label>
                        <input type="number" class="form-control" id="Sayi" name="Sayi" placeholder="Sayı giriniz (opsiyonel)" min="0">
                        <div class="form-text">Bu alan opsiyonel, sadece sayı girilebilir.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1" aria-labelledby="duzenleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Guncelle", "AdminLisansTip")" method="post" id="duzenleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="duzenleModalLabel">Lisans Tipi Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editAdi" class="form-label">Lisans Tipi Adı *</label>
                        <input type="text" class="form-control" id="editAdi" name="Adi" required maxlength="100">
                    </div>
                    <div class="mb-3">
                        <label for="editSayi" class="form-label">Sayı</label>
                        <input type="number" class="form-control" id="editSayi" name="Sayi" min="0">
                        <div class="form-text">Boş bırakılabilir.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-labelledby="silModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminLisansTip")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="silId" name="Id">
                <div class="modal-header">
                    <h5 class="modal-title" id="silModalLabel">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silAdi"></span>"</strong> adlı lisans tipini silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <script>
        $(document).ready(function() {
            let suAnSeciliLisansId = null;
            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#lisansTablosu tr[data-lisans-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button')) {
                    const $radio = $(this).find('.lisans-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });
                    // ============= LİSANS TİPİ FİLTRELEME SİSTEMİ =============
        let lisansAktifFiltreler = {
            arama: '',
            baslangicTarih: null,
            bitisTarih: null,
            minSayi: null,
            maxSayi: null,
            siralama: 'yeni'
        };

        // Lisans arama fonksiyonu
        function lisansAramaFiltrele() {
            const aramaInput = document.getElementById('lisansArama');
            const temizleBtn = document.getElementById('lisansAramaTemizle');

            if (aramaInput && temizleBtn) {
                const kelime = aramaInput.value.trim().toLowerCase();

                // Temizle butonunu göster/gizle
                temizleBtn.style.display = kelime ? 'block' : 'none';

                lisansAktifFiltreler.arama = kelime;
                lisansFiltreEtiketleriniGoster();
                lisansFiltreleVeSirala();
            }
        }

        // Arama inputuna event listener ekle
        const aramaInput = document.getElementById('lisansArama');
        const temizleBtn = document.getElementById('lisansAramaTemizle');

        if (aramaInput) {
            aramaInput.addEventListener('input', lisansAramaFiltrele);
            aramaInput.addEventListener('keyup', lisansAramaFiltrele);
        }

        if (temizleBtn) {
            temizleBtn.addEventListener('click', function () {
                aramaInput.value = '';
                lisansAramaFiltrele();
                aramaInput.focus();
            });
        }

        // Tarih Filtresi Uygula
        window.lisansTarihFiltreUygula = function() {
            const baslangicInput = document.getElementById('filtreBaslangicTarih');
            const bitisInput = document.getElementById('filtreBitisTarih');

            lisansAktifFiltreler.baslangicTarih = baslangicInput.value || null;
            lisansAktifFiltreler.bitisTarih = bitisInput.value || null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('tarihFiltreBtn'));
            if (dropdown) dropdown.hide();

            lisansFiltreEtiketleriniGoster();
            lisansFiltreleVeSirala();
        };

        // Tarih Filtresi Temizle
        window.lisansTarihFiltreTemizle = function() {
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';
            lisansAktifFiltreler.baslangicTarih = null;
            lisansAktifFiltreler.bitisTarih = null;
            lisansFiltreEtiketleriniGoster();
            lisansFiltreleVeSirala();
        };

        // Sayı Filtresi Uygula
        window.lisansSayiFiltreUygula = function() {
            const minInput = document.getElementById('filtreMinSayi');
            const maxInput = document.getElementById('filtreMaxSayi');

            lisansAktifFiltreler.minSayi = minInput.value ? parseInt(minInput.value) : null;
            lisansAktifFiltreler.maxSayi = maxInput.value ? parseInt(maxInput.value) : null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('sayiFiltreBtn'));
            if (dropdown) dropdown.hide();

            lisansFiltreEtiketleriniGoster();
            lisansFiltreleVeSirala();
        };

        // Sayı Filtresi Temizle
        window.lisansSayiFiltreTemizle = function() {
            document.getElementById('filtreMinSayi').value = '';
            document.getElementById('filtreMaxSayi').value = '';
            lisansAktifFiltreler.minSayi = null;
            lisansAktifFiltreler.maxSayi = null;
            lisansFiltreEtiketleriniGoster();
            lisansFiltreleVeSirala();
        };

        // Sıralama Uygula
        window.lisansSiralamaUygula = function() {
            const siralama = document.getElementById('siralamaFiltre').value;
            lisansAktifFiltreler.siralama = siralama;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('siralamaFiltreBtn'));
            if (dropdown) dropdown.hide();

            lisansFiltreEtiketleriniGoster();
            lisansFiltreleVeSirala();
        };

        // Tüm Filtreleri Temizle
        window.lisansTumFiltreleriTemizle = function() {
            // Arama kutusunu temizle
            document.getElementById('lisansArama').value = '';
            document.getElementById('lisansAramaTemizle').style.display = 'none';

            // Tarih filtrelerini temizle
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';

            // Sayı filtrelerini temizle
            document.getElementById('filtreMinSayi').value = '';
            document.getElementById('filtreMaxSayi').value = '';

            // Sıralamayı varsayılana getir
            document.getElementById('siralamaFiltre').value = 'yeni';

            // Buton stillerini sıfırla
            document.getElementById('tarihFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('sayiFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('siralamaFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';

            // Filtre değişkenlerini sıfırla
            lisansAktifFiltreler = {
                arama: '',
                baslangicTarih: null,
                bitisTarih: null,
                minSayi: null,
                maxSayi: null,
                siralama: 'yeni'
            };

            // Filtre etiketlerini gizle
            document.getElementById('aktifFiltreler').style.display = 'none';
            document.getElementById('lisansFiltreTemizleBtn').style.display = 'none';

            // Filtrelemeyi yeniden uygula
            lisansFiltreleVeSirala();
        };

        // Filtre etiketlerini göster
        function lisansFiltreEtiketleriniGoster() {
            const etiketler = [];
            const filtreTemizleBtn = document.getElementById('lisansFiltreTemizleBtn');

            if (lisansAktifFiltreler.arama) {
                etiketler.push(`<span class="badge bg-primary">Arama: ${lisansAktifFiltreler.arama}</span>`);
            }

            if (lisansAktifFiltreler.baslangicTarih) {
                etiketler.push(`<span class="badge bg-primary">Başlangıç: ${formatLisansDate(lisansAktifFiltreler.baslangicTarih)}</span>`);
            }
            if (lisansAktifFiltreler.bitisTarih) {
                etiketler.push(`<span class="badge bg-primary">Bitiş: ${formatLisansDate(lisansAktifFiltreler.bitisTarih)}</span>`);
            }

            if (lisansAktifFiltreler.minSayi !== null && lisansAktifFiltreler.maxSayi !== null) {
                etiketler.push(`<span class="badge bg-success">Sayı: ${lisansAktifFiltreler.minSayi} - ${lisansAktifFiltreler.maxSayi}</span>`);
            } else if (lisansAktifFiltreler.minSayi !== null) {
                etiketler.push(`<span class="badge bg-success">Min Sayı: ${lisansAktifFiltreler.minSayi}</span>`);
            } else if (lisansAktifFiltreler.maxSayi !== null) {
                etiketler.push(`<span class="badge bg-success">Max Sayı: ${lisansAktifFiltreler.maxSayi}</span>`);
            }

            if (lisansAktifFiltreler.siralama !== 'yeni') {
                const siralamaMetin = {
                    'eski': 'En Eski',
                    'adi_az': 'İsim (A-Z)',
                    'adi_za': 'İsim (Z-A)',
                    'sayi_azalan': 'Sayı (Azalan)',
                    'sayi_artan': 'Sayı (Artan)'
                };
                etiketler.push(`<span class="badge bg-info">Sıralama: ${siralamaMetin[lisansAktifFiltreler.siralama]}</span>`);
            }

            if (etiketler.length > 0) {
                document.getElementById('filtreEtiketleri').innerHTML = etiketler.join(' ');
                document.getElementById('aktifFiltreler').style.display = 'block';
                filtreTemizleBtn.style.display = 'inline-block';

                // Buton stillerini güncelle
                document.getElementById('tarihFiltreBtn').className = lisansAktifFiltreler.baslangicTarih || lisansAktifFiltreler.bitisTarih
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('sayiFiltreBtn').className = lisansAktifFiltreler.minSayi !== null || lisansAktifFiltreler.maxSayi !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';
            } else {
                document.getElementById('aktifFiltreler').style.display = 'none';
                filtreTemizleBtn.style.display = 'none';
            }
        }

        // Tarih formatlama
        function formatLisansDate(dateStr) {
            if (!dateStr) return '';
            const [yil, ay, gun] = dateStr.split('-');
            return `${gun}.${ay}.${yil}`;
        }

        // Lisans tarih parse (dd.MM.yyyy HH:mm formatı)
        function lisansParseDate(dateStr) {
            if (!dateStr) return null;
            const [gun, ay, yilSaat] = dateStr.split('.');
            const [yil, saat] = yilSaat.split(' ');
            return new Date(`${yil}-${ay}-${gun}T${saat}`);
        }

        // Ana filtreleme ve sıralama fonksiyonu
        function lisansFiltreleVeSirala() {
            const tbody = document.getElementById('lisansTablosu');
            if (!tbody) return;

            const satirlar = Array.from(tbody.querySelectorAll('tr.lisans-satiri'));

            if (satirlar.length === 0) return;

            // Filtreleme
            let filtrelenmisSatirlar = satirlar.filter(satir => {
                let goster = true;

                // Arama filtresi (Lisans Adı - 3. sütun)
                if (lisansAktifFiltreler.arama) {
                    const adi = satir.querySelector('td:nth-child(3)')?.textContent.toLowerCase() || '';
                    if (!adi.includes(lisansAktifFiltreler.arama.toLowerCase())) {
                        goster = false;
                    }
                }

                // Tarih filtresi (5. sütun - Eklenme Tarihi)
                if (goster && (lisansAktifFiltreler.baslangicTarih || lisansAktifFiltreler.bitisTarih)) {
                    const tarihTd = satir.querySelector('td:nth-child(5)')?.textContent.trim();
                    if (tarihTd) {
                        const tarih = lisansParseDate(tarihTd);

                        if (lisansAktifFiltreler.baslangicTarih) {
                            const filtreBaslangic = new Date(lisansAktifFiltreler.baslangicTarih + 'T00:00:00');
                            if (tarih < filtreBaslangic) {
                                goster = false;
                            }
                        }

                        if (goster && lisansAktifFiltreler.bitisTarih) {
                            const filtreBitis = new Date(lisansAktifFiltreler.bitisTarih + 'T23:59:59');
                            if (tarih > filtreBitis) {
                                goster = false;
                            }
                        }
                    }
                }

                // Sayı filtresi (4. sütun)
                if (goster && (lisansAktifFiltreler.minSayi !== null || lisansAktifFiltreler.maxSayi !== null)) {
                    const sayiTd = satir.querySelector('td:nth-child(4)')?.textContent.trim();
                    if (sayiTd && sayiTd !== '-') {
                        const sayi = parseInt(sayiTd);

                        if (lisansAktifFiltreler.minSayi !== null && sayi < lisansAktifFiltreler.minSayi) {
                            goster = false;
                        }

                        if (goster && lisansAktifFiltreler.maxSayi !== null && sayi > lisansAktifFiltreler.maxSayi) {
                            goster = false;
                        }
                    }
                }

                return goster;
            });

            // Sıralama
            switch(lisansAktifFiltreler.siralama) {
                case 'yeni':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = lisansParseDate(a.querySelector('td:nth-child(5)')?.textContent.trim() || '');
                        const tarihB = lisansParseDate(b.querySelector('td:nth-child(5)')?.textContent.trim() || '');
                        return (tarihB || 0) - (tarihA || 0);
                    });
                    break;

                case 'eski':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = lisansParseDate(a.querySelector('td:nth-child(5)')?.textContent.trim() || '');
                        const tarihB = lisansParseDate(b.querySelector('td:nth-child(5)')?.textContent.trim() || '');
                        return (tarihA || 0) - (tarihB || 0);
                    });
                    break;

                case 'adi_az':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiA.localeCompare(adiB, 'tr');
                    });
                    break;

                case 'adi_za':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const adiA = a.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        const adiB = b.querySelector('td:nth-child(3)')?.textContent.trim() || '';
                        return adiB.localeCompare(adiA, 'tr');
                    });
                    break;

                case 'sayi_azalan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const sayiA = parseInt(a.querySelector('td:nth-child(4)')?.textContent.trim()) || 0;
                        const sayiB = parseInt(b.querySelector('td:nth-child(4)')?.textContent.trim()) || 0;
                        return sayiB - sayiA;
                    });
                    break;

                case 'sayi_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const sayiA = parseInt(a.querySelector('td:nth-child(4)')?.textContent.trim()) || 0;
                        const sayiB = parseInt(b.querySelector('td:nth-child(4)')?.textContent.trim()) || 0;
                        return sayiA - sayiB;
                    });
                    break;
            }

            // Tüm satırları gizle
            satirlar.forEach(satir => {
                satir.style.display = 'none';
            });

            // Filtrelenmiş satırları göster ve tbody'ye yeniden ekle (sıralama için)
            filtrelenmisSatirlar.forEach((satir, index) => {
                satir.style.display = '';
                // Sıra numarasını güncelle (2. sütun)
                const siraHucresi = satir.querySelector('td:nth-child(2)');
                if (siraHucresi) {
                    siraHucresi.textContent = index + 1;
                }
                tbody.appendChild(satir);
            });

            // "Gösterilecek kayıt yok" mesajı
            let bosSatir = tbody.querySelector('.filtre-bos-satir');

            if (filtrelenmisSatirlar.length === 0) {
                if (!bosSatir) {
                    bosSatir = document.createElement('tr');
                    bosSatir.className = 'filtre-bos-satir';
                    bosSatir.innerHTML = '<td colspan="7" class="text-center py-5"><i class="fas fa-filter fa-3x text-muted mb-3"></i><p class="text-muted">Filtreleme kriterlerine uygun lisans tipi bulunamadı.</p><button class="btn btn-sm btn-outline-secondary" onclick="lisansTumFiltreleriTemizle()">Filtreleri Temizle</button></td>';
                    tbody.appendChild(bosSatir);
                }
            } else if (bosSatir) {
                bosSatir.remove();
            }
        }

        // Enter tuşu ile filtreleme
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const aktifElement = document.activeElement;
                if (aktifElement.id === 'lisansArama' ||
                    aktifElement.id === 'filtreBaslangicTarih' ||
                    aktifElement.id === 'filtreBitisTarih' ||
                    aktifElement.id === 'filtreMinSayi' ||
                    aktifElement.id === 'filtreMaxSayi') {
                    e.preventDefault();
                    lisansFiltreleVeSirala();
                }
            }
        });
            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.lisans-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliLisansId = $(this).val();
                    const $seciliSatir = $(this).closest('tr');
                    const lisansAdi = $seciliSatir.data('lisans-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#lisansTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    $seciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${lisansAdi}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliLisansId) {
                    duzenleGetir(suAnSeciliLisansId);
                } else {
                    toastr.warning('Lütfen önce bir lisans tipi seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliLisansId) {
                    const $seciliSatir = $(`tr[data-lisans-id="${suAnSeciliLisansId}"]`);
                    const lisansAdi = $seciliSatir.data('lisans-adi');

                    $('#silId').val(suAnSeciliLisansId);
                    $('#silAdi').text(lisansAdi);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir lisans tipi seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme (silme başarılı olursa)
            $('#silModal').on('hidden.bs.modal', function() {
                // Silme başarılı olduysa satır DOM'dan kalkmış olacak, kontrol et
                if (suAnSeciliLisansId) {
                    const $satir = $(`tr[data-lisans-id="${suAnSeciliLisansId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        suAnSeciliLisansId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.lisans-sec-radio[value="${suAnSeciliLisansId}"]`).prop('checked', false);
                        $('#lisansTablosu tr').removeClass('table-active');
                        suAnSeciliLisansId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    }
                }
            });

            // ============= MEVCUT FONKSİYONLAR (AYNEN KORUNDU) =============

            // Silme onay fonksiyonu
            window.silOnay = function(id, adi) {
                $('#silId').val(id);
                $('#silAdi').text(adi);
                new bootstrap.Modal(document.getElementById('silModal')).show();
            };

            // Düzenleme fonksiyonu (API'den veri çeken)
            window.duzenleGetir = async function(id) {
                try {
                    const btn = event.target;
                    const originalHtml = btn.innerHTML;

                    // Loading state
                    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                    btn.disabled = true;

                    const response = await fetch('@Url.Action("Getir", "AdminLisansTip")?id=' + id);

                    if (!response.ok) {
                        const errorData = await response.json().catch(() => null);
                        throw new Error(errorData?.error || `HTTP error! status: ${response.status}`);
                    }

                    const data = await response.json();

                    if (data.error) {
                        throw new Error(data.error);
                    }

                    // Modalı doldur
                    document.getElementById('editId').value = data.id;
                    document.getElementById('editAdi').value = data.adi;
                    document.getElementById('editSayi').value = data.sayi === 0 ? '' : data.sayi;

                    // Modalı göster
                    new bootstrap.Modal(document.getElementById('duzenleModal')).show();

                } catch (error) {
                    console.error('Hata:', error);
                    toastr.error('Lisans tipi bilgileri yüklenirken hata oluştu: ' + error.message);
                } finally {
                    // Butonu eski haline getir
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                }
            };

            // Form validasyonları
            const forms = document.querySelectorAll('#ekleForm, #duzenleForm');
            forms.forEach(form => {
                form.addEventListener('submit', function (e) {
                    const adiInput = this.querySelector('input[name="Adi"]');
                    if (!adiInput.value.trim()) {
                        e.preventDefault();
                        toastr.error('Lisans tipi adı gereklidir.');
                        adiInput.focus();
                    }
                });
            });

            // Modal kapandığında formları temizle
            ['ekleModal', 'duzenleModal'].forEach(modalId => {
                const modalEl = document.getElementById(modalId);
                modalEl.addEventListener('hidden.bs.modal', function () {
                    this.querySelector('form')?.reset();
                });
            });

            // Alert 5 saniye sonra otomatik kapan
            setTimeout(() => {
                document.querySelectorAll('.alert').forEach(alert => {
                    bootstrap.Alert.getOrCreateInstance(alert).close();
                });
            }, 5000);
        });
    </script>

