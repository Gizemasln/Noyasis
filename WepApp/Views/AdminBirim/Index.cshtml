@using WepApp.Models
@{
    ViewData["Title"] = "Birim Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    /* Seçim satırı için cursor pointer */
    tr[data-birim-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    /* Buton grupları için */
    .btn-group .btn {
        margin: 0 2px;
    }

        .btn-group .btn:first-child {
            margin-left: 0;
        }

        .btn-group .btn:last-child {
            margin-right: 0;
        }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card" style="margin-top: 70px;">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Birimler</h5>
                <div class="d-flex align-items-center gap-3">
                    <!-- Seçili Kayıt Bilgisi ve İşlem Butonları -->
                    <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                        <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                            <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                        </div>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-warning btn-sm" id="seciliDuzenleBtn" data-button-permission="duzenle" title="Seçili Birimi Düzenle" disabled style="margin-right:5px;">
                                <i class="fas fa-edit"></i> 
                            </button>
                            <button type="button" class="btn btn-danger btn-sm" id="seciliSilBtn" data-button-permission="sil" title="Seçili Birimi Sil" disabled>
                                <i class="fas fa-trash"></i> 
                            </button>
                        </div>
                    </div>

                    <!-- Yeni Ekle Butonu -->
                    <button class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                        <i class="fas fa-plus"></i> Yeni Birim Ekle
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th>#</th>
                                <th>Birim Adı</th>
                                <th>Eklenme Tarihi</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="birimTablosu">
                            @if (ViewBag.Birimler != null && ViewBag.Birimler.Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in ViewBag.Birimler)
                                {
                                    <tr data-birim-id="@item.Id" data-birim-adi="@item.Adi" class="birim-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input birim-sec-radio" type="radio" name="seciliBirimRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td><strong>@item.Adi</strong></td>
                                        <td>@item.EklenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                        <!-- İşlemler sütunundaki butonlar KALDIRILDI -->
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4">
                                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                        <p>Henüz birim eklenmemiş.</p>
                                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ekleModal">
                                            İlk Birimi Ekle
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminBirim", FormMethod.Post, new { id = "ekleForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Birim Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Birim Adı *</label>
                        <input type="text" class="form-control" name="Adi" id="Adi" placeholder="Ör: Adet, Kutu" required oninput="kontrolEtAdi()">
                        <div id="adiMesaj" class="form-text"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary" disabled>Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Guncelle", "AdminBirim")" method="post" id="duzenleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editId">
                <div class="modal-header">
                    <h5 class="modal-title">Birim Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Birim Adı *</label>
                        <input type="text" class="form-control" name="Adi" id="editAdi" required oninput="kontrolEtAdi(true)">
                        <div id="editAdiMesaj" class="form-text"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary" disabled>Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Modal -->
<div class="modal fade" id="silModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminBirim")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="silId">
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p><strong id="silAdiGoster"></strong> birimini pasif yapmak istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            // Toastr ayarları
            toastr.options = {
                "closeButton": true,
                "progressBar": true,
                "positionClass": "toast-top-right",
                "timeOut": "5000"
            };

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============
            let suAnSeciliBirimId = null;
            let suAnSeciliBirimAdi = null;
            let suAnSeciliSatir = null;

            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#birimTablosu tr[data-birim-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button') && !$(e.target).is('a')) {
                    const $radio = $(this).find('.birim-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.birim-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliBirimId = $(this).val();
                    suAnSeciliSatir = $(this).closest('tr');
                    suAnSeciliBirimAdi = suAnSeciliSatir.data('birim-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#birimTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    suAnSeciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${suAnSeciliBirimAdi}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliBirimId) {
                    duzenleGetir(suAnSeciliBirimId, suAnSeciliBirimAdi);
                } else {
                    toastr.warning('Lütfen önce bir birim seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliBirimId) {
                    $('#silId').val(suAnSeciliBirimId);
                    $('#silAdiGoster').text(suAnSeciliBirimAdi);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir birim seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliBirimId) {
                    const $satir = $(`tr[data-birim-id="${suAnSeciliBirimId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        clearSelection();
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.birim-sec-radio[value="${suAnSeciliBirimId}"]`).prop('checked', false);
                        clearSelection();
                    }
                }
            });

            // Seçimi temizleme yardımcı fonksiyonu
            function clearSelection() {
                $('#birimTablosu tr').removeClass('table-active');
                suAnSeciliBirimId = null;
                suAnSeciliBirimAdi = null;
                suAnSeciliSatir = null;
                $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                // Tüm butonları devre dışı bırak
                $seciliDuzenleBtn.prop('disabled', true);
                $seciliSilBtn.prop('disabled', true);
            }

            $('#ekleModal').on('show.bs.modal', () => {
                duzenleme = false;
                adiGecerli = false;
                $('#adiMesaj').empty();
                guncelleButon();
            });

            setTimeout(() => $('.alert').each((i, el) => bootstrap.Alert.getOrCreateInstance(el).close()), 5000);
        });

        let adiGecerli = false;
        let duzenleme = false;

        function kontrolEtAdi(duzenle = false) {
            const input = duzenle ? $('#editAdi') : $('#Adi');
            const mesaj = duzenle ? $('#editAdiMesaj') : $('#adiMesaj');
            const val = input.val().trim();
            const birimId = duzenle ? $('#editId').val() : null;
            if (val === '') {
                mesaj.html('<small class="text-muted">Birim adı giriniz.</small>');
                adiGecerli = false;
            } else if (val.length < 2) {
                mesaj.html('<small class="text-warning">En az 2 karakter.</small>');
                adiGecerli = false;
            } else {
                fetch(`@Url.Action("AdiKontrol", "AdminBirim")?adi=${encodeURIComponent(val)}&birimId=${birimId || ''}`)
                    .then(r => r.json())
                    .then(d => {
                        if (d.success) {
                            mesaj.html(`<small class="text-success">${d.message}</small>`);
                            adiGecerli = true;
                        } else {
                            mesaj.html(`<small class="text-danger">${d.message}</small>`);
                            adiGecerli = false;
                        }
                        guncelleButon();
                    });
                return;
            }
            guncelleButon();
        }

        function guncelleButon() {
            const modal = duzenleme ? '#duzenleModal' : '#ekleModal';
            $(modal).find('button[type="submit"]').prop('disabled', !adiGecerli);
        }

        function duzenleGetir(id, adi) {
            $('#editId').val(id);
            $('#editAdi').val(adi);
            duzenleme = true;
            adiGecerli = true;
            guncelleButon();
            kontrolEtAdi(true);
            new bootstrap.Modal(document.getElementById('duzenleModal')).show();
        }

        // Sadece ID ile silme onayı
        function silOnay(id) {
            $('#silId').val(id);
            new bootstrap.Modal(document.getElementById('silModal')).show();
        }
    </script>
}