                    </div>
                    <hr>
                    <h6 class="border-bottom pb-2">Kampanya İçeriği</h6>
                    <div class="mb-3">
                        <input type="text" id="editGenelArama" class="form-control" placeholder="Modül veya paket ara...">
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="editSelectAllTumu">
                        <label class="form-check-label fw-bold" for="editSelectAllTumu">Tümünü Seç</label>
                    </div>
                    <div class="single-table-container">
                        <table class="table table-sm table-hover paket-table">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th width="50">Seç</th>
                                    <th width="80">Tür</th>
                                    <th>Adı</th>
                                    <th>Detay</th>
                                    <th width="120" class="text-end">Fiyat</th>
                                </tr>
                            </thead>
                            <tbody id="editBirlesikListe"></tbody>
                        </table>
                    </div>
                    <div class="summary-info mt-3">
                        <div class="summary-item"><span>Seçili Paket Grupları:</span> <strong id="editSeciliPaketGrupSayisi">0</strong></div>
                        <div class="summary-item"><span>Seçili Paketler:</span> <strong id="editSeciliPaketSayisi">0</strong></div>
                        <div class="summary-item"><span>Toplam İçerik:</span> <strong id="editToplamIcerikSayisi" class="text-success">0</strong></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>İptal
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Güncelle
                    </button>
                </div>
            </form>
        </div>
