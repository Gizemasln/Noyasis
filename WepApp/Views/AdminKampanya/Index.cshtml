@section Script {
    <script>
        let silinecekGorselId = null;
        let seciliKampanyaId = 0;
        let seciliKampanyaBaslik = '';
                // ============= KAMPANYA FİLTRELEME SİSTEMİ (Sözleşmeler sayfasından uyarlandı) =============
        let kampanyaAktifFiltreler = {
            arama: '',
            baslangicTarih: null,
            bitisTarih: null,
            minIndirim: null,
            maxIndirim: null,
            siralama: 'yeni'
        };

        // Kampanya arama fonksiyonu
        document.addEventListener('DOMContentLoaded', function () {
            const aramaInput = document.getElementById('kampanyaArama');
            const temizleBtn = document.getElementById('kampanyaAramaTemizle');

            if (aramaInput && temizleBtn) {
                function kampanyaAramaFiltrele() {
                    const kelime = aramaInput.value.trim().toLowerCase();

                    // Temizle butonunu göster/gizle
                    temizleBtn.style.display = kelime ? 'block' : 'none';

                    kampanyaAktifFiltreler.arama = kelime;
                    kampanyaFiltreleVeSirala();
                }

                aramaInput.addEventListener('input', kampanyaAramaFiltrele);
                aramaInput.addEventListener('keyup', kampanyaAramaFiltrele);

                temizleBtn.addEventListener('click', function () {
                    aramaInput.value = '';
                    kampanyaAramaFiltrele();
                    aramaInput.focus();
                });
            }
        });

        // Tarih Filtresi Uygula
        function kampanyaTarihFiltreUygula() {
            const baslangicInput = document.getElementById('filtreBaslangicTarih');
            const bitisInput = document.getElementById('filtreBitisTarih');

            kampanyaAktifFiltreler.baslangicTarih = baslangicInput.value || null;
            kampanyaAktifFiltreler.bitisTarih = bitisInput.value || null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('tarihFiltreBtn'));
            if (dropdown) dropdown.hide();

            kampanyaFiltreEtiketleriniGoster();
            kampanyaFiltreleVeSirala();
        }

        // Tarih Filtresi Temizle
        function kampanyaTarihFiltreTemizle() {
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';
            kampanyaAktifFiltreler.baslangicTarih = null;
            kampanyaAktifFiltreler.bitisTarih = null;
            kampanyaFiltreEtiketleriniGoster();
            kampanyaFiltreleVeSirala();
        }

        // İndirim Filtresi Uygula
        function kampanyaIndirimFiltreUygula() {
            const minInput = document.getElementById('filtreMinIndirim');
            const maxInput = document.getElementById('filtreMaxIndirim');

            kampanyaAktifFiltreler.minIndirim = minInput.value ? parseFloat(minInput.value) : null;
            kampanyaAktifFiltreler.maxIndirim = maxInput.value ? parseFloat(maxInput.value) : null;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('indirimFiltreBtn'));
            if (dropdown) dropdown.hide();

            kampanyaFiltreEtiketleriniGoster();
            kampanyaFiltreleVeSirala();
        }

        // İndirim Filtresi Temizle
        function kampanyaIndirimFiltreTemizle() {
            document.getElementById('filtreMinIndirim').value = '';
            document.getElementById('filtreMaxIndirim').value = '';
            kampanyaAktifFiltreler.minIndirim = null;
            kampanyaAktifFiltreler.maxIndirim = null;
            kampanyaFiltreEtiketleriniGoster();
            kampanyaFiltreleVeSirala();
        }

        // Sıralama Uygula
        function kampanyaSiralamaUygula() {
            const siralama = document.getElementById('siralamaFiltre').value;
            kampanyaAktifFiltreler.siralama = siralama;

            // Dropdown'u kapat
            const dropdown = bootstrap.Dropdown.getInstance(document.getElementById('siralamaFiltreBtn'));
            if (dropdown) dropdown.hide();

            kampanyaFiltreEtiketleriniGoster();
            kampanyaFiltreleVeSirala();
        }

        // Tüm Filtreleri Temizle
        function kampanyaTumFiltreleriTemizle() {
            // Arama kutusunu temizle
            document.getElementById('kampanyaArama').value = '';
            document.getElementById('kampanyaAramaTemizle').style.display = 'none';

            // Tarih filtrelerini temizle
            document.getElementById('filtreBaslangicTarih').value = '';
            document.getElementById('filtreBitisTarih').value = '';

            // İndirim filtrelerini temizle
            document.getElementById('filtreMinIndirim').value = '';
            document.getElementById('filtreMaxIndirim').value = '';

            // Sıralamayı varsayılana getir
            document.getElementById('siralamaFiltre').value = 'yeni';

            // Buton stillerini sıfırla
            document.getElementById('tarihFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('indirimFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';
            document.getElementById('siralamaFiltreBtn').className = 'btn btn-sm btn-outline-secondary dropdown-toggle';

            // Filtre değişkenlerini sıfırla
            kampanyaAktifFiltreler = {
                arama: '',
                baslangicTarih: null,
                bitisTarih: null,
                minIndirim: null,
                maxIndirim: null,
                siralama: 'yeni'
            };

            // Filtre etiketlerini gizle
            document.getElementById('aktifFiltreler').style.display = 'none';
            document.getElementById('kampanyaFiltreTemizleBtn').style.display = 'none';

            // Filtrelemeyi yeniden uygula
            kampanyaFiltreleVeSirala();
        }

        // Filtre etiketlerini göster
        function kampanyaFiltreEtiketleriniGoster() {
            const etiketler = [];
            const filtreTemizleBtn = document.getElementById('kampanyaFiltreTemizleBtn');

            if (kampanyaAktifFiltreler.arama) {
                etiketler.push(`<span class="badge bg-primary">Arama: ${kampanyaAktifFiltreler.arama}</span>`);
            }

            if (kampanyaAktifFiltreler.baslangicTarih) {
                etiketler.push(`<span class="badge bg-primary">Başlangıç: ${formatKampanyaDate(kampanyaAktifFiltreler.baslangicTarih)}</span>`);
            }
            if (kampanyaAktifFiltreler.bitisTarih) {
                etiketler.push(`<span class="badge bg-primary">Bitiş: ${formatKampanyaDate(kampanyaAktifFiltreler.bitisTarih)}</span>`);
            }

            if (kampanyaAktifFiltreler.minIndirim !== null && kampanyaAktifFiltreler.maxIndirim !== null) {
                etiketler.push(`<span class="badge bg-success">İndirim: %${kampanyaAktifFiltreler.minIndirim} - %${kampanyaAktifFiltreler.maxIndirim}</span>`);
            } else if (kampanyaAktifFiltreler.minIndirim !== null) {
                etiketler.push(`<span class="badge bg-success">Min İndirim: %${kampanyaAktifFiltreler.minIndirim}</span>`);
            } else if (kampanyaAktifFiltreler.maxIndirim !== null) {
                etiketler.push(`<span class="badge bg-success">Max İndirim: %${kampanyaAktifFiltreler.maxIndirim}</span>`);
            }

            if (kampanyaAktifFiltreler.siralama !== 'yeni') {
                const siralamaMetin = {
                    'eski': 'En Eski',
                    'baslik': 'Başlık (A-Z)',
                    'indirim': 'İndirim % (Azalan)',
                    'indirim_artan': 'İndirim % (Artan)'
                };
                etiketler.push(`<span class="badge bg-info">Sıralama: ${siralamaMetin[kampanyaAktifFiltreler.siralama]}</span>`);
            }

            if (etiketler.length > 0) {
                document.getElementById('filtreEtiketleri').innerHTML = etiketler.join(' ');
                document.getElementById('aktifFiltreler').style.display = 'block';
                filtreTemizleBtn.style.display = 'inline-block';

                // Buton stillerini güncelle
                document.getElementById('tarihFiltreBtn').className = kampanyaAktifFiltreler.baslangicTarih || kampanyaAktifFiltreler.bitisTarih
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';

                document.getElementById('indirimFiltreBtn').className = kampanyaAktifFiltreler.minIndirim !== null || kampanyaAktifFiltreler.maxIndirim !== null
                    ? 'btn btn-sm btn-primary dropdown-toggle'
                    : 'btn btn-sm btn-outline-secondary dropdown-toggle';
            } else {
                document.getElementById('aktifFiltreler').style.display = 'none';
                filtreTemizleBtn.style.display = 'none';
            }
        }

        // Tarih formatlama
        function formatKampanyaDate(dateStr) {
            if (!dateStr) return '';
            const [yil, ay, gun] = dateStr.split('-');
            return `${gun}.${ay}.${yil}`;
        }

        // Kampanya tarih parse
        function kampanyaParseDate(dateStr) {
            if (!dateStr) return null;
            // Format: dd.MM.yyyy HH:mm
            const [gun, ay, yilSaat] = dateStr.split('.');
            const [yil, saat] = yilSaat.split(' ');
            return new Date(`${yil}-${ay}-${gun}T${saat}`);
        }

        // Ana filtreleme ve sıralama fonksiyonu
        function kampanyaFiltreleVeSirala() {
            const tablo = document.getElementById('kampanyaTablosu');
            if (!tablo) return;

            const tbody = tablo.querySelector('tbody');
            if (!tbody) return;

            const satirlar = Array.from(tbody.querySelectorAll('tr.kampanya-satiri'));

            if (satirlar.length === 0) return;

            // Filtreleme
            let filtrelenmisSatirlar = satirlar.filter(satir => {
                let goster = true;

                // Arama filtresi (Başlık)
                if (kampanyaAktifFiltreler.arama) {
                    const baslik = satir.querySelector('td:nth-child(4)')?.textContent.toLowerCase() || '';
                    if (!baslik.includes(kampanyaAktifFiltreler.arama.toLowerCase())) {
                        goster = false;
                    }
                }

                // Tarih filtresi
                if (goster && (kampanyaAktifFiltreler.baslangicTarih || kampanyaAktifFiltreler.bitisTarih)) {
                    const baslangicTd = satir.querySelector('td:nth-child(7)')?.textContent.trim();
                    const bitisTd = satir.querySelector('td:nth-child(8)')?.textContent.trim();

                    if (baslangicTd && bitisTd) {
                        const baslangicTarih = kampanyaParseDate(baslangicTd);
                        const bitisTarih = kampanyaParseDate(bitisTd);

                        if (kampanyaAktifFiltreler.baslangicTarih) {
                            const filtreBaslangic = new Date(kampanyaAktifFiltreler.baslangicTarih + 'T00:00:00');
                            if (bitisTarih < filtreBaslangic) {
                                goster = false;
                            }
                        }

                        if (goster && kampanyaAktifFiltreler.bitisTarih) {
                            const filtreBitis = new Date(kampanyaAktifFiltreler.bitisTarih + 'T23:59:59');
                            if (baslangicTarih > filtreBitis) {
                                goster = false;
                            }
                        }
                    }
                }

                // İndirim filtresi
                if (goster && (kampanyaAktifFiltreler.minIndirim !== null || kampanyaAktifFiltreler.maxIndirim !== null)) {
                    const indirimTd = satir.querySelector('td:nth-child(6)')?.textContent.trim();
                    if (indirimTd) {
                        const indirim = parseFloat(indirimTd.replace('%', ''));

                        if (kampanyaAktifFiltreler.minIndirim !== null && indirim < kampanyaAktifFiltreler.minIndirim) {
                            goster = false;
                        }

                        if (goster && kampanyaAktifFiltreler.maxIndirim !== null && indirim > kampanyaAktifFiltreler.maxIndirim) {
                            goster = false;
                        }
                    }
                }

                return goster;
            });

            // Sıralama
            switch(kampanyaAktifFiltreler.siralama) {
                case 'yeni':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = kampanyaParseDate(a.querySelector('td:nth-child(7)')?.textContent.trim() || '');
                        const tarihB = kampanyaParseDate(b.querySelector('td:nth-child(7)')?.textContent.trim() || '');
                        return (tarihB || 0) - (tarihA || 0);
                    });
                    break;

                case 'eski':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const tarihA = kampanyaParseDate(a.querySelector('td:nth-child(7)')?.textContent.trim() || '');
                        const tarihB = kampanyaParseDate(b.querySelector('td:nth-child(7)')?.textContent.trim() || '');
                        return (tarihA || 0) - (tarihB || 0);
                    });
                    break;

                case 'baslik':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const baslikA = a.querySelector('td:nth-child(4)')?.textContent.trim() || '';
                        const baslikB = b.querySelector('td:nth-child(4)')?.textContent.trim() || '';
                        return baslikA.localeCompare(baslikB, 'tr');
                    });
                    break;

                case 'indirim':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const indirimA = parseFloat(a.querySelector('td:nth-child(6)')?.textContent.replace('%', '') || '0');
                        const indirimB = parseFloat(b.querySelector('td:nth-child(6)')?.textContent.replace('%', '') || '0');
                        return indirimB - indirimA;
                    });
                    break;

                case 'indirim_artan':
                    filtrelenmisSatirlar.sort((a, b) => {
                        const indirimA = parseFloat(a.querySelector('td:nth-child(6)')?.textContent.replace('%', '') || '0');
                        const indirimB = parseFloat(b.querySelector('td:nth-child(6)')?.textContent.replace('%', '') || '0');
                        return indirimA - indirimB;
                    });
                    break;
            }

            // Tüm satırları gizle
            satirlar.forEach(satir => {
                satir.style.display = 'none';
            });

            // Filtrelenmiş satırları göster ve tbody'ye yeniden ekle (sıralama için)
            filtrelenmisSatirlar.forEach((satir, index) => {
                satir.style.display = '';
                // Sıra numarasını güncelle
                const siraHucresi = satir.querySelector('td:first-child');
                if (siraHucresi) {
                    siraHucresi.textContent = index + 1;
                }
                tbody.appendChild(satir);
            });

            // "Gösterilecek kayıt yok" mesajı
            let bosSatir = tbody.querySelector('.filtre-bos-satir');

            if (filtrelenmisSatirlar.length === 0) {
                if (!bosSatir) {
                    bosSatir = document.createElement('tr');
                    bosSatir.className = 'filtre-bos-satir';
                    bosSatir.innerHTML = '<td colspan="10" class="text-center py-5"><i class="fas fa-filter fa-3x text-muted mb-3"></i><p class="text-muted">Filtreleme kriterlerine uygun kampanya bulunamadı.</p><button class="btn btn-sm btn-outline-secondary" onclick="kampanyaTumFiltreleriTemizle()">Filtreleri Temizle</button></td>';
                    tbody.appendChild(bosSatir);
                }
            } else if (bosSatir) {
                bosSatir.remove();
            }
        }

        // Enter tuşu ile filtreleme
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                const aktifElement = document.activeElement;
                if (aktifElement.id === 'kampanyaArama' ||
                    aktifElement.id === 'filtreBaslangicTarih' ||
                    aktifElement.id === 'filtreBitisTarih' ||
                    aktifElement.id === 'filtreMinIndirim' ||
                    aktifElement.id === 'filtreMaxIndirim') {
                    e.preventDefault();
                    kampanyaFiltreleVeSirala();
                }
            }
        });
        // Görsel önizleme fonksiyonu
        function previewImage(input, previewId) {
            const preview = document.getElementById(previewId);
            preview.innerHTML = '';

            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'modal-gorsel-preview';
                    img.alt = 'Görsel önizleme';
                    preview.appendChild(img);
                }

                reader.readAsDataURL(input.files[0]);
            }
        }

        // Görsel büyütme fonksiyonu
        function gorselGoster(gorselYolu) {
            document.getElementById('modalGorsel').src = gorselYolu;
            var gorselModal = new bootstrap.Modal(document.getElementById('gorselModal'));
            gorselModal.show();
        }

        // ÖZET GÜNCELLEME (ekle ve düzenle modalı için ortak)
        function updateSummary(prefix = '') {
            const paketSelector = prefix
                ? `input[name="${prefix}seciliPaketler"]:checked`
                : `input[name="seciliPaketler"]:checked`;

            const grupSelector = prefix
                ? `input[name="${prefix}seciliPaketGruplari"]:checked`
                : `input[name="seciliPaketGruplari"]:checked`;

            const paketSayisi = document.querySelectorAll(paketSelector).length;
            const grupSayisi = document.querySelectorAll(grupSelector).length;

            // ID'leri doğru büyük harfle oluştur
            const paketId = prefix ? `${prefix}SeciliPaketSayisi` : 'seciliPaketSayisi';
            const grupId   = prefix ? `${prefix}SeciliPaketGrupSayisi` : 'seciliPaketGrupSayisi';
            const toplamId = prefix ? `${prefix}ToplamIcerikSayisi` : 'toplamIcerikSayisi';

            const elPaket = document.getElementById(paketId);
            const elGrup  = document.getElementById(grupId);
            const elToplam = document.getElementById(toplamId);

            if (elPaket)  elPaket.textContent  = paketSayisi;
            if (elGrup)   elGrup.textContent   = grupSayisi;
            if (elToplam) elToplam.textContent = paketSayisi + grupSayisi;
        }

        // GENEL ARAMA (ekle ve düzenle modalı için)
        function genelArama(inputId, tbodyId) {
            const term = document.getElementById(inputId).value.toLowerCase();
            document.querySelectorAll(`#${tbodyId} tr`).forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(term) ? '' : 'none';
            });
        }

        // Seçili kampanya sayısını güncelle
        function seciliKampanyaSayisiniGuncelle() {
            const tumCheckboxlar = document.querySelectorAll('.kampanya-sec-checkbox');
            const seciliCheckboxlar = document.querySelectorAll('.kampanya-sec-checkbox:checked');
            const sayi = seciliCheckboxlar.length;
            const gosterge = document.getElementById('seciliKampanyaGosterge');
            const metinSpan = document.getElementById('seciliKampanyaMetin');

            // Eğer birden fazla seçiliyse → sadece son seçileni bırak (tek seçim zorla)
            if (sayi > 1) {
                const sonSecili = seciliCheckboxlar[seciliCheckboxlar.length - 1];
                tumCheckboxlar.forEach(cb => {
                    if (cb !== sonSecili) cb.checked = false;
                });
                return seciliKampanyaSayisiniGuncelle();
            }

            if (sayi === 0) {
                gosterge.classList.add('d-none');
                metinSpan.textContent = '';

                // Butonları devre dışı bırak
                document.getElementById('topluKampanyaDuzenleBtn').disabled = true;
                document.getElementById('topluKampanyaSilBtn').disabled = true;

                seciliKampanyaId = 0;
                seciliKampanyaBaslik = '';
            }
            else if (sayi === 1) {
                // Tek kampanya seçili
                const seciliTr = seciliCheckboxlar[0].closest('tr');
                const baslikTd = seciliTr.querySelector('td:nth-child(4)'); // Başlık sütunu (4. td)
                let baslik = baslikTd ? baslikTd.textContent.trim() : 'Kampanya';

                // Çok uzunsa kısalt
                if (baslik.length > 30) {
                    baslik = baslik.substring(0, 27) + '...';
                }

                seciliKampanyaId = seciliCheckboxlar[0].value;
                seciliKampanyaBaslik = baslik;

                metinSpan.textContent = `"${baslik}" seçili`;
                gosterge.classList.remove('d-none');

                // Butonları aktif et
                document.getElementById('topluKampanyaDuzenleBtn').disabled = false;
                document.getElementById('topluKampanyaSilBtn').disabled = false;
            }
        }

        // Seçili kampanya için işlem yap
        function seciliKampanyaIslem(tip) {
            const secili = document.querySelector('.kampanya-sec-checkbox:checked');
            if (!secili) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Uyarı',
                    text: 'Lütfen önce bir kampanya seçin!'
                });
                return;
            }

            const kampanyaId = secili.value;

            switch(tip) {
                case 'duzenle':
                    duzenleGetir(kampanyaId);
                    break;
                case 'sil':
                    silOnay(kampanyaId, seciliKampanyaBaslik);
                    break;
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            // Ekle modalı başlangıç değerleri
            updateSummary();

            // === EKLE MODALI EVENTLERI ===
            const genelAramaInput = document.getElementById('genelArama');
            if (genelAramaInput) {
                genelAramaInput.addEventListener('input', () => genelArama('genelArama', 'birlesikListe'));
            }

            const selectAllTumu = document.getElementById('selectAllTumu');
            if (selectAllTumu) {
                selectAllTumu.addEventListener('change', function () {
                    document.querySelectorAll('#birlesikListe .birlesik-checkbox').forEach(cb => {
                        cb.checked = this.checked;
                    });
                    updateSummary();
                });
            }

            document.getElementById('birlesikListe')?.addEventListener('change', e => {
                if (e.target.matches('.birlesik-checkbox')) {
                    updateSummary();
                }
            });

            // Sürükle-bırak desteği
            document.querySelectorAll('.gorsel-upload-area').forEach(area => {
                area.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    area.style.borderColor = '#0d6efd';
                    area.style.backgroundColor = '#e7f1ff';
                });

                area.addEventListener('dragleave', (e) => {
                    e.preventDefault();
                    area.style.borderColor = '#dee2e6';
                    area.style.backgroundColor = '#f8f9fa';
                });

                area.addEventListener('drop', (e) => {
                    e.preventDefault();
                    area.style.borderColor = '#dee2e6';
                    area.style.backgroundColor = '#f8f9fa';

                    const files = e.dataTransfer.files;
                    const input = area.nextElementSibling;
                    if (files.length > 0 && input) {
                        input.files = files;
                        const previewId = input.id === 'Gorsel' ? 'eklePreview' : 'editPreview';
                        previewImage(input, previewId);
                    }
                });
            });

            // Alert 5 saniye sonra otomatik kapanır
            setTimeout(() => {
                document.querySelectorAll('.alert').forEach(a => {
                    const bsAlert = bootstrap.Alert.getInstance(a);
                    if (bsAlert) bsAlert.close();
                });
            }, 5000);

            // Satır tıklama ile seçim
            const kampanyaTbody = document.querySelector('#kampanyaTablosu tbody');
            if (kampanyaTbody) {
                kampanyaTbody.addEventListener('click', function(e) {
                    const tr = e.target.closest('tr');
                    if (!tr) return;

                    // Eğer checkbox'a, butona veya link'e tıklanmışsa işlem yapma
                    if (e.target.type === 'checkbox' ||
                        e.target.tagName === 'BUTTON' ||
                        e.target.closest('button') ||
                        e.target.tagName === 'A' ||
                        e.target.closest('a') ||
                        e.target.classList.contains('kampanya-gorsel-preview')) {
                        return;
                    }

                    const checkbox = tr.querySelector('.kampanya-sec-checkbox');
                    if (checkbox) {
                        // Diğer tüm checkbox'ları temizle
                        document.querySelectorAll('.kampanya-sec-checkbox').forEach(cb => {
                            cb.checked = false;
                        });
                        // Sadece bu satırın checkbox'ını seç
                        checkbox.checked = true;
                        seciliKampanyaSayisiniGuncelle();
                    }
                });
            }

            // Checkbox değişim olayı
            document.addEventListener('change', function(e) {
                if (e.target.classList.contains('kampanya-sec-checkbox')) {
                    seciliKampanyaSayisiniGuncelle();
                }
            });

            // Modal kapandığında seçimi temizle
            const modals = ['duzenleModal', 'silModal'];
            modals.forEach(modalId => {
                const modal = document.getElementById(modalId);
                if (modal) {
                    modal.addEventListener('hidden.bs.modal', function() {
                        // Seçimi temizle
                        document.querySelectorAll('.kampanya-sec-checkbox').forEach(cb => {
                            cb.checked = false;
                        });
                        seciliKampanyaSayisiniGuncelle();
                    });
                }
            });
        });

        // ===================== DÜZENLE MODALI =====================
        function duzenleGetir(id) {
            fetch('@Url.Action("Getir")' + '?id=' + id)
                .then(r => r.json())
                .then(data => {
                    // Form alanlarını doldur
                    document.getElementById('editId').value = data.id;
                    document.getElementById('editBaslik').value = data.baslik || '';
                    document.getElementById('editMetin').value = data.metin || '';
                    document.getElementById('editIndirimYuzdesi').value = data.indirimYuzdesi;
                    document.getElementById('editBaslangicTarihi').value = data.baslangicTarihi;
                    document.getElementById('editBitisTarihi').value = data.bitisTarihi;

                    // Mevcut görsel varsa göster
                    const mevcutGorselAlani = document.getElementById('mevcutGorselAlani');
                    const mevcutGorselImg = document.getElementById('mevcutGorselImg');
                    const editMevcutGorsel = document.getElementById('editMevcutGorsel');

                    if (data.gorselyolu) {
                        mevcutGorselImg.src = data.gorselyolu;
                        mevcutGorselAlani.style.display = 'block';
                        editMevcutGorsel.value = data.gorselyolu;
                        silinecekGorselId = data.id;
                    } else {
                        mevcutGorselAlani.style.display = 'none';
                        editMevcutGorsel.value = '';
                        silinecekGorselId = null;
                    }

                    // Tabloyu yeniden oluştur
                    document.getElementById('editBirlesikListe').innerHTML = data.birlesikHtml || '';

                    // Özet sıfırla
                    updateSummary('edit');

                    // === DÜZENLE MODALI EVENTLERİNİ YENİDEN BAĞLA ===
                    // Checkbox değişim
                    document.querySelectorAll('#editBirlesikListe .birlesik-checkbox').forEach(cb => {
                        cb.onchange = () => updateSummary('edit');
                    });

                    // Tümünü seç
                    const editSelectAll = document.getElementById('editSelectAllTumu');
                    if (editSelectAll) {
                        editSelectAll.onchange = function () {
                            document.querySelectorAll('#editBirlesikListe .birlesik-checkbox').forEach(cb => {
                                cb.checked = this.checked;
                            });
                            updateSummary('edit');
                        };
                    }

                    // Arama
                    const editAramaInput = document.getElementById('editGenelArama');
                    if (editAramaInput) {
                        editAramaInput.oninput = () => genelArama('editGenelArama', 'editBirlesikListe');
                    }

                    // Önizleme alanını temizle
                    document.getElementById('editPreview').innerHTML = '';
                    document.getElementById('editGorsel').value = '';

                    // Modalı aç
                    new bootstrap.Modal(document.getElementById('duzenleModal')).show();
                })
                .catch(err => {
                    console.error(err);
                    alert('Kampanya bilgileri yüklenirken hata oluştu.');
                });
        }

        function mevcutGorselSil() {
            if (silinecekGorselId) {
                if (confirm('Görseli silmek istediğinizden emin misiniz?')) {
                    fetch('@Url.Action("GorselSilAjax", "AdminKampanya")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: 'id=' + silinecekGorselId
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById('mevcutGorselAlani').style.display = 'none';
                            document.getElementById('editMevcutGorsel').value = '';
                            silinecekGorselId = null;

                            // Başarı mesajı göster
                            var alertHtml = '<div class="alert alert-success alert-dismissible fade show" role="alert">' +
                                data.message +
                                '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>' +
                                '</div>';
                            document.querySelector('.modal-body').insertAdjacentHTML('afterbegin', alertHtml);

                            // 3 saniye sonra mesajı kaldır
                            setTimeout(function() {
                                var alerts = document.querySelectorAll('.alert');
                                alerts.forEach(function(alert) {
                                    alert.remove();
                                });
                            }, 3000);
                        } else {
                            alert('Hata: ' + data.message);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Görsel silinirken bir hata oluştu.');
                    });
                }
            }
        }

        // ===================== PAKETLER MODALI =====================
        function paketleriGoster(id) {
            fetch('@Url.Action("GetirKampanyaPaketleri")' + '?id=' + id)
                .then(r => r.json())
                .then(res => {
                    document.getElementById('paketModalBaslik').textContent = res.kampanyaBaslik + " - Paketler";
                    document.getElementById('paketTarihAraligi').textContent = res.baslangic + " - " + res.bitis;

                    const tbody = document.getElementById('paketlerListesi');
                    if (!res.success || res.data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">Bu kampanyaya direkt paket eklenmemiş.</td></tr>';
                    } else {
                        let html = '';
                        res.data.forEach((p, i) => {
                            html += `<tr>
                                <td>${i + 1}</td>
                                <td><strong>${p.adi}</strong></td>
                                <td class="text-decoration-line-through text-muted">${p.normalFiyat.toFixed(2)} ₺</td>
                                <td class="text-success fw-bold">${p.kampanyaFiyat.toFixed(2)} ₺</td>
                            </tr>`;
                        });
                        tbody.innerHTML = html;
                    }
                    new bootstrap.Modal(document.getElementById('paketlerModal')).show();
                });
        }

        // ===================== GRUPLAR MODALI =====================
        function gruplariGoster(id) {
            fetch('@Url.Action("GetirKampanyaPaketGruplari")' + '?id=' + id)
                .then(r => r.json())
                .then(res => {
                    document.getElementById('grupModalBaslik').textContent = res.kampanyaBaslik + " - Paket Grupları";
                    const tbody = document.getElementById('gruplarListesi');

                    if (!res.success || res.data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">Bu kampanyaya paket grubu eklenmemiş.</td></tr>';
                    } else {
                        let html = '';
                        res.data.forEach((g, i) => {
                            html += `<tr>
                                <td>${i + 1}</td>
                                <td><strong>${g.adi}</strong></td>
                                <td><span class="badge bg-primary">${g.icerikSayisi}</span></td>
                                <td class="fw-bold">${parseFloat(g.fiyat).toFixed(2)} ₺</td>
                            </tr>`;
                        });
                        tbody.innerHTML = html;
                    }
                    new bootstrap.Modal(document.getElementById('gruplarModal')).show();
                });
        }

        // ===================== SİL MODALI =====================
        function silOnay(id, baslik) {
            document.getElementById('silId').value = id;
            document.getElementById('silBaslik').textContent = baslik;
            new bootstrap.Modal(document.getElementById('silModal')).show();
        }

        // Modal kapandığında formları temizle
        document.getElementById('ekleModal')?.addEventListener('hidden.bs.modal', function () {
            this.querySelector('form').reset();
            document.getElementById('eklePreview').innerHTML = '';
        });

        document.getElementById('duzenleModal')?.addEventListener('hidden.bs.modal', function () {
            this.querySelector('form').reset();
            document.getElementById('mevcutGorselAlani').style.display = 'none';
            document.getElementById('editPreview').innerHTML = '';
            silinecekGorselId = null;
        });
    </script>
}