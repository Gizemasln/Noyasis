@using WepApp.Models
@{
    ViewData["Title"] = "Bayi Sözleşme Kriterleri Yönetimi";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<style>
    .table-actions {
        white-space: nowrap;
        width: 120px;
    }

    .card {
        margin-top: 70px;
    }

    .table th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }

    /* Seçim satırı için cursor pointer */
    tr[data-kriter-id] {
        cursor: pointer;
    }

    /* Seçili satır efekti */
    tr.table-active {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }

    /* İşlem butonları alanı */
    .islem-butonlari-alani {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        border: 1px solid #dee2e6;
    }

    .secili-bilgi {
        font-size: 0.85rem;
        color: #28a745;
        font-weight: 500;
    }

        .secili-bilgi i {
            font-size: 1rem;
        }

    /* Buton stilleri */
    .aksiyon-btn {
        transition: all 0.2s;
    }

        .aksiyon-btn:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .aksiyon-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
</style>

<div class="row">
    <div class="col-md-12">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Bayi Sözleşme Kriterleri</h5>
                    <div class="d-flex align-items-center gap-3">
                        <!-- Seçili Kayıt Bilgisi ve İşlem Butonları -->
                        <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                            <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                                <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                            </div>
                            <div class="btn-group btn-group-sm" role="group">
                                <button type="button" class="btn btn-warning aksiyon-btn" id="seciliDuzenleBtn" title="Seçili Kriteri Düzenle" disabled data-button-permission="duzenle">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button type="button" class="btn btn-danger aksiyon-btn" id="seciliSilBtn" title="Seçili Kriteri Sil" disabled data-button-permission="sil">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Yeni Ekle Butonu -->
                        <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#ekleModal">
                            <i class="fas fa-plus"></i> Yeni Kriter Ekle
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th width="40">Seç</th>
                                <th width="50">#</th>
                                <th>Kriter Adı</th>
                                <th>Açıklama</th>
                                <th>Oran (%)</th>
                                <th>Eklenme Tarihi</th>
                                <!-- İşlemler sütunu kaldırıldı -->
                            </tr>
                        </thead>
                        <tbody id="kriterTablosu">
                            @if (ViewBag.Kriterler != null && ((List<BayiSozlesmeKriteri>)ViewBag.Kriterler).Count > 0)
                            {
                                var counter = 1;
                                foreach (var item in (List<BayiSozlesmeKriteri>)ViewBag.Kriterler)
                                {
                                    <tr data-kriter-id="@item.Id" data-kriter-adi="@item.Adi" data-kriter-aciklama="@(item.Aciklama ?? "")" data-kriter-uzunaciklama="@(item.UzunAciklama ?? "")" data-kriter-konu="@(item.Konu ?? "")" data-kriter-oran="@item.Oran" class="kriter-satiri">
                                        <td class="text-center">
                                            <div class="form-check" onclick="event.stopPropagation();">
                                                <input class="form-check-input kriter-sec-radio" type="radio" name="seciliKriterRadio" value="@item.Id" id="secim_@item.Id">
                                            </div>
                                        </td>
                                        <td>@counter</td>
                                        <td><strong>@item.Adi</strong></td>
                                        <td>@(string.IsNullOrEmpty(item.Aciklama) ? "-" : item.Aciklama)</td>
                                        <td>%@item.Oran.ToString("N2")</td>
                                        <td>@item.EklenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    </tr>
                                    counter++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                        <p class="text-muted">Henüz kriter eklenmemiş.</p>
                                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ekleModal">
                                            İlk Kriteri Ekle
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ekle Modal -->
<div class="modal fade" id="ekleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            @using (Html.BeginForm("Ekle", "AdminBayiSozlesmeKriteri", FormMethod.Post, new { id = "ekleForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Yeni Bayi Sözleşme Kriteri Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kriter Adı *</label>
                            <input type="text" class="form-control" name="Adi" required maxlength="200" placeholder="Örn: Ciro Hedefi" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Oran (%)</label>
                            <input class="form-control" name="Oran" value="0" min="0" max="100" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kısa Açıklama</label>
                        <input type="text" class="form-control" name="Aciklama" maxlength="500" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Konu / Madde</label>
                        <input type="text" class="form-control" name="Konu" maxlength="300" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Uzun Açıklama (Opsiyonel)</label>
                        <textarea class="form-control" name="UzunAciklama" rows="4"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Düzenle Modal -->
<div class="modal fade" id="duzenleModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form action="@Url.Action("Guncelle", "AdminBayiSozlesmeKriteri")" method="post" id="duzenleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Kriter Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Kriter Adı *</label>
                            <input type="text" class="form-control" id="editAdi" name="Adi" required maxlength="200" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Oran (%)</label>
                            <input  class="form-control" id="editOran" name="Oran" min="0" max="10000" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kısa Açıklama</label>
                        <input type="text" class="form-control" id="editAciklama" name="Aciklama" maxlength="500" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Konu / Madde</label>
                        <input type="text" class="form-control" id="editKonu" name="Konu" maxlength="300" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Uzun Açıklama</label>
                        <textarea class="form-control" id="editUzunAciklama" name="UzunAciklama" rows="4"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Sil Modal -->
<div class="modal fade" id="silModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="@Url.Action("Sil", "AdminBayiSozlesmeKriteri")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="silId" name="Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Silme Onayı</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p><strong>"<span id="silAdi"></span>"</strong> kriterini silmek istediğinizden emin misiniz?</p>
                    <p class="text-danger"><small>Bu işlem geri alınamaz.</small></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-danger">Sil</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Script {
    <!-- Toastr için gerekli script ve CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function() {
            let suAnSeciliKriterId = null;
            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#kriterTablosu tr[data-kriter-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button')) {
                    const $radio = $(this).find('.kriter-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.kriter-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliKriterId = $(this).val();
                    const $seciliSatir = $(this).closest('tr');
                    const kriterAdi = $seciliSatir.data('kriter-adi');

                    // Tüm satırlardan active class'ı kaldır
                    $('#kriterTablosu tr').removeClass('table-active');
                    // Seçili satıra active class ekle
                    $seciliSatir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${kriterAdi}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function() {
                if (suAnSeciliKriterId) {
                    const $seciliSatir = $(`tr[data-kriter-id="${suAnSeciliKriterId}"]`);
                    const adi = $seciliSatir.data('kriter-adi');
                    const aciklama = $seciliSatir.data('kriter-aciklama') || '';
                    const uzunAciklama = $seciliSatir.data('kriter-uzunaciklama') || '';
                    const konu = $seciliSatir.data('kriter-konu') || '';
                    const oran = $seciliSatir.data('kriter-oran') || 0;

                    duzenleGetir(suAnSeciliKriterId, adi, aciklama, uzunAciklama, konu, oran);
                } else {
                    toastr.warning('Lütfen önce bir kriter seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliKriterId) {
                    const $seciliSatir = $(`tr[data-kriter-id="${suAnSeciliKriterId}"]`);
                    const kriterAdi = $seciliSatir.data('kriter-adi');

                    $('#silId').val(suAnSeciliKriterId);
                    $('#silAdi').text(kriterAdi);
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir kriter seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function() {
                if (suAnSeciliKriterId) {
                    const $satir = $(`tr[data-kriter-id="${suAnSeciliKriterId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        suAnSeciliKriterId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    } else {
                        // İptal edildi, radio'yu temizle
                        $(`.kriter-sec-radio[value="${suAnSeciliKriterId}"]`).prop('checked', false);
                        $('#kriterTablosu tr').removeClass('table-active');
                        suAnSeciliKriterId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);
                        $seciliDuzenleBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    }
                }
            });

            // ============= MEVCUT FONKSİYONLAR (AYNEN KORUNDU) =============

            window.duzenleGetir = function(id, adi, aciklama, uzunAciklama, konu, oran) {
                $('#editId').val(id);
                $('#editAdi').val(adi);
                $('#editAciklama').val(aciklama);
                $('#editUzunAciklama').val(uzunAciklama);
                $('#editKonu').val(konu);
                $('#editOran').val(oran);
                new bootstrap.Modal(document.getElementById('duzenleModal')).show();
            };

            window.silOnay = function(id, adi) {
                $('#silId').val(id);
                $('#silAdi').text(adi);
                new bootstrap.Modal(document.getElementById('silModal')).show();
            };

            // Form validasyon + modal temizleme + alert kapatma
            document.querySelectorAll('form').forEach(f => {
                f.addEventListener('submit', e => {
                    const adi = f.querySelector('[name="Adi"]');
                    if (adi && !adi.value.trim()) {
                        e.preventDefault();
                        toastr.error('Kriter adı zorunludur.');
                        adi.focus();
                    }
                });
            });

            ['ekleModal', 'duzenleModal'].forEach(id => {
                const modal = document.getElementById(id);
                if (modal) modal.addEventListener('hidden.bs.modal', () => modal.querySelector('form')?.reset());
            });

            setTimeout(() => document.querySelectorAll('.alert').forEach(a => bootstrap.Alert.getOrCreateInstance(a).close()), 5000);
        });
    </script>
}