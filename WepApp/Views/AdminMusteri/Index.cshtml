@section Script {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <script type="text/javascript">
        // ============= GLOBAL DEĞİŞKENLER =============
        let currentTeklifMusteriId = 0;
        let currentSozlesmeMusteriId = 0;
        let currentMusteriId = 0;
        let ekleYetkiliListesi = [];
        let duzenleYetkiliListesi = [];
        let secilenYetkiliId = 0;
        let mevcutLogoAdi = '';
        let mevcutImzaAdi = '';
        let currentDosyaTipi = '';

        // "Diğer" tipi ID'si
        const digerTipId = @((ViewBag.MusteriTipleri as List<MusteriTipi>)?.FirstOrDefault(x => x.Adi?.Trim().ToLower() == "diğer")?.Id ?? 0);

        // ============= AKILLI SÜTUN BAZLI ARAMA =============
        let aktifAramaSutunu = null; // null = tüm sütunlarda ara
        let aramaMetni = '';
        let aramaZamanlayici = null;

        // Sütun indekslerini ve adlarını tanımla (Seç sütunu kalktığı için)
        const sutunlar = [
            { index: 0, ad: 'Sıra', alan: 'sira' },
            { index: 1, ad: 'Ad Soyad', alan: 'adSoyad' },
            { index: 2, ad: 'Unvan', alan: 'unvan' },
            { index: 3, ad: 'Kullanıcı Adı', alan: 'kullaniciAdi' },
            { index: 4, ad: 'Email', alan: 'email' },
            { index: 5, ad: 'Telefon', alan: 'telefon' },
            { index: 6, ad: 'Bayi', alan: 'bayi' },
            { index: 7, ad: 'Müşteri Tipi', alan: 'tip' },
            { index: 8, ad: 'Müş. Ol.Tarihi', alan: 'musteriTarih' },
            { index: 9, ad: 'A. Müş. Olma Tarihi', alan: 'adayTarih' }
        ];
        // Sütun başlıklarına tıklama olayı ekle
        $(document).ready(function () {
                    document.getElementById("KullaniciAdi").disabled = true;
                otomatikBayiSec();

            // Flatpickr'ı başlat
            initTarihFiltresi();

                // Sütun başlıklarına tıklama olayı ekle (ready içinde)
        $('thead th').each(function (index) {
            // 0. sütun (Sıra) dahil, tüm sütunlara tıklama ekle
            if (index < sutunlar.length) {
                $(this).css('cursor', 'pointer')
                    .attr('title', 'Bu sütunda ara')
                    .data('sutun-index', index)
                    .data('sutun-ad', sutunlar[index].ad)
                    .data('sutun-alan', sutunlar[index].alan);

                $(this).on('click', function (e) {
                    if (!$(e.target).is('button') && !$(e.target).is('a') && !$(e.target).is('select') && !$(e.target).is('option')) {
                        e.stopPropagation();

                        const tiklananIndex = $(this).data('sutun-index');
                        const tiklananAd = $(this).data('sutun-ad');
                        const tiklananAlan = $(this).data('sutun-alan');

                        if (aktifAramaSutunu === tiklananAlan) {
                            sutunFiltresiniKaldir();
                        } else {
                            sutunFiltresiAktifEt(tiklananIndex, tiklananAd, tiklananAlan);
                        }

                        $('#akilliArama').focus();
                    }
                });
            }
        });

            // Çift tıklama ile sütun filtresini kaldır
            $('thead th').on('dblclick', function (e) {
                e.stopPropagation();
                sutunFiltresiniKaldir();
            });

            // Arama inputu olayları
            $('#akilliArama').on('input', function () {
                aramaMetni = $(this).val().toLowerCase().trim();

                if (aramaZamanlayici) {
                    clearTimeout(aramaZamanlayici);
                }

                aramaZamanlayici = setTimeout(function () {
                    filtreleVeSirala();
                }, 300);
            });

            // Enter tuşu ile anında arama
            $('#akilliArama').on('keypress', function (e) {
                if (e.which === 13) {
                    e.preventDefault();
                    if (aramaZamanlayici) {
                        clearTimeout(aramaZamanlayici);
                    }
                    filtreleVeSirala();
                }
            });

            // Temizle butonu
            $('#akilliAramaTemizle').on('click', function () {
                $('#akilliArama').val('');
                aramaMetni = '';
                sutunFiltresiniKaldir();
                filtreleVeSirala();
            });

            // Tarih filtre temizle butonu
            $('#tarihFiltreTemizle').on('click', function () {
                if (typeof flatpickr !== 'undefined') {
                    const fp = $("#tarihAraligi").flatpickr();
                    if (fp) {
                        fp.clear();
                    }
                }
                $('#tarihAraligi').val('');
                tarihFiltre.baslangic = null;
                tarihFiltre.bitis = null;
                tarihFiltre.aktif = false;

                gosterAktifFiltreler();
                filtreleVeSirala();
            });

            // Sıralama değişikliği
            $('#siralamaSecenek').on('change', function () {
                mevcutSiralama = $(this).val();
                filtreleVeSirala();
            });

            // Başlangıçta aktif sütun göstergesini gizle
            $('#aktifSutunGosterge').hide();

            // Klavye kısayolu: ESC tuşu ile temizle
            $(document).on('keydown', function (e) {
                if (e.key === 'Escape' && $('#akilliArama').is(':focus')) {
                    $('#akilliAramaTemizle').click();
                }
            });

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============
            let suAnSeciliMusteriId = null;
            let suAnSeciliMusteriAd = null;
            let suAnSeciliMusteriUnvan = null;
            let suAnSeciliSatir = null;

            const $seciliDetayBtn = $('#seciliDetayGoster');
            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliTekliflerBtn = $('#seciliTekliflerBtn');
            const $seciliSozlesmelerBtn = $('#seciliSozlesmelerBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#musteriTablosu tbody tr[data-musteri-id]', function (e) {
                // Eğer tıklanan element radio butonunun kendisi değilse
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('button') && !$(e.target).is('a')) {
                    const $radio = $(this).find('.musteri-sec-radio');
                    $radio.prop('checked', true).trigger('change');
                }
            });

               // Tablo satırına tıklandığında seç
        $(document).on('click', '#musteriTablosu tbody tr[data-musteri-id]', function(e) {
            // Eğer tıklanan element buton veya link değilse
            if (!$(e.target).is('button') && !$(e.target).is('a') && !$(e.target).closest('.btn').length) {
                satirSec($(this));
            }
        });

        // Satır seçme fonksiyonu
        function satirSec($satir) {
            const musteriId = $satir.data('musteri-id');

            if (suAnSeciliMusteriId === musteriId) {
                // Aynı satıra tekrar tıklandığında seçimi kaldır
                suAnSeciliMusteriId = null;
                suAnSeciliMusteriAd = null;
                suAnSeciliMusteriUnvan = null;
                suAnSeciliSatir = null;

                $('#musteriTablosu tbody tr').removeClass('table-active');
                $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                // Butonları devre dışı bırak
                $seciliDetayBtn.prop('disabled', true);
                $seciliDuzenleBtn.prop('disabled', true);
                $seciliTekliflerBtn.prop('disabled', true);
                $seciliSozlesmelerBtn.prop('disabled', true);
                $seciliSilBtn.prop('disabled', true);
            } else {
                // Yeni satır seç
                suAnSeciliMusteriId = musteriId;
                suAnSeciliSatir = $satir;
                suAnSeciliMusteriAd = $satir.data('musteri-ad');
