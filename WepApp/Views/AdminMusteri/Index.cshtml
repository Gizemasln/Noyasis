$('#duzenleForm').on('submit', function(e) {
    const durumId = $('#editMusteriDurumuId').val();
    const tcvNo = $('#editTCVNo').val().trim();
    
    // Aday müşteri için özel kontroller
    if (durumId == 2) {
        // Aday müşteri için sadece temel alanları kontrol et
        const ticariUnvan = $('#editTicariUnvan').val().trim();
        const ad = $('#editAd').val().trim();
        const soyad = $('#editSoyad').val().trim();
        
        if (!ticariUnvan || !ad || !soyad) {
            e.preventDefault();
            alert('Aday müşteri için Ticari Unvan, Ad ve Soyad alanları zorunludur!');
            return false;
        }
        
        // Email opsiyonel ama varsa formatını kontrol et
        const email = $('#editEmail').val().trim();
        if (email && !isValidEmail(email)) {
            e.preventDefault();
            alert('Geçerli bir email adresi giriniz!');
            return false;
        }
        
        return true; // Aday müşteri için diğer kontrolleri atla
    }
    
    // Normal müşteri kontrolleri
    if (tcvNo && tcvNo.length !== 10 && tcvNo.length !== 11) {
        e.preventDefault();
        alert('Vergi No 10, TC Kimlik No 11 karakter olmalıdır!');
        return false;
    }
});


