                 function toggleAdayMusteriAlanları(durumId, modalTipi = 'ekle') {
            const prefix = modalTipi === 'ekle' ? '' : 'edit';
            const isAday = parseInt(durumId) === 2;

            // ────────────────────────────────────────────────
            // A) HER ZAMAN AKTİF KALACAK ZORUNLU ALANLAR
            // ────────────────────────────────────────────────
            const zorunluAlanlar = ['TicariUnvan', 'AdSoyad', 'Email'];
            zorunluAlanlar.forEach(field => {
                const el = document.getElementById(prefix + field);
                if (el) {
                    el.disabled = false;
                    el.readOnly = false;
                    el.required = true;
                    el.style.backgroundColor = '#ffffff';
                }
            });

            if (isAday) {
                // ────────────────────────────────────────────────
                // B) ADAY MODUNDA KAPATILACAK ALANLAR
                // ────────────────────────────────────────────────
                const kapatilacakAlanlar = [
                    'KullaniciAdi', 'Sifre', 'TabelaAdi',
                    'Telefon', 'Bolge', 'Il', 'Ilce', 'Belde', 'Adres',
                    'TCVNo', 'VergiDairesi', 'KepAdresi', 'WebAdresi',
                    'Aciklama', 'AlpemixFirmaAdi', 'AlpemixGrupAdi', 'AlpemixSifre'
                ];

                kapatilacakAlanlar.forEach(field => {
                    const el = document.getElementById(prefix + field);
                    if (el) {
                        el.value = '';
                        el.disabled = true;
                        el.readOnly = true;
                        el.required = false;
                        el.style.backgroundColor = '#e9ecef';
                    }
                });

                // ────────────────────────────────────────────────
                // BAYİ SEÇİMİNİ TAMAMEN KAPAT - DÜZELTİLMİŞ VERSİYON
                // ────────────────────────────────────────────────
                const bayiSelect = document.getElementById(prefix + 'BayiId');
                if (bayiSelect) {
                    // Dropdown'u devre dışı bırak
                    bayiSelect.disabled = true;

                    // Değeri temizle
                    bayiSelect.value = '';

                    // Tüm optionları devre dışı bırak (opsiyonel)
                    Array.from(bayiSelect.options).forEach(option => {
                        option.disabled = true;
                    });

                    // CSS ile de görsel olarak devre dışı olduğunu belirt
                    bayiSelect.style.backgroundColor = '#e9ecef';
                    bayiSelect.style.cursor = 'not-allowed';
                    bayiSelect.style.pointerEvents = 'none'; // Bu çok önemli!

                    // Mevcut uyarıyı kaldır
                    const eskiUyari = document.getElementById('bayiUyari' + prefix);
                    if (eskiUyari) eskiUyari.remove();

                    // Yeni uyarı metni ekle
                    const uyari = document.createElement('small');
                    uyari.id = 'bayiUyari' + prefix;
                    uyari.className = 'text-danger d-block mt-1 fw-bold';
                    uyari.innerHTML = '<i class="fas fa-exclamation-circle me-1"></i>Aday müşterilerde bayi seçimi yapılamaz';

                    // Form-floating içine veya yanına ekle
                    const floatingDiv = bayiSelect.closest('.form-floating');
                    if (floatingDiv) {
                        floatingDiv.appendChild(uyari);
                    } else {
                        bayiSelect.parentNode.appendChild(uyari);
                    }
                }

                // ────────────────────────────────────────────────
                // Kullanıcı adı ve şifre butonlarını gizle
                // ────────────────────────────────────────────────
                const butonlar = [
                    'kullaniciAdiOluşturBtn',
                    'editKullaniciAdiOluşturBtn',
                    'sifreYenileBtn'
                ];
                butonlar.forEach(id => {
                    const btn = document.getElementById(id);
                    if (btn) btn.style.display = 'none';
                });

                // ────────────────────────────────────────────────
                // Kullanıcı adı ve şifre alanlarının üstüne bilgi kutusu
                // ────────────────────────────────────────────────
                let infoBox = document.getElementById('kadiSifreInfo' + prefix);
                if (!infoBox) {
                    infoBox = document.createElement('div');
                    infoBox.id = 'kadiSifreInfo' + prefix;
                    infoBox.className = 'alert alert-info mt-3';
                    infoBox.innerHTML = `
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Sistem tarafından otomatik oluşturulacak:</strong><br>
                        • Kullanıcı Adı<br>
                        • Şifre<br>
                        <small>(Kayıt tamamlandıktan sonra görüntülenebilir / sıfırlanabilir)</small>
                    `;

                    // Kullanıcı adı alanının olduğu kolona ekle
                    const kadiKolon = document.getElementById(prefix + 'KullaniciAdi')?.closest('.col-md-6');
                    if (kadiKolon) kadiKolon.appendChild(infoBox);
                }

                // ────────────────────────────────────────────────
                // Müşteri tipi seçeneğini de devre dışı bırak
                // ────────────────────────────────────────────────
                const musteriTipi = document.getElementById(prefix + 'MusteriTipiId');
                if (musteriTipi) {
                    musteriTipi.disabled = true;
                    musteriTipi.style.backgroundColor = '#e9ecef';
                    musteriTipi.style.cursor = 'not-allowed';
                    musteriTipi.style.pointerEvents = 'none';
                }

                // ────────────────────────────────────────────────
                // Yetkili ekleme butonlarını devre dışı bırak
                // ────────────────────────────────────────────────
                document.querySelectorAll(`#${modalTipi === 'ekle' ? 'ekleModal' : 'duzenleModal'} button[onclick*="yeniYetkiliEkle"]`)
                    .forEach(btn => {
                        btn.disabled = true;
                        btn.style.opacity = '0.5';
                        btn.style.cursor = 'not-allowed';
                    });

            } else {
                // ────────────────────────────────────────────────
                // C) NORMAL MÜŞTERİ MODU → HER ŞEYİ GERİ AÇ
                // ────────────────────────────────────────────────

                // Bayi seçimini aktif et - DÜZELTİLMİŞ VERSİYON
                const bayiSelect = document.getElementById(prefix + 'BayiId');
                if (bayiSelect) {
                    bayiSelect.disabled = false;

                    // Optionları aktif et
                    Array.from(bayiSelect.options).forEach(option => {
                        option.disabled = false;
                    });

                    // CSS'i normale döndür
                    bayiSelect.style.backgroundColor = '';
                    bayiSelect.style.cursor = '';
                    bayiSelect.style.pointerEvents = '';

                    // Uyarı metnini kaldır
                    const uyari = document.getElementById('bayiUyari' + prefix);
                    if (uyari) uyari.remove();
                }

                // Kullanıcı adı ve şifre butonlarını geri göster
                const butonlar = [
                    'kullaniciAdiOluşturBtn',
                    'editKullaniciAdiOluşturBtn',
                    'sifreYenileBtn'
                ];
                butonlar.forEach(id => {
                    const btn = document.getElementById(id);
                    if (btn) btn.style.display = '';
                });

                // Bilgi kutularını kaldır
                const infoBox = document.getElementById('kadiSifreInfo' + prefix);
                if (infoBox) infoBox.remove();

                // Müşteri tipini aktif et
                const musteriTipi = document.getElementById(prefix + 'MusteriTipiId');
                if (musteriTipi) {
                    musteriTipi.disabled = false;
                    musteriTipi.style.backgroundColor = '';
                    musteriTipi.style.cursor = '';
                    musteriTipi.style.pointerEvents = '';
                }

                // Yetkili ekleme butonlarını aktif et
                document.querySelectorAll(`#${modalTipi === 'ekle' ? 'ekleModal' : 'duzenleModal'} button[onclick*="yeniYetkiliEkle"]`)
                    .forEach(btn => {
                        btn.disabled = false;
                        btn.style.opacity = '';
                        btn.style.cursor = '';
                    });

                // Diğer alanları normale döndür
                const acilacakAlanlar = [
                    'KullaniciAdi', 'Sifre', 'TabelaAdi',
                    'Telefon', 'Bolge', 'Il', 'Ilce', 'Belde', 'Adres',
                    'TCVNo', 'VergiDairesi', 'KepAdresi', 'WebAdresi',
                    'Aciklama', 'AlpemixFirmaAdi', 'AlpemixGrupAdi', 'AlpemixSifre'
                ];

                acilacakAlanlar.forEach(field => {
                    const el = document.getElementById(prefix + field);
                    if (el) {
                        el.disabled = false;
                        el.readOnly = false;
                        el.required = false;
                        el.style.backgroundColor = '#ffffff';
                    }
                });
            }
        }

