                                                        <th>Sözleşme No</th>
                                                        <th>Lisans No</th>
                                                        <th>Tarih</th>
                                                        <th>Tip</th>
                                                        <th>Dosyalar</th>
                                                    </tr>
                                                </thead>
                                                <tbody>`;

                            data.data.forEach(sozlesme => {
                                dosyalarHtml += `
                                    <tr>
                                        <td><strong>${escapeHtml(sozlesme.dokumanNo)}</strong></td>
                                        <td>${escapeHtml(sozlesme.lisansNo || '-')}</td>
