                function duzenleYetkiliListedenSil(i) {
                    if (confirm('Kaldırmak istediğinizden emin misiniz?')) {
                        duzenleYetkiliListesi.splice(i, 1);
                        guncelleDuzenleYetkiliListesi();
                    }
