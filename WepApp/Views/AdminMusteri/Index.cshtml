                durumDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Lütfen önce il seçiniz.';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Kullanıcı Adı Oluştur';
                return;
            }

            if (!ilceSelect.value) {
                durumDiv.style.display = 'block';
                durumDiv.className = 'mt-2 alert alert-warning py-2';
                durumDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Lütfen önce ilçe seçiniz.';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Kullanıcı Adı Oluştur';
                return;
            }

            const ilId = ilSelect.value;
            const ilceId = ilceSelect.value;
            const rastgeleSayi = Math.floor(1000 + Math.random() * 9000);
            let olusanKullaniciAdi = `${ilId}${ilceId}${rastgeleSayi}`;

            kullaniciAdiInput.value = olusanKullaniciAdi;
            kullaniciAdiKontrolEt(olusanKullaniciAdi, null, 'ekle');

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Kullanıcı Adı Oluştur';
        }

        // Düzenle modalı için kullanıcı adı yenile
        function kullaniciAdiYenileDuzenle() {
            const ilSelect = document.getElementById('editIl');
            const ilceSelect = document.getElementById('editIlce');
            const kullaniciAdiInput = document.getElementById('editKullaniciAdi');
            const durumDiv = document.getElementById('kullaniciAdiDurumDuzenle');
            const btn = document.getElementById('editKullaniciAdiOluşturBtn');
            const musteriId = document.getElementById('editId').value;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Yenileniyor...';

            if (!ilSelect.value) {
                durumDiv.style.display = 'block';
                durumDiv.className = 'mt-2 alert alert-warning py-2';
                durumDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Lütfen önce il seçiniz.';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Yenile';
                return;
            }

            if (!ilceSelect.value) {
                durumDiv.style.display = 'block';
                durumDiv.className = 'mt-2 alert alert-warning py-2';
                durumDiv.innerHTML = '<i class="fas fa-exclamation-triangle me-1"></i> Lütfen önce ilçe seçiniz.';
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Yenile';
                return;
            }

            const ilId = ilSelect.value;
            const ilceId = ilceSelect.value;
            const rastgeleSayi = Math.floor(1000 + Math.random() * 9000);
            let olusanKullaniciAdi = `${ilId}${ilceId}${rastgeleSayi}`;

            kullaniciAdiInput.value = olusanKullaniciAdi;
            kullaniciAdiKontrolEt(olusanKullaniciAdi, musteriId, 'duzenle');

            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-sync-alt me-1"></i> Yenile';
        }

        // Kullanıcı adı benzersizlik kontrolü
        function kullaniciAdiKontrolEt(kullaniciAdi, musteriId = null, modal = 'ekle') {
            if (!kullaniciAdi) return;

            const durumDiv = document.getElementById(modal === 'ekle' ? 'kullaniciAdiDurumEkle' : 'kullaniciAdiDurumDuzenle');
            const submitBtn = document.getElementById(modal === 'ekle' ? 'ekleBtn' : 'duzenleSubmitBtn');

            let url = `/AdminMusteri/KullaniciAdiKontrol?kullaniciAdi=${encodeURIComponent(kullaniciAdi)}`;
            if (musteriId) url += `&musteriId=${musteriId}`;

            fetch(url)
                .then(response => response.json())
                .then(res => {
                    durumDiv.style.display = 'block';

                    if (res.success) {
                        durumDiv.className = 'mt-2 alert alert-success py-2';
                        durumDiv.innerHTML = `<i class="fas fa-check-circle me-1"></i> Kullanılabilir.`;
                        if (submitBtn) submitBtn.disabled = false;
                    } else {
                        durumDiv.className = 'mt-2 alert alert-danger py-2';
                        durumDiv.innerHTML = `<i class="fas fa-times-circle me-1"></i> ${res.message}`;
                        if (submitBtn) submitBtn.disabled = true;

                        // 2 saniye sonra otomatik yeni kullanıcı adı oluştur
                        setTimeout(() => {
                            if (modal === 'ekle') {
                                kullaniciAdiOluştur('ekle');
                            } else {
                                kullaniciAdiYenileDuzenle();
                            }
                        }, 2000);
                    }
                })
                .catch(err => {
                    durumDiv.style.display = 'block';
                    durumDiv.className = 'mt-2 alert alert-danger py-2';
                    durumDiv.innerHTML = `<i class="fas fa-exclamation-triangle me-1"></i> Kontrol sırasında hata oluştu.`;
                });
        }
                // İl seçildiğinde
        function ilSecildi(ilId, hedefSelectId, modalTipi) {
            ilceleriGetir(ilId, hedefSelectId).then(() => {
                const ilceSelect = document.getElementById(hedefSelectId);
                if (ilceSelect.value && modalTipi === 'ekle') {
                    kullaniciAdiOluştur('ekle');
                }
            });
        }
                function ilceleriGetir(ilId, hedefSelectId) {
            return new Promise((resolve, reject) => {
                const ilceSelect = document.getElementById(hedefSelectId);
                if (!ilceSelect) {
                    reject('Hedef select bulunamadı');
                    return;
                }

                ilceSelect.innerHTML = '<option value="">Yükleniyor...</option>';
                ilceSelect.disabled = true;

                if (!ilId) {
                    ilceSelect.innerHTML = '<option value="">Önce il seçiniz</option>';
                    ilceSelect.disabled = false;
                    resolve();
                    return;
                }

                fetch(`/AdminMusteri/GetIlcelerByIlId?ilId=${ilId}`)
                    .then(response => response.json())
                    .then(res => {
                        ilceSelect.innerHTML = '<option value="">Seçiniz</option>';
                        if (res.success && res.data && res.data.length > 0) {
                            res.data.forEach(ilce => {
                                ilceSelect.innerHTML += `<option value="${ilce.id}">${escapeHtml(ilce.ilceadi)}</option>`;
                            });
                        } else {
                            ilceSelect.innerHTML = '<option value="">İlçe bulunamadı</option>';
                        }
                        ilceSelect.disabled = false;
                        resolve();
                    })
                    .catch(err => {
                        console.error('İlçeler yüklenirken hata:', err);
                        ilceSelect.innerHTML = '<option value="">Hata oluştu</option>';
                        ilceSelect.disabled = false;
                        reject(err);
                    });
            });
        }
        // İlçe seçildiğinde
        function ilceSecildi(modalTipi) {
            if (modalTipi === 'ekle') {
                const ilSelect = document.getElementById('Il');
                const ilceSelect = document.getElementById('Ilce');
                if (ilSelect.value && ilceSelect.value) {
                    kullaniciAdiOluştur('ekle');
                }
            } else {
                const ilSelect = document.getElementById('editIl');
                const ilceSelect = document.getElementById('editIlce');
                if (ilSelect.value && ilceSelect.value) {
                    kullaniciAdiYenileDuzenle();
                }
            }
        }
                function yukleDepartmanlarEkle() {
                    fetch('@Url.Action("GetDepartmanlar", "AdminMusteri")')
                        .then(r => r.json())
                        .then(data => {
                            if (data.success && document.getElementById('yetkiliDepartmanSelectEkle')) {
                                document.getElementById('yetkiliDepartmanSelectEkle').innerHTML =
                                    '<option value="">Seçiniz</option>' +
                                    data.data.map(d => `<option value="${d.id}">${escapeHtml(d.adi)}</option>`).join('');
                            }
                        });
                }

                function yeniYetkiliListeyeEkle() {
                    const form = document.getElementById('yeniYetkiliEkleForm');
                    const fd = new FormData(form);
                    const y = {
                        Adi: fd.get('Adi')?.trim(),
                        Soyadi: fd.get('Soyadi')?.trim(),
                        Gorevi: fd.get('Gorevi')?.trim() || '',
                        Email: fd.get('Email')?.trim() || '',
                        Cep: fd.get('Cep')?.trim() || '',
                        DahiliNo: fd.get('DahiliNo')?.trim() || '',
                        DepartmanId: fd.get('DepartmanId') || null,
                        Cinsiyet: fd.get('Cinsiyet') || '',
                        Kodu: fd.get('Kodu')?.trim() || ''
                    };
                    if (!y.Adi || !y.Soyadi) return alert('Ad ve Soyad zorunludur!');
                    ekleYetkiliListesi.push(y);
                    guncelleEkleYetkiliListesi();
                    bootstrap.Modal.getInstance(document.getElementById('yeniYetkiliEkleModal')).hide();
                    form.reset();
                }

                function guncelleEkleYetkiliListesi() {
                    const c = document.getElementById('ekleYetkiliListesi');
                    if (ekleYetkiliListesi.length === 0) {
                        c.innerHTML = '<div class="alert alert-info text-center">Henüz yetkili eklenmedi.</div>';
                        return;
                    }
                    let html = '';
                    ekleYetkiliListesi.forEach((y, i) => {
                        html += `
                            <div class="yetkili-item p-3 mb-2 border rounded position-relative shadow-sm bg-light">
                                <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2" onclick="yetkiliyiListedenSil(${i})"><i class="fas fa-times"></i></button>
                                <div class="row"><div class="col-md-4"><strong>${escapeHtml(y.Adi)} ${escapeHtml(y.Soyadi)}</strong></div>
                                    <div class="col-md-4"><small>Görevi: ${escapeHtml(y.Gorevi || '-')}</small></div>
