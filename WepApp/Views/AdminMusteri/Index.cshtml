                                        <small>${parseFloat(s.yillikBakim).toLocaleString('tr-TR', { minimumFractionDigits: 2 })} ₺</small>
                                    </td>
                                    <td>${escapeHtml(s.entegratorAdi)}</td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            ${pdfButon}
                                        </div>
                                    </td>
                                </tr>`;
