@using WepApp.Models
@{
    ViewData["Title"] = "Bayi Sözleşmeleri";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<link href="/WebAdminTheme/assets/css/admin.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="teklif-container">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Bayi Sözleşmeleri</h5>
                    </div>

                    <div class="card-body p-0">
                        <div class="card-body border-bottom">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <!-- Aktif sütun göstergesi -->
                                        <div id="aktifSutunGosterge" class="small text-muted mt-1" style="display: none;">
                                            <i class="fas fa-filter"></i> <span id="aktifSutunAdi"></span>'da ara:
                                        </div>
                                        <!-- Arama kutusu - Akıllı sütun bazlı -->
                                        <div class="search-box">
                                            <div class="input-group input-group-sm" style="min-width: 400px;">
                                                <span class="input-group-text bg-white border-end-0">
                                                    <i class="fas fa-search text-muted"></i>
                                                </span>
                                                <input type="text" id="akilliArama" class="form-control border-start-0"
                                                       placeholder="Tabloda ara (sütun başlığına tıkla)">
                                                <button class="btn btn-outline-secondary" type="button" id="akilliAramaTemizle" title="Temizle">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <!-- TARİH ARALIĞI FİLTRESİ ve SIRALAMA -->
                                    <div class="d-flex justify-content-end align-items-center gap-3">
                                        <div class="tarih-filtre">
                                            <div class="input-group input-group-sm">
                                                <span class="input-group-text bg-white">
                                                    <i class="fas fa-calendar-alt text-muted"></i>
                                                </span>
                                                <input type="text"
                                                       id="tarihAraligi"
                                                       class="form-control"
                                                       placeholder="Yayın Tarihi Aralığı">
                                                <button class="btn btn-outline-secondary" type="button" id="tarihFiltreTemizle" title="Filtreyi Temizle">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="siralama-filtre" style="min-width: 170px;">
                                            <select id="siralamaSecenek" class="form-select form-select-sm">
                                                <option value="tarih_azalan">En Yeni → En Eski</option>
                                                <option value="tarih_artan">En Eski → En Yeni</option>
                                                <option value="dokuman_az">Doküman No (A-Z)</option>
                                                <option value="dokuman_za">Doküman No (Z-A)</option>
                                                <option value="bayi_az">Bayi Adı (A-Z)</option>
                                                <option value="bayi_za">Bayi Adı (Z-A)</option>
                                                <option value="kriter_azalan">Kriter Sayısı (Azalan)</option>
                                                <option value="kriter_artan">Kriter Sayısı (Artan)</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4">
                                    <div class="islem-butonlari-alani d-flex align-items-center gap-2">
                                        <div id="seciliKayitBilgi" class="secili-bilgi me-2">
                                            <i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi
                                        </div>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button type="button" class="btn btn-warning btn-sm" id="seciliDuzenleBtn" title="Düzenle" disabled data-button-permission="duzenle" style="margin-right:5px;">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button type="button" class="btn btn-danger btn-sm" id="seciliSilBtn" data-button-permission="sil" title="Seçili Sözleşmeyi Sil" disabled>
                                                <i class="fas fa-trash"></i>
                                            </button>
                                            <!-- Yeni Sözleşme Ekle Butonu -->
                                            <button type="button" class="btn btn-primary" data-button-permission="ekle" data-bs-toggle="modal" data-bs-target="#sozlesmeModal">
                                                <i class="fas fa-plus"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Aktif Filtreler -->
                        <div class="row mt-3" id="aktifFiltreler" style="display: none; padding: 0 15px;">
                            <div class="col-12">
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-light text-dark me-2 p-2">
                                        <i class="fas fa-filter me-1"></i>Aktif Filtreler:
                                    </span>
                                    <div id="filtreEtiketleri" class="d-flex flex-wrap gap-2"></div>
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover mb-0" id="bayiSozlesmeTablosu">
                                <thead>
                                    <tr>
                                        <th style="width: 4%;">#</th>
                                        <th style="width: 12%;" data-sutun-index="1" data-sutun-ad="Doküman No" data-sutun-alan="dokumanNo">Doküman No</th>
                                        <th style="width: 20%;" data-sutun-index="2" data-sutun-ad="Bayi" data-sutun-alan="bayi">Bayi</th>
                                        <th style="width: 10%;" data-sutun-index="3" data-sutun-ad="Yayın Tarihi" data-sutun-alan="yayinTarihi">Yayın Tarihi</th>
                                        <th style="width: 10%;" data-sutun-index="4" data-sutun-ad="Bitiş Tarihi" data-sutun-alan="bitisTarihi">Bitiş Tarihi</th>
                                        <th style="width: 10%;" data-sutun-index="5" data-sutun-ad="Durum" data-sutun-alan="durum">Sözleşme Durumu</th>
                                        <th style="width: 8%;" data-sutun-index="6" data-sutun-ad="Kriter Sayısı" data-sutun-alan="kriterSayisi">Kriterler</th>
                                        <th style="width: 8%;" data-sutun-index="7" data-sutun-ad="Dosya" data-sutun-alan="dosya">Dosya</th>
                                        <th style="width: 8%;" data-sutun-index="8" data-sutun-ad="Revizyon" data-sutun-alan="revizyon">Revizyon</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ViewBag.Sozlesmeler != null && ((List<BayiSozlesme>)ViewBag.Sozlesmeler).Any())
                                    {
                                        var counter = 1;
                                        foreach (var s in (List<BayiSozlesme>)ViewBag.Sozlesmeler)
                                        {
                                            var kriterSayisi = s.BayiSozlesmeBayiKriter?.Count(k => k.Durumu == 1) ?? 0;
                                            <tr data-sozlesme-id="@s.Id"
                                                data-dokuman-no="@s.DokumanNo"
                                                data-bayi="@(s.Bayi?.Unvan ?? "")"
                                                data-yayin-tarihi="@s.YayinTarihi.ToString()"
                                                data-bitis-tarihi="@s.BitisTarihi.ToString()"
                                                data-durum="@(s.SozlesmeDurumu?.Adi ?? "")"
                                                data-kriter-sayisi="@kriterSayisi"
                                                data-revizyon="@(s.RevizyonNo ?? "")">
                                                <td>@counter</td>
                                                <td>
                                                    <strong>@s.DokumanNo</strong>
                                                </td>
                                                <td>@(s.Bayi?.Kodu ?? "") - @(s.Bayi?.Unvan ?? "")</td>
                                                <td>
                                                    <span class="badge bg-info" title="@s.YayinTarihi.ToString()">
                                                        <i class="fas fa-calendar-alt me-1"></i>@s.YayinTarihi.ToString()
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge bg-warning text-dark" title="@s.BitisTarihi.ToString("dd MMMM yyyy")">
                                                        <i class="fas fa-calendar-check me-1"></i>@s.BitisTarihi.ToString("dd.MM.yyyy")
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge bg-success">@(s.SozlesmeDurumu?.Adi ?? "")</span>
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-sm btn-info" onclick="kriterleriGoster(@s.Id, '@s.DokumanNo')">
                                                        <i class="fas fa-list me-1"></i>@kriterSayisi
                                                    </button>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(s.DosyaYolu))
                                                    {
                                                        <a href="@s.DosyaYolu" target="_blank" class="btn btn-sm btn-success" title="PDF Görüntüle">
                                                            <i class="fas fa-file-pdf"></i>
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(s.RevizyonNo))
                                                    {
                                                        <span class="badge bg-secondary">Rev. @s.RevizyonNo</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                            </tr>
                                            counter++;
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="9" class="empty-state">
                                                <i class="fas fa-file-contract"></i>
                                                <h5>Henüz sözleşme bulunmuyor</h5>
                                                <p>Yeni bir sözleşme eklemek için "Yeni Sözleşme Ekle" butonuna tıklayın.</p>
                                                <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#sozlesmeModal">
                                                    <i class="fas fa-plus"></i> Yeni Sözleşme Ekle
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sözleşme Ekle/Düzenle Modal -->
<div class="modal fade" id="sozlesmeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="sozlesmeForm" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="sozlesmeId" value="0" />
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Yeni Sözleşme Ekle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Bayi *</label>
                            <select class="form-select" name="BayiId" id="bayiId" required>
                                <option value="">Bayi Seçiniz</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Döküman No *</label>
                            <input type="text" class="form-control" name="DokumanNo" id="dokumanNo" required />
                            <div id="benzersizUyari" class="text-danger small mt-1"></div>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Yayın Tarihi *</label>
                            <input type="date" class="form-control" name="YayinTarihi" id="yayinTarihi" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bitiş Tarihi *</label>
                            <input type="date" class="form-control" name="BitisTarihi" id="bitisTarihi" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sözleşme Durumu *</label>
                            <select class="form-select" name="SozlesmeDurumuId" id="durumId" required>
                                <option value="">Durum Seçiniz</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Geçerlilik Süresi (Ay)</label>
                            <input type="number" step="0.1" class="form-control" name="GecerlilikSuresi" id="gecerlilikSuresi" value="12" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Revizyon No</label>
                            <input type="text" class="form-control" name="RevizyonNo" id="revizyonNo" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Revize Tarihi</label>
                            <input type="date" class="form-control" name="RevizeTarihi" id="revizeTarihi" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Sözleşme Dosyası (PDF)</label>
                            <input type="file" class="form-control" name="Dosya" id="dosya" accept=".pdf" />
                            <div id="mevcutDosyaDiv" class="mt-1 small text-success"></div>
                            <small class="text-muted">Maks. 20 MB, sadece PDF</small>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Ek Kriterler (Çoklu Seçim)</label>
                            <div class="kriter-list-container" id="kriterListContainer"></div>
                            <div class="mt-2">
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="tumunuSec()">Tümünü Seç</button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="secimiTemizle()">Temizle</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Kriterleri Göster Modal -->
<div class="modal fade" id="kriterGoruntuleModal" tabindex="-1">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Sözleşme Kriterleri - <span id="kriterModalDokumanNo"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="kriterListesi" class="text-center py-3">Yükleniyor...</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

<!-- Silme Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Sözleşme Silme
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2"><strong id="silinecekDokumanNo"></strong> numaralı sözleşmeyi silmek istediğinizden emin misiniz?</p>
                <p class="text-danger mb-0">
                    <small><i class="fas fa-info-circle me-1"></i> Bu işlem geri alınamaz.</small>
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-danger" id="silBtn">Sil</button>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

    <script type="text/javascript">
        // ============= GLOBAL DEĞİŞKENLER =============
        let aktifAramaSutunu = null;
        let aramaMetni = '';
        let aramaZamanlayici = null;
        let mevcutSiralama = 'tarih_azalan';
        let currentSozlesmeId = null;
        let suAnSeciliSozlesmeId = null;
        let suAnSeciliDokumanNo = null;
        let suAnSeciliSatir = null;

        let kriterList = [];
        let selectedKriterIds = [];

        // Sütun tanımları
        const sutunlar = [
            { index: 1, ad: 'Doküman No', alan: 'dokumanNo' },
            { index: 2, ad: 'Bayi', alan: 'bayi' },
            { index: 3, ad: 'Yayın Tarihi', alan: 'yayinTarihi' },
            { index: 4, ad: 'Bitiş Tarihi', alan: 'bitisTarihi' },
            { index: 5, ad: 'Durum', alan: 'durum' },
            { index: 6, ad: 'Kriter Sayısı', alan: 'kriterSayisi' },
            { index: 7, ad: 'Dosya', alan: 'dosya' },
            { index: 8, ad: 'Revizyon', alan: 'revizyon' }
        ];

        let tarihFiltre = {
            baslangic: null,
            bitis: null,
            aktif: false
        };

        // ============= SAYFA YÜKLENDİĞİNDE =============
        $(document).ready(function () {
            initTarihFiltresi();
            yukleVeriler();

            // Sütun başlıklarına tıklama olayı
            $('thead th[data-sutun-index]').each(function () {
                const index = $(this).data('sutun-index');
                const ad = $(this).data('sutun-ad');
                const alan = $(this).data('sutun-alan');

                $(this).css('cursor', 'pointer').attr('title', 'Bu sütunda ara');

                $(this).on('click', function (e) {
                    if (!$(e.target).is('button') && !$(e.target).is('a')) {
                        e.stopPropagation();

                        if (aktifAramaSutunu === alan) {
                            sutunFiltresiniKaldir();
                        } else {
                            sutunFiltresiAktifEt(index, ad, alan);
                        }
                        $('#akilliArama').focus();
                    }
                });
            });

            // Çift tıklama ile sütun filtresini kaldır
            $('thead th[data-sutun-index]').on('dblclick', function (e) {
                e.stopPropagation();
                sutunFiltresiniKaldir();
            });

            // Arama inputu olayları
            $('#akilliArama').on('input', function () {
                aramaMetni = $(this).val().toLowerCase().trim();

                if (aramaZamanlayici) {
                    clearTimeout(aramaZamanlayici);
                }

                aramaZamanlayici = setTimeout(function () {
                    filtreleVeSirala();
                }, 300);
            });

            // Enter tuşu ile anında arama
            $('#akilliArama').on('keypress', function (e) {
                if (e.which === 13) {
                    e.preventDefault();
                    if (aramaZamanlayici) {
                        clearTimeout(aramaZamanlayici);
                    }
                    filtreleVeSirala();
                }
            });

            // Temizle butonu
            $('#akilliAramaTemizle').on('click', function () {
                $('#akilliArama').val('');
                aramaMetni = '';
                sutunFiltresiniKaldir();
                filtreleVeSirala();
            });

            // Tarih filtre temizle butonu
            $('#tarihFiltreTemizle').on('click', function () {
                if (typeof flatpickr !== 'undefined') {
                    const fp = $("#tarihAraligi").flatpickr();
                    if (fp) {
                        fp.clear();
                    }
                }
                $('#tarihAraligi').val('');
                tarihFiltre.baslangic = null;
                tarihFiltre.bitis = null;
                tarihFiltre.aktif = false;

                gosterAktifFiltreler();
                filtreleVeSirala();
            });

            // Sıralama değişikliği
            $('#siralamaSecenek').on('change', function () {
                mevcutSiralama = $(this).val();
                filtreleVeSirala();
            });

            // Başlangıçta aktif sütun göstergesini gizle
            $('#aktifSutunGosterge').hide();

            // Klavye kısayolu: ESC tuşu ile temizle
            $(document).on('keydown', function (e) {
                if (e.key === 'Escape' && $('#akilliArama').is(':focus')) {
                    $('#akilliAramaTemizle').click();
                }
            });

            // ============= SATIR SEÇME VE ÜST BUTONLAR =============
            const $seciliDuzenleBtn = $('#seciliDuzenleBtn');
            const $seciliSilBtn = $('#seciliSilBtn');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // Tablo satırına tıklandığında seç
            $(document).on('click', '#bayiSozlesmeTablosu tbody tr[data-sozlesme-id]', function (e) {
                if (!$(e.target).is('button') && !$(e.target).is('a') && !$(e.target).closest('.btn').length) {
                    satirSec($(this));
                }
            });

            // Satır seçme fonksiyonu
            function satirSec($satir) {
                const sozlesmeId = $satir.data('sozlesme-id');

                if (suAnSeciliSozlesmeId === sozlesmeId) {
                    // Aynı satıra tekrar tıklandığında seçimi kaldır
                    suAnSeciliSozlesmeId = null;
                    suAnSeciliDokumanNo = null;
                    suAnSeciliSatir = null;

                    $('#bayiSozlesmeTablosu tbody tr').removeClass('table-active');
                    $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                    // Butonları devre dışı bırak
                    $seciliDuzenleBtn.prop('disabled', true);
                    $seciliSilBtn.prop('disabled', true);
                } else {
                    // Yeni satır seç
                    suAnSeciliSozlesmeId = sozlesmeId;
                    suAnSeciliSatir = $satir;
                    suAnSeciliDokumanNo = $satir.data('dokuman-no');

                    // Tüm satırlardan active class'ı kaldır ve seçili satıra ekle
                    $('#bayiSozlesmeTablosu tbody tr').removeClass('table-active');
                    $satir.addClass('table-active');

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: ${suAnSeciliDokumanNo}`);

                    // Butonları aktif et
                    $seciliDuzenleBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            }

            // Üstteki "Düzenle" butonu
            $seciliDuzenleBtn.click(function () {
                if (suAnSeciliSozlesmeId) {
                    duzenle(suAnSeciliSozlesmeId);
                } else {
                    toastr.warning('Lütfen önce bir sözleşme seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function () {
                if (suAnSeciliSozlesmeId) {
                    $('#silinecekDokumanNo').text(suAnSeciliDokumanNo);
                    window.seciliSilinecekId = suAnSeciliSozlesmeId;
                    new bootstrap.Modal(document.getElementById('silModal')).show();
                } else {
                    toastr.warning('Lütfen önce bir sözleşme seçin.');
                }
            });

            // Silme modalı kapandıktan sonra seçimi temizleme
            $('#silModal').on('hidden.bs.modal', function () {
                if (suAnSeciliSozlesmeId) {
                    const $satir = $(`tr[data-sozlesme-id="${suAnSeciliSozlesmeId}"]`);
                    if ($satir.length === 0) {
                        // Satır silinmiş, seçimi temizle
                        clearSelection();
                    } else {
                        // İptal edildi
                        clearSelection();
                    }
                }
            });

            // Seçimi temizleme yardımcı fonksiyonu
            function clearSelection() {
                $('#bayiSozlesmeTablosu tbody tr').removeClass('table-active');
                suAnSeciliSozlesmeId = null;
                suAnSeciliDokumanNo = null;
                suAnSeciliSatir = null;
                $seciliBilgiDiv.html(`<i class="fas fa-info-circle text-muted me-1"></i>Kayıt seçilmedi`);

                // Tüm butonları devre dışı bırak
                $seciliDuzenleBtn.prop('disabled', true);
                $seciliSilBtn.prop('disabled', true);
            }

            // Silme butonu işleyicisi
            $('#silBtn').click(function () {
                if (window.seciliSilinecekId) {
                    sil(window.seciliSilinecekId);
                }
            });

            // Modal event'leri
            $('#sozlesmeModal').on('hidden.bs.modal', function () {
                formTemizle();
            });

            $('#sozlesmeModal').on('show.bs.modal', function () {
                if (!currentSozlesmeId) {
                    const today = new Date().toISOString().split('T')[0];
                    $('#yayinTarihi').val(today);
                    const oneYearLater = new Date();
                    oneYearLater.setFullYear(oneYearLater.getFullYear() + 1);
                    $('#bitisTarihi').val(oneYearLater.toISOString().split('T')[0]);
                }
            });
        });

        // ============= TARİH ARALIĞI FİLTRESİ =============
        function initTarihFiltresi() {
            if (typeof flatpickr !== 'undefined') {
                flatpickr("#tarihAraligi", {
                    mode: "range",
                    dateFormat: "d.m.Y",
                    locale: {
                        rangeSeparator: " - ",
                        firstDayOfWeek: 1,
                        weekdays: {
                            shorthand: ['Paz', 'Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt'],
                            longhand: ['Pazar', 'Pazartesi', 'Salı', 'Çarşamba', 'Perşembe', 'Cuma', 'Cumartesi']
                        },
                        months: {
                            shorthand: ['Oca', 'Şub', 'Mar', 'Nis', 'May', 'Haz', 'Tem', 'Ağu', 'Eyl', 'Eki', 'Kas', 'Ara'],
                            longhand: ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran', 'Temmuz', 'Ağustos', 'Eylül', 'Ekim', 'Kasım', 'Aralık']
                        }
                    },
                    onChange: function (selectedDates, dateStr, instance) {
                        if (selectedDates.length === 2) {
                            tarihFiltre.baslangic = selectedDates[0];
                            tarihFiltre.bitis = selectedDates[1];
                            tarihFiltre.bitis.setHours(23, 59, 59, 999);
                            tarihFiltre.aktif = true;

                            gosterAktifFiltreler();
                            filtreleVeSirala();
                        } else if (selectedDates.length === 0) {
                            tarihFiltre.baslangic = null;
                            tarihFiltre.bitis = null;
                            tarihFiltre.aktif = false;

                            gosterAktifFiltreler();
                            filtreleVeSirala();
                        }
                    }
                });
            } else {
                setTimeout(initTarihFiltresi, 100);
            }
        }

        // ============= SÜTUN FİLTRESİ =============
        function sutunFiltresiAktifEt(index, ad, alan) {
            $('thead th[data-sutun-index]').removeClass('sutun-aktif');
            $(`thead th[data-sutun-index="${index}"]`).addClass('sutun-aktif');
            aktifAramaSutunu = alan;
            $('#aktifSutunAdi').text(ad);
            $('#aktifSutunGosterge').fadeIn(200);

            if (aramaMetni) {
                filtreleVeSirala();
            }
        }

        function sutunFiltresiniKaldir() {
            $('thead th[data-sutun-index]').removeClass('sutun-aktif');
            aktifAramaSutunu = null;
            $('#aktifSutunGosterge').fadeOut(200);

            if (aramaMetni) {
                filtreleVeSirala();
            } else {
                tumSatirlariGoster();
            }
        }

        function tumSatirlariGoster() {
            $('#bayiSozlesmeTablosu tbody tr:not(.empty-state)').each(function () {
                $(this).show();
                $(this).find('td').removeClass('arama-vurgula');
            });
            $('#bayiSozlesmeTablosu .arama-bos-mesaj').remove();
        }

        function hucreMetniniAl($hucre, sutunAlani) {
            if (sutunAlani === 'yayinTarihi' || sutunAlani === 'bitisTarihi') {
                const badge = $hucre.find('.badge');
                return badge.length ? badge.text().toLowerCase().trim() : $hucre.text().toLowerCase().trim();
            } else if (sutunAlani === 'durum') {
                const badge = $hucre.find('.badge');
                return badge.length ? badge.text().toLowerCase().trim() : $hucre.text().toLowerCase().trim();
            } else if (sutunAlani === 'kriterSayisi') {
                const buton = $hucre.find('button');
                return buton.length ? buton.text().toLowerCase().trim() : $hucre.text().toLowerCase().trim();
            } else {
                return $hucre.text().toLowerCase().trim();
            }
        }

        function getSutunIndex(sutunAlani) {
            const bulunan = sutunlar.find(s => s.alan === sutunAlani);
            return bulunan ? bulunan.index : -1;
        }

        function getSutunAlani(index) {
            const bulunan = sutunlar.find(s => s.index === index);
            return bulunan ? bulunan.alan : null;
        }

        function parseTableDate(dateStr) {
            if (!dateStr || dateStr === '-' || dateStr.trim() === '') return null;
            const parts = dateStr.split('.');
            if (parts.length === 3) {
                const day = parseInt(parts[0]);
                const month = parseInt(parts[1]) - 1;
                const year = parseInt(parts[2]);
                return new Date(year, month, day);
            }
            return null;
        }

        function formatDateForDisplay(date) {
            if (!date) return '';
            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();
            return `${day}.${month}.${year}`;
        }

        function gosterAktifFiltreler() {
            const $aktifFiltreler = $('#aktifFiltreler');
            $aktifFiltreler.empty();

            if (tarihFiltre.aktif && tarihFiltre.baslangic && tarihFiltre.bitis) {
                const baslangicStr = formatDateForDisplay(tarihFiltre.baslangic);
                const bitisStr = formatDateForDisplay(tarihFiltre.bitis);

                $aktifFiltreler.append(`
                    <div class="filtre-badge">
                        <i class="fas fa-calendar-alt"></i>
                        Yayın Tarihi: ${baslangicStr} - ${bitisStr}
                        <span class="filtre-temizle" onclick="$('#tarihFiltreTemizle').click()">
                            <i class="fas fa-times"></i>
                        </span>
                    </div>
                `);
            }
        }

        // ============= ANA FİLTRELEME VE SIRALAMA =============
        function filtreleVeSirala() {
            const $satirlar = $('#bayiSozlesmeTablosu tbody tr:not(.empty-state, .filtre-bos-satir)');
            if ($satirlar.length === 0) return;

            let gosterilecekSatirlar = [];

            $satirlar.each(function () {
                const $satir = $(this);
                let goster = true;

                // Arama filtresi
                if (aramaMetni) {
                    let eslesmeVar = false;

                    if (aktifAramaSutunu) {
                        const sutunIndex = getSutunIndex(aktifAramaSutunu);
                        if (sutunIndex !== -1) {
                            const $hucre = $satir.find(`td:eq(${sutunIndex})`);
                            const hucreMetni = hucreMetniniAl($hucre, aktifAramaSutunu);

                            if (hucreMetni.includes(aramaMetni)) {
                                eslesmeVar = true;
                                $hucre.addClass('arama-vurgula');
                            }
                        }
                    } else {
                        $satir.find('td').each(function (index) {
                            if (index > 0) {
                                const $hucre = $(this);
                                const sutunAlani = getSutunAlani(index);
                                if (sutunAlani) {
                                    const hucreMetni = hucreMetniniAl($hucre, sutunAlani);
                                    if (hucreMetni.includes(aramaMetni)) {
                                        eslesmeVar = true;
                                        $hucre.addClass('arama-vurgula');
                                    }
                                }
                            }
                        });
                    }

                    if (!eslesmeVar) {
                        goster = false;
                    }
                }

                // Tarih filtresi
                if (goster && tarihFiltre.aktif && tarihFiltre.baslangic && tarihFiltre.bitis) {
                    const tarihStr = $satir.find('td:nth-child(4) .badge').text().trim();
                    if (tarihStr && tarihStr !== '-') {
                        const tarih = parseTableDate(tarihStr);
                        if (tarih) {
                            if (tarih < tarihFiltre.baslangic || tarih > tarihFiltre.bitis) {
                                goster = false;
                            }
                        } else {
                            goster = false;
                        }
                    } else {
                        goster = false;
                    }
                }

                if (goster) {
                    const dokumanNo = $satir.find('td:nth-child(2)').text().trim();
                    const bayi = $satir.find('td:nth-child(3)').text().trim();
                    const tarihStr = $satir.find('td:nth-child(4) .badge').text().trim();
                    const tarih = parseTableDate(tarihStr);
                    const kriterButon = $satir.find('td:nth-child(7) button').text().trim();
                    const kriterSayisi = parseInt(kriterButon.replace(/[^0-9]/g, '')) || 0;

                    gosterilecekSatirlar.push({
                        element: $satir,
                        dokumanNo: dokumanNo,
                        bayi: bayi,
                        tarih: tarih,
                        kriterSayisi: kriterSayisi
                    });
                }
            });

            // Sıralama
            gosterilecekSatirlar.sort((a, b) => {
                switch (mevcutSiralama) {
                    case 'tarih_azalan':
                        return (b.tarih || 0) - (a.tarih || 0);
                    case 'tarih_artan':
                        return (a.tarih || 0) - (b.tarih || 0);
                    case 'dokuman_az':
                        return (a.dokumanNo || '').localeCompare(b.dokumanNo || '', 'tr');
                    case 'dokuman_za':
                        return (b.dokumanNo || '').localeCompare(a.dokumanNo || '', 'tr');
                    case 'bayi_az':
                        return (a.bayi || '').localeCompare(b.bayi || '', 'tr');
                    case 'bayi_za':
                        return (b.bayi || '').localeCompare(a.bayi || '', 'tr');
                    case 'kriter_azalan':
                        return b.kriterSayisi - a.kriterSayisi;
                    case 'kriter_artan':
                        return a.kriterSayisi - b.kriterSayisi;
                    default:
                        return (b.tarih || 0) - (a.tarih || 0);
                }
            });

            // Tüm satırları gizle
            $satirlar.hide();

            // Sıralanmış satırları tabloya yeniden ekle
            const $tbody = $('#bayiSozlesmeTablosu tbody');
            gosterilecekSatirlar.forEach((item, index) => {
                $tbody.append(item.element);
                item.element.show();

                // Sıra numarasını güncelle
                const siraHucresi = item.element.find('td:nth-child(1)');
                if (siraHucresi) {
                    siraHucresi.text(index + 1);
                }
            });

            // Boş durum kontrolü
            if (gosterilecekSatirlar.length === 0) {
                let bosMesaj = $tbody.find('.arama-bos-mesaj');
                if (bosMesaj.length === 0) {
                    let mesaj = 'Filtreleme kriterlerine uygun sözleşme bulunamadı.';
                    if (tarihFiltre.aktif) {
                        mesaj = `Seçilen tarih aralığında (${formatDateForDisplay(tarihFiltre.baslangic)} - ${formatDateForDisplay(tarihFiltre.bitis)}) sözleşme bulunamadı.`;
                    } else if (aramaMetni) {
                        mesaj = `"${aramaMetni}" için sonuç bulunamadı.`;
                    }

                    $tbody.append(`
                        <tr class="arama-bos-mesaj">
                            <td colspan="9" class="text-center text-muted py-5">
                                <i class="fas fa-search fa-3x mb-3 opacity-50"></i><br>
                                <strong>${mesaj}</strong>
                                ${aktifAramaSutunu ? `<br><small class="text-muted">Aranan sütun: ${$('thead th.sutun-aktif').data('sutun-ad')}</small>` : ''}
                            </td>
                        </tr>
                    `);
                }
            } else {
                $tbody.find('.arama-bos-mesaj').remove();
            }
        }

        // ============= VERİ YÜKLEME FONKSİYONLARI =============
        function yukleVeriler() {
            // Bayileri yükle
            $.getJSON('/AdminBayiSozlesme/GetBayiler').done(function (data) {
                var bayiSelect = $('#bayiId').empty().append('<option value="">Bayi Seçiniz</option>');
                data.forEach(function (b) {
                    var option = $('<option>', {
                        value: b.value,
                        text: b.text
                    });
                    bayiSelect.append(option);
                });
                if (data.length > 0) {
                    bayiSelect.val(data[0].value);
                }
            });

            // Durumları yükle
            $.getJSON('/AdminBayiSozlesme/GetSozlesmeDurumlari').done(function (data) {
                $('#durumId').empty().append('<option value="">Durum Seçiniz</option>');
                data.forEach(function (d) {
                    $('#durumId').append(`<option value="${d.value}">${d.text}</option>`);
                });
            });

            // Kriter tanımlarını yükle
            $.getJSON('/AdminBayiSozlesme/GetKriterTanimlari').done(function (data) {
                kriterList = data;
                kriterListesiYukle();
            });
        }

        function kriterListesiYukle() {
            const container = $('#kriterListContainer');
            container.empty();

            if (kriterList && kriterList.length > 0) {
                kriterList.forEach(k => {
                    const secili = selectedKriterIds.includes(k.value.toString());
                    const div = $(`<div class="kriter-item ${secili ? 'selected' : ''}" data-id="${k.value}">${k.text}</div>`);
                    div.on('click', function() {
                        const idStr = $(this).data('id').toString();
                        const idx = selectedKriterIds.indexOf(idStr);
                        if (idx > -1) {
                            selectedKriterIds.splice(idx, 1);
                            $(this).removeClass('selected');
                        } else {
                            selectedKriterIds.push(idStr);
                            $(this).addClass('selected');
                        }
                    });
                    container.append(div);
                });
            } else {
                container.append('<div class="text-muted text-center py-3">Kriter bulunamadı.</div>');
            }
        }

        function tumunuSec() {
            selectedKriterIds = kriterList.map(k => k.value.toString());
            kriterListesiYukle();
        }

        function secimiTemizle() {
            selectedKriterIds = [];
            kriterListesiYukle();
        }

        function kriterleriGoster(id, dokumanNo) {
            $.get('/AdminBayiSozlesme/Getir?id=' + id, function (data) {
                $('#kriterModalDokumanNo').text(dokumanNo);
                const liste = $('#kriterListesi');

                if (data.kriterList && data.kriterList.length > 0) {
                    let html = '<ul class="list-group">';
                    data.kriterList.forEach(k => {
                        html += `<li class="list-group-item d-flex justify-content-between align-items-center">
                                    ${k.adi}
                                    <span class="badge bg-primary rounded-pill">%${k.oran}</span>
                                </li>`;
                    });
                    html += '</ul>';
                    liste.html(html);
                } else {
                    liste.html('<p class="text-muted text-center py-3">Bu sözleşmeye kriter eklenmemiş.</p>');
                }
                $('#kriterGoruntuleModal').modal('show');
            }).fail(function () {
                $('#kriterListesi').html('<p class="text-danger text-center py-3">Kriterler yüklenirken hata oluştu.</p>');
            });
        }

        function duzenle(id) {
            currentSozlesmeId = id;
            $.get('/AdminBayiSozlesme/Getir?id=' + id, function (data) {
                $('#sozlesmeId').val(data.id);
                $('#bayiId').val(data.bayiId);
                $('#dokumanNo').val(data.dokumanNo);
                $('#yayinTarihi').val(data.yayinTarihi);
                $('#bitisTarihi').val(data.bitisTarihi);
                $('#revizyonNo').val(data.revizyonNo || '');
                $('#revizeTarihi').val(data.revizeTarihi || '');
                $('#durumId').val(data.sozlesmeDurumuId);
                $('#gecerlilikSuresi').val(data.gecerlilikSuresi);

                if (data.dosyaYolu) {
                    $('#mevcutDosyaDiv').html(`<small class="text-success">Mevcut dosya: <a href="${data.dosyaYolu}" target="_blank">Görüntüle</a></small>`);
                } else {
                    $('#mevcutDosyaDiv').empty();
                }

                selectedKriterIds = data.kriterIds ? data.kriterIds.map(x => x.toString()) : [];
                kriterListesiYukle();

                $('#modalTitle').text('Sözleşme Düzenle');
                $('#sozlesmeModal').modal('show');
                benzersizKontrol();
            });
        }

        function benzersizKontrol() {
            const dokumanNo = $('#dokumanNo').val().trim();
            if (!dokumanNo) {
                $('#benzersizUyari').empty();
                return;
            }
            $.get('/AdminBayiSozlesme/BenzersizKontrol', {
                dokumanNo: dokumanNo,
                excludeId: currentSozlesmeId || null
            }, function (res) {
                if (res.varMi) {
                    $('#benzersizUyari').html('<small class="text-danger">Bu döküman no zaten kayıtlı!</small>');
                } else {
                    $('#benzersizUyari').empty();
                }
            });
        }



        function sil(id) {
            $.post('/AdminBayiSozlesme/Sil', { Id: id }, function (res) {
                if (res.success) {
                    Swal.fire('Silindi!', res.message, 'success').then(function () {
                        location.reload();
                    });
                } else {
                    Swal.fire('Hata!', res.message, 'error');
                }
            });
        }

        function formTemizle() {
            $('#sozlesmeForm')[0].reset();
            $('#sozlesmeId').val('0');
            $('#mevcutDosyaDiv').empty();
            $('#benzersizUyari').empty();
            selectedKriterIds = [];
            currentSozlesmeId = null;
            $('#modalTitle').text('Yeni Sözleşme Ekle');
            kriterListesiYukle();

            // Bayi listesini tekrar yükle ve ilk veriyi seç
            $.getJSON('/AdminBayiSozlesme/GetBayiler').done(function (data) {
                var bayiSelect = $('#bayiId').empty().append('<option value="">Bayi Seçiniz</option>');
                data.forEach(function (b) {
                    var option = $('<option>', {
                        value: b.value,
                        text: b.text
                    });
                    bayiSelect.append(option);
                });
                if (data.length > 0) {
                    bayiSelect.val(data[0].value);
                }
            });
        }

        // ============= YARDIMCI FONKSİYONLAR =============
        function escapeHtml(text) {
            if (text === null || text === undefined) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
                // Form submit olayını yakala
        $('#sozlesmeForm').on('submit', function (e) {
            e.preventDefault(); // Normal submit'i engelle

            if ($('#benzersizUyari').children().length > 0) {
                Swal.fire('Uyarı!', 'Bu döküman no zaten kayıtlı!', 'warning');
                return;
            }

            const formData = new FormData(this); // this = form elementi

            // KriterIds'leri manuel ekliyoruz (select multiple yok, checkbox da yok)
            // çünkü kriterler div click ile seçiliyor
            formData.delete('KriterIds'); // varsa temizle
            selectedKriterIds.forEach(id => {
                formData.append('KriterIds', id);
            });

            const url = currentSozlesmeId ? '/AdminBayiSozlesme/Guncelle' : '/AdminBayiSozlesme/Ekle';

            $.ajax({
                url: url,
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                cache: false,
                beforeSend: function () {
                    Swal.fire({
                        title: 'Kaydediliyor...',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });
                },
                success: function (res) {
                    Swal.close();
                    if (res.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Başarılı!',
                            text: res.message,
                            timer: 2000
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire('Hata!', res.message || 'Bilinmeyen hata oluştu.', 'error');
                    }
                },
                error: function (xhr, status, error) {
                    Swal.close();
                    let hataMesaji = 'Sunucu ile iletişim kurulamadı.';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        hataMesaji = xhr.responseJSON.message;
                    }
                    Swal.fire('Hata!', hataMesaji, 'error');
                    console.error(error);
                }
            });
        });
    </script>
}