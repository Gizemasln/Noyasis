                                            </div>
                                            <span class="badge ${response.cevapVerenTip === 'Admin' ? 'badge-admin' : 'badge-bayi'}">
                                                <i class="fas fa-user me-1"></i>${response.cevapVerenTip}
                                            </span>
                                        </div>
                                        <div class="card-body">

                                            <div class="mb-2">
                                                <strong>Cevap Tarihi:</strong> ${response.distributorCevapTarihi || '-'}
                                            </div>
                                            <div class="border rounded p-3 bg-light mb-2" style="white-space: pre-line;">
                                                ${response.distributorCevap}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            `;
                        }

                        let islemButonlari = '';

                        if (response.durumDuzenleyebilir && !response.distributorCevap) {
                            islemButonlari += `<button type="button" class="btn btn-info btn-sm ms-2 durum-guncelle-modal" data-bildirim-id="${response.id}"><i class="fas fa-sync me-1"></i>Durum Güncelle</button>`;
                        }
                        if (response.silebilir) {
                            islemButonlari += `<button type="button" class="btn btn-danger btn-sm ms-2 sil-bildirim-modal" data-bildirim-id="${response.id}" data-adsoyad="${response.adi} ${response.soyadi}"><i class="fas fa-trash me-1"></i>Sil</button>`;
                        }

                        $('#detayModalIcerik').html(`
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="card h-100">
                                        <div class="card-header bg-primary text-white">
                                            <i class="fas fa-info-circle me-2"></i>
                                            Temel Bilgiler
                                        </div>
                                        <div class="card-body">
                                            <div class="row small g-2">
                                                <div class="col-12">
                                                    <label class="text-muted">ID:</label>
                                                    <div class="fw-bold">#${response.id}</div>
                                                </div>
                                                <div class="col-12">
                                                    <label class="text-muted">Tip:</label>
                                                    <div>
                                                        <span class="badge ${response.tipi === 'ARGE' ? 'badge-ar-ge' : 'badge-hata'}">
                                                            ${response.tipi}
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-12">
                                                    <label class="text-muted">Ad Soyad:</label>
                                                    <div>${response.adi} ${response.soyadi}</div>
                                                </div>
                                                <div class="col-12">
                                                    <label class="text-muted">Durum:</label>
                                                    <div class="fw-bold ${response.argeDurumAdi === 'Cevap Verildi' ? 'text-success' : 'text-primary'}">
                                                        ${response.argeDurumAdi}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="card h-100">
                                        <div class="card-header bg-info text-white">
                                            <i class="fas fa-building me-2"></i>
                                            İşletme Bilgileri
                                        </div>
                                        <div class="card-body">
                                            <div class="row small g-2">
                                                <div class="col-12">
                                                    <label class="text-muted">Müşteri:</label>
                                                    <div>${response.musteriAdi}</div>
                                                </div>
                                                <div class="col-12">
                                                    <label class="text-muted">Bayi:</label>
                                                    <div>${response.bayiAdi}</div>
                                                </div>
                                                <div class="col-12">
                                                    <label class="text-muted">Lisans Tipi:</label>
                                                    <div>${response.lisansTipAdi}</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="card">
                                        <div class="card-header bg-warning ">
                                            <i class="fas fa-file-alt me-2"></i>
                                            İçerik
                                        </div>
                                        <div class="card-body">
                                            <div class="border rounded p-3 bg-light" style="white-space: pre-line; min-height: 100px;">
                                                ${response.metni || '-'}
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                ${cevapHtml}

                                <div class="col-md-6">
                                    <div class="card">
                                        <div class="card-header bg-secondary text-white">
                                            <i class="fas fa-history me-2"></i>
                                            Zaman Bilgileri
                                        </div>
                                        <div class="card-body">
                                            <div class="row small g-2">
                                                <div class="col-12">
                                                    <label class="text-muted">Eklenme Tarihi:</label>
                                                    <div>${response.eklenmeTarihi}</div>
                                                </div>
                                                <div class="col-12">
                                                    <label class="text-muted">Son Güncelleme:</label>
                                                    <div>${response.guncellenmeTarihi}</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="card">
                                        <div class="card-header bg-dark text-white">
                                            <i class="fas fa-paperclip me-2"></i>
