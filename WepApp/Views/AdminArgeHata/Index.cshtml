@using WepApp.Models
@model dynamic
@{
    ViewData["Title"] = "Ar-Ge & Hata Bildirimleri";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
    var durumlar = ViewBag.DurumListesi as List<ARGEDurum>;
    var bildirimler = ViewBag.ArgeHataListesi as List<ArgeHata>;
    var kullaniciTipi = ViewBag.KullaniciTipi as string;
    var kullaniciId = ViewBag.KullaniciId as int?;
    var bayiInfo = ViewBag.BayiInfo as Bayi;
    var isAuthenticated = !string.IsNullOrEmpty(kullaniciTipi);
    var isAdmin = kullaniciTipi == "Kurumsal";
    var isBayi = kullaniciTipi == "Bayi";
}
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<link href="/WebAdminTheme/assets/css/adminargehata.css" rel="stylesheet" />



<div class="argehata-container">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">
                        <i class="fas fa-bug me-2 text-primary"></i>Ar-Ge & Hata Bildirimleri
                    </h2>
                    @if (isAuthenticated)
                    {
                        <div class="d-flex align-items-center">
                            @if (isBayi && bayiInfo != null)
                            {
                                <span class="bayi-info me-2">
                                    <i class="fas fa-store me-1"></i> @bayiInfo.Unvan
                                </span>
                            }
                            <span class="user-info-badge">
                                <i class="fas fa-user me-1"></i>
                                @(isAdmin ? "Admin" : isBayi ? "Bayi" : "Kullanıcı")
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Tüm Bildirimler</h5>
                    
                    </div>
                    <div class="card-body p-0">
                        <!-- Filtreleme Paneli - Card'ın içinde, card-header'dan sonra -->
                        <div class="card-body border-bottom">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="mb-0 text-primary">
                                            <i class="fas fa-filter me-2"></i>Filtreleme Seçenekleri
                                        </h6>
                                        <div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary me-2" id="filtreleriTemizle">
                                                <i class="fas fa-eraser me-1"></i>Temizle
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-info" id="filtreUygula">
                                                <i class="fas fa-search me-1"></i>Filtre Uygula
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <!-- Tarih Filtreleri -->
                                <div class="col-md-2">
                                    <label class="form-label fw-bold small">Tarih Aralığı</label>
                                    <div class="btn-group w-100" role="group">
                                        <button type="button" class="btn btn-outline-primary btn-sm tarih-hizli" data-periyot="bugun">Bugün</button>
                                        <button type="button" class="btn btn-outline-primary btn-sm tarih-hizli" data-periyot="hafta">Bu Hafta</button>
                                        <button type="button" class="btn btn-outline-primary btn-sm tarih-hizli" data-periyot="ay">Bu Ay</button>
                                    </div>
                                </div>

                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Baş. T.</label>
                                    <input type="date" class="form-control form-control-sm" id="baslangicTarih">
                                </div>

                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Bit. T.</label>
                                    <input type="date" class="form-control form-control-sm" id="bitisTarih">
                                </div>

                                <!-- Tip Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Bildirim T.</label>
                                    <select class="form-select form-select-sm" id="tipFiltre">
                                        <option value="">Tüm Tipler</option>
                                        <option value="ARGE">AR-GE</option>
                                        <option value="Hata">Hata</option>
                                    </select>
                                </div>

                                <!-- Durum Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Durum</label>
                                    <select class="form-select form-select-sm" id="durumFiltre">
                                        <option value="0">Tüm Durumlar</option>
                                        @if (durumlar != null)
                                        {
                                            foreach (var durum in durumlar.Where(d => d.Durumu == 1).OrderBy(d => d.Sira))
                                            {
                                                <option value="@durum.Id">@durum.Adi</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <!-- Lisans Tipi Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Lisans T.</label>
                                    <select class="form-select form-select-sm" id="lisansTipFiltre">
                                        <option value="0">Tüm Lisans Tipleri</option>
                                        @{
                                            var lisansTipleri = bildirimler?
                                            .Where(b => b.LisansTip != null)
                                            .Select(b => b.LisansTip)
                                            .GroupBy(lt => lt.Id)
                                            .Select(g => g.First())
                                            .OrderBy(lt => lt.Adi)
                                            .ToList() ?? new List<LisansTip>();
                                        }
                                        @foreach (var lisansTip in lisansTipleri)
                                        {
                                            <option value="@lisansTip.Id">@lisansTip.Adi</option>
                                        }
                                    </select>
                                </div>

                                <!-- Cevap Durumu Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Cevap D.</label>
                                    <select class="form-select form-select-sm" id="cevapDurumFiltre">
                                        <option value="">Tümü</option>
                                        <option value="cevapli">Cevaplı</option>
                                        <option value="cevapsiz">Cevapsız</option>
                                    </select>
                                </div>
                                <!-- Sıralama -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Sıralama</label>
                                    <select class="form-select form-select-sm" id="siralamaFiltre">
                                        <option value="yeni">En Yeni → En Eski</option>
                                        <option value="eski">En Eski → En Yeni</option>
                                        <option value="tip">Tip (A-Z)</option>
                                        <option value="durum">Duruma Göre</option>
                                        <option value="musteri">Müşteri Adı (A-Z)</option>
                                        <option value="cevap">Cevap Durumuna Göre</option>
                                    </select>
                                </div>
                                <!-- Müşteri Arama -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Müşteri / Bayi</label>
                                    <input type="text" class="form-control form-control-sm" id="musteriFiltre" placeholder="Müşteri veya bayi ara...">
                                </div>

                                <!-- YENİ: Seçim ve İşlem Butonları Alanı -->
                                <div class="col-md-2 d-flex align-items-end">
                                    <div class="d-flex flex-column w-100">
                                        <label class="form-label fw-bold small invisible" style="user-select: none;">İşlemler</label> <!-- Görünmez label, hizalamayı düzeltir -->
                                        <div class="d-flex align-items-center gap-2 bg-light p-2 rounded border">
                                            <!-- Seçili Kayıt Bilgisi -->
                                            <div id="seciliKayitBilgi" class="small text-muted flex-grow-1" style="min-width: 120px;">
                                                <i class="fas fa-info-circle me-1"></i> Kayıt seçilmedi
                                            </div>
                                            <!-- Taşınan Butonlar -->
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button type="button" class="btn btn-outline-primary aksiyon-btn" id="seciliDetayGoster" title="Seçili Bildirimin Detaylarını Gör" data-button-permission="detay">
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-danger aksiyon-btn" id="seciliSil" title="Seçili Bildirimi Sil" disabled data-button-permission="sil">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Aktif Filtreler -->
                                <div class="col-12 mt-3" id="aktifFiltreler" style="display: none;">
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-light text-dark me-2 p-2">
                                            <i class="fas fa-filter me-1"></i>Aktif Filtreler:
                                        </span>
                                        <div id="filtreEtiketleri" class="d-flex flex-wrap gap-2"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th width="50">Seç</th>
                                        <th width="50">ID</th>
                                        <th width="50">Tip</th>
                                        <th width="120">Ad/Soyad</th>
                                        <th width="150">Müşteri</th>
                                        <th width="120">Bayi</th>
                                        <th width="120">L. Tipi</th>
                                        <th width="150">L. No</th>
                                        <th width="50">İçerik</th>
                                        <th width="80">Dosya</th>
                                        <th width="50">Cevap</th>
                                        <th width="50" class="durum-hucresi">Durum</th>
                                        <th width="50">Tarih</th>
                                    </tr>
                                </thead>
                                <tbody id="bildirimTablosu">
                                    @if (bildirimler != null && bildirimler.Count > 0)
                                    {
                                        foreach (var bildirim in bildirimler)
                                        {
                                            var durumId = bildirim.ARGEDurumId ?? 0;
                                            var satirCss = "";
                                            var durumCss = "";
                                            var durumAdi = bildirim.ARGEDurum?.Adi ?? "Yeni";

                                            // Satır CSS sınıfını belirle
                                            switch (durumId)
                                            {
                                                case 1: // Yeni
                                                    satirCss = "satir-yeni";
                                                    durumCss = "durum-yeni";
                                                    break;
                                                case 2: // Değerlendirmede
                                                    satirCss = "satir-degerlendirmede";
                                                    durumCss = "durum-degerlendirmede";
                                                    break;
                                                case 3: // Onaylandı
                                                    satirCss = "satir-onaylandi";
                                                    durumCss = "durum-onaylandi";
                                                    break;
                                                case 4: // Uygulandı
                                                    satirCss = "satir-uygulandi";
                                                    durumCss = "durum-uygulandi";
                                                    break;
                                                case 5: // Reddedildi
                                                    satirCss = "satir-reddedildi";
                                                    durumCss = "durum-reddedildi";
                                                    break;
                                                case 6: // Ertelendi
                                                    satirCss = "satir-ertelendi";
                                                    durumCss = "durum-ertelendi";
                                                    break;
                                                case 7: // Tamamlandı
                                                    satirCss = "satir-tamamlandi";
                                                    durumCss = "durum-tamamlandi";
                                                    break;
                                                default:
                                                    satirCss = "";
                                                    durumCss = "";
                                                    break;
                                            }

                                            // Cevap verildi mi kontrolü
                                            if (bildirim.DistributorCevapVerdiMi || bildirim.AdminCevapVerdiMi)
                                            {
                                                satirCss += " cevap-verildi";
                                            }

                                            // Bayi sadece kendi müşterilerini görebilsin
                                            var bayiGorebilir = !isBayi || (isBayi && bildirim.BayiId == kullaniciId);
                                            if (!bayiGorebilir) continue;

                                            // Cevap durumu kontrolü
                                            var cevapVerdiMi = bildirim.DistributorCevapVerdiMi || bildirim.AdminCevapVerdiMi;
                                            var cevapVerenTip = "";
                                            var cevapVerenAdi = "";
                                            if (bildirim.AdminCevapVerdiMi)
                                            {
                                                cevapVerenTip = "Admin";
                                            }
                                            else if (bildirim.DistributorCevapVerdiMi)
                                            {
                                                cevapVerenTip = "Bayi";
                                            }

                                            // Kullanıcının bu kayıt üzerinde yapabileceği işlemler
                                            var cevapYazabilir = isAuthenticated && !cevapVerdiMi;
                                            var cevapDuzenleyebilir = (isAdmin && bildirim.AdminCevapVerdiMi) ||
                                            (isBayi && bildirim.DistributorCevapVerdiMi && bildirim.DistributorBayiId == kullaniciId);
                                            var durumDuzenleyebilir = isAdmin || (isBayi && bildirim.BayiId == kullaniciId);
                                            var silebilir = isAdmin;

                                            <tr data-bildirim-id="@bildirim.Id" class="@satirCss">
                                                <td class="text-center">
                                                    <div class="form-check" onclick="event.stopPropagation();">
                                                        <!-- Satır tıklaması burada durmalı -->
                                                        <input class="form-check-input bildirim-sec-radio" type="radio" name="seciliBildirimRadio" value="@bildirim.Id" id="secim_@bildirim.Id">
                                                    </div>
                                                </td>
                                                <td><small class="text-muted">#@bildirim.Id</small></td>

                                                <td>
                                                    <span class="badge @(bildirim.Tipi == "ARGE" ? "badge-ar-ge" : "badge-hata")">
                                                        @bildirim.Tipi
                                                    </span>
                                                </td>

                                                <td>
                                                    <div class="fw-medium">@bildirim.Adi @bildirim.Soyadi</div>
                                                </td>

                                                <td>
                                                    @if (bildirim.Musteri != null)
                                                    {
                                                        <div>@bildirim.Musteri.Ad</div>
                                                        <small class="text-muted">@bildirim.Musteri.Telefon</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>

                                                <td>
                                                    <div class="small">@(bildirim.Bayi?.Unvan ?? "-")</div>
                                                </td>

                                                <td>
                                                    <span class="small">@(bildirim.LisansTip?.Adi ?? "-")</span>
                                                </td>
                                                <td>
                                                    <span class="small">@(bildirim.LisansNo ?? "-")</span>
                                                </td>
                                                <td>
                                                    <div class="metin-kisaltma" title="@bildirim.Metni">
                                                        @if (!string.IsNullOrEmpty(bildirim.Metni))
                                                        {
                                                            @(bildirim.Metni.Length > 100 ? bildirim.Metni.Substring(0, 100) + "..." : bildirim.Metni)
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    </div>
                                                </td>

                                                <td class="text-center">
                                                    @if (!string.IsNullOrEmpty(bildirim.DosyaYolu))
                                                    {
                                                        var dosyaAdi = System.IO.Path.GetFileName(bildirim.DosyaYolu);
                                                        <a href="~/WebAdminTheme/Arge/@dosyaAdi"
                                                           target="_blank"
                                                           class="text-primary"
                                                           title="Dosyayı indir">
                                                            <i class="fas fa-download"></i>
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>

                                                <td class="cevap-sutunu">
                                                  
                                                                            @if(!string.IsNullOrEmpty(bildirim.DistributorCevap))
                                                                            {
                                                            <div class="cevap-icerik mb-2" title="@bildirim.DistributorCevap">
                                                                <small class="d-block text-muted mb-1">Bayi Cevabı:</small>
                                                                @(bildirim.DistributorCevap.Length > 50 ? bildirim.DistributorCevap.Substring(0, 50) + "..." : bildirim.DistributorCevap)
                                                            </div>
                                                        }
                                                        @if (!string.IsNullOrEmpty(bildirim.AdminCevap))
                                                        {
                                                            <div class="cevap-icerik" title="@bildirim.AdminCevap">
                                                                <small class="d-block text-muted mb-1">Admin Cevabı:</small>
                                                                @(bildirim.AdminCevap.Length > 50 ? bildirim.AdminCevap.Substring(0, 50) + "..." : bildirim.AdminCevap)
                                                            </div>
                                                        }

                                                        <!-- Düzenle butonu artık her zaman görünecek (cevap varsa) -->
                                                        <button type="button" class="btn btn-sm btn-outline-warning cevap-duzenle" data-bildirim-id="@bildirim.Id">
                                                            <i class="fas fa-edit me-1"></i>Düzenle
                                                        </button>
                                                    
                                                </td>
                                                <!-- Durum sütunu -->
                                                <td class="durum-hucresi">
                                                   
                                                        <select class="form-select form-select-sm durum-select @durumCss"
                                                                data-bildirim-id="@bildirim.Id"
                                                                data-current-durum="@durumId"
                                                                data-current-durum-adi="@durumAdi"
                                                                title="@durumAdi">
                                                            @foreach (var d in durumlar)
                                                            {
                                                                <option value="@d.Id"
                                                                        data-durum-adi="@d.Adi"
                                                                @(durumId == d.Id ? "selected" : "")>
                                                                    @d.Adi
                                                                </option>
                                                            }
                                                        </select>
                                                 
                                                </td>

                                                <td>
                                                    <small class="text-muted">@bildirim.EklenmeTarihi.ToString("dd.MM.yy HH:mm")</small>
                                                </td>

                                              
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="13" class="empty-state">
                                                <i class="fas fa-inbox fa-2x mb-2"></i>
                                                <h5>Henüz bildirim bulunmuyor</h5>
                                                <p>Henüz bildirim eklenmemiş.</p>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detay Modal -->
<div class="modal fade" id="detayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fas fa-file-alt me-2"></i>
                    Bildirim Detayları
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detayModalIcerik">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Yükleniyor...</span>
                    </div>
                    <p class="mt-3">Bildirim detayları yükleniyor...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Kapat
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Silme Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Bildirim Silme
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2"><strong id="silinecekAdSoyad"></strong> isimli bildirimi silmek istediğinizden emin misiniz?</p>
                <p class="text-danger mb-0">
                    <small><i class="fas fa-info-circle me-1"></i> Bu işlem geri alınamaz.</small>
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>İptal
                </button>
                <button type="button" class="btn btn-danger" id="silBtn">
                    <i class="fas fa-trash me-2"></i>Sil
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Cevap Yazma Modal'ı -->
<div class="modal fade" id="cevapYazModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="fas fa-reply me-2"></i>
                    <span id="cevapModalBaslik">Cevap Yaz</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Cevap Metni <span class="text-danger">*</span></label>
                    <textarea class="form-control modal-cevap-textarea"
                              id="cevapMetni"
                              rows="8"
                              placeholder="Lütfen cevabınızı buraya yazınız..."></textarea>
                    <div class="form-text">
                        <i class="fas fa-info-circle me-1"></i>
                        Müşteriye göndereceğiniz cevap bu alana yazılacaktır.
                    </div>
                </div>
                <div class="alert alert-info">
                    <i class="fas fa-lightbulb me-2"></i>
                    <strong>İpucu:</strong> Cevabınız net, anlaşılır ve kapsamlı olsun. Müşterinin sorununu tam olarak çözmeyi hedefleyin.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>İptal
                </button>
                <button type="button" class="btn btn-success" id="cevapKaydetBtn">
                    <i class="fas fa-paper-plane me-2"></i>Gönder
                </button>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            let seciliBildirimId = null;
            let secilenDurumId = null;
            let secilenDurumAdi = null;

            // Arama fonksiyonu
            $('#bildirimArama').on('input', function () {
                const term = $(this).val().toLowerCase().trim();
                $('#bildirimTablosu tr').each(function () {
                    const $row = $(this);
                    if ($row.find('.empty-state').length > 0) return;

                    const text = $row.text().toLowerCase();
                    $row.toggle(text.includes(term));
                });
            });

            // Durum değiştirme
            $(document).on('change', '.durum-select', async function () {
                const $select = $(this);
                const bildirimId = $select.data('bildirim-id');
                const yeniDurumId = parseInt($select.val());
                const eskiDurumId = parseInt($select.data('current-durum'));

                if (yeniDurumId === eskiDurumId) {
                    return;
                }

                try {
                    const response = await $.ajax({
                        url: '/AdminArgeHata/DurumGuncelle',
                        type: 'POST',
                        data: {
                            id: bildirimId,
                            durumId: yeniDurumId
                        },
                        dataType: 'json'
                    });

                    if (response.success) {
                        $select.data('current-durum', yeniDurumId);

                        // Durum adını güncelle
                        const durumAdi = $select.find('option:selected').data('durum-adi') || response.durumAdi;
                        $select.attr('title', durumAdi);

                        // Satır rengini güncelle
                        const $row = $select.closest('tr');

                        // Tüm satır sınıflarını temizle
                        $row.removeClass('satir-yeni satir-degerlendirmede satir-onaylandi satir-uygulandi satir-reddedildi satir-ertelendi satir-tamamlandi');
                        $select.removeClass('durum-yeni durum-degerlendirmede durum-onaylandi durum-uygulandi durum-reddedildi durum-ertelendi durum-tamamlandi');

                        // Yeni sınıfları belirle
                        const satirCssMap = {
                            1: 'satir-yeni',
                            2: 'satir-degerlendirmede',
                            3: 'satir-onaylandi',
                            4: 'satir-uygulandi',
                            5: 'satir-reddedildi',
                            6: 'satir-ertelendi',
                            7: 'satir-tamamlandi'
                        };

                        const durumCssMap = {
                            1: 'durum-yeni',
                            2: 'durum-degerlendirmede',
                            3: 'durum-onaylandi',
                            4: 'durum-uygulandi',
                            5: 'durum-reddedildi',
                            6: 'durum-ertelendi',
                            7: 'durum-tamamlandi'
                        };

                        const yeniSatirCss = satirCssMap[yeniDurumId] || '';
                        const yeniDurumCss = durumCssMap[yeniDurumId] || '';

                        if (yeniSatirCss) $row.addClass(yeniSatirCss);
                        if (yeniDurumCss) $select.addClass(yeniDurumCss);

                        toastr.success(response.message || 'Durum başarıyla güncellendi.');
                    } else {
                        toastr.error(response.message || 'Durum güncellenemedi.');
                        $select.val(eskiDurumId);
                    }
                } catch (err) {
                    console.error('Hata:', err);
                    toastr.error('Sunucu ile bağlantı kurulamadı.');
