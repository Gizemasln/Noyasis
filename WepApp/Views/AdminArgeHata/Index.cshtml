                                        </div>
                                        <div class="card-body">
                                            <div>${response.dosyaGorunum || '-'}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            ${islemButonlari ? `<div class="mt-3 text-center">${islemButonlari}</div>` : ''}
                        `);

                        // Modal içindeki butonlara event listener ekle
                        if (response.cevapDuzenleyebilir) {
                            $('.cevap-duzenle-modal').off('click').on('click', function() {
                                detayModal.hide();
                                const id = $(this).data('bildirim-id');
                                $(`tr[data-bildirim-id="${id}"] .cevap-duzenle`).click();
                            });
