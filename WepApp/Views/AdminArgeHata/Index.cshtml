                    console.error('Hata:', error);
                    $('#detayModalIcerik').html(
                        '<div class="alert alert-danger">' +
                            '<i class="fas fa-exclamation-triangle me-2"></i>' +
                            'Bir hata oluştu: ' + (error.message || 'Sunucu ile bağlantı kurulamadı.') +
                        '</div>'
                    );
                }
            }

            // ============= SİLME FONKSİYONU =============
            async function bildirimSil(bildirimId) {
                if (!bildirimId) return;

                try {
                    const response = await $.ajax({
                        url: '/AdminArgeHata/Sil',
                        type: 'POST',
                        data: { Id: bildirimId },
                        dataType: 'json'
                    });

                    if (response.success) {
                        // Satırı tablodan kaldır
                        $(`tr[data-bildirim-id="${bildirimId}"]`).remove();

                        // Tablo boşsa boş durum mesajını göster
                        if ($('#bildirimTablosu tr:not(.empty-state)').length === 0) {
                            $('#bildirimTablosu').html(`
                                <tr>
                                    <td colspan="14" class="empty-state">
                                        <i class="fas fa-inbox fa-2x mb-2"></i>
                                        <h5>Henüz bildirim bulunmuyor</h5>
                                        <p>Henüz bildirim eklenmemiş.</p>
                                    </td>
                                </tr>
                            `);
                        }

                        toastr.success(response.message || 'Kayıt başarıyla silindi.');
                        return true;
                    } else {
                        toastr.error(response.message || 'Silme işlemi başarısız oldu.');
                        return false;
                    }
                } catch (error) {
                    console.error('Hata:', error);
                    if (error.status === 401) {
                        toastr.error('Bu işlem için yetkiniz bulunmamaktadır.');
                    } else if (error.responseJSON && error.responseJSON.message) {
                        toastr.error(error.responseJSON.message);
                    } else {
                        toastr.error('Silme işlemi sırasında bir hata oluştu.');
                    }
                    return false;
                }
            }

            // ============= YENİ: SATIR SEÇME VE ÜST BUTONLAR =============
            let suAnSeciliBildirimId = null;
            const $seciliDetayBtn = $('#seciliDetayGoster');
            const $seciliSilBtn = $('#seciliSil');
            const $seciliBilgiDiv = $('#seciliKayitBilgi');

            // Tablo satırına tıklandığında radio'yu seç
            $(document).on('click', '#bildirimTablosu tr[data-bildirim-id]', function(e) {
                // Eğer tıklanan element radio butonunun kendisi değilse (sonsuz döngüyü engelle)
                if (!$(e.target).is('input[type=radio]') && !$(e.target).is('select') && !$(e.target).is('button')) {
                    const $radio = $(this).find('.bildirim-sec-radio');
                    $radio.prop('checked', true).trigger('change'); // change event'ini tetikle
                }
            });

            // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
            $(document).on('change', '.bildirim-sec-radio', function() {
                if ($(this).is(':checked')) {
                    suAnSeciliBildirimId = $(this).val();
                    const $seciliSatir = $(this).closest('tr');
                    const bildirimId = suAnSeciliBildirimId;
                    const adSoyad = $seciliSatir.find('td:nth-child(4)').text().trim(); // Ad Soyad sütunu

                    // Bilgiyi güncelle
                    $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: #${bildirimId} - ${adSoyad}`);

                    // Butonları aktif et
                    $seciliDetayBtn.prop('disabled', false);
                    $seciliSilBtn.prop('disabled', false);
                }
            });

            // Üstteki "Detay Göster" butonu
            $seciliDetayBtn.click(function() {
                if (suAnSeciliBildirimId) {
                    // Doğrudan detay fonksiyonunu çağır
                    detayGoster(suAnSeciliBildirimId);
                } else {
                    toastr.warning('Lütfen önce bir bildirim seçin.');
                }
            });

            // Üstteki "Sil" butonu
            $seciliSilBtn.click(function() {
                if (suAnSeciliBildirimId) {
                    const $seciliSatir = $(`tr[data-bildirim-id="${suAnSeciliBildirimId}"]`);
                    const adSoyad = $seciliSatir.find('td:nth-child(4)').text().trim();

                    // Global değişkenleri set et ve modalı göster
                    seciliBildirimId = suAnSeciliBildirimId; // Mevcut silme kodundaki değişken
                    $('#silinecekAdSoyad').text(adSoyad);
                    const silModal = new bootstrap.Modal(document.getElementById('silModal'));
                    silModal.show();
                } else {
                    toastr.warning('Lütfen önce bir bildirim seçin.');
                }
            });

            // Silme butonu (modal içindeki)
            $('#silBtn').click(async function() {
                if (!seciliBildirimId) return;

                const $btn = $(this);
                $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Siliniyor...');

                const basarili = await bildirimSil(seciliBildirimId);

                if (basarili) {
                    // Modal'ı kapat
                    const silModal = bootstrap.Modal.getInstance(document.getElementById('silModal'));
                    silModal.hide();

                    // Seçimi temizle
                    if (suAnSeciliBildirimId == seciliBildirimId) {
                        $(`.bildirim-sec-radio[value="${suAnSeciliBildirimId}"]`).prop('checked', false);
                        suAnSeciliBildirimId = null;
                        $seciliBilgiDiv.html(`<i class="fas fa-info-circle me-1"></i> Kayıt seçilmedi`);
                        $seciliDetayBtn.prop('disabled', true);
                        $seciliSilBtn.prop('disabled', true);
                    }

                    seciliBildirimId = null;
                }

                $btn.prop('disabled', false).html('<i class="fas fa-trash me-2"></i>Sil');
            });

            // Modal kapandıktan sonra seçimi temizleme (iptal durumunda)
            $('#silModal').on('hidden.bs.modal', function() {
                // Sadece silme işlemi başarısız olduysa veya iptal edildiyse
                // Ama seçili öğeyi temizleme
                seciliBildirimId = null;
            });

            // Filtreleme sonrası seçimi temizle (çünkü satırlar yeniden düzenleniyor)
            $('#filtreUygula, #filtreleriTemizle').click(function() {
                if (suAnSeciliBildirimId) {
                    $(`.bildirim-sec-radio[value="${suAnSeciliBildirimId}"]`).prop('checked', false);
                    suAnSeciliBildirimId = null;
                    $seciliBilgiDiv.html(`<i class="fas fa-info-circle me-1"></i> Kayıt seçilmedi`);
                    $seciliDetayBtn.prop('disabled', true);
                    $seciliSilBtn.prop('disabled', true);
                }
            });
            // ============================================================

            // ============= AR-GE/HATA FİLTRELEME SİSTEMİ =============
            let aktifFiltreler = {
                baslangicTarih: null,
                bitisTarih: null,
                tip: '',
                durumId: 0,
                lisansTipId: 0,
                cevapDurum: '',
                musteriFiltre: '',
                siralama: 'yeni'
            };

            // Tarih hızlı seçimler
            $('.tarih-hizli').click(function() {
                const periyot = $(this).data('periyot');
                const bugun = new Date();
                let baslangic = new Date();
                let bitis = new Date();

                switch(periyot) {
                    case 'bugun':
                        baslangic = new Date(bugun.setHours(0,0,0,0));
                        bitis = new Date(bugun.setHours(23,59,59,999));
                        break;
                    case 'hafta':
                        // Pazartesi'den bugüne
                        const gun = bugun.getDay();
                        const pazartesiFarki = gun === 0 ? 6 : gun - 1;
                        baslangic = new Date(bugun);
                        baslangic.setDate(bugun.getDate() - pazartesiFarki);
                        baslangic.setHours(0,0,0,0);
                        bitis = new Date();
                        bitis.setHours(23,59,59,999);
                        break;
                    case 'ay':
                        baslangic = new Date(bugun.getFullYear(), bugun.getMonth(), 1);
                        baslangic.setHours(0,0,0,0);
                        bitis = new Date(bugun.getFullYear(), bugun.getMonth() + 1, 0);
                        bitis.setHours(23,59,59,999);
                        break;
                }

                $('#baslangicTarih').val(formatDateForInput(baslangic));
                $('#bitisTarih').val(formatDateForInput(bitis));

                filtreUygula();
            });

            // Filtre uygula butonu
            $('#filtreUygula').click(function() {
                filtreUygula();
            });

            // Filtreleri temizle
            $('#filtreleriTemizle').click(function() {
                $('#baslangicTarih').val('');
                $('#bitisTarih').val('');
                $('#tipFiltre').val('');
                $('#durumFiltre').val('0');
                $('#lisansTipFiltre').val('0');
                $('#cevapDurumFiltre').val('');
                $('#musteriFiltre').val('');
                $('#siralamaFiltre').val('yeni');
                $('#bildirimArama').val('');

                aktifFiltreler = {
                    baslangicTarih: null,
                    bitisTarih: null,
                    tip: '',
                    durumId: 0,
                    lisansTipId: 0,
                    cevapDurum: '',
                    musteriFiltre: '',
                    siralama: 'yeni'
                };

                $('#aktifFiltreler').hide();
                $('#filtreEtiketleri').empty();

                // Tüm satırları göster
                $('#bildirimTablosu tr').show();

                filtreleVeSirala();
            });

            // Ana filtreleme fonksiyonu
            function filtreUygula() {
                // Filtre değerlerini al
                const baslangicTarih = $('#baslangicTarih').val();
                const bitisTarih = $('#bitisTarih').val();
                const tip = $('#tipFiltre').val();
                const durumId = parseInt($('#durumFiltre').val());
                const lisansTipId = parseInt($('#lisansTipFiltre').val());
                const cevapDurum = $('#cevapDurumFiltre').val();
                const musteriFiltre = $('#musteriFiltre').val().toLowerCase().trim();
                const siralama = $('#siralamaFiltre').val();

                // Aktif filtreleri güncelle
                aktifFiltreler = {
                    baslangicTarih: baslangicTarih || null,
                    bitisTarih: bitisTarih || null,
                    tip: tip,
                    durumId: durumId,
                    lisansTipId: lisansTipId,
                    cevapDurum: cevapDurum,
                    musteriFiltre: musteriFiltre,
                    siralama: siralama
                };

                // Filtre etiketlerini göster
                filtreEtiketleriniGoster();

                // Filtrele ve sırala
                filtreleVeSirala();
            }

            // Filtre etiketlerini göster
            function filtreEtiketleriniGoster() {
                const etiketler = [];

                if (aktifFiltreler.baslangicTarih) {
                    etiketler.push(`<span class="badge bg-primary">Başlangıç: ${formatDateForDisplay(aktifFiltreler.baslangicTarih)}</span>`);
                }
                if (aktifFiltreler.bitisTarih) {
                    etiketler.push(`<span class="badge bg-primary">Bitiş: ${formatDateForDisplay(aktifFiltreler.bitisTarih)}</span>`);
                }
                if (aktifFiltreler.tip) {
                    etiketler.push(`<span class="badge bg-info">Tip: ${aktifFiltreler.tip}</span>`);
                }
                if (aktifFiltreler.durumId && aktifFiltreler.durumId !== 0) {
                    const durumAdi = $('#durumFiltre option:selected').text();
                    etiketler.push(`<span class="badge bg-success">Durum: ${durumAdi}</span>`);
                }
                if (aktifFiltreler.lisansTipId && aktifFiltreler.lisansTipId !== 0) {
                    const lisansAdi = $('#lisansTipFiltre option:selected').text();
                    etiketler.push(`<span class="badge bg-secondary">Lisans: ${lisansAdi}</span>`);
                }
                if (aktifFiltreler.cevapDurum) {
                    const cevapAdi = aktifFiltreler.cevapDurum === 'cevapli' ? 'Cevaplı' : 'Cevapsız';
                    etiketler.push(`<span class="badge bg-warning">${cevapAdi}</span>`);
                }
                if (aktifFiltreler.musteriFiltre) {
                    etiketler.push(`<span class="badge bg-dark">Arama: ${aktifFiltreler.musteriFiltre}</span>`);
                }
                if (aktifFiltreler.siralama !== 'yeni') {
                    const siralamaMetin = {
                        'eski': 'En Eski',
                        'tip': 'Tip',
                        'durum': 'Durum',
                        'musteri': 'Müşteri',
                        'cevap': 'Cevap Durumu'
                    };
                    etiketler.push(`<span class="badge bg-info">Sıralama: ${siralamaMetin[aktifFiltreler.siralama]}</span>`);
                }

                if (etiketler.length > 0) {
                    $('#filtreEtiketleri').html(etiketler.join(' '));
                    $('#aktifFiltreler').show();
                } else {
                    $('#aktifFiltreler').hide();
                }
            }

            // Filtrele ve sırala
            function filtreleVeSirala() {
                const $tablo = $('#bildirimTablosu');
                const $satirlar = $tablo.find('tr:not(.empty-state)');

                // Eğer hiç satır yoksa çık
                if ($satirlar.length === 0) return;

                let gorunenSatirlar = [];

                // Filtreleme işlemi
                $satirlar.each(function() {
                    const $satir = $(this);

                    // Tarih (sondan 3. sütun - index: -3)
                    const tarihStr = $satir.find('td:nth-last-child(3) small').text().trim() ||
                                     $satir.find('td:nth-last-child(3)').text().trim();
                    const tarih = parseDateTime(tarihStr);

                    // Tip (3. sütun - çünkü 1.seçim, 2.id, 3.tip)
                    const tip = $satir.find('td:nth-child(3) .badge').text().trim();

                    // Durum ID (data attribute)
                    const durumId = parseInt($satir.data('durum-id') || '0');

                    // Lisans tipi (7. sütun)
                    const lisansTipi = $satir.find('td:nth-child(7) .small').text().trim();

                    // Cevap durumu (11. sütunda cevap var mı?)
                    const cevapVar = $satir.find('.cevap-icerik').length > 0 ||
                                     $satir.find('.cevap-veren').length > 0;

                    // Müşteri/Bayi bilgisi (5. ve 6. sütunlar)
                    const musteriAdi = $satir.find('td:nth-child(5)').text().toLowerCase();
                    const bayiAdi = $satir.find('td:nth-child(6)').text().toLowerCase();

                    let goster = true;

                    // Tarih filtresi
                    if (aktifFiltreler.baslangicTarih && tarih) {
                        const baslangic = new Date(aktifFiltreler.baslangicTarih);
                        baslangic.setHours(0,0,0,0);
                        if (tarih < baslangic) goster = false;
                    }

                    if (goster && aktifFiltreler.bitisTarih && tarih) {
                        const bitis = new Date(aktifFiltreler.bitisTarih);
                        bitis.setHours(23,59,59,999);
                        if (tarih > bitis) goster = false;
                    }

                    // Tip filtresi
                    if (goster && aktifFiltreler.tip) {
                        if (tip !== aktifFiltreler.tip) goster = false;
                    }

                    // Durum filtresi
                    if (goster && aktifFiltreler.durumId && aktifFiltreler.durumId !== 0) {
                        if (durumId !== aktifFiltreler.durumId) goster = false;
                    }

                    // Lisans tipi filtresi
                    if (goster && aktifFiltreler.lisansTipId && aktifFiltreler.lisansTipId !== 0) {
                        const seciliLisansAdi = $('#lisansTipFiltre option:selected').text().toLowerCase();
                        if (!lisansTipi.toLowerCase().includes(seciliLisansAdi)) {
                            goster = false;
                        }
                    }

                    // Cevap durumu filtresi
                    if (goster && aktifFiltreler.cevapDurum) {
                        if (aktifFiltreler.cevapDurum === 'cevapli' && !cevapVar) {
                            goster = false;
                        } else if (aktifFiltreler.cevapDurum === 'cevapsiz' && cevapVar) {
                            goster = false;
                        }
                    }

                    // Müşteri/Bayi arama filtresi
                    if (goster && aktifFiltreler.musteriFiltre) {
                        const aranacakMetin = musteriAdi + ' ' + bayiAdi;
                        if (!aranacakMetin.includes(aktifFiltreler.musteriFiltre)) {
                            goster = false;
                        }
                    }

                    if (goster) {
                        gorunenSatirlar.push($satir);
                    } else {
                        $satir.hide();
                    }
                });

                // Sıralama işlemi
                if (gorunenSatirlar.length > 0) {
                    siralaVeGoster(gorunenSatirlar, $tablo);
                } else {
                    // Hiç sonuç yoksa mesaj göster
                    $tablo.find('.arama-bos-mesaj').remove();
                    $tablo.append(`
                        <tr class="arama-bos-mesaj">
                            <td colspan="14" class="text-center text-muted py-5">
                                <i class="fas fa-filter fa-2x mb-3"></i><br>
                                Filtreleme kriterlerine uygun bildirim bulunamadı.
                            </td>
                        </tr>
                    `);
                }
            }

            // Sıralama ve gösterme
            function siralaVeGoster(satirlar, $tablo) {
                const siralamaliSatirlar = [...satirlar];

                switch(aktifFiltreler.siralama) {
                    case 'yeni':
                        siralamaliSatirlar.sort((a, b) => {
                            const tarihA = parseDateTime($(a).find('td:nth-last-child(3) small').text().trim() ||
                                                        $(a).find('td:nth-last-child(3)').text().trim());
                            const tarihB = parseDateTime($(b).find('td:nth-last-child(3) small').text().trim() ||
                                                        $(b).find('td:nth-last-child(3)').text().trim());
                            return (tarihB || 0) - (tarihA || 0);
                        });
                        break;

                    case 'eski':
                        siralamaliSatirlar.sort((a, b) => {
                            const tarihA = parseDateTime($(a).find('td:nth-last-child(3) small').text().trim() ||
                                                        $(a).find('td:nth-last-child(3)').text().trim());
                            const tarihB = parseDateTime($(b).find('td:nth-last-child(3) small').text().trim() ||
                                                        $(b).find('td:nth-last-child(3)').text().trim());
                            return (tarihA || 0) - (tarihB || 0);
                        });
                        break;

                    case 'tip':
                        siralamaliSatirlar.sort((a, b) => {
                            const tipA = $(a).find('td:nth-child(3) .badge').text().trim();
                            const tipB = $(b).find('td:nth-child(3) .badge').text().trim();
                            return tipA.localeCompare(tipB, 'tr');
                        });
                        break;

                    case 'durum':
                        siralamaliSatirlar.sort((a, b) => {
                            const durumA = parseInt($(a).data('durum-id') || '0');
                            const durumB = parseInt($(b).data('durum-id') || '0');
                            return durumA - durumB;
                        });
                        break;

                    case 'musteri':
                        siralamaliSatirlar.sort((a, b) => {
                            const musteriA = $(a).find('td:nth-child(5)').text().trim();
                            const musteriB = $(b).find('td:nth-child(5)').text().trim();
                            return musteriA.localeCompare(musteriB, 'tr');
                        });
                        break;

                    case 'cevap':
                        siralamaliSatirlar.sort((a, b) => {
                            const cevapA = $(a).find('.cevap-icerik').length > 0 ? 1 : 0;
                            const cevapB = $(b).find('.cevap-icerik').length > 0 ? 1 : 0;
                            return cevapB - cevapA;
                        });
                        break;
                }

                // Tüm satırları gizle
                $tablo.find('tr:not(.arama-bos-mesaj)').hide();

                // Sıralanmış satırları göster
                siralamaliSatirlar.forEach(satir => {
                    $(satir).show();
                });

                // Boş mesaj varsa kaldır
                $tablo.find('.arama-bos-mesaj').remove();
            }

            // Tarih formatlama yardımcı fonksiyonları
            function formatDateForInput(date) {
                const yil = date.getFullYear();
                const ay = String(date.getMonth() + 1).padStart(2, '0');
                const gun = String(date.getDate()).padStart(2, '0');
                return `${yil}-${ay}-${gun}`;
            }

            function formatDateForDisplay(dateStr) {
                if (!dateStr) return '';
                const [yil, ay, gun] = dateStr.split('-');
                return `${gun}.${ay}.${yil}`;
            }

            function parseDateTime(dateStr) {
                if (!dateStr) return null;
                // Format: dd.MM.yy HH:mm
                const parts = dateStr.split(' ');
                if (parts.length < 2) return null;

                const dateParts = parts[0].split('.');
                if (dateParts.length !== 3) return null;

                const gun = parseInt(dateParts[0]);
                const ay = parseInt(dateParts[1]) - 1;
                let yil = parseInt(dateParts[2]);

                // 2 haneli yıl formatı varsa 20 ekle
                if (yil < 100) {
                    yil = 2000 + yil;
                }

                return new Date(yil, ay, gun);
            }

            // Enter tuşu ile filtreleme
            $('#baslangicTarih, #bitisTarih, #tipFiltre, #durumFiltre, #lisansTipFiltre, #cevapDurumFiltre, #musteriFiltre, #siralamaFiltre').on('keyup change', function(e) {
                if (e.type === 'change' || (e.type === 'keyup' && e.key === 'Enter')) {
                    filtreUygula();
                }
            });
        });
    </script>
}