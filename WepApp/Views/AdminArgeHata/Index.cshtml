            // Cevap kaydet butonu (yeni + güncelle)
            $('#cevapKaydetBtn').click(async function() {
                const $btn = $(this);
                const islem = $btn.data('islem');
                const bildirimId = $btn.data('bildirim-id');
                const cevap = $('#cevapMetni').val().trim();

                // Validasyon
                if (!cevap) {
                    toastr.warning('Lütfen cevap metnini giriniz.');
                    $('#cevapMetni').focus();
                    return;
                }
                if (cevap.length < 10) {
                    toastr.warning('Cevap metni en az 10 karakter olmalıdır.');
                    $('#cevapMetni').focus();
                    return;
                }

                // Butonu devre dışı bırak + loading göster
                $btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Kaydediliyor...');

                try {
                    let url = '';
                    if (islem === 'yeni') {
                        url = '/AdminArgeHata/CevapVer';
                    } else {
                        url = '/AdminArgeHata/CevapGuncelle';
                    }

                    const response = await $.ajax({
                        url: url,
                        type: 'POST',
                        data: {
                            id: bildirimId,
                            aciklama: cevap,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()  // ← BU SATIR ÇOK ÖNEMLİ!
                        },
                        dataType: 'json'
                    });

                    if (response.success) {
                        // Modal'ı kapat
                        const cevapModal = bootstrap.Modal.getInstance(document.getElementById('cevapYazModal'));
                        cevapModal.hide();

                        // Satırı güncelle (tablodaki görünümü yenile)
                        const $row = $(`tr[data-bildirim-id="${bildirimId}"]`);
                        const kisaCevap = cevap.length > 50 ? cevap.substring(0, 50) + '...' : cevap;

                        const cevapVerenBadge = response.cevapVerenTip === 'Admin' ? 'badge-admin' : 'badge-bayi';

                        const cevapHtml = `
                            <div class="cevap-icerik" title="${cevap}">
                                ${kisaCevap}
                            </div>

                            <div class="mt-1">
                                <button type="button" class="btn btn-sm btn-outline-warning cevap-duzenle" data-bildirim-id="${bildirimId}">
                                    <i class="fas fa-edit me-1"></i>Düzenle
                                </button>
                            </div>
                        `;

                        $row.find('.cevap-sutunu').html(cevapHtml);
                        $row.addClass('cevap-verildi');

                        toastr.success(response.message || 'Cevabınız başarıyla kaydedildi.');
                    } else {
                        toastr.error(response.message || 'Kayıt sırasında bir hata oluştu.');
                    }
                } catch (err) {
                    console.error('AJAX Hatası:', err);

                    if (err.status === 401 || err.status === 403) {
                        toastr.error('Bu işlem için giriş yapmanız gerekmektedir.');
                    } else if (err.status === 400) {
                        toastr.error('Geçersiz istek. Lütfen formu kontrol edin.');
                    } else if (err.status === 404) {
                        toastr.error('Güncelleme servisi bulunamadı.');
                    } else {
                        toastr.error('Sunucu ile bağlantı kurulamadı. Lütfen daha sonra tekrar deneyin.');
                    }
                } finally {
                    $btn.prop('disabled', false).html('<i class="fas fa-paper-plane me-2"></i>Gönder');
                }
            });

            // Cevap içeriğine tıklayınca tamamını göster
            $(document).on('click', '.cevap-icerik', async function() {
                const $cevapDiv = $(this);
                const $row = $cevapDiv.closest('tr');
                const bildirimId = $row.data('bildirim-id');

            });

            // ============= DETAY GÖSTERME FONKSİYONU (ÜST BUTON İÇİN) =============
            async function detayGoster(bildirimId) {
                try {
                    const detayModal = new bootstrap.Modal(document.getElementById('detayModal'));
                    detayModal.show();

                    $('#detayModalIcerik').html(
