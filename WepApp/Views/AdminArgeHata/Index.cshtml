                        if (response.silebilir) {
                            $('.sil-bildirim-modal').off('click').on('click', function() {
                                detayModal.hide();
                                seciliBildirimId = $(this).data('bildirim-id');
                                $('#silinecekAdSoyad').text($(this).data('adsoyad'));
