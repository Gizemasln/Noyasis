            // Filtre değerlerini al
            const baslangicTarih = $('#baslangicTarih').val();
            const bitisTarih = $('#bitisTarih').val();
            const konu = $('#konuFiltre').val().toLowerCase().trim();
            const durumId = parseInt($('#durumFiltre').val());
            const lisansTipId = parseInt($('#lisansTipFiltre').val());
            const gonderenTip = $('#gonderenTipFiltre').val();
            const gonderenAd = $('#gonderenAdFiltre').val().toLowerCase().trim();
            const cevapDurum = $('#cevapDurumFiltre').val();
            const siralama = $('#siralamaFiltre').val();

            // Aktif filtreleri güncelle
            aktifFiltreler = {
                baslangicTarih: baslangicTarih || null,
                bitisTarih: bitisTarih || null,
                konu: konu,
                durumId: durumId,
                lisansTipId: lisansTipId,
                gonderenTip: gonderenTip,
                gonderenAd: gonderenAd,
                cevapDurum: cevapDurum,
                siralama: siralama
            };

            // Filtre etiketlerini göster
            filtreEtiketleriniGoster();

            // Filtrele ve sırala
            filtreleVeSirala();
        }

        // Filtre etiketlerini göster
        function filtreEtiketleriniGoster() {
            const etiketler = [];

            if (aktifFiltreler.baslangicTarih) {
                etiketler.push(`<span class="badge bg-primary">Başlangıç: ${formatDateForDisplay(aktifFiltreler.baslangicTarih)}</span>`);
            }
            if (aktifFiltreler.bitisTarih) {
                etiketler.push(`<span class="badge bg-primary">Bitiş: ${formatDateForDisplay(aktifFiltreler.bitisTarih)}</span>`);
            }
            if (aktifFiltreler.konu) {
                etiketler.push(`<span class="badge bg-info">Konu: ${aktifFiltreler.konu}</span>`);
            }
            if (aktifFiltreler.durumId && aktifFiltreler.durumId !== 0) {
                const durumAdi = $('#durumFiltre option:selected').text();
                etiketler.push(`<span class="badge bg-success">Durum: ${durumAdi}</span>`);
            }
            if (aktifFiltreler.lisansTipId && aktifFiltreler.lisansTipId !== 0) {
                const lisansAdi = $('#lisansTipFiltre option:selected').text();
                etiketler.push(`<span class="badge bg-secondary">Lisans: ${lisansAdi}</span>`);
            }
            if (aktifFiltreler.gonderenTip) {
                etiketler.push(`<span class="badge bg-warning">Gönderen Tipi: ${aktifFiltreler.gonderenTip}</span>`);
            }
            if (aktifFiltreler.gonderenAd) {
                etiketler.push(`<span class="badge bg-dark">Gönderen: ${aktifFiltreler.gonderenAd}</span>`);
            }
            if (aktifFiltreler.cevapDurum) {
                const cevapAdi = aktifFiltreler.cevapDurum === 'cevapli' ? 'Cevaplı' : 'Cevapsız';
                etiketler.push(`<span class="badge bg-info">${cevapAdi}</span>`);
            }
            if (aktifFiltreler.siralama !== 'yeni') {
                const siralamaMetin = {
                    'eski': 'En Eski',
                    'konu': 'Konu',
                    'durum': 'Durum',
                    'gonderen': 'Gönderen',
                    'cevap': 'Cevap Durumu'
                };
                etiketler.push(`<span class="badge bg-info">Sıralama: ${siralamaMetin[aktifFiltreler.siralama]}</span>`);
            }

            if (etiketler.length > 0) {
                $('#filtreEtiketleri').html(etiketler.join(' '));
                $('#aktifFiltreler').show();
            } else {
                $('#aktifFiltreler').hide();
            }
        }

        // Filtrele ve sırala
        function filtreleVeSirala() {
            const $tablo = $('#bildirimTablosu');
            const $satirlar = $tablo.find('tr:not(.empty-state)');

            // Eğer hiç satır yoksa çık
            if ($satirlar.length === 0) return;

            let gorunenSatirlar = [];

            // Filtreleme işlemi
            $satirlar.each(function() {
                const $satir = $(this);

                // Tarih (sondan 2. sütun - index: -2)
                const tarihStr = $satir.find('td:nth-last-child(2) small').text().trim() ||
                                 $satir.find('td:nth-last-child(2)').text().trim();
                const tarih = parseDateTime(tarihStr);

                // Konu (2. sütun)
                const konu = $satir.find('td:nth-child(2)').text().toLowerCase().trim();

                // İçerik (3. sütun)
                const icerik = $satir.find('td:nth-child(3)').text().toLowerCase().trim();

                // Gönderen (4. sütun)
                const gonderen = $satir.find('td:nth-child(4) .gonderen-info').text().toLowerCase().trim();
                const gonderenTip = $satir.find('td:nth-child(4) small').text().trim();

                // Lisans tipi (5. sütun)
                const lisansTipi = $satir.find('td:nth-child(5) .small').text().trim();

                // Durum ID (data attribute)
                const durumId = parseInt($satir.data('durum-id') || '0');

                // Cevap durumu (6. sütunda cevap var mı?)
                const cevapVar = $satir.find('.cevap-icerik').length > 0 ||
                                 $satir.find('.cevap-veren').length > 0;

                let goster = true;

                // Tarih filtresi
                if (aktifFiltreler.baslangicTarih && tarih) {
                    const baslangic = new Date(aktifFiltreler.baslangicTarih);
                    baslangic.setHours(0,0,0,0);
                    if (tarih < baslangic) goster = false;
                }

                if (goster && aktifFiltreler.bitisTarih && tarih) {
                    const bitis = new Date(aktifFiltreler.bitisTarih);
                    bitis.setHours(23,59,59,999);
                    if (tarih > bitis) goster = false;
                }

                // Konu filtresi
                if (goster && aktifFiltreler.konu) {
                    if (!konu.includes(aktifFiltreler.konu) && !icerik.includes(aktifFiltreler.konu)) {
                        goster = false;
                    }
                }

                // Durum filtresi
                if (goster && aktifFiltreler.durumId && aktifFiltreler.durumId !== 0) {
                    if (durumId !== aktifFiltreler.durumId) goster = false;
                }

                // Lisans tipi filtresi
                if (goster && aktifFiltreler.lisansTipId && aktifFiltreler.lisansTipId !== 0) {
                    const seciliLisansAdi = $('#lisansTipFiltre option:selected').text().toLowerCase();
                    if (!lisansTipi.toLowerCase().includes(seciliLisansAdi)) {
                        goster = false;
                    }
                }

                // Gönderen tipi filtresi
                if (goster && aktifFiltreler.gonderenTip) {
                    if (!gonderenTip.includes(aktifFiltreler.gonderenTip)) {
                        goster = false;
                    }
                }

                // Gönderen adı filtresi
                if (goster && aktifFiltreler.gonderenAd) {
                    if (!gonderen.includes(aktifFiltreler.gonderenAd)) {
                        goster = false;
                    }
                }

                // Cevap durumu filtresi
                if (goster && aktifFiltreler.cevapDurum) {
                    if (aktifFiltreler.cevapDurum === 'cevapli' && !cevapVar) {
                        goster = false;
                    } else if (aktifFiltreler.cevapDurum === 'cevapsiz' && cevapVar) {
                        goster = false;
                    }
                }

                if (goster) {
                    gorunenSatirlar.push($satir);
                } else {
                    $satir.hide();
                }
            });

            // Sıralama işlemi
            if (gorunenSatirlar.length > 0) {
                siralaVeGoster(gorunenSatirlar, $tablo);
            } else {
                // Hiç sonuç yoksa mesaj göster
                $tablo.find('.arama-bos-mesaj').remove();
                $tablo.append(`
                    <tr class="arama-bos-mesaj">
                        <td colspan="9" class="text-center text-muted py-5">
                            <i class="fas fa-filter fa-2x mb-3"></i><br>
                            Filtreleme kriterlerine uygun bildirim bulunamadı.
                        </td>
                    </tr>
                `);
            }
        }

        // Sıralama ve gösterme
        function siralaVeGoster(satirlar, $tablo) {
            const siralamaliSatirlar = [...satirlar];

            switch(aktifFiltreler.siralama) {
                case 'yeni':
                    siralamaliSatirlar.sort((a, b) => {
                        const tarihA = parseDateTime($(a).find('td:nth-last-child(2) small').text().trim() ||
                                                    $(a).find('td:nth-last-child(2)').text().trim());
                        const tarihB = parseDateTime($(b).find('td:nth-last-child(2) small').text().trim() ||
                                                    $(b).find('td:nth-last-child(2)').text().trim());
                        return (tarihB || 0) - (tarihA || 0);
                    });
                    break;

                case 'eski':
                    siralamaliSatirlar.sort((a, b) => {
                        const tarihA = parseDateTime($(a).find('td:nth-last-child(2) small').text().trim() ||
                                                    $(a).find('td:nth-last-child(2)').text().trim());
                        const tarihB = parseDateTime($(b).find('td:nth-last-child(2) small').text().trim() ||
                                                    $(b).find('td:nth-last-child(2)').text().trim());
                        return (tarihA || 0) - (tarihB || 0);
                    });
                    break;

                case 'konu':
                    siralamaliSatirlar.sort((a, b) => {
                        const konuA = $(a).find('td:nth-child(2)').text().trim();
                        const konuB = $(b).find('td:nth-child(2)').text().trim();
                        return konuA.localeCompare(konuB, 'tr');
                    });
                    break;

                case 'durum':
                    siralamaliSatirlar.sort((a, b) => {
                        const durumA = parseInt($(a).data('durum-id') || '0');
                        const durumB = parseInt($(b).data('durum-id') || '0');
                        return durumA - durumB;
                    });
                    break;

                case 'gonderen':
                    siralamaliSatirlar.sort((a, b) => {
                        const gonderenA = $(a).find('td:nth-child(4) .gonderen-info').text().trim();
                        const gonderenB = $(b).find('td:nth-child(4) .gonderen-info').text().trim();
                        return gonderenA.localeCompare(gonderenB, 'tr');
                    });
                    break;

                case 'cevap':
                    siralamaliSatirlar.sort((a, b) => {
                        const cevapA = $(a).find('.cevap-icerik').length > 0 ? 1 : 0;
                        const cevapB = $(b).find('.cevap-icerik').length > 0 ? 1 : 0;
                        return cevapB - cevapA;
                    });
                    break;
            }

            // Tüm satırları gizle
            $tablo.find('tr:not(.arama-bos-mesaj)').hide();

            // Sıralanmış satırları göster
            siralamaliSatirlar.forEach(satir => {
                $(satir).show();
            });

            // Boş mesaj varsa kaldır
            $tablo.find('.arama-bos-mesaj').remove();
        }

        // Tarih formatlama yardımcı fonksiyonları
        function formatDateForInput(date) {
            const yil = date.getFullYear();
            const ay = String(date.getMonth() + 1).padStart(2, '0');
            const gun = String(date.getDate()).padStart(2, '0');
            return `${yil}-${ay}-${gun}`;
        }

        function formatDateForDisplay(dateStr) {
            if (!dateStr) return '';
            const [yil, ay, gun] = dateStr.split('-');
            return `${gun}.${ay}.${yil}`;
        }

        function parseDateTime(dateStr) {
            if (!dateStr) return null;
            // Format: dd.MM.yy HH:mm
            const parts = dateStr.split(' ');
            if (parts.length < 2) return null;

            const dateParts = parts[0].split('.');
            if (dateParts.length !== 3) return null;

            const gun = parseInt(dateParts[0]);
            const ay = parseInt(dateParts[1]) - 1;
            let yil = parseInt(dateParts[2]);

            // 2 haneli yıl formatı varsa 20 ekle
            if (yil < 100) {
                yil = 2000 + yil;
            }

            return new Date(yil, ay, gun);
        }

        // Enter tuşu ile filtreleme
        $('#baslangicTarih, #bitisTarih, #konuFiltre, #durumFiltre, #lisansTipFiltre, #gonderenTipFiltre, #gonderenAdFiltre, #cevapDurumFiltre, #siralamaFiltre').on('keyup change', function(e) {
            if (e.type === 'change' || (e.type === 'keyup' && e.key === 'Enter')) {
                filtreUygula();
            }
        });

        // Sayfa yüklendiğinde mevcut arama inputunu filtreleme sistemine entegre et
        $(document).ready(function() {
                    // ============= YENİ: SATIR SEÇME VE ÜST BUTONLAR =============
        let suAnSeciliBildirimId = null;
        const $seciliDetayBtn = $('#seciliDetayGoster');
        const $seciliSilBtn = $('#seciliSil');
        const $seciliBilgiDiv = $('#seciliKayitBilgi');

        // Tablo satırına tıklandığında radio'yu seç
        $(document).on('click', '#bildirimTablosu tr[data-bildirim-id]', function(e) {
            // Eğer tıklanan element radio butonunun kendisi, select veya buton değilse
            if (!$(e.target).is('input[type=radio]') && !$(e.target).is('select') && !$(e.target).is('button')) {
                const $radio = $(this).find('.bildirim-sec-radio');
                $radio.prop('checked', true).trigger('change');
            }
        });

        // Radio butonu değiştiğinde (seçildiğinde) üst butonları ve bilgiyi güncelle
        $(document).on('change', '.bildirim-sec-radio', function() {
            if ($(this).is(':checked')) {
                suAnSeciliBildirimId = $(this).val();
                const $seciliSatir = $(this).closest('tr');
                const bildirimId = suAnSeciliBildirimId;
                const konu = $seciliSatir.find('td:nth-child(3)').text().trim(); // Konu sütunu (index: 1.seçim, 2.id, 3.konu)

                // Bilgiyi güncelle
                $seciliBilgiDiv.html(`<i class="fas fa-check-circle text-success me-1"></i> Seçili: #${bildirimId} - ${konu.substring(0, 30)}${konu.length > 30 ? '...' : ''}`);

                // Butonları aktif et
                $seciliDetayBtn.prop('disabled', false);
                $seciliSilBtn.prop('disabled', false);
            }
        });

          // Üstteki "Detay Göster" butonu
        $seciliDetayBtn.click(function() {
            if (suAnSeciliBildirimId) {
                // Doğrudan detay modalını aç
                detayGoster(suAnSeciliBildirimId);
            } else {
                toastr.warning('Lütfen önce bir bildirim seçin.');
            }
        });
                       // Detay gösterme fonksiyonu
        async function detayGoster(bildirimId) {
            try {
                const detayModal = new bootstrap.Modal(document.getElementById('detayModal'));
                detayModal.show();

                $('#detayModalIcerik').html(
                    '<div class="text-center py-5">' +
                        '<div class="spinner-border text-success" role="status"></div>' +
                        '<p class="mt-3">Bildirim detayları yükleniyor...</p>' +
                    '</div>'
                );

                const response = await $.ajax({
                    url: '/AdminIstekOneri/DetayGetir',
                    type: 'GET',
                    data: { id: bildirimId },
                    dataType: 'json'
                });

                if (response.success) {
                    let cevapHtml = '';
                    if (response.distributorCevap) {
                        cevapHtml = `
                            <div class="col-12 mb-3">
                                <div class="card border-success">
                                    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="fas fa-comment-dots me-2"></i>
                                            Cevap
                                        </div>
                                        <span class="badge ${response.cevapVerenTip === 'Admin' ? 'badge-admin' : 'badge-bayi'}">
                                            <i class="fas fa-user me-1"></i>${response.cevapVerenTip}
                                        </span>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-2">
                                            <strong>Cevap Tarihi:</strong> ${response.distributorCevapTarihi || '-'}
                                        </div>
                                        <div class="border rounded p-3 bg-light mb-2" style="white-space: pre-line;">
                                            ${response.distributorCevap}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                    }

                    $('#detayModalIcerik').html(`
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="card h-100">
                                    <div class="card-header bg-primary text-white">
                                        <i class="fas fa-info-circle me-2"></i>
                                        Temel Bilgiler
                                    </div>
                                    <div class="card-body">
                                        <div class="row small g-2">
                                            <div class="col-12">
                                                <label class="text-muted">ID:</label>
                                                <div class="fw-bold">#${response.id}</div>
                                            </div>
                                            <div class="col-12">
                                                <label class="text-muted">Konu:</label>
                                                <div>${response.konu}</div>
                                            </div>
                                            <div class="col-12">
                                                <label class="text-muted">Durum:</label>
                                                <div class="fw-bold">${response.istekDurumAdi}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="card h-100">
                                    <div class="card-header bg-info text-white">
                                        <i class="fas fa-building me-2"></i>
                                        İşletme Bilgileri
                                    </div>
                                    <div class="card-body">
                                        <div class="row small g-2">
                                            <div class="col-12">
                                                <label class="text-muted">Gönderen:</label>
                                                <div>${response.musteriAdi != "Belirtilmemiş" ? response.musteriAdi : response.bayiAdi}</div>
                                            </div>
                                            <div class="col-12">
                                                <label class="text-muted">Gönderen Tipi:</label>
                                                <div>${response.musteriAdi != "Belirtilmemiş" ? 'Müşteri' : (response.bayiAdi != "Belirtilmemiş" ? 'Bayi' : 'Belirtilmemiş')}</div>
                                            </div>
                                            <div class="col-12">
                                                <label class="text-muted">Lisans Tipi:</label>
                                                <div>${response.lisansTipAdi}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header bg-warning">
                                        <i class="fas fa-file-alt me-2"></i>
                                        İçerik
                                    </div>
                                    <div class="card-body">
                                        <div class="border rounded p-3 bg-light" style="white-space: pre-line; min-height: 100px;">
                                            ${response.metni || '-'}
                                        </div>
                                    </div>
                                </div>
                            </div>

                            ${cevapHtml}

                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-header bg-secondary text-white">
                                        <i class="fas fa-history me-2"></i>
                                        Zaman Bilgileri
                                    </div>
                                    <div class="card-body">
                                        <div class="row small g-2">
                                            <div class="col-12">
                                                <label class="text-muted">Eklenme Tarihi:</label>
                                                <div>${response.eklenmeTarihi}</div>
                                            </div>
                                            <div class="col-12">
                                                <label class="text-muted">Son Güncelleme:</label>
                                                <div>${response.guncellenmeTarihi}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `);
                } else {
                    $('#detayModalIcerik').html(
                        '<div class="alert alert-danger">' +
                            '<i class="fas fa-exclamation-triangle me-2"></i>' +
                            (response.message || 'Detay bilgileri alınamadı.') +
                        '</div>'
                    );
                }
            } catch (error) {
                console.error('Hata:', error);
                $('#detayModalIcerik').html(
                    '<div class="alert alert-danger">' +
                        '<i class="fas fa-exclamation-triangle me-2"></i>' +
                        'Bir hata oluştu: ' + (error.message || 'Sunucu ile bağlantı kurulamadı.') +
                    '</div>'
                );
            }
        }
        // Üstteki "Sil" butonu
        $seciliSilBtn.click(function() {
            if (suAnSeciliBildirimId) {
                const $seciliSatir = $(`tr[data-bildirim-id="${suAnSeciliBildirimId}"]`);
                const konu = $seciliSatir.find('td:nth-child(3)').text().trim();

                // Global değişkenleri set et ve modalı göster
                seciliBildirimId = suAnSeciliBildirimId;
                $('#silinecekKonu').text(konu);
                const silModal = new bootstrap.Modal(document.getElementById('silModal'));
                silModal.show();
            } else {
                toastr.warning('Lütfen önce bir bildirim seçin.');
            }
        });

        // Modal kapandıktan sonra seçimi temizle (silme başarılı veya iptal)
        $('#silModal').on('hidden.bs.modal', function() {
            if (suAnSeciliBildirimId) {
                // Silme başarılı olduysa satır zaten DOM'dan kalktı, kontrol et
                const $satir = $(`tr[data-bildirim-id="${suAnSeciliBildirimId}"]`);
                if ($satir.length === 0) {
                    // Satır silinmiş, seçimi temizle
                    suAnSeciliBildirimId = null;
                    $seciliBilgiDiv.html(`<i class="fas fa-info-circle me-1"></i> Kayıt seçilmedi`);
                    $seciliDetayBtn.prop('disabled', true);
                    $seciliSilBtn.prop('disabled', true);
                } else {
                    // İptal edildi, radio'yu temizle
                    $(`.bildirim-sec-radio[value="${suAnSeciliBildirimId}"]`).prop('checked', false);
                    suAnSeciliBildirimId = null;
                    $seciliBilgiDiv.html(`<i class="fas fa-info-circle me-1"></i> Kayıt seçilmedi`);
                    $seciliDetayBtn.prop('disabled', true);
                    $seciliSilBtn.prop('disabled', true);
                }
            }
            seciliBildirimId = null;
        });

        // Filtreleme sonrası seçimi temizle
        $('#filtreleriTemizle, .tarih-hizli').click(function() {
            setTimeout(function() {
                if (suAnSeciliBildirimId) {
                    $(`.bildirim-sec-radio[value="${suAnSeciliBildirimId}"]`).prop('checked', false);
                    suAnSeciliBildirimId = null;
                    $seciliBilgiDiv.html(`<i class="fas fa-info-circle me-1"></i> Kayıt seçilmedi`);
                    $seciliDetayBtn.prop('disabled', true);
                    $seciliSilBtn.prop('disabled', true);
                }
            }, 100);
        });
        // ============================================================
            // Mevcut arama inputu zaten varsa, onu da dinle
            const originalArama = $('#bildirimArama');
            if (originalArama.length) {
                originalArama.on('input', function() {
                    const deger = $(this).val().toLowerCase().trim();
                    $('#konuFiltre').val(deger);
                    aktifFiltreler.konu = deger;
                    filtreleVeSirala();
                });
            }
        });});
    </script>
}