@using WepApp.Models
@model dynamic
@{
    ViewData["Title"] = "İstek & Öneri Bildirimleri";
    Layout = "~/Views/Shared/_LayoutWebAdmin.cshtml";
    var durumlar = ViewBag.DurumListesi as List<IstekOneriDurum>;
    var bildirimler = ViewBag.IstekOneriListesi as List<IstekOneriler>;
    var kullaniciTipi = ViewBag.KullaniciTipi as string;
    var kullaniciId = ViewBag.KullaniciId as int?;
    var bayiInfo = ViewBag.BayiInfo as Bayi;
    var isAuthenticated = !string.IsNullOrEmpty(kullaniciTipi);
    var isAdmin = kullaniciTipi == "Kurumsal";
    var isBayi = kullaniciTipi == "Bayi";

}
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
<link href="/WebAdminTheme/assets/css/administekoneri.css" rel="stylesheet" />




<div class="istekoner-container">
    <div class="container-fluid">
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">
                        <i class="fas fa-lightbulb me-2 text-success"></i>İstek & Öneri Bildirimleri
                    </h2>
                    @if (isAuthenticated)
                    {
                        <div class="d-flex align-items-center">
                            @if (isBayi && bayiInfo != null)
                            {
                                <span class="bayi-info me-2">
                                    <i class="fas fa-store me-1"></i> @bayiInfo.Unvan
                                </span>
                            }
                            <span class="user-info-badge">
                                <i class="fas fa-user me-1"></i>
                                @(isAdmin ? "Admin" : isBayi ? "Bayi" : "Kullanıcı")
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Tüm Bildirimler</h5>
                        <div class="search-box">
                      
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <!-- Filtreleme Paneli - Card'ın içinde, card-header'dan sonra -->
                        <div class="card-body border-bottom">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="mb-0 text-primary">
                                            <i class="fas fa-filter me-2"></i>Filtreleme Seçenekleri
                                        </h6>
                                        <div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary me-2" id="filtreleriTemizle">
                                                <i class="fas fa-eraser me-1"></i>Temizle
                                            </button>
                                      
                                        </div>
                                    </div>
                                </div>

                                <!-- Tarih Filtreleri -->
                                <div class="col-md-2">
                                    <label class="form-label fw-bold small">Tarih Aralığı</label>
                                    <div class="btn-group w-100 " role="group">
                                        <button type="button" class="btn btn-outline-primary btn-sm tarih-hizli" data-periyot="bugun">Bugün</button>
                                        <button type="button" class="btn btn-outline-primary btn-sm tarih-hizli" data-periyot="hafta">Bu Hafta</button>
                                        <button type="button" class="btn btn-outline-primary btn-sm tarih-hizli" data-periyot="ay">Bu Ay</button>
                                    </div>
                                </div>

                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Baş. T.</label>
                                    <input type="date" class="form-control form-control-sm" id="baslangicTarih">
                                </div>

                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Bit. T.</label>
                                    <input type="date" class="form-control form-control-sm" id="bitisTarih">
                                </div>
                                <!-- Gönderen Tipi Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Gönderen Tipi</label>
                                    <select class="form-select form-select-sm" id="gonderenTipFiltre">
                                        <option value="">Tümü</option>
                                        <option value="Müşteri">Müşteri</option>
                                        <option value="Bayi">Bayi</option>
                                    </select>
                                </div>

 
                                <!-- Durum Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Durum</label>
                                    <select class="form-select form-select-sm" id="durumFiltre">
                                        <option value="0">Tüm Durumlar</option>
                                        @if (durumlar != null)
                                        {
                                            foreach (var durum in durumlar.Where(d => d.Durumu == 1).OrderBy(d => d.Sira))
                                            {
                                                <option value="@durum.Id">@durum.Adi</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <!-- Lisans Tipi Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Lisans Tipi</label>
                                    <select class="form-select form-select-sm" id="lisansTipFiltre">
                                        <option value="0">Tüm Lisans Tipleri</option>
                                        @{
                                            var lisansTipleri = bildirimler?
                                            .Where(b => b.LisansTip != null)
                                            .Select(b => b.LisansTip)
                                            .GroupBy(lt => lt.Id)
                                            .Select(g => g.First())
                                            .OrderBy(lt => lt.Adi)
                                            .ToList() ?? new List<LisansTip>();
                                        }
                                        @foreach (var lisansTip in lisansTipleri)
                                        {
                                            <option value="@lisansTip.Id">@lisansTip.Adi</option>
                                        }
                                    </select>
                                </div>



                                <!-- Cevap Durumu Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Cevap/label>
                                    <select class="form-select form-select-sm" id="cevapDurumFiltre">
                                        <option value="">Tümü</option>
                                        <option value="cevapli">Cevaplı</option>
                                        <option value="cevapsiz">Cevapsız</option>
                                    </select>
                                </div>

                                <!-- Sıralama -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Sıralama</label>
                                    <select class="form-select form-select-sm" id="siralamaFiltre">
                                        <option value="yeni">En Yeni → En Eski</option>
                                        <option value="eski">En Eski → En Yeni</option>
                                        <option value="konu">Konu (A-Z)</option>
                                        <option value="durum">Duruma Göre</option>
                                        <option value="gonderen">Gönderen Adı (A-Z)</option>
                                        <option value="cevap">Cevap Durumuna Göre</option>
                                    </select>
                                </div>


                                <!-- Gönderen Adı Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Gönd. Adı</label>
                                    <input type="text" class="form-control form-control-sm" id="gonderenAdFiltre" placeholder="Gönderen adı ara...">
                                </div>

                                <!-- Konu Filtresi -->
                                <div class="col-md-1">
                                    <label class="form-label fw-bold small">Konu</label>
                                    <input type="text" class="form-control form-control-sm" id="konuFiltre" placeholder="Konu ara...">
                                </div>
                                <!-- YENİ: Seçim ve İşlem Butonları Alanı -->
                                <div class="col-md-1 d-flex align-items-end">
                                    <div class="d-flex flex-column w-100">
                                        <label class="form-label fw-bold small invisible" style="user-select: none;">İşlemler</label>
                                        <div class="d-flex align-items-center gap-2 bg-light p-2 rounded border">
                                            <!-- Taşınan Butonlar -->
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button type="button" class="btn btn-outline-primary aksiyon-btn" id="seciliDetayGoster" data-button-permission="detay" title="Seçili Bildirimin Detaylarını Gör" disabled>
                                                    <i class="fas fa-eye"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-danger aksiyon-btn" id="seciliSil" data-button-permission="sil" title="Seçili Bildirimi Sil" disabled>
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- Aktif Filtreler -->
                                <div class="col-12 mt-3" id="aktifFiltreler" style="display: none;">
                                    <div class="d-flex align-items-center">
                                        <span class="badge bg-light text-dark me-2 p-2">
                                            <i class="fas fa-filter me-1"></i>Aktif Filtreler:
                                        </span>
                                        <div id="filtreEtiketleri" class="d-flex flex-wrap gap-2"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th width="40">Seç</th> <!-- YENİ SÜTUN -->

                                        <th width="60">ID</th>
                                        <th width="120">Konu</th>
                                        <th width="200">İçerik</th>
                                        <th width="150">Gönderen</th>
                                        <th width="120">Lisans Tipi</th>
                                        <th width="220">Cevap</th>
                                        <th width="100" class="durum-hucresi">Durum</th>
                                        <th width="120">Tarih</th>
                                     
                                    </tr>
                                </thead>
                                <tbody id="bildirimTablosu">
                                    @if (bildirimler != null && bildirimler.Count > 0)
                                    {
                                        int gosterilenSatir = 0;
                                        foreach (var bildirim in bildirimler)
                                        {
                                            var durumId = bildirim.IstekOneriDurumId;
                                            var satirCss = "";
                                            var durumCss = "";
                                            var durumAdi = bildirim.IstekOneriDurum?.Adi ?? "Yeni";

                                            // Satır CSS sınıfını belirle
                                            switch (durumId)
                                            {
                                                case 1:
                                                    satirCss = "satir-yeni";
                                                    durumCss = "durum-yeni";
                                                    break;
                                                case 2:
                                                    satirCss = "satir-degerlendirmede";
                                                    durumCss = "durum-degerlendirmede";
                                                    break;
                                                case 3:
                                                    satirCss = "satir-onaylandi";
                                                    durumCss = "durum-onaylandi";
                                                    break;
                                                case 4:
                                                    satirCss = "satir-uygulandi";
                                                    durumCss = "durum-uygulandi";
                                                    break;
                                                case 5:
                                                    satirCss = "satir-reddedildi";
                                                    durumCss = "durum-reddedildi";
                                                    break;
                                                case 6:
                                                    satirCss = "satir-ertelendi";
                                                    durumCss = "durum-ertelendi";
                                                    break;
                                                case 7:
                                                    satirCss = "satir-tamamlandi";
                                                    durumCss = "durum-tamamlandi";
                                                    break;
                                            }

                                            // Cevap verildi mi kontrolü
                                            if (bildirim.DistributorCevapVerdiMi || bildirim.AdminCevapVerdiMi)
                                            {
                                                satirCss += " cevap-verildi";
                                            }

                                            // Gönderen bilgisini belirle
                                            string gonderen = "";
                                            string gonderenTip = "";
                                            if (bildirim.BayiId != null)
                                            {
                                                gonderen = bildirim.Bayi?.Unvan ?? "Bayi";
                                                gonderenTip = "Bayi";
                                            }
                                            else if (bildirim.MusteriId != null)
                                            {
                                                gonderen = bildirim.Musteri?.AdSoyad ?? bildirim.Musteri?.TicariUnvan ?? "Müşteri";
                                                gonderenTip = "Müşteri";
                                            }
                                            else
                                            {
                                                gonderen = "Belirtilmemiş";
                                                gonderenTip = "";
                                            }

                                            // Cevap durumu kontrolü
                                            var cevapVerdiMi = bildirim.DistributorCevapVerdiMi || bildirim.AdminCevapVerdiMi;
                                            var cevapVerenTip = "";
                                            var cevapVerenAdi = "";
                                            if (bildirim.AdminCevapVerdiMi)
                                            {
                                                cevapVerenTip = "Admin";
                                            }
                                            else if (bildirim.DistributorCevapVerdiMi)
                                            {
                                                cevapVerenTip = "Bayi";
                                            }

                                            // Kullanıcının bu kayıt üzerinde yapabileceği işlemler
                                            var cevapYazabilir = isAuthenticated && !cevapVerdiMi;
                                            var cevapDuzenleyebilir = (isAdmin && bildirim.AdminCevapVerdiMi) ||
                                            (isBayi && bildirim.DistributorCevapVerdiMi && bildirim.DistributorBayiId == kullaniciId);
                                            var durumDuzenleyebilir = isAdmin || (isBayi && bildirim.BayiId == kullaniciId);
                                            var silebilir = isAdmin;

                                            gosterilenSatir++;
                                            <tr data-bildirim-id="@bildirim.Id" data-durum-id="@durumId" class="@satirCss">
                                                <td class="text-center">
                                                    <div class="form-check" onclick="event.stopPropagation();">
                                                        <input class="form-check-input bildirim-sec-radio" type="radio" name="seciliBildirimRadio" value="@bildirim.Id" id="secim_@bildirim.Id">
                                                    </div>
                                                </td>
                                                <td><small class="text-muted">#@bildirim.Id</small></td>

                                                <td>
                                                    <div class="fw-medium">@bildirim.Konu</div>
                                                </td>

                                                <td>
                                                    <div class="metin-kisaltma" title="@bildirim.Metni">
                                                        @if (!string.IsNullOrEmpty(bildirim.Metni))
                                                        {
                                                            @(bildirim.Metni.Length > 100 ? bildirim.Metni.Substring(0, 100) + "..." : bildirim.Metni)
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    </div>
                                                </td>

                                                <td>
                                                    <div class="gonderen-info">@gonderen</div>
                                                    @if (!string.IsNullOrEmpty(gonderenTip))
                                                    {
                                                        <small class="text-muted">@gonderenTip</small>
                                                    }
                                                </td>

                                                <td>
                                                    <span class="small">@(bildirim.LisansTip?.Adi ?? "-")</span>
                                                </td>

                                                <!-- Cevap sütunu -->
                                                <td class="cevap-sutunu">
                                                    @if (cevapVerdiMi)
                                                    {
                                                        <div class="cevap-icerik" title="@bildirim.DistributorCevap">
                                                            @if (!string.IsNullOrEmpty(bildirim.DistributorCevap))
                                                            {
                                                                if (bildirim.DistributorCevap.Length > 50)
                                                                {
                                                                    @bildirim.DistributorCevap.Substring(0, 50) <text>...</text>
                                                                }
                                                                else
                                                                {
                                                                    @bildirim.DistributorCevap
                                                                }
                                                            }
                                                        </div>
                                                    
                                                      
                                                            <div class="mt-1">
                                                            <button type="button" data-button-permission="cevapduzenle"
                                                                        class="btn btn-sm btn-outline-warning cevap-duzenle"
                                                                        data-bildirim-id="@bildirim.Id">
                                                                    <i class="fas fa-edit me-1"></i>Düzenle
                                                                </button>
                                                            </div>
                                                        
                                                    }
                                                    else
                                                    {
                                                        @if (cevapYazabilir)
                                                        {
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-success cevap-yaz" data-button-permission="cevapyaz"
                                                                    data-bildirim-id="@bildirim.Id">
                                                                <i class="fas fa-reply me-1"></i>Cevap Yaz
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">-</span>
                                                        }
                                                    }
                                                </td>

                                                <!-- Durum sütunu -->
                                                <td class="durum-hucresi">
                                                    <select class="form-select form-select-sm durum-select @durumCss"
                                                                data-bildirim-id="@bildirim.Id"
                                                                data-current-durum="@durumId"
                                                                data-current-durum-adi="@durumAdi"
                                                                title="@durumAdi">
                                                            @foreach (var d in durumlar)
                                                            {
                                                                <option value="@d.Id"
                                                                        data-durum-adi="@d.Adi"
                                                                @(durumId == d.Id ? "selected" : "")>
                                                                    @d.Adi
                                                                </option>
                                                            }
                                                        </select>
                                                   
                                                </td>

                                                <td>
                                                    <small class="text-muted">@bildirim.EklenmeTarihi.ToString("dd.MM.yy HH:mm")</small>
                                                </td>

                                           
                                            </tr>
                                        }
                                        <!-- Debug: Kaç satır gösterildiğini kontrol et -->
                                        <tr style="display: none;">
                                            <td colspan="9">Toplam gösterilen satır: @gosterilenSatir</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="9" class="empty-state">
                                                <i class="fas fa-inbox fa-2x mb-2"></i>
                                                <h5>Henüz bildirim bulunmuyor</h5>
                                                <p>
                                                    @if (bildirimler == null)
                                                    {
                                                        <text>ViewBag.IstekOneriListesi null</text>
                                                    }
                                                    else if (bildirimler.Count == 0)
                                                    {
                                                        <text>Liste boş</text>
                                                    }
                                                    else
                                                    {
                                                        <text>Bilinmeyen hata</text>
                                                    }
                                                </p>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detay Modal -->
<div class="modal fade" id="detayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="fas fa-file-alt me-2"></i>
                    Bildirim Detayları
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detayModalIcerik">
                <div class="text-center py-5">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">Yükleniyor...</span>
                    </div>
                    <p class="mt-3">Bildirim detayları yükleniyor...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Kapat
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Silme Onay Modal -->
<div class="modal fade" id="silModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Bildirim Silme
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2"><strong id="silinecekKonu"></strong> konulu bildirimi silmek istediğinizden emin misiniz?</p>
                <p class="text-danger mb-0">
                    <small><i class="fas fa-info-circle me-1"></i> Bu işlem geri alınamaz.</small>
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>İptal
                </button>
                <button type="button" class="btn btn-danger" id="silBtn">
                    <i class="fas fa-trash me-2"></i>Sil
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Cevap Yazma Modal'ı -->
<div class="modal fade" id="cevapYazModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title">
                    <i class="fas fa-reply me-2"></i>
                    <span id="cevapModalBaslik">Cevap Yaz</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Cevap Metni <span class="text-danger">*</span></label>
                    <textarea class="form-control modal-cevap-textarea"
                              id="cevapMetni"
                              rows="8"
                              placeholder="Lütfen cevabınızı buraya yazınız..."></textarea>
                    <div class="form-text">
                        <i class="fas fa-info-circle me-1"></i>
                        Müşteriye göndereceğiniz cevap bu alana yazılacaktır.
                    </div>
                </div>
                <div class="alert alert-info">
                    <i class="fas fa-lightbulb me-2"></i>
                    <strong>İpucu:</strong> Cevabınız net, anlaşılır ve kapsamlı olsun. Müşterinin istek veya önerisini tam olarak karşılamayı hedefleyin.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>İptal
                </button>
                <button type="button" class="btn btn-success" id="cevapKaydetBtn">
                    <i class="fas fa-paper-plane me-2"></i>Gönder
                </button>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            let seciliBildirimId = null;
            let secilenDurumId = null;
            let secilenDurumAdi = null;

               // Arama fonksiyonu - Bu satırı geçici olarak devre dışı bırakın veya düzeltin
        $('#bildirimArama').on('input', function () {
            // Bu fonksiyon tüm satırları gizliyor olabilir
            const term = $(this).val().toLowerCase().trim();
            $('#bildirimTablosu tr').each(function () {
                const $row = $(this);
                if ($row.find('.empty-state').length > 0) return;

                const text = $row.text().toLowerCase();
                $row.toggle(text.includes(term));
            });
        });
            // Durum değiştirme
            $(document).on('change', '.durum-select', async function () {
                const $select = $(this);
                const bildirimId = $select.data('bildirim-id');
                const yeniDurumId = parseInt($select.val());
                const eskiDurumId = parseInt($select.data('current-durum'));

                if (yeniDurumId === eskiDurumId) {
                    return;
                }

                try {
